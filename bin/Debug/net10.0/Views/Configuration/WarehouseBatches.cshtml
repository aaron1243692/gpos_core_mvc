@using System.Globalization
@model gpos.Models.ViewModels.ProductStockPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Inventory</li>
                <li class="breadcrumb-item">Batches</li>
                <li class="breadcrumb-item active" aria-current="page">Warehouse</li>
            </ol>
        </nav>
        <h1>Warehouse Batches</h1>
        <p class="page-subtitle">View warehouse stock by branch, product, and batch.</p>
    </div>
</div>

<section class="card content-card table-card full-height-card mb-0">
    <div class="table-toolbar d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
        <form class="products-search-wrap d-flex gap-2 flex-wrap" asp-action="WarehouseBatches" method="get">
            <label class="visually-hidden" for="warehouse-batch-search">Search warehouse batches</label>
            <input class="form-control form-control-sm products-search" id="warehouse-batch-search" name="search" value="@Model.Search" type="search" placeholder="Search warehouse batches" autocomplete="off" />
            <select class="form-select form-select-sm" name="filterBranchId">
                @foreach (var branch in Model.BranchOptions)
                {
                    <option value="@branch.Value" selected="@((Model.BranchId?.ToString() ?? string.Empty) == branch.Value ? "selected" : null)">@branch.Text</option>
                }
            </select>
            <button class="btn btn-sm btn-outline-primary" type="submit">Search</button>
            <a class="btn btn-sm btn-outline-secondary" asp-action="WarehouseBatches">Clear</a>
        </form>
    </div>

    <div class="table-responsive table-scroll-wrap flex-table-wrap gpos-table-wrap">
        <table class="table table-sm table-hover align-middle admin-table gpos-table product-batches-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-normal" />
                <col class="col-product" />
                <col class="col-batch-number" />
                <col class="col-cost-price" />
                <col class="col-selling-price" />
                <col class="col-qty" />
                <col class="col-date" />
                <col class="col-status" />
                <col class="col-action" />
            </colgroup>
            <thead>
                <tr>
                    <th class="col-no" scope="col">No</th>
                    <th scope="col">Branch</th>
                    <th class="col-product" scope="col">Product</th>
                    <th class="col-batch-number" scope="col">Batch No</th>
                    <th class="col-cost-price" scope="col">Cost Price</th>
                    <th class="col-selling-price" scope="col">Selling Price</th>
                    <th class="number-cell" scope="col">Quantity</th>
                    <th class="col-date" scope="col">Date Created</th>
                    <th class="col-status status-cell" scope="col">Status</th>
                    <th class="col-action" scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.WarehouseStocks.Count == 0)
                {
                    <tr>
                        <td class="text-center text-muted fw-bold" colspan="10">No warehouse batches found.</td>
                    </tr>
                }
                @for (var index = 0; index < Model.WarehouseStocks.Count; index += 1)
                {
                    var stock = Model.WarehouseStocks[index];
                    var batch = stock.Batch;
                    var batchIsActive = batch is not null && batch.Status == 1 && batch.IsActive;
                    <tr>
                        <td class="col-no">@(index + 1)</td>
                        <td class="text-cell">@(stock.Branch?.Name ?? "-")</td>
                        <td class="col-product text-cell text-truncate">@(stock.Product?.Name ?? "-")</td>
                        <td class="col-batch-number text-nowrap">@(batch?.BatchNo ?? "-")</td>
                        <td class="col-cost-price number-cell">&#8369;@((batch?.CostPrice ?? 0m).ToString("N2", CultureInfo.InvariantCulture))</td>
                        <td class="col-selling-price number-cell">&#8369;@((batch?.SellingPrice ?? 0m).ToString("N2", CultureInfo.InvariantCulture))</td>
                        <td class="col-qty number-cell">@stock.Quantity.ToString("#,0.##", CultureInfo.InvariantCulture)</td>
                        <td class="col-date number-cell">@(batch?.CreatedAt?.ToString("MMM dd, yyyy", CultureInfo.InvariantCulture) ?? "-")</td>
                        <td class="col-status status-cell"><span class="badge @(batchIsActive ? "text-bg-success" : "text-bg-secondary")">@(batchIsActive ? "Active" : "Inactive")</span></td>
                        <td class="col-action action-cell">
                            <span class="badge text-bg-light border text-secondary">View only</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
