@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Discounts</li><li class="breadcrumb-item active">Points Ledger</li></ol></nav><h1>Points Ledger</h1><p class="page-subtitle">Track member points earned, used, deducted, and set.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="PointsLedger" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search points ledger..." /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#pointsLedgerModal">Add Ledger Entry</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table points-ledger-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-member" /><col class="col-type" /><col class="col-points" /><col class="col-old-points" /><col class="col-new-points" /><col class="col-remarks" /><col class="col-date" /></colgroup><thead><tr><th class="col-no">No</th><th class="col-id">ID</th><th class="col-member">Member</th><th class="col-type">Type</th><th class="col-points">Points</th><th class="col-old-points">Old Points</th><th class="col-new-points">New Points</th><th class="col-remarks">Remarks</th><th class="col-date">Date</th></tr></thead><tbody>
@if (Model.PointsLedger.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="9">No points ledger entries yet.</td></tr> }
@for (var i = 0; i < Model.PointsLedger.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.PointsLedger[i].Id</td><td>@Model.PointsLedger[i].Member?.FullName</td><td>@(Model.PointsLedger[i].TransactionType == "earned" ? "Earned" : Model.PointsLedger[i].TransactionType == "used" ? "Used" : Model.PointsLedger[i].TransactionType == "deduct" ? "Deduct" : Model.PointsLedger[i].TransactionType == "set" ? "Set" : "-")</td><td>@Model.PointsLedger[i].Points.ToString("+#,##0.00;-#,##0.00;0.00")</td><td>@Model.PointsLedger[i].OldPoints.ToString("N2")</td><td>@Model.PointsLedger[i].NewPoints.ToString("N2")</td><td>@Model.PointsLedger[i].Remarks</td><td>@Model.PointsLedger[i].CreatedAt?.ToString("yyyy-MM-dd")</td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="pointsLedgerModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SavePointsLedger" method="post">@Html.AntiForgeryToken()<input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Points Ledger</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="PointsLedgerForm.MemberId" class="form-label">Member</label><input asp-for="PointsLedgerForm.MemberId" id="pointsLedgerMemberId" type="hidden" /><div class="input-group member-picker-field"><input asp-for="PointsLedgerForm.MemberName" id="pointsLedgerMemberName" class="form-control" placeholder="Select member" readonly /><button class="btn btn-outline-secondary member-picker-button" id="openMemberPickerButton" type="button" aria-label="Search member"><img src="~/icons/magnifying-glass.png" alt="" /></button></div><span asp-validation-for="PointsLedgerForm.MemberId" class="text-danger"></span></div><div class="mb-3"><label asp-for="PointsLedgerForm.Type" class="form-label">Type</label><select asp-for="PointsLedgerForm.Type" class="form-select"><option>Earned</option><option>Used</option><option>Deduct</option><option>Set</option></select><span asp-validation-for="PointsLedgerForm.Type" class="text-danger"></span></div><div class="mb-3"><label asp-for="PointsLedgerForm.Points" class="form-label">Points</label><input asp-for="PointsLedgerForm.Points" class="form-control" type="number" step="0.01" /><span asp-validation-for="PointsLedgerForm.Points" class="text-danger"></span></div><div class="mb-3"><label asp-for="PointsLedgerForm.Remarks" class="form-label">Remarks</label><input asp-for="PointsLedgerForm.Remarks" class="form-control" /></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
<div class="modal fade member-picker-modal" id="memberPickerModal" tabindex="-1" aria-labelledby="memberPickerModalLabel" aria-hidden="true"><div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5" id="memberPickerModalLabel">Select Member</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><div class="mb-3"><input class="form-control" id="memberPickerSearch" type="search" placeholder="Search card no, name, or contact" autocomplete="off" /></div><div class="setup-table-scroll member-picker-table-wrap"><table class="table app-table table-sm align-middle admin-table member-picker-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-card" /><col class="col-name" /><col class="col-contact" /><col class="col-points" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Card No</th><th>Name</th><th>Contact</th><th>Points</th><th>Action</th></tr></thead><tbody id="memberPickerRows"><tr><td class="text-center text-muted fw-bold" colspan="7">Loading members...</td></tr></tbody></table></div></div></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}const memberIdInput=document.getElementById("pointsLedgerMemberId");const memberNameInput=document.getElementById("pointsLedgerMemberName");const openMemberPickerButton=document.getElementById("openMemberPickerButton");const memberPickerElement=document.getElementById("memberPickerModal");const memberPickerSearch=document.getElementById("memberPickerSearch");const memberPickerRows=document.getElementById("memberPickerRows");const memberPickerModal=memberPickerElement&&window.bootstrap?bootstrap.Modal.getOrCreateInstance(memberPickerElement,{backdrop:false}):null;let memberSearchTimer=0;function escapeHtml(value){return String(value??"").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;");}function formatPoints(value){return Number(value||0).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2});}function renderMembers(members){if(!members.length){memberPickerRows.innerHTML='<tr><td class="text-center text-muted fw-bold" colspan="7">No members found.</td></tr>';return;}memberPickerRows.innerHTML=members.map((member,index)=>`<tr><td>${index+1}</td><td>${member.id}</td><td>${escapeHtml(member.cardNo||"-")}</td><td>${escapeHtml(member.name)}</td><td>${escapeHtml(member.contact||"-")}</td><td>${formatPoints(member.points)}</td><td><button class="btn btn-sm btn-primary member-select-button" type="button" data-member-id="${member.id}" data-member-name="${escapeHtml(member.name)}">Select</button></td></tr>`).join("");}async function loadMembers(){const search=memberPickerSearch.value.trim();memberPickerRows.innerHTML='<tr><td class="text-center text-muted fw-bold" colspan="7">Loading members...</td></tr>';try{const response=await fetch(`/Configuration/PointsLedger/Members?search=${encodeURIComponent(search)}`,{headers:{"Accept":"application/json"}});if(!response.ok){throw new Error("Unable to load members.");}renderMembers(await response.json());}catch{memberPickerRows.innerHTML='<tr><td class="text-center text-muted fw-bold" colspan="7">No members found.</td></tr>';}}openMemberPickerButton.addEventListener("click",()=>{memberPickerSearch.value="";loadMembers();if(memberPickerModal){memberPickerModal.show();memberPickerSearch.focus();}});memberPickerSearch.addEventListener("input",()=>{window.clearTimeout(memberSearchTimer);memberSearchTimer=window.setTimeout(loadMembers,250);});memberPickerRows.addEventListener("click",(event)=>{const button=event.target.closest(".member-select-button");if(!button){return;}memberIdInput.value=button.dataset.memberId||"0";memberNameInput.value=button.dataset.memberName||"";if(memberPickerModal){memberPickerModal.hide();}});});</script> }
