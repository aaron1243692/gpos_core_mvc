@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Fuel</li><li class="breadcrumb-item active">Fuel Deliveries</li></ol></nav><h1>Fuel Deliveries</h1><p class="page-subtitle">Record fuel deliveries into tanks.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="FuelDeliveries" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search deliveries" /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#fuelDeliveryModal">Add Delivery</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Delivery No</th><th>Supplier</th><th>Fuel</th><th>Tank</th><th>Delivered Liters</th><th>Delivery Date</th><th>Status</th><th>Action</th></tr></thead><tbody>
@if (Model.FuelDeliveries.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="10">No fuel deliveries yet.</td></tr> }
@for (var i = 0; i < Model.FuelDeliveries.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.FuelDeliveries[i].Id</td><td>@Model.FuelDeliveries[i].DeliveryNo</td><td>@Model.FuelDeliveries[i].Supplier?.Name</td><td>@Model.FuelDeliveries[i].Fuel?.Name</td><td>@Model.FuelDeliveries[i].Tank?.TankNo</td><td>@Model.FuelDeliveries[i].DeliveredLiters.ToString("N2") L</td><td>@Model.FuelDeliveries[i].DeliveryDate.ToString("yyyy-MM-dd")</td><td><span class="badge @(Model.FuelDeliveries[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.FuelDeliveries[i].Status == 1 ? "Active" : "Inactive")</span></td><td class="col-action"><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="FuelDeliveries" asp-route-editId="@Model.FuelDeliveries[i].Id" asp-route-search="@Model.Search">Edit</a><form asp-action="DeleteFuelDelivery" method="post" data-deactivate-form>@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.FuelDeliveries[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-danger" type="submit">Deactivate</button></form></div></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="fuelDeliveryModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveFuelDelivery" method="post">@Html.AntiForgeryToken()<input asp-for="FuelDeliveryForm.Id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Fuel Delivery</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="FuelDeliveryForm.DeliveryNo" class="form-label">Delivery No</label><input asp-for="FuelDeliveryForm.DeliveryNo" class="form-control" /><span asp-validation-for="FuelDeliveryForm.DeliveryNo" class="text-danger"></span></div><div class="mb-3"><label asp-for="FuelDeliveryForm.SupplierId" class="form-label">Supplier</label><select asp-for="FuelDeliveryForm.SupplierId" asp-items="Model.SupplierOptions" class="form-select"></select></div><div class="mb-3"><label asp-for="FuelDeliveryForm.FuelId" class="form-label">Fuel</label><select asp-for="FuelDeliveryForm.FuelId" asp-items="Model.FuelOptions" class="form-select"><option value="0">Select fuel</option></select><span asp-validation-for="FuelDeliveryForm.FuelId" class="text-danger"></span></div><div class="mb-3"><label asp-for="FuelDeliveryForm.TankId" class="form-label">Tank</label><select asp-for="FuelDeliveryForm.TankId" asp-items="Model.TankOptions" class="form-select"><option value="0">Select tank</option></select><span asp-validation-for="FuelDeliveryForm.TankId" class="text-danger"></span></div><div class="row g-2"><div class="col-md-6 mb-3"><label asp-for="FuelDeliveryForm.DeliveredLiters" class="form-label">Delivered Liters</label><input asp-for="FuelDeliveryForm.DeliveredLiters" class="form-control" type="number" step="0.01" min="0.01" /><span asp-validation-for="FuelDeliveryForm.DeliveredLiters" class="text-danger"></span></div><div class="col-md-6 mb-3"><label asp-for="FuelDeliveryForm.CostPerLiter" class="form-label">Cost Per Liter</label><input asp-for="FuelDeliveryForm.CostPerLiter" class="form-control" type="number" step="0.01" min="0" /></div></div><div class="mb-3"><label asp-for="FuelDeliveryForm.DeliveryDate" class="form-label">Delivery Date</label><input asp-for="FuelDeliveryForm.DeliveryDate" class="form-control" type="date" /><span asp-validation-for="FuelDeliveryForm.DeliveryDate" class="text-danger"></span></div><div class="mb-3"><label asp-for="FuelDeliveryForm.Remarks" class="form-label">Remarks</label><input asp-for="FuelDeliveryForm.Remarks" class="form-control" /></div><input asp-for="FuelDeliveryForm.Status" type="hidden" /></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
