@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Discounts</li><li class="breadcrumb-item active">Discount Rules</li></ol></nav><h1>Discount Rules</h1><p class="page-subtitle">Configure discount rules by value type and application area.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="DiscountRules" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search discount rules" /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#discountRuleModal">Add Rule</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Name</th><th>Type</th><th>Value</th><th>Applies To</th><th>Status</th><th>Action</th></tr></thead><tbody>
@if (Model.DiscountRules.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="8">No discount rules yet.</td></tr> }
@for (var i = 0; i < Model.DiscountRules.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.DiscountRules[i].Id</td><td>@Model.DiscountRules[i].Name</td><td>@Model.DiscountRules[i].DiscountType</td><td>@Model.DiscountRules[i].DiscountValue.ToString("N2")</td><td>@Model.DiscountRules[i].AppliesTo</td><td><span class="badge @(Model.DiscountRules[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.DiscountRules[i].Status == 1 ? "Active" : "Disabled")</span></td><td class="col-action"><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="DiscountRules" asp-route-editId="@Model.DiscountRules[i].Id" asp-route-search="@Model.Search">Edit</a><form asp-action="DeleteDiscountRule" method="post" onsubmit="return confirm('Disable this rule?');">@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.DiscountRules[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-danger" type="submit">Delete</button></form></div></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="discountRuleModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveDiscountRule" method="post">@Html.AntiForgeryToken()<input asp-for="DiscountRuleForm.Id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Discount Rule</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="DiscountRuleForm.Name" class="form-label">Name</label><input asp-for="DiscountRuleForm.Name" class="form-control" /><span asp-validation-for="DiscountRuleForm.Name" class="text-danger"></span></div><div class="mb-3"><label asp-for="DiscountRuleForm.DiscountType" class="form-label">Type</label><select asp-for="DiscountRuleForm.DiscountType" class="form-select"><option>Percentage</option><option>Fixed</option></select></div><div class="mb-3"><label asp-for="DiscountRuleForm.DiscountValue" class="form-label">Value</label><input asp-for="DiscountRuleForm.DiscountValue" class="form-control" type="number" step="0.01" min="0" /></div><div class="mb-3"><label asp-for="DiscountRuleForm.AppliesTo" class="form-label">Applies To</label><select asp-for="DiscountRuleForm.AppliesTo" class="form-select"><option>Fuel</option><option>Product</option><option>All</option></select></div><div class="mb-3"><label asp-for="DiscountRuleForm.Status" class="form-label">Status</label><select asp-for="DiscountRuleForm.Status" class="form-select"><option value="1">Active</option><option value="0">Disabled</option></select></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
