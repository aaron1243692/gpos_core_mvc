@model gpos.Models.ViewModels.SetupModulesPageViewModel

@{
    var currentRebateId = Model.RebateRules.FirstOrDefault()?.Id;
}

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Configuration</li><li class="breadcrumb-item active">Rebate</li></ol></nav><h1>Rebate</h1><p class="page-subtitle">Versioned point-to-cash conversion history.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="Rebate" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search rebates..." /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#rebateRuleModal">New Rebate</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table rebate-table mb-0"><colgroup><col class="col-no" /><col class="col-name" /><col class="col-points" /><col class="col-amount" /><col class="col-normal" /><col class="col-date" /><col class="col-status" /></colgroup><thead><tr><th>No</th><th>Name</th><th>Points Required</th><th>Cash Value</th><th>Created By</th><th>Created At</th><th>Status</th></tr></thead><tbody>
@if (Model.RebateRules.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="7">No rebate history yet.</td></tr> }
@for (var i = 0; i < Model.RebateRules.Count; i++) { var rebate = Model.RebateRules[i]; var isCurrent = rebate.Id == currentRebateId; <tr><td>@(i + 1)</td><td>@rebate.Name</td><td>@rebate.PointsRequired.ToString("N2")</td><td>?@rebate.RebateValue.ToString("N2")</td><td>System</td><td>@rebate.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</td><td><span class="badge @(isCurrent ? "text-bg-success" : "text-bg-secondary")">@(isCurrent ? "Current" : "Historical")</span></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="rebateRuleModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveRebateRule" method="post">@Html.AntiForgeryToken()<input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">New Rebate</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="RebateRuleForm.Name" class="form-label">Name</label><input asp-for="RebateRuleForm.Name" class="form-control" /><span asp-validation-for="RebateRuleForm.Name" class="text-danger"></span></div><div class="mb-3"><label asp-for="RebateRuleForm.AppliesTo" class="form-label">Applies To</label><select asp-for="RebateRuleForm.AppliesTo" class="form-select"><option>Fuel</option><option>Product</option><option>Both</option></select><span asp-validation-for="RebateRuleForm.AppliesTo" class="text-danger"></span></div><div class="mb-3"><label asp-for="RebateRuleForm.PointsRequired" class="form-label">Points Required</label><input asp-for="RebateRuleForm.PointsRequired" class="form-control" type="number" step="0.01" min="0.01" /><span asp-validation-for="RebateRuleForm.PointsRequired" class="text-danger"></span></div><div class="mb-3"><label asp-for="RebateRuleForm.RebateValue" class="form-label">Cash Value</label><input asp-for="RebateRuleForm.RebateValue" class="form-control" type="number" step="0.01" min="0.01" /><span asp-validation-for="RebateRuleForm.RebateValue" class="text-danger"></span></div><div class="mb-3"><label asp-for="RebateRuleForm.MinimumPurchase" class="form-label">Minimum Purchase</label><input asp-for="RebateRuleForm.MinimumPurchase" class="form-control" type="number" step="0.01" min="0" /><span asp-validation-for="RebateRuleForm.MinimumPurchase" class="text-danger"></span></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Create Version</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
