@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Products</li><li class="breadcrumb-item active">Low Stock Settings</li></ol></nav><h1>Low Stock Settings</h1><p class="page-subtitle">Set minimum product quantities by location.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="LowStockSettings" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search low stock settings" /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#lowStockSettingModal">Add Setting</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Product</th><th>Batch</th><th>Location</th><th>Minimum Quantity</th><th>Status</th><th>Action</th></tr></thead><tbody>
@if (Model.LowStockSettings.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="8">No low stock settings yet.</td></tr> }
@for (var i = 0; i < Model.LowStockSettings.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.LowStockSettings[i].Id</td><td>@Model.LowStockSettings[i].Product?.Name</td><td>@Model.LowStockSettings[i].ProductBatch?.BatchNo</td><td>@Model.LowStockSettings[i].Location</td><td>@Model.LowStockSettings[i].MinimumQuantity.ToString("N2")</td><td><span class="badge @(Model.LowStockSettings[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.LowStockSettings[i].Status == 1 ? "Active" : "Disabled")</span></td><td class="col-action"><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="LowStockSettings" asp-route-editId="@Model.LowStockSettings[i].Id" asp-route-search="@Model.Search">Edit</a>@if (Model.LowStockSettings[i].Status == 1)
                                {
                                    <form asp-action="DeleteLowStockSetting" method="post" onsubmit="return confirm('Are you sure you want to disable this setting?');">@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.LowStockSettings[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-danger" type="submit">Disable</button></form>
                                }
                                @if (!(Model.LowStockSettings[i].Status == 1))
                                {
                                    <form asp-action="ActivateLowStockSetting" method="post" onsubmit="return confirm('Are you sure you want to activate this setting?');">@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.LowStockSettings[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-success" type="submit">Activate</button></form>
                                }</div></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="lowStockSettingModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveLowStockSetting" method="post">@Html.AntiForgeryToken()<input asp-for="LowStockSettingForm.Id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Low Stock Setting</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="LowStockSettingForm.ProductId" class="form-label">Product</label><select asp-for="LowStockSettingForm.ProductId" asp-items="Model.ProductOptions" class="form-select"><option value="0">Select product</option></select><span asp-validation-for="LowStockSettingForm.ProductId" class="text-danger"></span></div><div class="mb-3"><label asp-for="LowStockSettingForm.ProductBatchId" class="form-label">Batch</label><select asp-for="LowStockSettingForm.ProductBatchId" asp-items="Model.ProductBatchOptions" class="form-select"><option value="">No batch</option></select></div><div class="mb-3"><label asp-for="LowStockSettingForm.Location" class="form-label">Location</label><input asp-for="LowStockSettingForm.Location" class="form-control" /><span asp-validation-for="LowStockSettingForm.Location" class="text-danger"></span></div><div class="mb-3"><label asp-for="LowStockSettingForm.MinimumQuantity" class="form-label">Minimum Quantity</label><input asp-for="LowStockSettingForm.MinimumQuantity" class="form-control" type="number" step="0.01" min="0" /></div><div class="mb-3"><label asp-for="LowStockSettingForm.Status" class="form-label">Status</label><select asp-for="LowStockSettingForm.Status" class="form-select"><option value="1">Active</option><option value="0">Disabled</option></select></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
