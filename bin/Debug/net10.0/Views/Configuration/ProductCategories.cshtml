@model gpos.Models.ViewModels.ProductStockPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item">Products</li>
                <li class="breadcrumb-item active" aria-current="page">Categories</li>
            </ol>
        </nav>
        <h1>Product Categories</h1>
        <p class="page-subtitle">Manage product category records.</p>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

<section class="card content-card table-card full-height-card mb-0">
    <div class="table-toolbar d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
        <form class="products-search-wrap" asp-action="ProductCategories" method="get">
            <label class="visually-hidden" for="product-category-search">Search categories</label>
            <input class="form-control form-control-sm products-search" id="product-category-search" name="search" value="@Model.Search" type="search" placeholder="Search categories" autocomplete="off" />
        </form>
        <div class="col-12 col-sm-auto ms-sm-auto">
            <button class="btn btn-primary btn-sm w-100" type="button" data-bs-toggle="modal" data-bs-target="#productCategoryModal">Add Category</button>
        </div>
    </div>

    <div class="table-responsive table-scroll-wrap flex-table-wrap">
        <table class="table table-sm table-hover align-middle admin-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-id" />
                <col class="col-name" />
                <col class="col-description" />
                <col class="col-normal" />
                <col class="col-action" />
            </colgroup>
            <thead>
                <tr>
                    <th class="col-no" scope="col">No</th>
                    <th class="col-id" scope="col">ID</th>
                    <th class="col-name" scope="col">Name</th>
                    <th class="col-description" scope="col">Description</th>
                    <th class="col-status" scope="col">Status</th>
                    <th class="col-action" scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Categories.Count == 0)
                {
                    <tr>
                        <td class="text-center text-muted fw-bold" colspan="6">No product categories yet.</td>
                    </tr>
                }
                @for (var index = 0; index < Model.Categories.Count; index += 1)
                {
                    <tr>
                        <td class="col-no">@(index + 1)</td>
                        <td class="col-id">@Model.Categories[index].Id</td>
                        <td>@Model.Categories[index].Name</td>
                        <td>@Model.Categories[index].Description</td>
                        <td><span class="badge @(Model.Categories[index].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.Categories[index].Status == 1 ? "Active" : "Inactive")</span></td>
                        <td class="col-action">
                            <div class="setup-row-actions">
                                <button class="btn btn-outline-primary btn-sm edit-category-btn" type="button" data-bs-toggle="modal" data-bs-target="#editCategoryModal" data-id="@Model.Categories[index].Id" data-name="@Model.Categories[index].Name" data-description="@Model.Categories[index].Description">Edit</button>
                                @if (Model.Categories[index].Status == 1 && Model.Categories[index].IsActive)
                                {
                                    <form asp-action="DeleteProductCategory" method="post" data-deactivate-form>
                                    @Html.AntiForgeryToken()
                                    <input name="id" type="hidden" value="@Model.Categories[index].Id" />
                                    <input name="search" type="hidden" value="@Model.Search" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Deactivate</button>
                                </form>
                                }
                                @if (!(Model.Categories[index].Status == 1 && Model.Categories[index].IsActive))
                                {
                                    <form asp-action="ActivateProductCategory" method="post">
                                    @Html.AntiForgeryToken()
                                    <input name="id" type="hidden" value="@Model.Categories[index].Id" />
                                    <input name="search" type="hidden" value="@Model.Search" />
                                    <button class="btn btn-sm btn-outline-success" type="submit">Activate</button>
                                </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="productCategoryModal" tabindex="-1" aria-labelledby="productCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SaveProductCategory" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="search" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="productCategoryModalLabel">Add Category</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="d-grid gap-3">
                        <div>
                            <label class="form-label" asp-for="CategoryForm.Name">Name</label>
                            <input class="form-control" asp-for="CategoryForm.Name" autocomplete="off" />
                            <span class="text-danger small" asp-validation-for="CategoryForm.Name"></span>
                        </div>
                        <div>
                            <label class="form-label" asp-for="CategoryForm.Description">Description</label>
                            <input class="form-control" asp-for="CategoryForm.Description" type="text" />
                        </div>
                        <div>
                            <label class="form-check">
                                <input class="form-check-input" asp-for="CategoryForm.IsActive" />
                                <span class="form-check-label">Active</span>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-labelledby="editCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="UpdateProductCategory" method="post">
                @Html.AntiForgeryToken()
                <input id="editCategoryId" name="CategoryForm.Id" type="hidden" value="@Model.CategoryForm.Id" />
                <input type="hidden" name="search" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="editCategoryModalLabel">Edit Category</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="d-grid gap-3">
                        <div>
                            <label class="form-label" for="editCategoryName">Name</label>
                            <input class="form-control" id="editCategoryName" name="CategoryForm.Name" value="@Model.CategoryForm.Name" autocomplete="off" />
                            <span class="text-danger small" asp-validation-for="CategoryForm.Name"></span>
                        </div>
                        <div>
                            <label class="form-label" for="editCategoryDescription">Description</label>
                            <input class="form-control" id="editCategoryDescription" name="CategoryForm.Description" value="@Model.CategoryForm.Description" type="text" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const activeModalId = "@Model.ActiveModalId";
            const editCategoryId = document.getElementById("editCategoryId");
            const editCategoryName = document.getElementById("editCategoryName");
            const editCategoryDescription = document.getElementById("editCategoryDescription");

            document.querySelectorAll(".edit-category-btn").forEach(button => {
                button.addEventListener("click", () => {
                    if (editCategoryId) {
                        editCategoryId.value = button.dataset.id || "";
                    }

                    if (editCategoryName) {
                        editCategoryName.value = button.dataset.name || "";
                    }

                    if (editCategoryDescription) {
                        editCategoryDescription.value = button.dataset.description || "";
                    }
                });
            });

            if (!activeModalId || !window.bootstrap) {
                return;
            }

            const activeModal = document.getElementById(activeModalId);

            if (activeModal) {
                bootstrap.Modal.getOrCreateInstance(activeModal).show();
            }
        });
    </script>
}
