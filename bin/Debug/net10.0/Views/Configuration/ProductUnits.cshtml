@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Products</li><li class="breadcrumb-item active" aria-current="page">Product Units</li></ol></nav>
        <h1>Product Units</h1>
        <p class="page-subtitle">Manage selling and stocking units for products.</p>
    </div>
</div>

<section class="content-card setup-crud-card setup-table-card">
    <div class="table-actions fuel-toolbar">
        <form asp-action="ProductUnits" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search units" /></form>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#productUnitModal">Add Product Unit</button>
    </div>
    <div class="setup-table-scroll">
        <table class="table app-table table-sm align-middle admin-table mb-0">
            <colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-action" /></colgroup>
            <thead><tr><th class="col-no">No</th><th class="col-id">ID</th><th class="col-name">Name</th><th>Abbreviation</th><th class="col-status">Status</th><th class="col-action">Action</th></tr></thead>
            <tbody>
                @if (Model.ProductUnits.Count == 0)
                {
                    <tr><td class="text-center text-muted fw-bold" colspan="6">No product units yet.</td></tr>
                }
                @for (var i = 0; i < Model.ProductUnits.Count; i++)
                {
                    <tr>
                        <td class="col-no">@(i + 1)</td><td class="col-id">@Model.ProductUnits[i].Id</td><td>@Model.ProductUnits[i].Name</td><td>@Model.ProductUnits[i].Abbreviation</td>
                        <td><span class="badge @(Model.ProductUnits[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.ProductUnits[i].Status == 1 ? "Active" : "Disabled")</span></td>
                        <td class="col-action"><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="ProductUnits" asp-route-editId="@Model.ProductUnits[i].Id" asp-route-search="@Model.Search">Edit</a><form asp-action="DeleteProductUnit" method="post" onsubmit="return confirm('Disable this unit?');">@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.ProductUnits[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-danger" type="submit">Delete</button></form></div></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="productUnitModal" tabindex="-1" aria-labelledby="productUnitModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveProductUnit" method="post">@Html.AntiForgeryToken()
        <input asp-for="ProductUnitForm.Id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" />
        <div class="modal-header"><h2 class="modal-title fs-5" id="productUnitModalLabel">Product Unit</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div>
        <div class="modal-body">
            <div class="mb-3"><label asp-for="ProductUnitForm.Name" class="form-label">Name</label><input asp-for="ProductUnitForm.Name" class="form-control" /><span asp-validation-for="ProductUnitForm.Name" class="text-danger"></span></div>
            <div class="mb-3"><label asp-for="ProductUnitForm.Abbreviation" class="form-label">Abbreviation</label><input asp-for="ProductUnitForm.Abbreviation" class="form-control" /></div>
            <div class="mb-3"><label asp-for="ProductUnitForm.Status" class="form-label">Status</label><select asp-for="ProductUnitForm.Status" class="form-select"><option value="1">Active</option><option value="0">Disabled</option></select></div>
        </div>
        <div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div>
    </form></div></div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
