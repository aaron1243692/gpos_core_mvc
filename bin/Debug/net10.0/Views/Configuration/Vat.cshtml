@model gpos.Models.ViewModels.VatSetupPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item">Config</li>
                <li class="breadcrumb-item active" aria-current="page">VAT</li>
            </ol>
        </nav>
        <h1>VAT</h1>
        <p class="page-subtitle">Manage VAT settings for future sales configuration.</p>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<section class="card content-card table-card full-height-card mb-0">
    <div class="table-toolbar d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
        <form class="products-search-wrap" asp-action="Vat" method="get">
            <label class="visually-hidden" for="vat-search">Search VAT</label>
            <input class="form-control form-control-sm products-search" id="vat-search" name="search" value="@Model.Search" type="search" placeholder="Search VAT" autocomplete="off" />
        </form>
        <div class="col-12 col-sm-auto ms-sm-auto">
            <button class="btn btn-primary btn-sm w-100" type="button" data-bs-toggle="modal" data-bs-target="#vatModal">Add VAT</button>
        </div>
    </div>

    <div class="table-responsive table-scroll-wrap flex-table-wrap">
        <table class="table table-sm table-hover align-middle admin-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-name" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-status" />
                <col class="col-status" />
                <col class="col-date" />
                <col class="col-action" />
            </colgroup>
            <thead>
                <tr>
                    <th class="col-no" scope="col">No</th>
                    <th scope="col">VAT Name</th>
                    <th scope="col">Rate</th>
                    <th scope="col">Type</th>
                    <th scope="col">Default</th>
                    <th scope="col">Status</th>
                    <th scope="col">Created At</th>
                    <th class="col-action" scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.VatSettings.Count == 0)
                {
                    <tr>
                        <td class="text-center text-muted fw-bold" colspan="8">No VAT settings yet.</td>
                    </tr>
                }
                @for (var index = 0; index < Model.VatSettings.Count; index += 1)
                {
                    <tr>
                        <td class="col-no">@(index + 1)</td>
                        <td>@Model.VatSettings[index].Name</td>
                        <td>@Model.VatSettings[index].Rate.ToString("N2")%</td>
                        <td>@Model.VatSettings[index].Type</td>
                        <td><span class="badge @(Model.VatSettings[index].IsDefault ? "text-bg-primary" : "text-bg-secondary")">@(Model.VatSettings[index].IsDefault ? "Default" : "No")</span></td>
                        <td><span class="badge @(Model.VatSettings[index].IsActive ? "text-bg-success" : "text-bg-secondary")">@(Model.VatSettings[index].IsActive ? "Active" : "Disabled")</span></td>
                        <td>@Model.VatSettings[index].CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="col-action">
                            <div class="setup-row-actions">
                                <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#vatViewModal_@Model.VatSettings[index].Id">View</button>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Vat" asp-route-editId="@Model.VatSettings[index].Id" asp-route-search="@Model.Search">Edit</a>
                                @if (Model.VatSettings[index].IsActive)
                                {
                                    <form asp-action="DisableVat" method="post" onsubmit="return confirm('Are you sure you want to disable this record?');">
                                        @Html.AntiForgeryToken()
                                        <input name="id" type="hidden" value="@Model.VatSettings[index].Id" />
                                        <input name="search" type="hidden" value="@Model.Search" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">Disable</button>
                                    </form>
                                }
                                @if (!Model.VatSettings[index].IsActive)
                                {
                                    <form asp-action="ActivateVat" method="post" onsubmit="return confirm('Are you sure you want to activate this record?');">
                                        @Html.AntiForgeryToken()
                                        <input name="id" type="hidden" value="@Model.VatSettings[index].Id" />
                                        <input name="search" type="hidden" value="@Model.Search" />
                                        <button class="btn btn-sm btn-outline-success" type="submit">Activate</button>
                                    </form>
                                }
                                @if (Model.VatSettings[index].IsActive && !Model.VatSettings[index].IsDefault)
                                {
                                    <form asp-action="SetDefaultVat" method="post" onsubmit="return confirm('Set this VAT as default?');">
                                        @Html.AntiForgeryToken()
                                        <input name="id" type="hidden" value="@Model.VatSettings[index].Id" />
                                        <input name="search" type="hidden" value="@Model.Search" />
                                        <button class="btn btn-sm btn-outline-success" type="submit">Set as Default</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

@for (var index = 0; index < Model.VatSettings.Count; index += 1)
{
    <div class="modal fade" id="vatViewModal_@Model.VatSettings[index].Id" tabindex="-1" aria-labelledby="vatViewModalLabel_@Model.VatSettings[index].Id" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="vatViewModalLabel_@Model.VatSettings[index].Id">VAT Details</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <dl class="row mb-0">
                        <dt class="col-5">VAT Name</dt>
                        <dd class="col-7">@Model.VatSettings[index].Name</dd>
                        <dt class="col-5">Rate</dt>
                        <dd class="col-7">@Model.VatSettings[index].Rate.ToString("N2")%</dd>
                        <dt class="col-5">Type</dt>
                        <dd class="col-7">@Model.VatSettings[index].Type</dd>
                        <dt class="col-5">Default</dt>
                        <dd class="col-7">@(Model.VatSettings[index].IsDefault ? "Yes" : "No")</dd>
                        <dt class="col-5">Status</dt>
                        <dd class="col-7">@(Model.VatSettings[index].IsActive ? "Active" : "Disabled")</dd>
                        <dt class="col-5">Created At</dt>
                        <dd class="col-7">@Model.VatSettings[index].CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<div class="modal fade" id="vatModal" tabindex="-1" aria-labelledby="vatModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SaveVat" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="VatForm.Id" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="vatModalLabel">@(Model.VatForm.Id > 0 ? "Edit VAT" : "Add VAT")</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="d-grid gap-3">
                        <div>
                            <label class="form-label" asp-for="VatForm.Name">VAT Name</label>
                            <input class="form-control" asp-for="VatForm.Name" autocomplete="off" />
                            <span class="text-danger small" asp-validation-for="VatForm.Name"></span>
                        </div>
                        <div>
                            <label class="form-label" asp-for="VatForm.Rate">Rate</label>
                            <div class="input-group">
                                <input class="form-control" asp-for="VatForm.Rate" type="number" min="0" step="0.01" />
                                <span class="input-group-text">%</span>
                            </div>
                            <span class="text-danger small" asp-validation-for="VatForm.Rate"></span>
                        </div>
                        <div>
                            <label class="form-label" asp-for="VatForm.Type">Type</label>
                            <select class="form-select" asp-for="VatForm.Type" asp-items="Model.TypeOptions"></select>
                            <span class="text-danger small" asp-validation-for="VatForm.Type"></span>
                        </div>
                        <div>
                            <label class="form-check">
                                <input class="form-check-input" asp-for="VatForm.IsDefault" />
                                <span class="form-check-label">Set as Default</span>
                            </label>
                            <span class="text-danger small" asp-validation-for="VatForm.IsDefault"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const activeModalId = "@Model.ActiveModalId";

            if (!activeModalId || !window.bootstrap) {
                return;
            }

            const activeModal = document.getElementById(activeModalId);

            if (activeModal) {
                bootstrap.Modal.getOrCreateInstance(activeModal).show();
            }
        });
    </script>
}
