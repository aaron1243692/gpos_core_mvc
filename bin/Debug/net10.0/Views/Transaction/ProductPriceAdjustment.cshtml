@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Transaction</li>
                <li class="breadcrumb-item">Price Adjustment</li>
                <li class="breadcrumb-item active">Product Price Adjustment</li>
            </ol>
        </nav>
        <h1>Product Price Adjustment</h1>
        <p class="page-subtitle">Product price history and adjustments.</p>
    </div>
</div>

<section class="content-card setup-crud-card setup-table-card">
    <div class="table-actions fuel-toolbar">
        <form asp-action="ProductPriceAdjustment" method="get" class="setup-search-form fuel-toolbar-search">
            <input class="form-control" name="search" value="@Model.Search" placeholder="Search product prices" />
        </form>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#productPriceAdjustmentModal">Add Price Adjustment</button>
    </div>
    <div class="setup-table-scroll">
        <table class="table app-table table-sm align-middle admin-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-id" />
                <col class="col-name" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-date" />
                <col class="col-status" />
                <col class="col-normal" />
                <col class="col-date" />
                <col class="col-action" />
            </colgroup>
            <thead>
                <tr>
                    <th>No</th>
                    <th>ID</th>
                    <th>Product</th>
                    <th>Batch Number</th>
                    <th>Old Price</th>
                    <th>New Price</th>
                    <th>Effective Date</th>
                    <th>Status</th>
                    <th>Created By</th>
                    <th>Created At</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.ProductPriceHistory.Count == 0)
                {
                    <tr><td class="text-center text-muted fw-bold" colspan="11">No product price adjustments yet.</td></tr>
                }
                @for (var i = 0; i < Model.ProductPriceHistory.Count; i += 1)
                {
                    var item = Model.ProductPriceHistory[i];
                    var isCurrent = Model.CurrentProductPriceHistoryIds.Contains(item.Id);
                    var createdBy = item.CreatedBy.HasValue && Model.ProductPriceHistoryCreatedBy.TryGetValue(item.CreatedBy.Value, out var name) ? name : "-";
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@item.Id</td>
                        <td>@(item.Product?.Name ?? "-")</td>
                        <td>@(item.Batch?.BatchNo ?? "-")</td>
                        <td>@item.OldPrice.ToString("N2")</td>
                        <td>@item.NewPrice.ToString("N2")</td>
                        <td>@item.EffectiveDate.ToString("yyyy-MM-dd")</td>
                        <td><span class="badge @(item.Status == 1 ? (isCurrent ? "text-bg-primary" : "text-bg-success") : "text-bg-secondary")">@(item.Status == 1 ? (isCurrent ? "Current" : "History") : "Inactive")</span></td>
                        <td>@createdBy</td>
                        <td>@item.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="col-action">
                            <div class="setup-row-actions">
                                <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#productPriceViewModal_@item.Id">View</button>
                                <button class="btn btn-sm btn-outline-success" type="button" data-bs-toggle="modal" data-bs-target="#productPriceAdjustmentModal" data-adjust-product-id="@item.ProductId" data-adjust-batch-id="@item.BatchId" data-adjust-new-price="@item.NewPrice.ToString("0.##")" data-adjust-remarks="@item.Remarks">Adjust</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="productPriceAdjustmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SaveProductPriceAdjustment" method="post">
                @Html.AntiForgeryToken()
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Product Price Adjustment</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-3">
                        <label asp-for="ProductPriceHistoryForm.ProductId" class="form-label">Product</label>
                        <select asp-for="ProductPriceHistoryForm.ProductId" asp-items="Model.ProductOptions" class="form-select" data-product-price-product>
                            <option value="0">Select product</option>
                        </select>
                        <span asp-validation-for="ProductPriceHistoryForm.ProductId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ProductPriceHistoryForm.BatchId" class="form-label">Batch</label>
                        <select asp-for="ProductPriceHistoryForm.BatchId" class="form-select" data-product-price-batch>
                            <option value="">Latest active batch</option>
                            @for (var i = 0; i < Model.ProductBatches.Count; i += 1)
                            {
                                <option value="@Model.ProductBatches[i].Id" data-product-id="@Model.ProductBatches[i].ProductId" data-price="@Model.ProductBatches[i].SellingPrice.ToString("0.00")" selected="@(Model.ProductPriceHistoryForm.BatchId == Model.ProductBatches[i].Id ? "selected" : null)">@Model.ProductBatches[i].BatchNo</option>
                            }
                        </select>
                        <span asp-validation-for="ProductPriceHistoryForm.BatchId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ProductPriceHistoryForm.CurrentPrice" class="form-label">Current Selling Price</label>
                        <input asp-for="ProductPriceHistoryForm.CurrentPrice" class="form-control" type="number" step="0.01" readonly data-product-price-current />
                    </div>
                    <div class="mb-3">
                        <label asp-for="ProductPriceHistoryForm.NewPrice" class="form-label">New Selling Price</label>
                        <input asp-for="ProductPriceHistoryForm.NewPrice" class="form-control" type="number" step="0.01" min="0.01" data-product-price-new />
                        <span asp-validation-for="ProductPriceHistoryForm.NewPrice" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ProductPriceHistoryForm.EffectiveDate" class="form-label">Effective Date</label>
                        <input asp-for="ProductPriceHistoryForm.EffectiveDate" class="form-control" type="date" />
                        <span asp-validation-for="ProductPriceHistoryForm.EffectiveDate" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ProductPriceHistoryForm.Remarks" class="form-label">Remarks</label>
                        <input asp-for="ProductPriceHistoryForm.Remarks" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@for (var i = 0; i < Model.ProductPriceHistory.Count; i += 1)
{
    var item = Model.ProductPriceHistory[i];
    var createdBy = item.CreatedBy.HasValue && Model.ProductPriceHistoryCreatedBy.TryGetValue(item.CreatedBy.Value, out var name) ? name : "-";
    <div class="modal fade" id="productPriceViewModal_@item.Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Product Price Adjustment</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Product</dt><dd class="col-sm-7">@(item.Product?.Name ?? "-")</dd>
                        <dt class="col-sm-5">Batch</dt><dd class="col-sm-7">@(item.Batch?.BatchNo ?? "-")</dd>
                        <dt class="col-sm-5">Old Price</dt><dd class="col-sm-7">@item.OldPrice.ToString("N2")</dd>
                        <dt class="col-sm-5">New Price</dt><dd class="col-sm-7">@item.NewPrice.ToString("N2")</dd>
                        <dt class="col-sm-5">Effective Date</dt><dd class="col-sm-7">@item.EffectiveDate.ToString("yyyy-MM-dd")</dd>
                        <dt class="col-sm-5">Created By</dt><dd class="col-sm-7">@createdBy</dd>
                        <dt class="col-sm-5">Remarks</dt><dd class="col-sm-7">@(item.Remarks ?? "-")</dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const modalId = "@Model.ActiveModalId";
            const modalElement = modalId ? document.getElementById(modalId) : null;
            const productSelect = document.querySelector("[data-product-price-product]");
            const batchSelect = document.querySelector("[data-product-price-batch]");
            const currentPriceInput = document.querySelector("[data-product-price-current]");
            const newPriceInput = document.querySelector("[data-product-price-new]");
            const allBatchOptions = batchSelect ? Array.from(batchSelect.querySelectorAll("option[data-product-id]")) : [];

            function selectedProductId() {
                return productSelect ? productSelect.value : "";
            }

            function syncBatchOptions() {
                const productId = selectedProductId();
                allBatchOptions.forEach((option) => {
                    option.hidden = productId && option.dataset.productId !== productId;
                });

                const selected = batchSelect ? batchSelect.selectedOptions[0] : null;
                if (selected && selected.dataset.productId && selected.dataset.productId !== productId) {
                    batchSelect.value = "";
                }
            }

            function syncCurrentPrice() {
                const productId = selectedProductId();
                const selected = batchSelect ? batchSelect.selectedOptions[0] : null;
                let price = selected && selected.dataset.price ? selected.dataset.price : "";

                if (!price) {
                    const latestBatch = allBatchOptions.find((option) => option.dataset.productId === productId);
                    price = latestBatch ? latestBatch.dataset.price || "" : "";
                }

                if (currentPriceInput) {
                    currentPriceInput.value = price;
                }
            }

            if (productSelect) {
                productSelect.addEventListener("change", () => {
                    syncBatchOptions();
                    syncCurrentPrice();
                });
            }

            if (batchSelect) {
                batchSelect.addEventListener("change", syncCurrentPrice);
            }

            document.querySelectorAll("[data-adjust-product-id]").forEach((button) => {
                button.addEventListener("click", () => {
                    if (productSelect) {
                        productSelect.value = button.dataset.adjustProductId || "0";
                    }
                    syncBatchOptions();
                    if (batchSelect) {
                        batchSelect.value = button.dataset.adjustBatchId || "";
                    }
                    syncCurrentPrice();
                    if (newPriceInput) {
                        newPriceInput.value = "";
                    }
                });
            });

            syncBatchOptions();
            syncCurrentPrice();

            if (modalElement && window.bootstrap) {
                bootstrap.Modal.getOrCreateInstance(modalElement).show();
            }
        });
    </script>
}
