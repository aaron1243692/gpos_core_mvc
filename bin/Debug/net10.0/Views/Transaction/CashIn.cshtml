<section class="transaction-ui-page">
    <div class="content-card transaction-ui-card">
        <div class="card-title-row"><div><h1>Cash In</h1><p>UI-only list of cash added to a cashier drawer.</p></div><span class="status-badge">UI Only</span></div>
        <div class="transaction-ui-toolbar"><input class="form-control transaction-ui-search" type="search" placeholder="Search cash in..." data-transaction-search="#cashInTable" /><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#cashInFormModal">Add Cash In</button></div>
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="cashInTable">
                <thead><tr><th>No</th><th>Date</th><th>User/Cashier</th><th>Amount</th><th>Reason</th><th>Remarks</th><th>Status</th><th>Action</th></tr></thead>
                <tbody>
                    <tr data-search-row><td>1</td><td>2026-06-24</td><td>admin</td><td>₱500.00</td><td>Drawer top-up</td><td>Manager approved</td><td><span class="badge text-bg-warning">Pending</span></td><td><span class="transaction-ui-actions"><button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#cashInViewModal">View</button><button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#cashInFormModal">Edit</button><button class="btn btn-sm btn-outline-danger" type="button" data-bs-toggle="modal" data-bs-target="#cashInConfirmModal">Cancel</button></span></td></tr>
                    <tr data-empty-row hidden><td class="text-center text-muted fw-bold" colspan="8">No records found.</td></tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="content-card transaction-db-card"><h2 class="h5 mb-1">Recommended Future Table</h2><p class="mb-0">Reference only: cash in records should use <strong>cash_movements</strong> with movement_type = Cash In.</p><ul class="transaction-db-list"><li>cash_movements</li></ul></div>
</section>
<div class="modal fade" id="cashInFormModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5">Cash In</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="row g-3"><div class="col-md-6"><label class="form-label">Date</label><input class="form-control" type="date" value="2026-06-24" /></div><div class="col-md-6"><label class="form-label">User/Cashier</label><input class="form-control" value="admin" /></div><div class="col-md-6"><label class="form-label">Amount</label><input class="form-control" type="number" value="500" /></div><div class="col-md-6"><label class="form-label">Status</label><select class="form-select"><option>Pending</option><option>Approved</option><option>Cancelled</option></select></div><div class="col-12"><label class="form-label">Reason</label><input class="form-control" value="Drawer top-up" /></div><div class="col-12"><label class="form-label">Remarks</label><textarea class="form-control" rows="3">Manager approved</textarea></div></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="button" data-bs-dismiss="modal">Save UI Draft</button></div></div></div></div>
<div class="modal fade" id="cashInViewModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5">Cash In Details</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body">Cash In preview only. No movement is saved.</div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button></div></div></div></div>
<div class="modal fade" id="cashInConfirmModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5">Cancel Cash In</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body">Cancel this cash in draft? This is UI only.</div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Back</button><button class="btn btn-danger" type="button" data-bs-dismiss="modal">Cancel Movement</button></div></div></div></div>
