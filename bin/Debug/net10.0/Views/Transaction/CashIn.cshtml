@model gpos.Models.ViewModels.CashMovementPageViewModel
@{
    ViewData["Title"] = "Cash In";
    string Money(decimal value) => value.ToString("N2");
    string UserName(gpos.Models.User? user) => user is null ? "-" : string.IsNullOrWhiteSpace(user.FullName) ? user.Username : user.FullName;
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Transaction</li><li class="breadcrumb-item active" aria-current="page">Cash In</li></ol></nav>
        <h1 class="mb-0">Cash In</h1>
        <p class="page-subtitle text-muted mt-2">Record additional cash added to the cashier drawer during the shift.</p>
    </div>
    <div class="page-actions"><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#cashInFormModal">Add Cash In</button></div>
</div>

<section class="transaction-ui-page">
    <div class="content-card mb-3">
        <form asp-action="CashIn" method="get" class="row g-2 align-items-center">
            <div class="col-md-3"><input class="form-control" name="search" value="@Model.Filter.Search" type="search" placeholder="Search cash in..." /></div>
            <div class="col-md-2"><select class="form-select" name="branchId" asp-items="Model.BranchOptions"></select></div>
            <div class="col-md-2"><input class="form-control" name="dateFrom" value="@Model.Filter.DateFrom?.ToString("yyyy-MM-dd")" type="date" /></div>
            <div class="col-md-2"><input class="form-control" name="dateTo" value="@Model.Filter.DateTo?.ToString("yyyy-MM-dd")" type="date" /></div>
            <div class="col-md-1"><select class="form-select" name="status"><option value="">All</option><option value="Active" selected="@(Model.Filter.Status == "Active")">Active</option><option value="Inactive" selected="@(Model.Filter.Status == "Inactive")">Inactive</option></select></div>
            <div class="col-md-auto d-flex gap-1"><button class="btn btn-primary" type="submit">Search</button><a class="btn btn-outline-secondary" asp-action="CashIn">Clear</a></div>
        </form>
    </div>

    <div class="content-card transaction-ui-card">
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0">
                <thead><tr><th>No</th><th>Date</th><th>Branch</th><th>Shift</th><th>User</th><th class="text-end">Amount</th><th>Reason</th><th>Remarks</th><th>Created By</th><th>Status</th><th>Action</th></tr></thead>
                <tbody>
                    @if (Model.CashIns.Count == 0)
                    {
                        <tr><td class="text-center text-muted fw-bold" colspan="11">No records found.</td></tr>
                    }
                    else
                    {
                        @for (var i = 0; i < Model.CashIns.Count; i++)
                        {
                            var item = Model.CashIns[i];
                            <tr>
                                <td>@(i + 1)</td><td>@item.TransactionDateTime.ToString("yyyy-MM-dd HH:mm")</td><td>@item.Branch?.Name</td><td>@item.Shift?.Name</td><td>@UserName(item.User)</td><td class="text-end">@Money(item.Amount)</td><td>@item.Reason</td><td>@item.Remarks</td><td>@UserName(item.CreatedByUser)</td><td><span class="badge @(item.Status == 1 ? "bg-success" : "bg-secondary")">@(item.Status == 1 ? "Active" : "Inactive")</span></td>
                                <td><button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#cashInViewModal-@item.Id">View</button></td>
                            </tr>
                            <div class="modal fade" id="cashInViewModal-@item.Id" tabindex="-1" aria-labelledby="cashInViewModalLabel-@item.Id" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered modal-lg"><div class="modal-content">
                                    <div class="modal-header"><h2 class="modal-title fs-5" id="cashInViewModalLabel-@item.Id">View Cash In</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div>
                                    <div class="modal-body"><div class="row g-3">
                                        <div class="col-md-6"><label class="form-label">Cash In No</label><input class="form-control" value="@item.Id" readonly /></div>
                                        <div class="col-md-6"><label class="form-label">Daily Cash No</label><input class="form-control" value="@(item.DailyCashId?.ToString() ?? "-")" readonly /></div>
                                        <div class="col-md-6"><label class="form-label">Business Date</label><input class="form-control" value="@(item.DailyCash?.BusinessDate.ToString("yyyy-MM-dd") ?? "-")" readonly /></div>
                                        <div class="col-md-6"><label class="form-label">Branch</label><input class="form-control" value="@(item.Branch?.Name ?? "-")" readonly /></div>
                                        <div class="col-md-6"><label class="form-label">Shift</label><input class="form-control" value="@(item.Shift?.Name ?? "-")" readonly /></div>
                                        <div class="col-md-6"><label class="form-label">Cashier/User</label><input class="form-control" value="@UserName(item.User)" readonly /></div>
                                        <div class="col-md-6"><label class="form-label">Date/Time</label><input class="form-control" value="@item.TransactionDateTime.ToString("yyyy-MM-dd HH:mm")" readonly /></div>
                                        <div class="col-md-6"><label class="form-label">Amount</label><input class="form-control" value="@Money(item.Amount)" readonly /></div>
                                        <div class="col-12"><label class="form-label">Reason</label><input class="form-control" value="@item.Reason" readonly /></div>
                                        <div class="col-12"><label class="form-label">Remarks</label><textarea class="form-control" rows="3" readonly>@item.Remarks</textarea></div>
                                        <div class="col-md-6"><label class="form-label">Created By</label><input class="form-control" value="@UserName(item.CreatedByUser)" readonly /></div>
                                        <div class="col-md-6"><label class="form-label">Created At</label><input class="form-control" value="@(item.CreatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")" readonly /></div>
                                        <div class="col-md-6"><label class="form-label">Status</label><input class="form-control" value="@(item.Status == 1 ? "Active" : "Inactive")" readonly /></div>
                                    </div></div>
                                    <div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button></div>
                                </div></div>
                            </div>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<div class="modal fade" id="cashInFormModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form asp-action="SaveCashIn" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header"><h2 class="modal-title fs-5">Add Cash In</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="Form.BranchId" class="form-label">Branch</label>
                            <input asp-for="Form.BranchId" id="cashInBranchId" type="hidden" />
                            <div class="input-group" data-branch-selector data-branch-hidden="#cashInBranchId" data-branch-display="#cashInBranchDisplay" data-branch-empty-text="Select branch">
                                <input asp-for="Form.BranchName" id="cashInBranchDisplay" class="form-control" placeholder="Select branch" readonly />
                                <button type="button" class="btn btn-outline-secondary branch-select-btn" data-branch-open><img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" /></button>
                            </div>
                            <span asp-validation-for="Form.BranchId" class="text-danger"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Form.DailyCashId" class="form-label">Daily Cash</label>
                            <input asp-for="Form.DailyCashId" id="cashInDailyCashId" type="hidden" />
                            <div class="input-group" data-daily-cash-selector data-daily-cash-hidden="#cashInDailyCashId" data-daily-cash-display="#cashInDailyCashDisplay" data-branch-hidden="#cashInBranchId" data-branch-display="#cashInBranchDisplay" data-business-date-display="#cashInBusinessDateDisplay" data-shift-display="#cashInShiftDisplay" data-user-display="#cashInUserDisplay">
                                <input asp-for="Form.DailyCashDisplay" id="cashInDailyCashDisplay" class="form-control" placeholder="Select Daily Cash" readonly />
                                <button type="button" class="btn btn-outline-secondary" data-daily-cash-open><img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" /></button>
                            </div>
                            <span asp-validation-for="Form.DailyCashId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6"><label class="form-label">Business Date</label><input id="cashInBusinessDateDisplay" class="form-control" value="@(Model.Form.BusinessDate?.ToString("yyyy-MM-dd") ?? string.Empty)" readonly /></div>
                        <div class="col-md-6"><label class="form-label">Shift</label><input id="cashInShiftDisplay" class="form-control" value="@Model.Form.ShiftName" readonly /></div>
                        <div class="col-md-6"><label class="form-label">Cashier</label><input id="cashInUserDisplay" class="form-control" value="@Model.Form.UserName" readonly /></div>
                        <div class="col-md-6"><label asp-for="Form.TransactionDateTime" class="form-label">Created At</label><input asp-for="Form.TransactionDateTime" class="form-control" type="datetime-local" /><span asp-validation-for="Form.TransactionDateTime" class="text-danger"></span></div>
                        <div class="col-md-6"><label asp-for="Form.Amount" class="form-label">Amount</label><input asp-for="Form.Amount" class="form-control" type="number" step="0.01" min="0.01" /><span asp-validation-for="Form.Amount" class="text-danger"></span></div>
                        <div class="col-md-12"><label asp-for="Form.Reason" class="form-label">Reason</label><input asp-for="Form.Reason" class="form-control" /><span asp-validation-for="Form.Reason" class="text-danger"></span></div>
                        <div class="col-12"><label asp-for="Form.Remarks" class="form-label">Remarks</label><textarea asp-for="Form.Remarks" class="form-control" rows="3"></textarea></div>
                    </div>
                </div>
                <div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div>
            </form>
        </div>
    </div>
</div>

<partial name="_DailyCashMovementSelector" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/daily-cash-movement-selector.js" asp-append-version="true"></script>
    @if (!string.IsNullOrWhiteSpace(Model.ActiveModalId))
    {
        <script>document.addEventListener('DOMContentLoaded', () => bootstrap.Modal.getOrCreateInstance(document.getElementById('@Model.ActiveModalId')).show());</script>
    }
}
