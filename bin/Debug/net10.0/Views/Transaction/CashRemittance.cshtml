@{
    ViewData["Title"] = "Cash Remittance";
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Transaction</li>
                <li class="breadcrumb-item">Cash</li>
                <li class="breadcrumb-item active" aria-current="page">Cash Remittance</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="mb-0">Cash Remittance</h1>
            <span class="badge bg-warning text-dark">UI Preview Only</span>
            <span class="badge bg-secondary">Backend not connected yet.</span>
        </div>
        <p class="page-subtitle text-muted mt-2">Record the final cash turnover from the cashier to an authorized person after shift reconciliation.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#cashRemittanceModal">Add Remittance</button>
    </div>
</div>

<section class="transaction-ui-page">
    <div class="content-card mb-3">
        <form class="row g-2 align-items-center" onsubmit="return false;">
            <div class="col-md-3">
                <input class="form-control" type="search" placeholder="Search remittance, cashier, receiver..." id="remitSearch" />
            </div>
            <div class="col-md-2">
                <select class="form-select" id="remitBranch">
                    <option value="">All Branches</option>
                    <option>Main Branch</option>
                    <option>Branch 2</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select" id="remitShift">
                    <option value="">All Shifts</option>
                    <option>Morning Shift</option>
                    <option>Afternoon Shift</option>
                    <option>Night Shift</option>
                </select>
            </div>
            <div class="col-md-1.5">
                <input class="form-control" type="date" value="2026-07-09" id="remitDateFrom" />
            </div>
            <div class="col-md-1.5">
                <input class="form-control" type="date" value="2026-07-09" id="remitDateTo" />
            </div>
            <div class="col-md-1">
                <select class="form-select" id="remitStatus">
                    <option value="">All Statuses</option>
                    <option>Completed</option>
                    <option>Pending</option>
                    <option>Cancelled</option>
                </select>
            </div>
            <div class="col-md-auto d-flex gap-1">
                <button class="btn btn-primary" type="button">Search</button>
                <button class="btn btn-outline-secondary" type="button">Clear</button>
            </div>
        </form>
    </div>

    <div class="content-card transaction-ui-card">
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="remitTable">
                <thead>
                    <tr>
                        <th class="text-nowrap">No</th>
                        <th class="text-nowrap">Remittance No</th>
                        <th class="text-nowrap">Date</th>
                        <th class="text-nowrap">Branch</th>
                        <th class="text-nowrap">Shift</th>
                        <th class="text-nowrap">Cashier</th>
                        <th class="text-nowrap">Expected Cash</th>
                        <th class="text-nowrap">Actual Cash</th>
                        <th class="text-nowrap">Remitted Amount</th>
                        <th class="text-nowrap">Difference</th>
                        <th class="text-nowrap">Received By</th>
                        <th class="text-nowrap">Received Date/Time</th>
                        <th class="text-nowrap">Status</th>
                        <th class="text-nowrap">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td class="text-nowrap fw-bold">REMIT-0001</td>
                        <td class="text-nowrap">2026-07-09</td>
                        <td>Main Branch</td>
                        <td>Morning Shift</td>
                        <td>cashier_01</td>
                        <td>₱41,100.00</td>
                        <td>₱41,050.00</td>
                        <td>₱41,050.00</td>
                        <td>₱-50.00</td>
                        <td>supervisor_01</td>
                        <td class="text-nowrap">2026-07-09 14:15</td>
                        <td><span class="badge bg-success text-nowrap">Completed</span></td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-primary" type="button" onclick="alert('Details backend not connected yet.');">View</button>
                        </td>
                    </tr>
                    <tr class="d-none">
                        <td class="text-center text-muted fw-bold" colspan="14">No remittance records found.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- Add/Edit Modal -->
<div class="modal fade" id="cashRemittanceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Add Cash Remittance</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Branch</label>
                        <select class="form-select">
                            <option>Main Branch</option>
                            <option>Branch 2</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Shift</label>
                        <select class="form-select">
                            <option>Morning Shift</option>
                            <option>Afternoon Shift</option>
                            <option>Night Shift</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Cashier</label>
                        <div class="input-group">
                            <input class="form-control" type="text" placeholder="Select cashier..." readonly />
                            <button class="btn btn-outline-secondary" type="button" onclick="alert('Selector backend not connected yet.');"><img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" /></button>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Daily Cash</label>
                        <div class="input-group">
                            <input class="form-control" type="text" placeholder="Select reconciled daily cash sheet..." readonly />
                            <button class="btn btn-outline-secondary" type="button" onclick="alert('Selector backend not connected yet.');"><img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" /></button>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Expected Cash</label>
                        <input class="form-control" type="text" value="0.00" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Actual Cash</label>
                        <input class="form-control" type="text" value="0.00" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Remitted Amount</label>
                        <input class="form-control" type="number" step="0.01" min="0" placeholder="1,234.00" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Difference</label>
                        <input class="form-control" type="text" value="0.00" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Received By</label>
                        <div class="input-group">
                            <input class="form-control" type="text" placeholder="Select receiver..." readonly />
                            <button class="btn btn-outline-secondary" type="button" onclick="alert('Selector backend not connected yet.');"><img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" /></button>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Received Date/Time</label>
                        <input class="form-control" type="datetime-local" value="2026-07-09T14:15" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Status</label>
                        <select class="form-select">
                            <option>Completed</option>
                            <option>Pending</option>
                            <option>Cancelled</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Remarks</label>
                        <textarea class="form-control" rows="3" placeholder="Enter remarks..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" type="button" onclick="alert('Backend not connected yet.');" data-bs-dismiss="modal">Save Remittance</button>
            </div>
        </div>
    </div>
</div>
