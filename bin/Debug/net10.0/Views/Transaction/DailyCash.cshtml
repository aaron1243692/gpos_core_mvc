@{
    ViewData["Title"] = "Daily Cash";
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Transaction</li>
                <li class="breadcrumb-item active" aria-current="page">Daily Cash</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="mb-0">Daily Cash</h1>
            <span class="badge bg-warning text-dark">UI Preview Only</span>
            <span class="badge bg-secondary">Backend not connected yet</span>
        </div>
        <p class="page-subtitle text-muted mt-2">UI-only cash control sheet. Expected Cash = Opening Cash + Sales Cash + Cash In - Cash Out.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#dailyCashFormModal">Add Daily Cash</button>
    </div>
</div>

<section class="transaction-ui-page">
    <div class="content-card mb-3">
        <form class="row g-2 align-items-center" onsubmit="return false;">
            <div class="col-md-3">
                <input class="form-control" type="search" placeholder="Search daily cash..." id="dailyCashSearch" />
            </div>
            <div class="col-md-2">
                <select class="form-select" id="dailyCashBranch">
                    <option value="">All Branches</option>
                    <option>Main Branch</option>
                    <option>Branch 2</option>
                </select>
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="dailyCashDate" />
            </div>
            <div class="col-md-2">
                <select class="form-select" id="dailyCashShift">
                    <option value="">All Shifts</option>
                    <option>Morning Shift</option>
                    <option>Afternoon Shift</option>
                    <option>Night Shift</option>
                </select>
            </div>
            <div class="col-md-1">
                <input class="form-control" placeholder="Cashier" id="dailyCashCashier" />
            </div>
            <div class="col-md-1">
                <select class="form-select" id="dailyCashStatus">
                    <option value="">All Statuses</option>
                    <option>Open</option>
                    <option>Closed</option>
                    <option>Reviewed</option>
                </select>
            </div>
            <div class="col-md-auto d-flex gap-1">
                <button class="btn btn-primary" type="button">Search</button>
                <button class="btn btn-outline-secondary" type="button">Clear</button>
            </div>
        </form>
    </div>

    <div class="content-card transaction-ui-card">
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="dailyCashTable">
                <thead>
                    <tr>
                        <th class="text-nowrap">No</th>
                        <th class="text-nowrap">Date</th>
                        <th class="text-nowrap">Branch</th>
                        <th class="text-nowrap">Shift</th>
                        <th class="text-nowrap">Cashier</th>
                        <th class="text-nowrap">Opening Cash</th>
                        <th class="text-nowrap">Cash In</th>
                        <th class="text-nowrap">Cash Out</th>
                        <th class="text-nowrap">Sales Cash</th>
                        <th class="text-nowrap">Expected Cash</th>
                        <th class="text-nowrap">Actual Cash</th>
                        <th class="text-nowrap">Difference</th>
                        <th class="text-nowrap">Status</th>
                        <th class="text-nowrap">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td class="text-nowrap">2026-07-09</td>
                        <td>Main Branch</td>
                        <td>Morning Shift</td>
                        <td>admin</td>
                        <td>₱5,000.00</td>
                        <td>₱500.00</td>
                        <td>₱200.00</td>
                        <td>₱18,400.00</td>
                        <td>₱23,700.00</td>
                        <td>₱23,650.00</td>
                        <td>₱-50.00</td>
                        <td><span class="badge bg-primary text-nowrap">Open</span></td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#dailyCashViewModal">View</button>
                            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#dailyCashFormModal">Edit</button>
                        </td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td class="text-nowrap">2026-07-08</td>
                        <td>Main Branch</td>
                        <td>Afternoon Shift</td>
                        <td>cashier_01</td>
                        <td>₱5,000.00</td>
                        <td>₱0.00</td>
                        <td>₱100.00</td>
                        <td>₱24,150.00</td>
                        <td>₱29,050.00</td>
                        <td>₱29,050.00</td>
                        <td>₱0.00</td>
                        <td><span class="badge bg-success text-nowrap">Closed</span></td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#dailyCashViewModal">View</button>
                            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#dailyCashFormModal" disabled>Edit</button>
                        </td>
                    </tr>
                    <tr class="d-none">
                        <td class="text-center text-muted fw-bold" colspan="14">No records found.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- Add/Edit Modal -->
<div class="modal fade" id="dailyCashFormModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Add/Edit Daily Cash</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Branch</label>
                        <select class="form-select">
                            <option>Main Branch</option>
                            <option>Branch 2</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Date</label>
                        <input class="form-control" type="date" value="2026-07-09" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Shift</label>
                        <select class="form-select">
                            <option>Morning Shift</option>
                            <option>Afternoon Shift</option>
                            <option>Night Shift</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Cashier</label>
                        <input class="form-control" value="admin" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Opening Cash Amount</label>
                        <input class="form-control" type="number" step="0.01" min="0" placeholder="1234.00" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Actual Cash Amount</label>
                        <input class="form-control" type="number" step="0.01" min="0" placeholder="1234.00" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Remarks</label>
                        <textarea class="form-control" rows="3" placeholder="Enter remarks here..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" type="button" onclick="alert('Backend not connected yet.');" data-bs-dismiss="modal">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- View Modal -->
<div class="modal fade" id="dailyCashViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Daily Cash Details</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>This is a UI preview. Daily cash recording backend is not connected yet.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
