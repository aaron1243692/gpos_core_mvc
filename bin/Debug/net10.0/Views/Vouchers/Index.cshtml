@model gpos.Models.ViewModels.VoucherSetupPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item">Voucher Management</li>
                <li class="breadcrumb-item active" aria-current="page">Vouchers</li>
            </ol>
        </nav>
        <h1>Vouchers</h1>
        <p class="page-subtitle">Manage voucher codes used during checkout.</p>
    </div>
</div>

<section class="content-card setup-crud-card setup-table-card">
    @if (TempData["VoucherSetupFeedback"] is string feedback)
    {
        <div class="alert alert-info mb-0" role="alert">@feedback</div>
    }
    <div class="table-actions fuel-toolbar">
        <form asp-action="Index" method="get" class="setup-search-form fuel-toolbar-search">
            <input class="form-control" name="search" value="@Model.Search" placeholder="Search vouchers" />
        </form>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#voucherModal">Add Voucher</button>
    </div>
    <div class="setup-table-scroll">
        <table class="table app-table table-sm align-middle admin-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-id" />
                <col class="col-name" />
                <col class="col-normal" />
                <col class="col-action" />
            </colgroup>
            <thead>
                <tr>
                    <th class="col-no">No</th>
                    <th class="col-id">ID</th>
                    <th class="col-name">Name</th>
                    <th class="col-status">Status</th>
                    <th class="col-action">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Vouchers.Count == 0)
                {
                    <tr><td class="text-center text-muted fw-bold" colspan="5">No vouchers yet.</td></tr>
                }
                @for (var i = 0; i < Model.Vouchers.Count; i++)
                {
                    <tr>
                        <td class="col-no">@(i + 1)</td>
                        <td class="col-id">@Model.Vouchers[i].Id</td>
                        <td>@Model.Vouchers[i].Code</td>
                        <td class="col-status">
                            @if (Model.Vouchers[i].Status == "Active")
                            {
                                <span class="badge text-bg-success">Active</span>
                            }
                            @if (Model.Vouchers[i].Status != "Active")
                            {
                                <span class="badge text-bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="col-action">
                            <div class="setup-row-actions">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Index" asp-route-editId="@Model.Vouchers[i].Id" asp-route-search="@Model.Search">Edit</a>
                                <form asp-action="DeleteVoucher" method="post" onsubmit="return confirm('Deactivate this voucher?');">
                                    @Html.AntiForgeryToken()
                                    <input name="id" type="hidden" value="@Model.Vouchers[i].Id" />
                                    <input name="search" type="hidden" value="@Model.Search" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="voucherModal" tabindex="-1" aria-labelledby="voucherModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SaveVoucher" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="VoucherForm.Id" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="voucherModalLabel">Voucher</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="VoucherForm.Name" class="form-label">Name</label>
                        <input asp-for="VoucherForm.Name" class="form-control text-uppercase" maxlength="8" autocomplete="off" />
                        <span asp-validation-for="VoucherForm.Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="VoucherForm.Status" class="form-label">Status</label>
                        <select asp-for="VoucherForm.Status" class="form-select">
                            <option>Active</option>
                            <option>Inactive</option>
                        </select>
                        <span asp-validation-for="VoucherForm.Status" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const modalId = "@Model.ActiveModalId";
            const modalElement = modalId ? document.getElementById(modalId) : null;
            const voucherName = document.getElementById("VoucherForm_Name");

            if (voucherName) {
                voucherName.addEventListener("input", () => {
                    voucherName.value = voucherName.value.toUpperCase().replace(/[^A-Z0-9]/g, "").slice(0, 8);
                });
            }

            if (modalElement && window.bootstrap) {
                bootstrap.Modal.getOrCreateInstance(modalElement).show();
            }
        });
    </script>
}
