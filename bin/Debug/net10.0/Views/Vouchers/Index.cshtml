@model gpos.Models.ViewModels.VoucherSetupPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item active" aria-current="page">Vouchers</li>
            </ol>
        </nav>
        <h1>Vouchers</h1>
        <p class="page-subtitle">Manage voucher codes, validity, limits, and discount rules used during checkout.</p>
    </div>
</div>

<section class="content-card setup-crud-card setup-table-card">
    @if (TempData["VoucherSetupFeedback"] is string feedback)
    {
        <div class="alert alert-info mb-0" role="alert">@feedback</div>
    }

    <div class="table-actions fuel-toolbar">
        <form asp-action="Index" method="get" class="setup-search-form fuel-toolbar-search">
            <input class="form-control" name="search" value="@Model.Search" placeholder="Search vouchers..." />
        </form>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#voucherModal">Add Voucher</button>
    </div>

    <div class="setup-table-scroll">
        <table class="table app-table table-sm align-middle admin-table discount-rules-table voucher-rules-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-id" />
                <col class="col-discount" />
                <col class="col-code" />
                <col class="col-applies-to" />
                <col class="col-type" />
                <col class="col-value" />
                <col class="col-minimum" />
                <col class="col-member-required" />
                <col class="col-usage-limit" />
                <col class="col-date" />
                <col class="col-date" />
                <col class="col-status" />
                <col class="col-action" />
            </colgroup>
            <thead>
                <tr>
                    <th>No</th>
                    <th>ID</th>
                    <th>Voucher Name</th>
                    <th>Voucher Code</th>
                    <th>Applies To</th>
                    <th>Type</th>
                    <th>Value</th>
                    <th>Minimum Amount</th>
                    <th>Member Required</th>
                    <th>Usage Limit</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.VoucherRules.Count == 0)
                {
                    <tr><td class="text-center text-muted fw-bold" colspan="14">No vouchers yet.</td></tr>
                }
                @for (var i = 0; i < Model.VoucherRules.Count; i++)
                {
                    var rule = Model.VoucherRules[i];
                    var usageLimit = rule.MaxRedemptions ?? rule.LimitedUseCount ?? 1;
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@rule.Id</td>
                        <td>@rule.Name</td>
                        <td>@rule.Code</td>
                        <td>@rule.AppliesTo</td>
                        <td>@rule.DiscountType</td>
                        <td>@(rule.DiscountType == "Percentage" ? rule.DiscountValue.ToString("0.##") + "%" : "PHP " + rule.DiscountValue.ToString("N2"))</td>
                        <td>PHP @rule.MinimumAmount.ToString("N2")</td>
                        <td>@(rule.MemberRequired == 1 ? "Yes" : "No")</td>
                        <td>@usageLimit</td>
                        <td>@rule.StartDate?.ToString("yyyy-MM-dd")</td>
                        <td>@rule.EndDate?.ToString("yyyy-MM-dd")</td>
                        <td><span class="badge @(rule.Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(rule.Status == 1 ? "Active" : "Disabled")</span></td>
                        <td class="col-action">
                            <div class="setup-row-actions">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Index" asp-route-editId="@rule.Id" asp-route-search="@Model.Search">Edit</a>
                                <button class="btn btn-sm btn-outline-danger voucher-delete-button" type="button" data-bs-toggle="modal" data-bs-target="#voucherDeleteModal" data-voucher-id="@rule.Id" data-voucher-name="@rule.Name">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="voucherModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form asp-action="SaveVoucher" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="VoucherRuleForm.Id" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Voucher</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="VoucherRuleForm.Name" class="form-label">Voucher Name</label>
                            <input asp-for="VoucherRuleForm.Name" class="form-control" maxlength="100" autocomplete="off" required />
                            <span asp-validation-for="VoucherRuleForm.Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VoucherRuleForm.Code" class="form-label">Voucher Code</label>
                            <input asp-for="VoucherRuleForm.Code" class="form-control text-uppercase" maxlength="6" readonly />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VoucherRuleForm.AppliesTo" class="form-label">Applies To</label>
                            <select asp-for="VoucherRuleForm.AppliesTo" class="form-select">
                                <option>Fuel</option>
                                <option>Product</option>
                                <option>Both</option>
                            </select>
                            <span asp-validation-for="VoucherRuleForm.AppliesTo" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VoucherRuleForm.DiscountType" class="form-label">Discount Type</label>
                            <select asp-for="VoucherRuleForm.DiscountType" class="form-select">
                                <option>Percentage</option>
                                <option>Fixed Amount</option>
                            </select>
                            <span asp-validation-for="VoucherRuleForm.DiscountType" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VoucherRuleForm.DiscountValue" class="form-label">Discount Value</label>
                            <input asp-for="VoucherRuleForm.DiscountValue" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="VoucherRuleForm.DiscountValue" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VoucherRuleForm.MinimumAmount" class="form-label">Minimum Amount</label>
                            <input asp-for="VoucherRuleForm.MinimumAmount" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="VoucherRuleForm.MinimumAmount" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VoucherRuleForm.UsageLimit" class="form-label">Usage Limit</label>
                            <input asp-for="VoucherRuleForm.UsageLimit" class="form-control" type="number" min="1" step="1" />
                            <span asp-validation-for="VoucherRuleForm.UsageLimit" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VoucherRuleForm.MemberRequired" class="form-label">Member Required</label>
                            <select asp-for="VoucherRuleForm.MemberRequired" class="form-select">
                                <option value="false">No</option>
                                <option value="true">Yes</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VoucherRuleForm.StartDate" class="form-label">Start Date</label>
                            <input asp-for="VoucherRuleForm.StartDate" class="form-control" type="date" />
                            <span asp-validation-for="VoucherRuleForm.StartDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VoucherRuleForm.EndDate" class="form-label">End Date</label>
                            <input asp-for="VoucherRuleForm.EndDate" class="form-control" type="date" />
                            <span asp-validation-for="VoucherRuleForm.EndDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="VoucherRuleForm.Status" class="form-label">Status</label>
                            <select asp-for="VoucherRuleForm.Status" class="form-select">
                                <option value="1">Active</option>
                                <option value="0">Disabled</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="voucherDeleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="DeleteVoucher" method="post">
                @Html.AntiForgeryToken()
                <input id="voucherDeleteId" name="id" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Delete Voucher</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Disable this voucher?</p>
                    <p class="fw-bold mb-0" id="voucherDeleteName"></p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-danger" type="submit">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const id = "@Model.ActiveModalId";
            const el = id ? document.getElementById(id) : null;
            if (el && window.bootstrap) {
                bootstrap.Modal.getOrCreateInstance(el).show();
            }

            const deleteModal = document.getElementById("voucherDeleteModal");
            if (deleteModal) {
                deleteModal.addEventListener("show.bs.modal", event => {
                    const button = event.relatedTarget;
                    document.getElementById("voucherDeleteId").value = button?.dataset.voucherId || "";
                    document.getElementById("voucherDeleteName").textContent = button?.dataset.voucherName || "";
                });
            }
        });
    </script>
}
