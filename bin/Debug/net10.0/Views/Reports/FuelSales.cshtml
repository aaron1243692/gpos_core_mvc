@{
    ViewData["Title"] = "Fuel Sales";
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Reports</li>
                <li class="breadcrumb-item active" aria-current="page">Fuel Sales</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="mb-0">Fuel Sales</h1>
            <span class="badge bg-warning text-dark">UI Preview Only</span>
            <span class="badge bg-secondary">Backend not connected yet</span>
        </div>
        <p class="page-subtitle text-muted mt-2">Detailed report of fuel volume and monetary value sold per pump transaction.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-outline-secondary" type="button" onclick="alert('Export backend not connected yet.');">Export CSV</button>
        <button class="btn btn-outline-secondary" type="button" onclick="alert('Print backend not connected yet.');">Print</button>
    </div>
</div>

<section class="reports-ui-page">
    <div class="content-card mb-3">
        <form class="row g-2 align-items-center" onsubmit="return false;">
            <div class="col-md-3">
                <input class="form-control" type="search" placeholder="Search fuel sales..." id="fuelSalesSearch" />
            </div>
            <div class="col-md-3">
                <select class="form-select" id="fuelSalesBranch">
                    <option value="">All Branches</option>
                    <option>Main Branch</option>
                    <option>Branch 2</option>
                </select>
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="fuelSalesDateFrom" />
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="fuelSalesDateTo" />
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button class="btn btn-primary w-100" type="button">Search</button>
                <button class="btn btn-outline-secondary" type="button">Clear</button>
            </div>
        </form>
    </div>

    <div class="content-card transaction-ui-card">
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="fuelSalesTable">
                <thead>
                    <tr>
                        <th class="text-nowrap">No</th>
                        <th class="text-nowrap">Date</th>
                        <th class="text-nowrap">Branch</th>
                        <th class="text-nowrap">Receipt No</th>
                        <th class="text-nowrap">Tank</th>
                        <th class="text-nowrap">Fuel</th>
                        <th class="text-nowrap">Liters</th>
                        <th class="text-nowrap">Price/Liter</th>
                        <th class="text-nowrap">Total</th>
                        <th class="text-nowrap">Cashier</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td class="text-nowrap">2026-07-09 08:32</td>
                        <td>Main Branch</td>
                        <td>RCPT-20260709-0001</td>
                        <td>Tank 1</td>
                        <td>Diesel</td>
                        <td>45.00</td>
                        <td>₱60.00</td>
                        <td>₱2,700.00</td>
                        <td>cashier_01</td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td class="text-nowrap">2026-07-09 08:45</td>
                        <td>Main Branch</td>
                        <td>RCPT-20260709-0002</td>
                        <td>Tank 2</td>
                        <td>Premium Gasoline</td>
                        <td>20.00</td>
                        <td>₱63.00</td>
                        <td>₱1,260.00</td>
                        <td>cashier_01</td>
                    </tr>
                    <tr class="d-none">
                        <td class="text-center text-muted fw-bold" colspan="10">No records found.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
