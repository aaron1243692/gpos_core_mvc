@model gpos.Models.ViewModels.SalesReportPageViewModel
@{ ViewData["Title"] = "Sales Report"; }

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Reports</li><li class="breadcrumb-item active">Sales</li></ol></nav><h1>Sales Report</h1><p class="page-subtitle text-muted">Read-only history of completed and voided transactions.</p></div></div>
<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

<section class="reports-ui-page">
 <div class="content-card mb-3">
  <form method="get" class="row g-2 align-items-end">
   <div class="col-12"><label class="form-label" for="salesSearch">Search</label><input id="salesSearch" class="form-control" type="search" name="search" value="@Model.Search" placeholder="Receipt, member, or payment reference" /></div>
   <div class="col-md-3"><label class="form-label" for="branchId">Branch</label><select id="branchId" class="form-select" name="branchId" asp-items="Model.BranchOptions"></select></div>
   <div class="col-md-3"><label class="form-label" for="userId">User</label><select id="userId" class="form-select" name="userId" asp-items="Model.UserOptions"></select></div>
   <div class="col-md-2"><label class="form-label" for="status">Status</label><select id="status" class="form-select" name="status"><option value="">All</option><option value="Completed" selected="@(Model.Status == "Completed")">Completed</option><option value="Voided" selected="@(Model.Status == "Voided")">Voided</option></select></div>
   <div class="col-md-2"><label class="form-label" for="from">From</label><input id="from" class="form-control" type="date" name="from" value="@Model.From?.ToString("yyyy-MM-dd")" /></div>
   <div class="col-md-2"><label class="form-label" for="to">To</label><input id="to" class="form-control" type="date" name="to" value="@Model.To?.ToString("yyyy-MM-dd")" /></div>
   <div class="col-12 d-flex gap-2"><button class="btn btn-primary" type="submit">Apply Filters</button><a class="btn btn-outline-secondary" asp-action="DailySales">Clear</a></div>
  </form>
 </div>

 <div class="row g-3 mb-3">
  <div class="col-md"><div class="content-card h-100"><small class="text-muted">Total Sales Records</small><div class="fs-4 fw-semibold">@Model.TotalRecords</div></div></div>
  <div class="col-md"><div class="content-card h-100"><small class="text-muted">Completed Sales</small><div class="fs-4 fw-semibold">@Model.CompletedCount</div></div></div>
  <div class="col-md"><div class="content-card h-100"><small class="text-muted">Voided Sales</small><div class="fs-4 fw-semibold">@Model.VoidedCount</div></div></div>
  <div class="col-md"><div class="content-card h-100"><small class="text-muted">Completed Sales Amount</small><div class="fs-4 fw-semibold">@Model.CompletedAmount.ToString("N2")</div></div></div>
  <div class="col-md"><div class="content-card h-100"><small class="text-muted">Voided Original Amount</small><div class="fs-4 fw-semibold">@Model.VoidedOriginalAmount.ToString("N2")</div><small class="text-muted">Historical value, not current revenue.</small></div></div>
 </div>

 <div class="content-card"><div class="table-responsive"><table class="table app-table table-sm align-middle mb-0"><thead><tr><th>Receipt No.</th><th>Sale Date</th><th>Branch</th><th>User</th><th>Sale Type</th><th>Payment Method</th><th class="text-end">Original Total</th><th>Status</th><th>Void Date</th><th>Voided By</th><th>Actions</th></tr></thead><tbody>
 @if (Model.Rows.Count == 0) { <tr><td colspan="11" class="text-center text-muted py-4">No sales match the selected filters.</td></tr> }
 @foreach (var row in Model.Rows) { <tr><td>@row.ReceiptNo</td><td class="text-nowrap">@row.SaleDate?.ToString("yyyy-MM-dd HH:mm")</td><td>@row.Branch</td><td>@row.User</td><td>@row.SaleType</td><td>@row.PaymentMethod</td><td class="text-end">@row.OriginalTotal.ToString("N2")</td><td><span class="badge @(row.Status == "Voided" ? "text-bg-secondary" : "text-bg-success")">@row.Status</span></td><td class="text-nowrap">@row.VoidDate?.ToString("yyyy-MM-dd HH:mm")</td><td>@row.VoidedBy</td><td><a class="btn btn-sm btn-outline-primary" asp-action="DailySales" asp-route-detailsId="@row.Id" asp-route-search="@Model.Search" asp-route-branchId="@Model.BranchId" asp-route-userId="@Model.UserId" asp-route-status="@Model.Status" asp-route-from="@Model.From?.ToString("yyyy-MM-dd")" asp-route-to="@Model.To?.ToString("yyyy-MM-dd")" asp-route-page="@Model.Page">View Details</a></td></tr> }
 </tbody></table></div></div>

 @if (Model.TotalPages > 1) { <nav class="mt-3" aria-label="Sales report pages"><ul class="pagination justify-content-end"><li class="page-item @(Model.Page == 1 ? "disabled" : "")"><a class="page-link" asp-route-page="@(Model.Page - 1)" asp-route-search="@Model.Search" asp-route-branchId="@Model.BranchId" asp-route-userId="@Model.UserId" asp-route-status="@Model.Status" asp-route-from="@Model.From?.ToString("yyyy-MM-dd")" asp-route-to="@Model.To?.ToString("yyyy-MM-dd")">Previous</a></li><li class="page-item disabled"><span class="page-link">Page @Model.Page of @Model.TotalPages</span></li><li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")"><a class="page-link" asp-route-page="@(Model.Page + 1)" asp-route-search="@Model.Search" asp-route-branchId="@Model.BranchId" asp-route-userId="@Model.UserId" asp-route-status="@Model.Status" asp-route-from="@Model.From?.ToString("yyyy-MM-dd")" asp-route-to="@Model.To?.ToString("yyyy-MM-dd")">Next</a></li></ul></nav> }
</section>

@if (Model.Details is { } details) {
 <div class="modal fade" id="saleDetailsModal" tabindex="-1" aria-labelledby="saleDetailsTitle"><div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5" id="saleDetailsTitle">Sale Details — @details.ReceiptNo</h2><a class="btn-close" aria-label="Close" asp-action="DailySales" asp-route-search="@Model.Search" asp-route-branchId="@Model.BranchId" asp-route-userId="@Model.UserId" asp-route-status="@Model.Status" asp-route-from="@Model.From?.ToString("yyyy-MM-dd")" asp-route-to="@Model.To?.ToString("yyyy-MM-dd")" asp-route-page="@Model.Page"></a></div><div class="modal-body">
  <dl class="row"><dt class="col-sm-2">Sale date</dt><dd class="col-sm-4">@details.SaleDate?.ToString("yyyy-MM-dd HH:mm:ss")</dd><dt class="col-sm-2">Branch</dt><dd class="col-sm-4">@details.Branch</dd><dt class="col-sm-2">Cashier</dt><dd class="col-sm-4">@details.User</dd><dt class="col-sm-2">Status / Type</dt><dd class="col-sm-4">@details.Status / @details.SaleType</dd><dt class="col-sm-2">Original total</dt><dd class="col-sm-4">@details.OriginalTotal.ToString("N2")</dd><dt class="col-sm-2">Payment</dt><dd class="col-sm-4">@details.PaymentMethod</dd></dl>
  @if (details.ProductItems.Count > 0) { <h3 class="fs-6 mt-3">Product Items</h3><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Product</th><th>Original Batch</th><th class="text-end">Quantity</th><th class="text-end">Selling Price</th><th class="text-end">Line Total</th></tr></thead><tbody>@foreach (var item in details.ProductItems) { <tr><td>@item.Product</td><td>@item.BatchNo</td><td class="text-end">@item.Quantity.ToString("N2")</td><td class="text-end">@item.SellingPrice.ToString("N2")</td><td class="text-end">@item.LineTotal.ToString("N2")</td></tr> }</tbody></table></div> }
  @if (details.FuelItems.Count > 0) { <h3 class="fs-6 mt-3">Fuel Items</h3><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Fuel</th><th>Tank</th><th>Pump</th><th class="text-end">Liters</th><th class="text-end">Price/Liter</th><th class="text-end">Line Total</th></tr></thead><tbody>@foreach (var item in details.FuelItems) { <tr><td>@item.Fuel</td><td>@item.Tank</td><td>@item.Pump</td><td class="text-end">@item.Liters.ToString("N2")</td><td class="text-end">@item.PricePerLiter.ToString("N2")</td><td class="text-end">@item.LineTotal.ToString("N2")</td></tr> }</tbody></table></div> }
  @if (details.Status == "Voided") { <h3 class="fs-6 mt-3">Void Information</h3><dl class="row"><dt class="col-sm-2">Void date</dt><dd class="col-sm-4">@details.VoidDate?.ToString("yyyy-MM-dd HH:mm:ss")</dd><dt class="col-sm-2">Voided by</dt><dd class="col-sm-4">@details.VoidedBy</dd><dt class="col-sm-2">Reason</dt><dd class="col-sm-10">@details.VoidReason</dd><dt class="col-sm-2">SaleVoid reference</dt><dd class="col-sm-10">#@details.SaleVoidId (@details.SaleVoidStatus)</dd></dl> }
 </div><div class="modal-footer"><a class="btn btn-secondary" asp-action="DailySales" asp-route-search="@Model.Search" asp-route-branchId="@Model.BranchId" asp-route-userId="@Model.UserId" asp-route-status="@Model.Status" asp-route-from="@Model.From?.ToString("yyyy-MM-dd")" asp-route-to="@Model.To?.ToString("yyyy-MM-dd")" asp-route-page="@Model.Page">Close</a></div></div></div></div>
 @section Scripts { <script>bootstrap.Modal.getOrCreateInstance(document.getElementById("saleDetailsModal")).show();</script> }
}
