@model gpos.Models.ViewModels.HeaderViewModel

<header class="eg-rb" data-gpos-ribbon aria-label="Primary navigation">
    <div class="eg-rb-top">
        <a class="eg-rb-brand" asp-controller="Dashboard" asp-action="Index" aria-label="GPOS dashboard">
            <span class="eg-rb-brand-mark" aria-hidden="true">G</span>
            <span>GPOS / Gas Station POS</span>
        </a>

        <nav class="eg-rb-tabs" aria-label="Main page groups">
            <div class="dropdown eg-rb-nav-dropdown eg-rb-setup-dropdown">
                <button class="eg-rb-tab dropdown-toggle @(Model.ActiveTab == "Configuration" ? "is-active" : "")" type="button" id="gposSetupDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">Setup</button>
                <div class="dropdown-menu eg-rb-setup-menu" aria-labelledby="gposSetupDropdown">
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Access</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Users.Index" ? "active" : "")" asp-controller="Users" asp-action="Index">Users</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Roles.Index" ? "active" : "")" asp-controller="Roles" asp-action="Index">Roles</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Branch Management</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Branch" ? "active" : "")" asp-controller="Configuration" asp-action="Branch">Branch</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Department" ? "active" : "")" asp-controller="Configuration" asp-action="Department">Department</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Product Management</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.ProductCategories" ? "active" : "")" asp-controller="Configuration" asp-action="ProductCategories">Product Categories</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.ProductUnits" ? "active" : "")" asp-controller="Configuration" asp-action="ProductUnits">Product Units</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Fuel Management</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Fuels" ? "active" : "")" asp-controller="Configuration" asp-action="Fuels">Fuels</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Pumps" ? "active" : "")" asp-controller="Configuration" asp-action="Pumps">Pumps</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Nozzles" ? "active" : "")" asp-controller="Configuration" asp-action="Nozzles">Nozzles</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Supplier Management</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Suppliers.Index" ? "active" : "")" asp-controller="Suppliers" asp-action="Index">Suppliers</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Member Management</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Members" ? "active" : "")" asp-controller="Configuration" asp-action="Members">Members</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Rebate" ? "active" : "")" asp-controller="Configuration" asp-action="Rebate">Rebate</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Discount Management</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Discounts" ? "active" : "")" asp-controller="Configuration" asp-action="Discounts">Discounts</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.DiscountRules" ? "active" : "")" asp-controller="Configuration" asp-action="DiscountRules">Rules</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Earning Management</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Earnings" ? "active" : "")" asp-controller="Configuration" asp-action="Earnings">Earnings</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.EarningRules" ? "active" : "")" asp-controller="Configuration" asp-action="EarningRules">Rules</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Voucher Management</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Vouchers.Index" ? "active" : "")" asp-controller="Vouchers" asp-action="Index">Vouchers</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Tax Management</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Vat" ? "active" : "")" asp-controller="Configuration" asp-action="Vat">VAT</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="dropdown eg-rb-nav-dropdown">
                <button class="eg-rb-tab dropdown-toggle @(Model.ActiveTab == "Transactions" ? "is-active" : "")" type="button" id="gposTransactionDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">Transaction</button>
                <div class="dropdown-menu eg-rb-setup-menu" aria-labelledby="gposTransactionDropdown">
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">POS</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.POS" ? "active" : "")" asp-controller="Transaction" asp-action="POS">POS</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Receiving</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.ProductReceiving" ? "active" : "")" asp-controller="Transaction" asp-action="ProductReceiving">Product Receiving</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.FuelReceiving" ? "active" : "")" asp-controller="Transaction" asp-action="FuelReceiving">Fuel Receiving</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Sales</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.ProductSales" ? "active" : "")" asp-controller="Transaction" asp-action="ProductSales">Product Sales</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.FuelSales" ? "active" : "")" asp-controller="Transaction" asp-action="FuelSales">Fuel Sales</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Stock Transfer</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.WarehouseToDisplayProduct" ? "active" : "")" asp-controller="Transaction" asp-action="WarehouseToDisplayProduct">Warehouse to Display Product</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.DisplayToWarehouseProduct" ? "active" : "")" asp-controller="Transaction" asp-action="DisplayToWarehouseProduct">Display to Warehouse Product</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.BranchToBranchProduct" ? "active" : "")" asp-controller="Transaction" asp-action="BranchToBranchProduct">Branch to Branch Product</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Price Adjustment</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.FuelPriceAdjustment" ? "active" : "")" asp-controller="Transaction" asp-action="FuelPriceAdjustment">Fuel Price Adjustment</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.ProductPriceAdjustment" ? "active" : "")" asp-controller="Transaction" asp-action="ProductPriceAdjustment">Product Price Adjustment</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle nav-group-not-working" type="button">Cash <span class="nav-status-pill">Not Working</span></button>
                        <div class="dropdown-menu eg-rb-submenu">
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Transaction.DailyCash" ? "active" : "")" asp-controller="Transaction" asp-action="DailyCash">Daily Cash <span class="nav-status-pill">UI Only</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Transaction.CashIn" ? "active" : "")" asp-controller="Transaction" asp-action="CashIn">Cash In <span class="nav-status-pill">UI Only</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Transaction.CashOut" ? "active" : "")" asp-controller="Transaction" asp-action="CashOut">Cash Out <span class="nav-status-pill">UI Only</span></a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle nav-group-not-working" type="button">Returns <span class="nav-status-pill">Not Working</span></button>
                        <div class="dropdown-menu eg-rb-submenu">
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Transaction.ProductReturn" ? "active" : "")" asp-controller="Transaction" asp-action="ProductReturn">Product Return <span class="nav-status-pill">UI Only</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Transaction.FuelReturn" ? "active" : "")" asp-controller="Transaction" asp-action="FuelReturn">Fuel Return <span class="nav-status-pill">UI Only</span></a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle nav-group-not-working" type="button">Void <span class="nav-status-pill">Not Working</span></button>
                        <div class="dropdown-menu eg-rb-submenu">
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Transaction.VoidSale" ? "active" : "")" asp-controller="Transaction" asp-action="VoidSale">Void Sale <span class="nav-status-pill">UI Only</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Transaction.VoidProduct" ? "active" : "")" asp-controller="Transaction" asp-action="VoidProduct">Void Product <span class="nav-status-pill">UI Only</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Transaction.VoidFuel" ? "active" : "")" asp-controller="Transaction" asp-action="VoidFuel">Void Fuel <span class="nav-status-pill">UI Only</span></a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle nav-group-not-working" type="button">Stock Adjustment <span class="nav-status-pill">Not Working</span></button>
                        <div class="dropdown-menu eg-rb-submenu">
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Transaction.DisplayStockAdjustment" ? "active" : "")" asp-controller="Transaction" asp-action="DisplayStockAdjustment">Display Stock Adjustment <span class="nav-status-pill">UI Only</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Transaction.WarehouseStockAdjustment" ? "active" : "")" asp-controller="Transaction" asp-action="WarehouseStockAdjustment">Warehouse Stock Adjustment <span class="nav-status-pill">UI Only</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Transaction.TankFuelAdjustment" ? "active" : "")" asp-controller="Transaction" asp-action="TankFuelAdjustment">Tank Fuel Adjustment <span class="nav-status-pill">UI Only</span></a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="dropdown eg-rb-nav-dropdown">
                <button class="eg-rb-tab dropdown-toggle" type="button" id="gposReportsDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">Reports</button>
                <div class="dropdown-menu eg-rb-setup-menu" aria-labelledby="gposReportsDropdown">
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle nav-group-partial" type="button">Member Reports <span class="nav-status-pill">Partial</span></button>
                        <div class="dropdown-menu eg-rb-submenu">
                            @* Partial / needs verification *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-partial @(Model.ActivePage == "Configuration.PointsLedger" ? "active" : "")" asp-controller="Configuration" asp-action="PointsLedger">Points Ledger <span class="nav-status-pill">Partial</span></a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle nav-group-partial" type="button">Fuel Reports <span class="nav-status-pill">Partial</span></button>
                        <div class="dropdown-menu eg-rb-submenu">
                            @* Partial / needs verification *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-partial @(Model.ActivePage == "Configuration.FuelDeliveries" ? "active" : "")" asp-controller="Configuration" asp-action="FuelDeliveries">Fuel Deliveries <span class="nav-status-pill">Partial</span></a>
                            @* Partial / needs verification *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-partial @(Model.ActivePage == "Configuration.PumpMeterReadings" ? "active" : "")" asp-controller="Configuration" asp-action="PumpMeterReadings">Pump Meter Readings <span class="nav-status-pill">Partial</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working" asp-controller="Reports" asp-action="FuelSalesReport">Fuel Sales Report <span class="nav-status-pill">Not Working</span></a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle nav-group-partial" type="button">Audit Reports <span class="nav-status-pill">Partial</span></button>
                        <div class="dropdown-menu eg-rb-submenu">
                            @* Partial / needs verification *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-partial @(Model.ActivePage == "Configuration.ActivityLogs" ? "active" : "")" asp-controller="Configuration" asp-action="ActivityLogs">Activity Logs <span class="nav-status-pill">Partial</span></a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle nav-group-not-working" type="button">Sales Reports <span class="nav-status-pill">Not Working</span></button>
                        <div class="dropdown-menu eg-rb-submenu">
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working" asp-controller="Reports" asp-action="DailySales">Daily Sales <span class="nav-status-pill">Not Working</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working" asp-controller="Reports" asp-action="FuelSales">Fuel Sales <span class="nav-status-pill">Not Working</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working" asp-controller="Reports" asp-action="ProductSales">Product Sales <span class="nav-status-pill">Not Working</span></a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle nav-group-not-working" type="button">Shift and Cash Reports <span class="nav-status-pill">Not Working</span></button>
                        <div class="dropdown-menu eg-rb-submenu">
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working" asp-controller="Reports" asp-action="ShiftReport">Shift Report <span class="nav-status-pill">Not Working</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working" asp-controller="Reports" asp-action="CashReport">Cash Report <span class="nav-status-pill">Not Working</span></a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="dropdown eg-rb-nav-dropdown">
                <button class="eg-rb-tab dropdown-toggle @(Model.ActiveTab == "Inventory" ? "is-active" : "")" type="button" id="gposInventoryDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">Inventory</button>
                <div class="dropdown-menu eg-rb-setup-menu" aria-labelledby="gposInventoryDropdown">
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Product Stock</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.WarehouseProducts" ? "active" : "")" asp-controller="Configuration" asp-action="WarehouseProducts">Warehouse Products</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.DisplayProducts" ? "active" : "")" asp-controller="Configuration" asp-action="DisplayProducts">Display Products</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.ProductBatches" ? "active" : "")" asp-controller="Configuration" asp-action="ProductBatches">Product Batches</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle nav-group-partial" type="button">Fuel Stock <span class="nav-status-pill">Partial</span></button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Tanks" ? "active" : "")" asp-controller="Configuration" asp-action="Tanks">Tanks</a>
                            @* Partial / needs verification *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-partial @(Model.ActivePage == "Configuration.FuelBatches" ? "active" : "")" asp-controller="Configuration" asp-action="FuelBatches">Fuel Batches <span class="nav-status-pill">Partial</span></a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle nav-group-partial" type="button">Settings <span class="nav-status-pill">Partial</span></button>
                        <div class="dropdown-menu eg-rb-submenu">
                            @* Partial / needs verification *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-partial @(Model.ActivePage == "Configuration.LowStockSettings" ? "active" : "")" asp-controller="Configuration" asp-action="LowStockSettings">Low Stock Settings <span class="nav-status-pill">Partial</span></a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle nav-group-not-working" type="button">Inventory Reports <span class="nav-status-pill">Not Working</span></button>
                        <div class="dropdown-menu eg-rb-submenu">
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Reports.InventoryReport" ? "active" : "")" asp-controller="Reports" asp-action="InventoryReport">Inventory Report <span class="nav-status-pill">Not Working</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Reports.PurchaseHistory" ? "active" : "")" asp-controller="Reports" asp-action="PurchaseHistory">Purchase History <span class="nav-status-pill">Not Working</span></a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle nav-group-not-working" type="button">Daily Stock <span class="nav-status-pill">Not Working</span></button>
                        <div class="dropdown-menu eg-rb-submenu">
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Reports.WarehouseDailyStock" ? "active" : "")" asp-controller="Reports" asp-action="WarehouseDailyStock">Warehouse <span class="nav-status-pill">Not Working</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Reports.DisplayDailyStock" ? "active" : "")" asp-controller="Reports" asp-action="DisplayDailyStock">Display <span class="nav-status-pill">Not Working</span></a>
                            @* UI-only / not working yet *@
                            <a class="dropdown-item eg-rb-dropdown-link nav-page-not-working @(Model.ActivePage == "Reports.TankDailyStock" ? "active" : "")" asp-controller="Reports" asp-action="TankDailyStock">Tank <span class="nav-status-pill">Not Working</span></a>
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        <details class="eg-rb-user" id="gposUserDropdown">
            <summary class="eg-rb-userbtn" aria-controls="gposUserMenu">
                <span class="eg-rb-avatar" aria-hidden="true">@Model.UserInitials</span>
                <span class="eg-rb-userlabel">@Model.Username</span>
                <span class="eg-rb-usercaret" aria-hidden="true"></span>
            </summary>
            <div class="eg-rb-usermenu" id="gposUserMenu" role="menu">
                <div class="eg-rb-usercaption">Signed in as</div>
                <div class="eg-rb-username">@Model.Username</div>
                <form asp-controller="SignIn" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button class="eg-rb-usermenu-link eg-rb-usermenu-link--danger" type="submit" role="menuitem">Logout</button>
                </form>
            </div>
        </details>
    </div>
</header>
