@model gpos.Models.SignInViewModel

@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - gpos</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/gpos.styles.css" asp-append-version="true" />
    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #064e3b 0%, #16a34a 52%, #dcfce7 100%);
        }

        .signin-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .signin-card {
            width: 100%;
            max-width: 430px;
            padding: 2rem;
            border: 1px solid rgba(187, 247, 208, 0.95);
            border-radius: 1rem;
            background: rgba(255, 255, 255, 0.96);
            box-shadow: 0 1.25rem 3rem rgba(6, 78, 59, 0.18);
        }

        .signin-title {
            color: #0f172a;
            font-weight: 700;
            letter-spacing: 0;
        }

        .signin-subtitle {
            color: #3f5f52;
        }

        .signin-card .form-label {
            margin-bottom: 0.45rem;
            color: #164936;
            font-weight: 600;
        }

        .signin-card .form-control {
            min-height: 3rem;
            border-radius: 0.75rem;
            border-color: #9fd9b4;
            transition: border-color 0.18s ease, box-shadow 0.18s ease;
        }

        .signin-card .form-control:hover {
            border-color: #74c991;
        }

        .signin-card .form-control:focus {
            border-color: #16a34a;
            box-shadow: 0 0 0 0.22rem rgba(22, 163, 74, 0.16);
        }

        .signin-card .form-check-input:focus {
            box-shadow: 0 0 0 0.18rem rgba(22, 163, 74, 0.16);
        }

        .signin-card a {
            color: #15803d;
            font-weight: 600;
        }

        .signin-card a:hover {
            color: #064e3b;
        }

        .signin-button {
            min-height: 3rem;
            border: 0;
            border-radius: 0.75rem;
            background: linear-gradient(135deg, #064e3b 0%, #16a34a 100%);
            font-weight: 700;
            box-shadow: 0 0.75rem 1.5rem rgba(22, 163, 74, 0.24);
            transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }

        .signin-button:hover,
        .signin-button:focus {
            background: linear-gradient(135deg, #052e25 0%, #15803d 100%);
            box-shadow: 0 0.9rem 1.8rem rgba(6, 78, 59, 0.3);
            transform: translateY(-1px);
        }

        .signin-card .text-danger,
        .signin-card .validation-summary-errors {
            color: #b42318 !important;
            font-size: 0.92rem;
        }

        @@media (max-width: 575.98px) {
            .signin-card {
                padding: 1.5rem;
                border-radius: 0.85rem;
            }
        }
    </style>
</head>
<body>
    <main class="signin-page">
        <section class="signin-card">
            <div class="mb-4 text-center">
                <h1 class="signin-title h3 mb-2">Sign In</h1>
                <p class="signin-subtitle mb-0">Access your GPOS account.</p>
            </div>

            <form method="post" asp-controller="SignIn" asp-action="Index" class="login-form">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Login" class="form-label">Email or Username</label>
                    <input asp-for="Login" type="text" class="form-control login-identity-input" placeholder="Enter your email or username" autocomplete="username" autofocus required />
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" type="password" class="form-control login-password-input" autocomplete="current-password" required />
                    <div asp-validation-summary="All" class="text-danger login-feedback mt-2"></div>
                </div>

                <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                        <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <a class="btn btn-outline-secondary flex-fill" asp-controller="Home" asp-action="Index">Cancel</a>
                    <button type="submit" class="signin-button btn btn-primary flex-fill">Sign In</button>
                </div>
            </form>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>
