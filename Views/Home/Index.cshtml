@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Gas Station Management System";
}

<main class="home-landing-wrap">
    <section class="home-landing-panel" aria-labelledby="homeTitle">
        <div class="home-brand-mark" aria-hidden="true">G</div>
        <h1 id="homeTitle">Gas Station Management System</h1>
        <p>Select where you want to continue.</p>

        <div class="home-choice-grid">
            <a class="home-choice-card" href="/Admin/Dashboard">
                <span class="home-choice-icon" aria-hidden="true">A</span>
                <span class="home-choice-content">
                    <strong>Administration</strong>
                    <small>Manage users, setup, inventory, fuel, reports, and system settings.</small>
                </span>
            </a>

            <a class="home-choice-card" href="/Salesman/Login">
                <span class="home-choice-icon" aria-hidden="true">P</span>
                <span class="home-choice-content">
                    <strong>POS</strong>
                    <small>Open the point of sale screen for product sales and cashier transactions.</small>
                </span>
            </a>
        </div>
    </section>
</main>
