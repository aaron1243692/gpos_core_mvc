@model gpos.Models.ViewModels.UsersPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item">Access</li>
                <li class="breadcrumb-item active" aria-current="page">Users</li>
            </ol>
        </nav>
        <h1>Users</h1>
        <p class="page-subtitle">Manage admin accounts and assign one active role per user.</p>
    </div>
</div>

<section class="content-card setup-crud-card setup-table-card">
    @if (TempData["UsersFeedback"] is string feedback)
    {
        <div class="alert alert-info mb-0" role="alert">@feedback</div>
    }
    <div class="table-actions fuel-toolbar">
        <form asp-action="Index" method="get" class="setup-search-form fuel-toolbar-search">
            <input class="form-control" name="search" value="@Model.Search" placeholder="Search users" />
        </form>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#userModal">Add User</button>
    </div>
    <div class="setup-table-scroll">
        <table class="table app-table table-sm align-middle admin-table employee-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-id" />
                <col class="col-username" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-role" />
                <col class="col-status" />
                <col class="col-action-wide" />
            </colgroup>
            <thead>
                <tr>
                    <th class="col-no">No</th>
                    <th class="col-id">ID</th>
                    <th class="col-username">Username</th>
                    <th class="col-normal">Email</th>
                    <th class="col-normal">Full Name</th>
                    <th class="col-normal">Branch</th>
                    <th class="col-normal">Department</th>
                    <th class="col-role">Role</th>
                    <th class="col-status">Status</th>
                    <th class="col-action-wide">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Users.Count == 0)
                {
                    <tr><td class="text-center text-muted fw-bold" colspan="10">No users found.</td></tr>
                }
                @for (var i = 0; i < Model.Users.Count; i++)
                {
                    <tr>
                        <td class="col-no">@(i + 1)</td>
                        <td class="col-id">@Model.Users[i].Id</td>
                        <td>@Model.Users[i].Username</td>
                        <td>@Model.Users[i].Email</td>
                        <td>@(Model.Users[i].FullName ?? "-")</td>
                        <td>@(Model.Users[i].Branch?.Name ?? "-")</td>
                        <td>@(Model.Users[i].Department?.Name ?? "-")</td>
                        <td>@(Model.Users[i].UserRoles.FirstOrDefault()?.Role?.Name ?? "-")</td>
                        <td><span class="badge @(Model.Users[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.Users[i].Status == 1 ? "Active" : "Disabled")</span></td>
                        <td class="col-action-wide">
                            <div class="setup-row-actions employee-action-buttons">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Index" asp-route-editId="@Model.Users[i].Id" asp-route-search="@Model.Search">Edit</a>
                                <button class="btn btn-sm btn-outline-secondary user-password-button" type="button" data-user-id="@Model.Users[i].Id" data-user-name="@Model.Users[i].Username" data-bs-toggle="modal" data-bs-target="#passwordModal">Reset Password</button>
                                <button class="btn btn-sm btn-outline-danger user-delete-button" type="button" data-user-id="@Model.Users[i].Id" data-user-name="@Model.Users[i].Username" data-bs-toggle="modal" data-bs-target="#deleteUserModal">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="userModal" tabindex="-1" aria-labelledby="userModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="Save" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="UserForm.Id" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="userModalLabel">@(Model.UserForm.Id > 0 ? "Edit User" : "Add User")</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="UserForm.Username" class="form-label">Username</label>
                        <input asp-for="UserForm.Username" class="form-control" placeholder="Username" />
                        <span asp-validation-for="UserForm.Username" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UserForm.Email" class="form-label">Email</label>
                        <input asp-for="UserForm.Email" class="form-control" placeholder="user@example.com" type="email" />
                        <span asp-validation-for="UserForm.Email" class="text-danger"></span>
                    </div>
                    @if (Model.UserForm.Id == 0)
                    {
                        <div class="mb-3">
                            <label asp-for="UserForm.Password" class="form-label">Password</label>
                            <input asp-for="UserForm.Password" class="form-control" placeholder="Password" type="password" />
                            <span asp-validation-for="UserForm.Password" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="UserForm.ConfirmPassword" class="form-label">Confirm Password</label>
                            <input asp-for="UserForm.ConfirmPassword" class="form-control" placeholder="Confirm password" type="password" />
                            <span asp-validation-for="UserForm.ConfirmPassword" class="text-danger"></span>
                        </div>
                    }
                    <div class="mb-3">
                        <label asp-for="UserForm.FullName" class="form-label">Full Name</label>
                        <input asp-for="UserForm.FullName" class="form-control" placeholder="Full name" />
                        <span asp-validation-for="UserForm.FullName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UserForm.ContactNumber" class="form-label">Contact Number</label>
                        <input asp-for="UserForm.ContactNumber" class="form-control" placeholder="Contact number" />
                        <span asp-validation-for="UserForm.ContactNumber" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UserForm.Address" class="form-label">Address</label>
                        <input asp-for="UserForm.Address" class="form-control" placeholder="Address" />
                        <span asp-validation-for="UserForm.Address" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UserForm.BranchId" class="form-label">Branch</label>
                        <select asp-for="UserForm.BranchId" asp-items="Model.BranchOptions" class="form-select" id="userBranchSelect">
                            <option value="0">Select branch</option>
                        </select>
                        <span asp-validation-for="UserForm.BranchId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UserForm.DepartmentId" class="form-label">Department</label>
                        <select asp-for="UserForm.DepartmentId" asp-items="Model.DepartmentOptions" class="form-select" id="userDepartmentSelect" data-selected-department-id="@Model.UserForm.DepartmentId">
                            <option value="0">Select department</option>
                        </select>
                        <span asp-validation-for="UserForm.DepartmentId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UserForm.RoleId" class="form-label">Role</label>
                        <select asp-for="UserForm.RoleId" asp-items="Model.RoleOptions" class="form-select">
                            <option value="0">Select role</option>
                        </select>
                        <span asp-validation-for="UserForm.RoleId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UserForm.Status" class="form-label">Status</label>
                        <select asp-for="UserForm.Status" class="form-select">
                            <option value="1">Active</option>
                            <option value="0">Disabled</option>
                        </select>
                        <span asp-validation-for="UserForm.Status" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="passwordModal" tabindex="-1" aria-labelledby="passwordModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="ResetPasswordForm.UserId" id="resetPasswordUserId" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="passwordModalLabel">Reset Password</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">Set a new password for <strong id="resetPasswordUserName">this user</strong>.</p>
                    <div class="mb-3">
                        <label asp-for="ResetPasswordForm.Password" class="form-label">New Password</label>
                        <input asp-for="ResetPasswordForm.Password" class="form-control" placeholder="New password" type="password" />
                        <span asp-validation-for="ResetPasswordForm.Password" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ResetPasswordForm.ConfirmPassword" class="form-label">Confirm Password</label>
                        <input asp-for="ResetPasswordForm.ConfirmPassword" class="form-control" placeholder="Confirm password" type="password" />
                        <span asp-validation-for="ResetPasswordForm.ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save Password</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteUserModal" tabindex="-1" aria-labelledby="deleteUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input id="deleteUserId" name="id" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="deleteUserModalLabel">Delete User</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Disable <strong id="deleteUserName">this user</strong>?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-danger" type="submit">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const modalId = "@Model.ActiveModalId";
            const modalElement = modalId ? document.getElementById(modalId) : null;

            if (modalElement && window.bootstrap) {
                bootstrap.Modal.getOrCreateInstance(modalElement).show();
            }

            const branchSelect = document.getElementById("userBranchSelect");
            const departmentSelect = document.getElementById("userDepartmentSelect");

            const resetDepartmentSelect = () => {
                if (!departmentSelect) {
                    return;
                }

                departmentSelect.innerHTML = '<option value="0">Select department</option>';
                departmentSelect.value = "0";
                departmentSelect.disabled = true;
            };

            const loadDepartments = async (branchId, selectedDepartmentId = "0") => {
                resetDepartmentSelect();

                if (!branchId || branchId === "0" || !departmentSelect) {
                    return;
                }

                departmentSelect.innerHTML = '<option value="0">Loading departments...</option>';

                try {
                    const response = await fetch(`/Users/DepartmentsByBranch?branchId=${encodeURIComponent(branchId)}`, {
                        headers: {
                            "Accept": "application/json"
                        }
                    });

                    if (!response.ok) {
                        throw new Error("Unable to load departments.");
                    }

                    const departments = await response.json();
                    departmentSelect.innerHTML = '<option value="0">Select department</option>';

                    departments.forEach((department) => {
                        const option = document.createElement("option");
                        option.value = department.id;
                        option.textContent = department.name;
                        departmentSelect.appendChild(option);
                    });

                    departmentSelect.disabled = departments.length === 0;

                    if (selectedDepartmentId && selectedDepartmentId !== "0") {
                        departmentSelect.value = selectedDepartmentId;
                    }
                } catch {
                    departmentSelect.innerHTML = '<option value="0">Unable to load departments</option>';
                    departmentSelect.disabled = true;
                }
            };

            if (branchSelect && departmentSelect) {
                const selectedDepartmentId = departmentSelect.dataset.selectedDepartmentId || "0";

                if (branchSelect.value && branchSelect.value !== "0") {
                    loadDepartments(branchSelect.value, selectedDepartmentId);
                } else {
                    resetDepartmentSelect();
                }

                branchSelect.addEventListener("change", () => {
                    loadDepartments(branchSelect.value, "0");
                });
            }

            document.querySelectorAll(".user-password-button").forEach((button) => {
                button.addEventListener("click", () => {
                    document.getElementById("resetPasswordUserId").value = button.dataset.userId || "";
                    document.getElementById("resetPasswordUserName").textContent = button.dataset.userName || "this user";
                });
            });

            document.querySelectorAll(".user-delete-button").forEach((button) => {
                button.addEventListener("click", () => {
                    document.getElementById("deleteUserId").value = button.dataset.userId || "";
                    document.getElementById("deleteUserName").textContent = button.dataset.userName || "this user";
                });
            });
        });
    </script>
}
