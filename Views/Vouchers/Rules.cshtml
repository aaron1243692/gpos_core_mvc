@model gpos.Models.ViewModels.VoucherSetupPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Voucher Management</li><li class="breadcrumb-item active">Voucher Rules</li></ol></nav><h1>Voucher Rules</h1><p class="page-subtitle">Configure when, how, and how much vouchers can be redeemed.</p></div></div>
<section class="content-card setup-crud-card setup-table-card">
    @if (TempData["VoucherSetupFeedback"] is string feedback) { <div class="alert alert-info mb-0" role="alert">@feedback</div> }
    <div class="table-actions fuel-toolbar"><form asp-action="Rules" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search voucher rules..." /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#voucherRuleModal">Add Voucher Rule</button></div>
    <div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table discount-rules-table mb-0"><thead><tr><th>No</th><th>ID</th><th>Name</th><th>Reward</th><th>Minimum</th><th>Applies To</th><th>Validity</th><th>Usage</th><th>Priority</th><th>Status</th><th>Action</th></tr></thead><tbody>
        @if (Model.VoucherRules.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="11">No voucher rules yet.</td></tr> }
        @for (var i = 0; i < Model.VoucherRules.Count; i++) { var rule = Model.VoucherRules[i]; <tr><td>@(i + 1)</td><td>@rule.Id</td><td>@rule.Name</td><td>@(rule.RewardType == "Percentage" ? rule.RewardValue.ToString("0.##") + "%" : "₱" + rule.RewardValue.ToString("N2"))</td><td>₱@rule.MinimumPurchaseAmount.ToString("N2")</td><td>@rule.AppliesTo</td><td>@(rule.NoExpiration ? "Forever" : $"{rule.EffectiveDate:yyyy-MM-dd} to {rule.ExpirationDate:yyyy-MM-dd}")</td><td>@rule.UsageLimitType</td><td>@rule.Priority</td><td><span class="badge @(rule.Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(rule.Status == 1 ? "Active" : "Inactive")</span></td><td class="col-action"><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="Rules" asp-route-editId="@rule.Id" asp-route-search="@Model.Search">Edit</a><button class="btn btn-sm btn-outline-danger voucher-rule-delete-button" type="button" data-bs-toggle="modal" data-bs-target="#voucherRuleDeleteModal" data-rule-id="@rule.Id" data-rule-name="@rule.Name">Delete</button></div></td></tr> }
    </tbody></table></div>
</section>
<div class="modal fade" id="voucherRuleModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered modal-lg"><div class="modal-content"><form asp-action="SaveRule" method="post">@Html.AntiForgeryToken()<input asp-for="VoucherRuleForm.Id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Voucher Rule</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="row g-3">
<div class="col-md-6"><label asp-for="VoucherRuleForm.Name" class="form-label">Name</label><input asp-for="VoucherRuleForm.Name" class="form-control" /><span asp-validation-for="VoucherRuleForm.Name" class="text-danger"></span></div>
<div class="col-md-3"><label asp-for="VoucherRuleForm.Priority" class="form-label">Priority</label><input asp-for="VoucherRuleForm.Priority" class="form-control" type="number" /></div>
<div class="col-md-3"><label asp-for="VoucherRuleForm.Status" class="form-label">Status</label><select asp-for="VoucherRuleForm.Status" class="form-select"><option value="1">Active</option><option value="0">Inactive</option></select></div>
<div class="col-md-4"><label asp-for="VoucherRuleForm.RewardType" class="form-label">Reward Type</label><select asp-for="VoucherRuleForm.RewardType" class="form-select"><option>Fixed Amount</option><option>Percentage</option></select><span asp-validation-for="VoucherRuleForm.RewardType" class="text-danger"></span></div>
<div class="col-md-4"><label asp-for="VoucherRuleForm.RewardValue" class="form-label">Reward Value</label><input asp-for="VoucherRuleForm.RewardValue" class="form-control" type="number" step="0.01" /><span asp-validation-for="VoucherRuleForm.RewardValue" class="text-danger"></span></div>
<div class="col-md-4"><label asp-for="VoucherRuleForm.MaxDiscountAmount" class="form-label">Max Discount</label><input asp-for="VoucherRuleForm.MaxDiscountAmount" class="form-control" type="number" step="0.01" /></div>
<div class="col-md-6"><label asp-for="VoucherRuleForm.MinimumPurchaseAmount" class="form-label">Minimum Purchase</label><input asp-for="VoucherRuleForm.MinimumPurchaseAmount" class="form-control" type="number" step="0.01" min="0" /><span asp-validation-for="VoucherRuleForm.MinimumPurchaseAmount" class="text-danger"></span></div>
<div class="col-md-6"><label asp-for="VoucherRuleForm.AppliesTo" class="form-label">Applies To</label><select asp-for="VoucherRuleForm.AppliesTo" class="form-select"><option>Both</option><option>Fuel</option><option>Product</option></select><span asp-validation-for="VoucherRuleForm.AppliesTo" class="text-danger"></span></div>
<div class="col-md-6"><label asp-for="VoucherRuleForm.ProductIds" class="form-label">Applicable Products</label><select asp-for="VoucherRuleForm.ProductIds" asp-items="Model.ProductOptions" class="form-select" multiple></select></div>
<div class="col-md-6"><label asp-for="VoucherRuleForm.CategoryIds" class="form-label">Applicable Categories</label><select asp-for="VoucherRuleForm.CategoryIds" asp-items="Model.CategoryOptions" class="form-select" multiple></select></div>
<div class="col-md-4"><label asp-for="VoucherRuleForm.EffectiveDate" class="form-label">Effective Date</label><input asp-for="VoucherRuleForm.EffectiveDate" class="form-control" type="date" /></div>
<div class="col-md-4"><label asp-for="VoucherRuleForm.ExpirationDate" class="form-label">Expiration Date</label><input asp-for="VoucherRuleForm.ExpirationDate" class="form-control" type="date" /><span asp-validation-for="VoucherRuleForm.ExpirationDate" class="text-danger"></span></div>
<div class="col-md-4 d-flex align-items-end"><label class="form-check mb-2"><input asp-for="VoucherRuleForm.NoExpiration" class="form-check-input" type="checkbox" /><span class="form-check-label">No Expiration</span></label></div>
<div class="col-md-4"><label asp-for="VoucherRuleForm.UsageLimitType" class="form-label">Usage Limit</label><select asp-for="VoucherRuleForm.UsageLimitType" class="form-select"><option>Once Per Voucher</option><option>Limited Uses</option><option>Unlimited</option></select><span asp-validation-for="VoucherRuleForm.UsageLimitType" class="text-danger"></span></div>
<div class="col-md-4"><label asp-for="VoucherRuleForm.MaxRedemptions" class="form-label">Max Redemptions</label><input asp-for="VoucherRuleForm.MaxRedemptions" class="form-control" type="number" min="1" /><span asp-validation-for="VoucherRuleForm.MaxRedemptions" class="text-danger"></span></div>
<div class="col-md-4"><label asp-for="VoucherRuleForm.LimitedUseCount" class="form-label">Limited Uses Per Voucher</label><input asp-for="VoucherRuleForm.LimitedUseCount" class="form-control" type="number" min="1" /><span asp-validation-for="VoucherRuleForm.LimitedUseCount" class="text-danger"></span></div>
<div class="col-12"><label class="form-check"><input asp-for="VoucherRuleForm.UnlimitedUses" class="form-check-input" type="checkbox" /><span class="form-check-label">Unlimited uses</span></label></div>
</div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
<div class="modal fade" id="voucherRuleDeleteModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="DeleteRule" method="post">@Html.AntiForgeryToken()<input id="voucherRuleDeleteId" name="id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Delete Voucher Rule</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><p class="mb-0">Disable this voucher rule?</p><p class="fw-bold mb-0" id="voucherRuleDeleteName"></p></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-danger" type="submit">Delete</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}const deleteModal=document.getElementById("voucherRuleDeleteModal");if(deleteModal){deleteModal.addEventListener("show.bs.modal",event=>{const button=event.relatedTarget;document.getElementById("voucherRuleDeleteId").value=button?.dataset.ruleId||"";document.getElementById("voucherRuleDeleteName").textContent=button?.dataset.ruleName||"";});}});</script> }
