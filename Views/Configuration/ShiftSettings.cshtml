@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Config</li><li class="breadcrumb-item active">Shift Settings</li></ol></nav><h1>Shift Settings</h1><p class="page-subtitle">Manage shift rules and cash handling options.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="ShiftSettings" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search shifts" /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#shiftSettingModal">Add Shift</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Name</th><th>Start Time</th><th>End Time</th><th>Opening Cash Required</th><th>Allow Cash In</th><th>Allow Cash Out</th><th>Closing Approval Required</th><th>Status</th><th>Action</th></tr></thead><tbody>
@if (Model.ShiftSettings.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="11">No shift settings yet.</td></tr> }
@for (var i = 0; i < Model.ShiftSettings.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.ShiftSettings[i].Id</td><td>@Model.ShiftSettings[i].Name</td><td>@Model.ShiftSettings[i].StartTime?.ToString(@"hh\:mm")</td><td>@Model.ShiftSettings[i].EndTime?.ToString(@"hh\:mm")</td><td>@(Model.ShiftSettings[i].RequireOpeningCash == 1 ? "Yes" : "No")</td><td>@(Model.ShiftSettings[i].AllowCashIn == 1 ? "Yes" : "No")</td><td>@(Model.ShiftSettings[i].AllowCashOut == 1 ? "Yes" : "No")</td><td>@(Model.ShiftSettings[i].RequireClosingApproval == 1 ? "Yes" : "No")</td><td><span class="badge @(Model.ShiftSettings[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.ShiftSettings[i].Status == 1 ? "Active" : "Inactive")</span></td><td class="col-action"><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="ShiftSettings" asp-route-editId="@Model.ShiftSettings[i].Id" asp-route-search="@Model.Search">Edit</a><form asp-action="DeleteShiftSetting" method="post" data-deactivate-form>@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.ShiftSettings[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-danger" type="submit">Deactivate</button></form></div></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="shiftSettingModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveShiftSetting" method="post">@Html.AntiForgeryToken()<input asp-for="ShiftSettingForm.Id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Shift Setting</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="ShiftSettingForm.Name" class="form-label">Name</label><input asp-for="ShiftSettingForm.Name" class="form-control" /><span asp-validation-for="ShiftSettingForm.Name" class="text-danger"></span></div><div class="row g-2"><div class="col-md-6 mb-3"><label asp-for="ShiftSettingForm.StartTime" class="form-label">Start Time</label><input asp-for="ShiftSettingForm.StartTime" class="form-control" type="time" /></div><div class="col-md-6 mb-3"><label asp-for="ShiftSettingForm.EndTime" class="form-label">End Time</label><input asp-for="ShiftSettingForm.EndTime" class="form-control" type="time" /></div></div><label class="form-check mb-2"><input asp-for="ShiftSettingForm.RequireOpeningCash" class="form-check-input" /><span class="form-check-label">Opening Cash Required</span></label><label class="form-check mb-2"><input asp-for="ShiftSettingForm.AllowCashIn" class="form-check-input" /><span class="form-check-label">Allow Cash In</span></label><label class="form-check mb-2"><input asp-for="ShiftSettingForm.AllowCashOut" class="form-check-input" /><span class="form-check-label">Allow Cash Out</span></label><label class="form-check mb-3"><input asp-for="ShiftSettingForm.RequireClosingApproval" class="form-check-input" /><span class="form-check-label">Closing Approval Required</span></label><input asp-for="ShiftSettingForm.Status" type="hidden" /></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
