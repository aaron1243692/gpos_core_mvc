@model gpos.Models.ViewModels.DiscountSetupPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item">Discounts</li>
                <li class="breadcrumb-item active" aria-current="page">Discounts</li>
            </ol>
        </nav>
        <h1>Discounts</h1>
        <p class="page-subtitle">Manage discount earning rates.</p>
    </div>
</div>

<section class="content-card setup-crud-card setup-table-card">
    @if (TempData["DiscountSetupFeedback"] is string feedback)
    {
        <div class="alert alert-info mb-0" role="alert">@feedback</div>
    }
    <div class="table-actions fuel-toolbar">
        <form asp-action="Discounts" method="get" class="setup-search-form fuel-toolbar-search">
            <input class="form-control" name="search" value="@Model.Search" placeholder="Search discounts" />
        </form>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#discountModal">Add Discount</button>
    </div>
    <div class="setup-table-scroll">
        <table class="table app-table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>No</th>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Earn Rate</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Discounts.Count == 0)
                {
                    <tr><td class="text-center text-muted fw-bold" colspan="6">No discounts yet.</td></tr>
                }
                @for (var i = 0; i < Model.Discounts.Count; i++)
                {
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@Model.Discounts[i].Id</td>
                        <td>@Model.Discounts[i].Name</td>
                        <td>@Model.Discounts[i].EarnRate.ToString("N2")%</td>
                        <td>
                            @if (Model.Discounts[i].Status == 1)
                            {
                                <span class="badge text-bg-success">Active</span>
                            }
                            @if (Model.Discounts[i].Status == 0)
                            {
                                <span class="badge text-bg-secondary">Disabled</span>
                            }
                        </td>
                        <td>
                            <div class="setup-row-actions">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Discounts" asp-route-editId="@Model.Discounts[i].Id" asp-route-search="@Model.Search">Edit</a>
                                <form asp-action="DeleteDiscount" method="post" onsubmit="return confirm('Disable this discount?');">
                                    @Html.AntiForgeryToken()
                                    <input name="id" type="hidden" value="@Model.Discounts[i].Id" />
                                    <input name="search" type="hidden" value="@Model.Search" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="discountModal" tabindex="-1" aria-labelledby="discountModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SaveDiscount" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="DiscountForm.Id" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="discountModalLabel">Discount</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="DiscountForm.Name" class="form-label">Name</label>
                        <input asp-for="DiscountForm.Name" class="form-control" autocomplete="off" />
                        <span asp-validation-for="DiscountForm.Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DiscountForm.EarnRate" class="form-label">Earn Rate (%)</label>
                        <input asp-for="DiscountForm.EarnRate" class="form-control" min="0" step="0.01" type="number" />
                        <span asp-validation-for="DiscountForm.EarnRate" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DiscountForm.Status" class="form-label">Status</label>
                        <select asp-for="DiscountForm.Status" class="form-select">
                            <option value="1">Active</option>
                            <option value="0">Disabled</option>
                        </select>
                        <span asp-validation-for="DiscountForm.Status" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const modalId = "@Model.ActiveModalId";
            const modalElement = modalId ? document.getElementById(modalId) : null;

            if (modalElement && window.bootstrap) {
                bootstrap.Modal.getOrCreateInstance(modalElement).show();
            }
        });
    </script>
}
