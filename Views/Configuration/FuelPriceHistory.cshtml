@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Fuel</li><li class="breadcrumb-item active">Fuel Price History</li></ol></nav><h1>Fuel Price History</h1><p class="page-subtitle">Add fuel price changes and keep historical prices.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="FuelPriceHistory" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search fuel prices" /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#fuelPriceHistoryModal">Add Price</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-status" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Fuel</th><th>Old Price</th><th>New Price</th><th>Effective At</th><th>Status</th><th>Action</th></tr></thead><tbody>
@if (Model.FuelPriceHistory.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="8">No fuel price history yet.</td></tr> }
@for (var i = 0; i < Model.FuelPriceHistory.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.FuelPriceHistory[i].Id</td><td>@Model.FuelPriceHistory[i].Fuel?.Name</td><td>@Model.FuelPriceHistory[i].OldPrice?.ToString("N2")</td><td>@Model.FuelPriceHistory[i].NewPrice.ToString("N2")</td><td>@Model.FuelPriceHistory[i].EffectiveAt.ToString("yyyy-MM-dd")</td><td><span class="badge @(Model.FuelPriceHistory[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.FuelPriceHistory[i].Status == 1 ? "Active" : "Disabled")</span></td><td class="col-action"><div class="setup-row-actions"><form asp-action="DeleteFuelPriceHistory" method="post" onsubmit="return confirm('Disable this price history?');">@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.FuelPriceHistory[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-danger" type="submit">Delete</button></form></div></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="fuelPriceHistoryModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveFuelPriceHistory" method="post">@Html.AntiForgeryToken()<input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Fuel Price</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="FuelPriceHistoryForm.FuelId" class="form-label">Fuel</label><select asp-for="FuelPriceHistoryForm.FuelId" asp-items="Model.FuelOptions" class="form-select"><option value="0">Select fuel</option></select><span asp-validation-for="FuelPriceHistoryForm.FuelId" class="text-danger"></span></div><div class="mb-3"><label asp-for="FuelPriceHistoryForm.NewPrice" class="form-label">New Price</label><input asp-for="FuelPriceHistoryForm.NewPrice" class="form-control" type="number" step="0.01" min="0" /><span asp-validation-for="FuelPriceHistoryForm.NewPrice" class="text-danger"></span></div><div class="mb-3"><label asp-for="FuelPriceHistoryForm.EffectiveAt" class="form-label">Effective At</label><input asp-for="FuelPriceHistoryForm.EffectiveAt" class="form-control" type="date" /><span asp-validation-for="FuelPriceHistoryForm.EffectiveAt" class="text-danger"></span></div><div class="mb-3"><label asp-for="FuelPriceHistoryForm.Remarks" class="form-label">Remarks</label><input asp-for="FuelPriceHistoryForm.Remarks" class="form-control" /></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
