@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Discounts</li><li class="breadcrumb-item active">Points Ledger</li></ol></nav><h1>Points Ledger</h1><p class="page-subtitle">Track member points earned, used, adjusted, and reversed.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="PointsLedger" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search points ledger" /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#pointsLedgerModal">Add Ledger Entry</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-name" /><col class="col-normal" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Member</th><th>Transaction Type</th><th>Points</th><th>Reference</th><th>Remarks</th><th>Date</th></tr></thead><tbody>
@if (Model.PointsLedger.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="8">No points ledger entries yet.</td></tr> }
@for (var i = 0; i < Model.PointsLedger.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.PointsLedger[i].Id</td><td>@Model.PointsLedger[i].Member?.FullName</td><td>@Model.PointsLedger[i].TransactionType</td><td>@Model.PointsLedger[i].Points.ToString("N2")</td><td>@(Model.PointsLedger[i].ReferenceType + " " + Model.PointsLedger[i].ReferenceId)</td><td>@Model.PointsLedger[i].Remarks</td><td>@Model.PointsLedger[i].CreatedAt?.ToString("yyyy-MM-dd")</td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="pointsLedgerModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SavePointsLedger" method="post">@Html.AntiForgeryToken()<input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Points Ledger</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="PointsLedgerForm.MemberId" class="form-label">Member</label><select asp-for="PointsLedgerForm.MemberId" asp-items="Model.MemberOptions" class="form-select"><option value="0">Select member</option></select><span asp-validation-for="PointsLedgerForm.MemberId" class="text-danger"></span></div><div class="mb-3"><label asp-for="PointsLedgerForm.TransactionType" class="form-label">Transaction Type</label><select asp-for="PointsLedgerForm.TransactionType" class="form-select"><option>Earned</option><option>Used</option><option>Adjusted</option><option>Reversed</option></select></div><div class="mb-3"><label asp-for="PointsLedgerForm.Points" class="form-label">Points</label><input asp-for="PointsLedgerForm.Points" class="form-control" type="number" step="0.01" /><span asp-validation-for="PointsLedgerForm.Points" class="text-danger"></span></div><div class="row g-2"><div class="col-md-6 mb-3"><label asp-for="PointsLedgerForm.ReferenceType" class="form-label">Reference Type</label><input asp-for="PointsLedgerForm.ReferenceType" class="form-control" /></div><div class="col-md-6 mb-3"><label asp-for="PointsLedgerForm.ReferenceId" class="form-label">Reference ID</label><input asp-for="PointsLedgerForm.ReferenceId" class="form-control" type="number" /></div></div><div class="mb-3"><label asp-for="PointsLedgerForm.Remarks" class="form-label">Remarks</label><input asp-for="PointsLedgerForm.Remarks" class="form-control" /></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
