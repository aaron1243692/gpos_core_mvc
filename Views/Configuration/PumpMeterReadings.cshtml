@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item">Fuel</li>
                <li class="breadcrumb-item active">Pump Meter Readings</li>
            </ol>
        </nav>
        <h1>Pump Meter Readings</h1>
        <p class="page-subtitle">Record opening and closing meter readings by nozzle.</p>
    </div>
</div>

<section class="content-card setup-crud-card setup-table-card">
    <div class="table-actions fuel-toolbar">
        <form asp-action="PumpMeterReadings" method="get" class="setup-search-form fuel-toolbar-search">
            <input class="form-control" name="search" value="@Model.Search" placeholder="Search readings" />
        </form>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#pumpMeterReadingModal">Add Reading</button>
    </div>
    <div class="setup-table-scroll">
        <table class="table app-table table-sm align-middle admin-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-id" />
                <col class="col-normal" />
                <col class="col-name" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-status" />
            </colgroup>
            <thead>
                <tr>
                    <th>No</th>
                    <th>ID</th>
                    <th>Nozzle</th>
                    <th>Pump</th>
                    <th>Tank</th>
                    <th>Fuel</th>
                    <th>Opening Meter</th>
                    <th>Closing Meter</th>
                    <th>Liters Sold</th>
                    <th>Reading Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.PumpMeterReadings.Count == 0)
                {
                    <tr><td class="text-center text-muted fw-bold" colspan="11">No pump meter readings yet.</td></tr>
                }
                @for (var i = 0; i < Model.PumpMeterReadings.Count; i++)
                {
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@Model.PumpMeterReadings[i].Id</td>
                        <td>@(Model.PumpMeterReadings[i].Nozzle?.NozzleNo ?? "-")</td>
                        <td>@(Model.PumpMeterReadings[i].Nozzle?.Pump?.Name ?? Model.PumpMeterReadings[i].Pump?.Name ?? "-")</td>
                        <td>@(Model.PumpMeterReadings[i].Nozzle?.Pump?.Tank?.TankNo ?? Model.PumpMeterReadings[i].Pump?.Tank?.TankNo ?? "-")</td>
                        <td>@(Model.PumpMeterReadings[i].Nozzle?.Pump?.Tank?.Fuel?.Name ?? Model.PumpMeterReadings[i].Pump?.Tank?.Fuel?.Name ?? "-")</td>
                        <td>@Model.PumpMeterReadings[i].OpeningMeter.ToString("N2")</td>
                        <td>@(Model.PumpMeterReadings[i].ClosingMeter?.ToString("N2") ?? "-")</td>
                        <td>@(Model.PumpMeterReadings[i].LitersSold?.ToString("N2") ?? "-")</td>
                        <td>@Model.PumpMeterReadings[i].ReadingDate.ToString("yyyy-MM-dd")</td>
                        <td><span class="badge @(Model.PumpMeterReadings[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.PumpMeterReadings[i].Status == 1 ? "Active" : "Inactive")</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="pumpMeterReadingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SavePumpMeterReading" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="PumpMeterReadingForm.Id" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Pump Meter Reading</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="PumpMeterReadingForm.NozzleId" class="form-label">Nozzle</label>
                        <select asp-for="PumpMeterReadingForm.NozzleId" class="form-select" data-nozzle-reading-source data-selected-nozzle="@Model.PumpMeterReadingForm.NozzleId">
                            <option value="0" data-pump="" data-tank="" data-fuel="">Select nozzle</option>
                            @for (var i = 0; i < Model.Nozzles.Count; i++)
                            {
                                <option value="@Model.Nozzles[i].Id" data-pump="@(Model.Nozzles[i].Pump?.Name ?? string.Empty)" data-tank="@(Model.Nozzles[i].Pump?.Tank?.TankNo ?? string.Empty)" data-fuel="@(Model.Nozzles[i].Pump?.Tank?.Fuel?.Name ?? string.Empty)">@(Model.Nozzles[i].NozzleNo) - @(Model.Nozzles[i].Pump?.Name ?? "-") - @(Model.Nozzles[i].Pump?.Tank?.TankNo ?? "-") - @(Model.Nozzles[i].Pump?.Tank?.Fuel?.Name ?? "-")</option>
                            }
                        </select>
                        <span asp-validation-for="PumpMeterReadingForm.NozzleId" class="text-danger"></span>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Pump</label>
                            <input class="form-control" type="text" data-derived-pump readonly />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Tank</label>
                            <input class="form-control" type="text" data-derived-tank readonly />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Fuel</label>
                            <input class="form-control" type="text" data-derived-fuel readonly />
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label asp-for="PumpMeterReadingForm.OpeningMeter" class="form-label">Opening Meter</label>
                            <input asp-for="PumpMeterReadingForm.OpeningMeter" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="PumpMeterReadingForm.OpeningMeter" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="PumpMeterReadingForm.ClosingMeter" class="form-label">Closing Meter</label>
                            <input asp-for="PumpMeterReadingForm.ClosingMeter" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="PumpMeterReadingForm.ClosingMeter" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PumpMeterReadingForm.ReadingDate" class="form-label">Reading Date</label>
                        <input asp-for="PumpMeterReadingForm.ReadingDate" class="form-control" type="date" />
                        <span asp-validation-for="PumpMeterReadingForm.ReadingDate" class="text-danger"></span>
                    </div>
                    <input asp-for="PumpMeterReadingForm.Status" type="hidden" />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const modalId = "@Model.ActiveModalId";
            const modalElement = modalId ? document.getElementById(modalId) : null;

            if (modalElement && window.bootstrap) {
                bootstrap.Modal.getOrCreateInstance(modalElement).show();
            }

            const nozzleSelect = document.querySelector("[data-nozzle-reading-source]");
            const pumpField = document.querySelector("[data-derived-pump]");
            const tankField = document.querySelector("[data-derived-tank]");
            const fuelField = document.querySelector("[data-derived-fuel]");

            if (!nozzleSelect || !pumpField || !tankField || !fuelField) {
                return;
            }

            const selectedNozzle = nozzleSelect.getAttribute("data-selected-nozzle");
            if (selectedNozzle) {
                nozzleSelect.value = selectedNozzle;
            }

            const updateDerivedFields = () => {
                const option = nozzleSelect.selectedOptions.length > 0 ? nozzleSelect.selectedOptions[0] : null;
                pumpField.value = option?.getAttribute("data-pump") || "";
                tankField.value = option?.getAttribute("data-tank") || "";
                fuelField.value = option?.getAttribute("data-fuel") || "";
            };

            nozzleSelect.addEventListener("change", updateDerivedFields);
            updateDerivedFields();
        });
    </script>
}
