@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Access</li><li class="breadcrumb-item active">Role Permissions</li></ol></nav><h1>Role Permissions</h1><p class="page-subtitle">Assign permissions to roles.</p></div></div>
<section class="content-card setup-crud-card">
    <form asp-action="RolePermissions" method="get" class="setup-search-form fuel-toolbar-search mb-3"><label class="form-label">Select Role</label><select class="form-select" name="roleId" asp-items="Model.RoleOptions" onchange="this.form.submit()"><option value="0">Select role</option></select></form>
    <form asp-action="SaveRolePermissions" method="post">@Html.AntiForgeryToken()<input asp-for="RolePermissionsForm.RoleId" type="hidden" /><span asp-validation-for="RolePermissionsForm.RoleId" class="text-danger"></span>
        <div class="setup-table-scroll">
            <table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-name" /><col class="col-normal" /></colgroup><thead><tr><th>Permission</th><th>Assigned</th></tr></thead><tbody>
                @if (Model.Permissions.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="2">No permissions yet.</td></tr> }
                @for (var i = 0; i < Model.Permissions.Count; i++)
                {
                    <tr><td>@Model.Permissions[i].Name</td><td><label class="form-check mb-0"><input class="form-check-input" type="checkbox" name="RolePermissionsForm.PermissionIds" value="@Model.Permissions[i].Id" checked="@Model.AssignedPermissionIds.Contains(Model.Permissions[i].Id)" /><span class="form-check-label">Allow</span></label></td></tr>
                }
            </tbody></table>
        </div>
        <div class="mt-3"><button class="btn btn-primary" type="submit">Save Permissions</button></div>
    </form>
</section>
<script>document.addEventListener("DOMContentLoaded",()=>{const roleSelect=document.querySelector("select[name='roleId']");const selected="@Model.RolePermissionsForm.RoleId";if(roleSelect&&selected){roleSelect.value=selected;}});</script>
