@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Discounts</li><li class="breadcrumb-item active">Rebate</li></ol></nav><h1>Rebate</h1><p class="page-subtitle">Define how member points convert into rebate value.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="Rebate" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search rebates" /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#rebateRuleModal">Add Rebate</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Name</th><th>Points Required</th><th>Rebate Value</th><th>Status</th><th>Action</th></tr></thead><tbody>
@if (Model.RebateRules.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="7">No rebate rules yet.</td></tr> }
@for (var i = 0; i < Model.RebateRules.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.RebateRules[i].Id</td><td>@Model.RebateRules[i].Name</td><td>@Model.RebateRules[i].PointsRequired.ToString("N2")</td><td>@Model.RebateRules[i].RebateValue.ToString("N2")</td><td><span class="badge @(Model.RebateRules[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.RebateRules[i].Status == 1 ? "Active" : "Disabled")</span></td><td class="col-action"><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="Rebate" asp-route-editId="@Model.RebateRules[i].Id" asp-route-search="@Model.Search">Edit</a><form asp-action="DeleteRebateRule" method="post" onsubmit="return confirm('Disable this rebate rule?');">@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.RebateRules[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-danger" type="submit">Delete</button></form></div></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="rebateRuleModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveRebateRule" method="post">@Html.AntiForgeryToken()<input asp-for="RebateRuleForm.Id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Rebate Rule</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="RebateRuleForm.Name" class="form-label">Name</label><input asp-for="RebateRuleForm.Name" class="form-control" /><span asp-validation-for="RebateRuleForm.Name" class="text-danger"></span></div><div class="mb-3"><label asp-for="RebateRuleForm.PointsRequired" class="form-label">Points Required</label><input asp-for="RebateRuleForm.PointsRequired" class="form-control" type="number" step="0.01" min="0.01" /></div><div class="mb-3"><label asp-for="RebateRuleForm.RebateValue" class="form-label">Rebate Value</label><input asp-for="RebateRuleForm.RebateValue" class="form-control" type="number" step="0.01" min="0.01" /></div><div class="mb-3"><label asp-for="RebateRuleForm.Status" class="form-label">Status</label><select asp-for="RebateRuleForm.Status" class="form-select"><option value="1">Active</option><option value="0">Disabled</option></select></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
