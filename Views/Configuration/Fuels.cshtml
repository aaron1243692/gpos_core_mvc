@model gpos.Models.ViewModels.FuelSetupPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item">Fuel</li>
                <li class="breadcrumb-item active" aria-current="page">Fuels</li>
            </ol>
        </nav>
        <h1>Fuels</h1>
        <p class="page-subtitle">Manage fuels, unit relationships, and current prices.</p>
    </div>
</div>

<section class="content-card setup-crud-card setup-table-card">
    @if (TempData["FuelSetupFeedback"] is string feedback)
    {
        <div class="alert alert-info mb-0" role="alert">@feedback</div>
    }
    <div class="table-actions fuel-toolbar">
        <form asp-action="Fuels" method="get" class="setup-search-form fuel-toolbar-search">
            <input class="form-control" name="search" value="@Model.Search" placeholder="Search by name or code" />
        </form>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#fuelModal">Add Fuel</button>
    </div>
    <div class="setup-table-scroll">
        <table class="table app-table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>No</th>
                    <th>ID</th>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Supplier</th>
                    <th>Current Price Per Liter</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Fuels.Count == 0)
                {
                    <tr><td class="text-center text-muted fw-bold" colspan="8">No records yet.</td></tr>
                }
                @for (var i = 0; i < Model.Fuels.Count; i++)
                {
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@Model.Fuels[i].Id</td>
                        <td>@Model.Fuels[i].Code</td>
                        <td>@Model.Fuels[i].Name</td>
                        <td>@(Model.Fuels[i].Supplier == null ? "No supplier" : Model.Fuels[i].Supplier!.Name)</td>
                        <td>&#8369;@Model.Fuels[i].CurrentPricePerLiter.ToString("N2")</td>
                        <td>@(Model.Fuels[i].IsActive ? "Active" : "Inactive")</td>
                        <td>
                            <div class="setup-row-actions">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Fuels" asp-route-editId="@Model.Fuels[i].Id" asp-route-search="@Model.Search">Edit</a>
                                <form asp-action="DeleteFuel" method="post" onsubmit="return confirm('Delete this fuel?');">
                                    @Html.AntiForgeryToken()
                                    <input name="id" type="hidden" value="@Model.Fuels[i].Id" />
                                    <input name="search" type="hidden" value="@Model.Search" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="fuelModal" tabindex="-1" aria-labelledby="fuelModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SaveFuel" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="FuelForm.Id" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="fuelModalLabel">Add Fuel</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="FuelForm.SupplierId" class="form-label">Supplier</label>
                        <input class="form-control mb-2" id="fuelSupplierSearch" type="search" placeholder="Search supplier" autocomplete="off" />
                        <select asp-for="FuelForm.SupplierId" asp-items="Model.SupplierOptions" class="form-select" id="fuelSupplierSelect"></select>
                        <span asp-validation-for="FuelForm.SupplierId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="FuelForm.Code" class="form-label">Code</label>
                        <input asp-for="FuelForm.Code" class="form-control" placeholder="DSL" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="FuelForm.Name" class="form-label">Name</label>
                        <input asp-for="FuelForm.Name" class="form-control" placeholder="Diesel" />
                        <span asp-validation-for="FuelForm.Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="FuelForm.CurrentPricePerLiter" class="form-label">Current Price Per Liter</label>
                        <input asp-for="FuelForm.CurrentPricePerLiter" class="form-control" min="0" step="0.01" type="number" />
                        <span asp-validation-for="FuelForm.CurrentPricePerLiter" class="text-danger"></span>
                    </div>
                    <label class="form-check">
                        <input asp-for="FuelForm.IsActive" class="form-check-input" />
                        <span class="form-check-label">Active</span>
                    </label>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const modalId = "@Model.ActiveModalId";
            const modalElement = modalId ? document.getElementById(modalId) : null;

            if (modalElement && window.bootstrap) {
                bootstrap.Modal.getOrCreateInstance(modalElement).show();
            }

            const supplierSearch = document.getElementById("fuelSupplierSearch");
            const supplierSelect = document.getElementById("fuelSupplierSelect");

            if (supplierSearch && supplierSelect) {
                const supplierOptions = Array.from(supplierSelect.options);

                supplierSearch.addEventListener("input", () => {
                    const searchText = supplierSearch.value.trim().toLowerCase();

                    supplierOptions.forEach(option => {
                        const isPlaceholder = option.value === "";
                        const matches = option.text.toLowerCase().includes(searchText);
                        option.hidden = !isPlaceholder && searchText.length > 0 && !matches;
                    });

                    if (supplierSelect.selectedOptions[0]?.hidden) {
                        supplierSelect.value = "";
                    }
                });
            }
        });
    </script>
}
