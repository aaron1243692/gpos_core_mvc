@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Fuel</li><li class="breadcrumb-item active">Nozzles</li></ol></nav><h1>Nozzles</h1><p class="page-subtitle">Manage pump nozzles and derive fuel through pump, tank, and fuel.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="Nozzles" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search nozzles" /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#nozzleModal">Add Nozzle</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Nozzle No</th><th>Pump</th><th>Tank</th><th>Fuel</th><th>Status</th><th>Action</th></tr></thead><tbody>
@if (Model.Nozzles.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="8">No nozzles yet.</td></tr> }
@for (var i = 0; i < Model.Nozzles.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.Nozzles[i].Id</td><td>@Model.Nozzles[i].NozzleNo</td><td>@Model.Nozzles[i].Pump?.Name</td><td>@Model.Nozzles[i].Pump?.Tank?.TankNo</td><td>@Model.Nozzles[i].Pump?.Tank?.Fuel?.Name</td><td><span class="badge @(Model.Nozzles[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.Nozzles[i].Status == 1 ? "Active" : "Inactive")</span></td><td class="col-action"><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="Nozzles" asp-route-editId="@Model.Nozzles[i].Id" asp-route-search="@Model.Search">Edit</a>@if (Model.Nozzles[i].Status == 1)
                                {
                                    <form asp-action="DeleteNozzle" method="post" data-deactivate-form>@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.Nozzles[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-danger" type="submit">Deactivate</button></form>
                                }
                                @if (!(Model.Nozzles[i].Status == 1))
                                {
                                    <form asp-action="ActivateNozzle" method="post">@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.Nozzles[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-success" type="submit">Activate</button></form>
                                }</div></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="nozzleModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveNozzle" method="post">@Html.AntiForgeryToken()<input asp-for="NozzleForm.Id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Nozzle</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="NozzleForm.NozzleNo" class="form-label">Nozzle No</label><input asp-for="NozzleForm.NozzleNo" class="form-control" /><span asp-validation-for="NozzleForm.NozzleNo" class="text-danger"></span></div><div class="mb-3"><label asp-for="NozzleForm.PumpId" class="form-label">Pump</label><select asp-for="NozzleForm.PumpId" asp-items="Model.PumpOptions" class="form-select"><option value="0">Select pump</option></select><span asp-validation-for="NozzleForm.PumpId" class="text-danger"></span></div><input asp-for="NozzleForm.Status" type="hidden" /></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
