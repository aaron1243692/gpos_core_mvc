@model gpos.Models.ViewModels.FuelEquipmentPageViewModel
<div class="page-header"><div class="page-heading"><h1>Pumps</h1><p class="page-subtitle">Manage pumps, tank connections, and their single nozzle.</p></div></div>
<section class="content-card setup-crud-card setup-table-card">
    <div class="table-actions fuel-toolbar">
        <form asp-action="FuelPumps" method="get" class="setup-search-form fuel-toolbar-search flex-wrap"><input class="form-control" name="search" value="@Model.Search" placeholder="Search pumps"/><select class="form-select" name="filterBranchId" asp-items="Model.BranchOptions"></select><button class="btn btn-outline-primary" type="submit">Search</button></form>
        <button class="btn btn-primary" id="addPumpButton" type="button">Add Pump</button>
    </div>
    <div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><thead><tr><th>No</th><th>Branch</th><th>Dispenser</th><th>Pump Code</th><th>Pump Name</th><th>Tank</th><th>Fuel</th><th>Nozzle</th><th>Status</th><th>Action</th></tr></thead><tbody>
    @if(Model.Pumps.Count==0){<tr><td colspan="10" class="text-center text-muted">No pumps yet.</td></tr>}
    @for(var i=0;i<Model.Pumps.Count;i++){var x=Model.Pumps[i];var n=x.Nozzles.SingleOrDefault();<tr><td>@(i+1)</td><td>@(x.Branch?.Name??"Unassigned")</td><td>@(x.Dispenser?.Name??"Legacy / unassigned")</td><td>@x.PumpNo</td><td>@x.Name</td><td>@(x.Tank?.TankNo??"-")</td><td>@(x.Tank?.Fuel?.Name??"-")</td><td>@(n?.NozzleNo??"Missing")</td><td><span class="badge @(x.Status==1?"text-bg-success":"text-bg-secondary")">@(x.Status==1?"Active":"Inactive")</span></td><td><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="FuelPumps" asp-route-editId="@x.Id" asp-route-search="@Model.Search" asp-route-filterBranchId="@Model.BranchId" asp-route-status="@Model.Status">Edit</a><form asp-action="SetFuelPumpStatus" method="post">@Html.AntiForgeryToken()<input name="id" value="@x.Id" type="hidden"/><input name="status" value="@(x.Status==1?0:1)" type="hidden"/><button type="submit" class="btn btn-sm @(x.Status==1?"btn-outline-danger":"btn-outline-success")">@(x.Status==1?"Deactivate":"Activate")</button></form></div></td></tr>}
    </tbody></table></div>
</section>

<div class="modal fade" id="pumpModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered modal-lg"><div class="modal-content"><form asp-action="SaveFuelPump" method="post" id="pumpForm">@Html.AntiForgeryToken()
    <input asp-for="PumpForm.Id" id="pumpId" type="hidden"/>
    <div class="modal-header"><h2 class="modal-title fs-5" id="pumpModalTitle">@(Model.PumpForm.Id > 0 ? "Edit Pump" : "Add Pump")</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div>
    <div class="modal-body"><div id="pumpEditWarning" class="alert alert-warning @(Model.PumpForm.Id>0?"":"d-none")">Changing the Dispenser or Tank affects future sales only; historical sales are not changed.</div><div class="row g-3">
        <div class="col-md-6"><label class="form-label">Branch</label><input asp-for="PumpForm.BranchId" id="equipmentBranch" type="hidden"/><div class="input-group" data-branch-selector data-branch-hidden="#equipmentBranch" data-branch-display="#pumpBranchName" data-branch-empty-text="Select branch"><input asp-for="PumpForm.BranchName" id="pumpBranchName" class="form-control" placeholder="Select branch" readonly/><button class="btn btn-outline-secondary branch-select-btn" type="button" data-branch-open><img src="/icons/search.png" alt="Search" width="16" height="16"/></button></div><span asp-validation-for="PumpForm.BranchId" class="text-danger"></span></div>
        <div class="col-md-6"><label class="form-label">Dispenser</label><input asp-for="PumpForm.DispenserId" id="dispenserId" type="hidden"/><div class="input-group"><input asp-for="PumpForm.DispenserName" id="dispenserName" class="form-control" placeholder="Select dispenser" readonly/><button class="btn btn-outline-secondary" id="openDispenserSelector" type="button"><img src="/icons/search.png" alt="Search" width="16" height="16"/></button></div><span asp-validation-for="PumpForm.DispenserId" class="text-danger"></span></div>
        <div class="col-md-6"><label class="form-label">Tank</label><input asp-for="PumpForm.TankId" id="tankId" type="hidden"/><div class="input-group"><input asp-for="PumpForm.TankName" id="tankName" class="form-control" placeholder="Select tank" readonly/><button class="btn btn-outline-secondary" id="openTankSelector" type="button"><img src="/icons/search.png" alt="Search" width="16" height="16"/></button></div><span asp-validation-for="PumpForm.TankId" class="text-danger"></span></div>
        <div class="col-md-6"><label class="form-label">Fuel</label><input asp-for="PumpForm.FuelName" class="form-control" id="derivedFuel" readonly/></div>
        <div class="col-md-6"><label class="form-label">Pump Code</label><input asp-for="PumpForm.PumpNo" class="form-control"/><span asp-validation-for="PumpForm.PumpNo" class="text-danger"></span></div>
        <div class="col-md-6"><label class="form-label">Pump Name</label><input asp-for="PumpForm.Name" class="form-control"/><span asp-validation-for="PumpForm.Name" class="text-danger"></span></div>
        <div class="col-md-6"><label class="form-label">Nozzle Code</label><input asp-for="PumpForm.NozzleNo" class="form-control"/><span asp-validation-for="PumpForm.NozzleNo" class="text-danger"></span></div>
        <div class="col-md-6"><label class="form-label">Nozzle Name</label><input asp-for="PumpForm.NozzleName" class="form-control"/></div>
        <div class="col-12"><label class="form-label">Remarks</label><textarea asp-for="PumpForm.Remarks" class="form-control"></textarea></div>
    </div><div asp-validation-summary="ModelOnly" class="text-danger"></div><input asp-for="PumpForm.Status" id="pumpStatus" type="hidden"/></div>
    <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" id="pumpSubmitButton" class="btn btn-primary">@(Model.PumpForm.Id > 0 ? "Update" : "Save")</button></div>
</form></div></div></div>

<div class="modal fade" id="dispenserSelectorModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered modal-lg"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5">Select Dispenser</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="input-group mb-3"><input id="dispenserSelectorSearch" class="form-control" type="search" placeholder="Search dispenser code or name"/><button id="searchDispensers" class="btn btn-outline-primary" type="button">Search</button></div><div class="table-responsive"><table class="table app-table table-sm"><thead><tr><th>No</th><th>Dispenser Code</th><th>Dispenser Name</th><th>Branch</th><th>Status</th><th>Action</th></tr></thead><tbody id="dispenserSelectorResults"></tbody></table></div></div></div></div></div>
<div class="modal fade" id="tankSelectorModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered modal-lg"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5">Select Tank</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="input-group mb-3"><input id="tankSelectorSearch" class="form-control" type="search" placeholder="Search tank or fuel"/><button id="searchTanks" class="btn btn-outline-primary" type="button">Search</button></div><div class="table-responsive"><table class="table app-table table-sm"><thead><tr><th>No</th><th>Tank</th><th>Fuel</th><th>Capacity</th><th>Current Liters</th><th>Status</th><th>Action</th></tr></thead><tbody id="tankSelectorResults"></tbody></table></div></div></div></div></div>
<div class="modal fade fuel-pump-message-modal" id="fuelPumpMessageModal" tabindex="-1" aria-labelledby="fuelPumpMessageModalTitle" aria-hidden="true"><div class="modal-dialog modal-dialog-centered modal-sm"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5" id="fuelPumpMessageModalTitle">Notice</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><p class="mb-0" id="fuelPumpMessageModalBody"></p></div><div class="modal-footer"><button class="btn btn-primary" id="fuelPumpMessageModalOk" type="button" data-bs-dismiss="modal">OK</button></div></div></div></div>
<style>.fuel-pump-message-modal{z-index:1070}.fuel-pump-message-backdrop{z-index:1065;background-color:transparent}</style>

@section Scripts {<partial name="_ValidationScriptsPartial"/><script>
document.addEventListener('DOMContentLoaded',()=>{
 const pumpModalEl=document.getElementById('pumpModal'),pumpModal=bootstrap.Modal.getOrCreateInstance(pumpModalEl),form=document.getElementById('pumpForm'),branch=document.getElementById('equipmentBranch'),branchName=document.getElementById('pumpBranchName'),dId=document.getElementById('dispenserId'),dName=document.getElementById('dispenserName'),tId=document.getElementById('tankId'),tName=document.getElementById('tankName'),fuel=document.getElementById('derivedFuel');
 const dModalEl=document.getElementById('dispenserSelectorModal'),tModalEl=document.getElementById('tankSelectorModal'),dModal=bootstrap.Modal.getOrCreateInstance(dModalEl),tModal=bootstrap.Modal.getOrCreateInstance(tModalEl);
 const messageModalEl=document.getElementById('fuelPumpMessageModal'),messageModal=bootstrap.Modal.getOrCreateInstance(messageModalEl),messageTitle=document.getElementById('fuelPumpMessageModalTitle'),messageBody=document.getElementById('fuelPumpMessageModalBody'),messageOk=document.getElementById('fuelPumpMessageModalOk');let messageTrigger=null;
 function showFuelPumpMessage(title,message){messageTrigger=document.activeElement;messageTitle.textContent=title||'Notice';messageBody.textContent=message||'';messageModal.show()}
 messageModalEl.addEventListener('shown.bs.modal',()=>{const backdrop=document.querySelector('.modal-backdrop:last-of-type');if(backdrop)backdrop.classList.add('fuel-pump-message-backdrop');messageOk.focus()});
 messageModalEl.addEventListener('hidden.bs.modal',()=>{if(document.querySelector('.modal.show'))document.body.classList.add('modal-open');if(messageTrigger&&document.contains(messageTrigger))messageTrigger.focus();messageTrigger=null});
 const esc=v=>String(v??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c]));
 const cleanUrl=()=>{const u=new URL(location.href);u.searchParams.delete('editId');history.replaceState({},'',u.pathname+(u.searchParams.size?'?'+u.searchParams.toString():''));};
 const clearErrors=()=>{form.querySelectorAll('.field-validation-error,.validation-summary-errors').forEach(x=>{x.textContent='';x.classList.remove('field-validation-error','validation-summary-errors');x.classList.add('field-validation-valid','validation-summary-valid')});form.querySelectorAll('.input-validation-error').forEach(x=>x.classList.remove('input-validation-error'));};
 function addMode(){form.reset();document.getElementById('pumpId').value='0';branch.value=branchName.value=dId.value=dName.value=tId.value=tName.value=fuel.value='';['PumpForm_PumpNo','PumpForm_Name','PumpForm_NozzleNo','PumpForm_NozzleName','PumpForm_Remarks'].forEach(id=>{const x=document.getElementById(id);if(x)x.value=''});document.getElementById('pumpStatus').value='1';document.getElementById('pumpModalTitle').textContent='Add Pump';document.getElementById('pumpSubmitButton').textContent='Save';document.getElementById('pumpEditWarning').classList.add('d-none');clearErrors();cleanUrl();}
 document.getElementById('addPumpButton').addEventListener('click',()=>{addMode();pumpModal.show()});
 branch.addEventListener('change',()=>{dId.value=dName.value=tId.value=tName.value=fuel.value='';clearErrors()});
 function needBranch(){if(branch.value)return true;showFuelPumpMessage('Validation','Please select a Branch first.');return false}
 async function loadDispensers(){try{const q=document.getElementById('dispenserSelectorSearch').value,response=await fetch(`/Configuration/SearchEquipmentDispensers?branchId=${branch.value}&search=${encodeURIComponent(q)}`);if(!response.ok)throw new Error(`Dispenser selector returned ${response.status}`);const rows=await response.json();document.getElementById('dispenserSelectorResults').innerHTML=rows.length?rows.map((x,i)=>`<tr><td>${i+1}</td><td>${esc(x.code)}</td><td>${esc(x.name)}</td><td>${esc(x.branch)}</td><td>${esc(x.status)}</td><td><button type="button" class="btn btn-sm btn-outline-primary" data-select-dispenser="${x.id}" data-name="${esc(x.name)}">Select</button></td></tr>`).join(''):'<tr><td colspan="6" class="text-center text-muted">No dispensers found.</td></tr>'}catch(error){console.error('Unable to load dispenser selector.',error);showFuelPumpMessage('Error','Unable to load Dispensers. Please try again.')}}
 async function loadTanks(){try{const q=document.getElementById('tankSelectorSearch').value,response=await fetch(`/Configuration/SearchEquipmentTanks?branchId=${branch.value}&search=${encodeURIComponent(q)}`);if(!response.ok)throw new Error(`Tank selector returned ${response.status}`);const rows=await response.json();document.getElementById('tankSelectorResults').innerHTML=rows.length?rows.map((x,i)=>`<tr><td>${i+1}</td><td>${esc(x.name)}</td><td>${esc(x.fuel)}</td><td>${Number(x.capacity).toLocaleString()}</td><td>${Number(x.currentLiters).toLocaleString()}</td><td>${esc(x.status)}</td><td><button type="button" class="btn btn-sm btn-outline-primary" data-select-tank="${x.id}" data-name="${esc(x.name)}" data-fuel="${esc(x.fuel)}">Select</button></td></tr>`).join(''):'<tr><td colspan="7" class="text-center text-muted">No tanks found.</td></tr>'}catch(error){console.error('Unable to load tank selector.',error);showFuelPumpMessage('Error','Unable to load Tanks. Please try again.')}}
 document.getElementById('openDispenserSelector').addEventListener('click',()=>{if(needBranch()){dModal.show();loadDispensers()}});document.getElementById('openTankSelector').addEventListener('click',()=>{if(needBranch()){tModal.show();loadTanks()}});document.getElementById('searchDispensers').addEventListener('click',loadDispensers);document.getElementById('searchTanks').addEventListener('click',loadTanks);
 document.getElementById('dispenserSelectorResults').addEventListener('click',e=>{const b=e.target.closest('[data-select-dispenser]');if(!b)return;dId.value=b.dataset.selectDispenser;dName.value=b.dataset.name;dModal.hide()});document.getElementById('tankSelectorResults').addEventListener('click',e=>{const b=e.target.closest('[data-select-tank]');if(!b)return;tId.value=b.dataset.selectTank;tName.value=b.dataset.name;fuel.value=b.dataset.fuel;tModal.hide()});
 [dModalEl,tModalEl].forEach(x=>x.addEventListener('hidden.bs.modal',()=>{document.body.classList.add('modal-open');pumpModalEl.classList.add('show')}));
 pumpModalEl.addEventListener('hidden.bs.modal',()=>{addMode()});
 const active='@Model.ActiveModalId';if(active==='pumpModal')pumpModal.show();
});
</script>}
