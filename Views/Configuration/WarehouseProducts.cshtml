<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item">Products</li>
                <li class="breadcrumb-item active" aria-current="page">Warehouse</li>
            </ol>
        </nav>
        <h1>Warehouse Products</h1>
        <p class="page-subtitle">Manage products stored in the warehouse.</p>
    </div>
</div>

<section class="card content-card mb-4">
    <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
        <div class="products-search-wrap">
            <label class="visually-hidden" for="warehouse-product-search">Search warehouse products</label>
            <input class="form-control form-control-sm products-search" id="warehouse-product-search" type="search" placeholder="Search warehouse products" autocomplete="off" />
        </div>
        <div class="col-12 col-sm-auto ms-sm-auto">
            <button class="btn btn-primary btn-sm w-100" type="button">Add Product</button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th scope="col">No</th>
                    <th scope="col">ID</th>
                    <th scope="col">Batch</th>
                    <th scope="col">Name</th>
                    <th scope="col">Supplier</th>
                    <th scope="col">Category</th>
                    <th scope="col">Cost</th>
                    <th scope="col">Selling Price</th>
                    <th scope="col">Quantity</th>
                    <th scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                <tr data-warehouse-product-empty-row>
                    <td class="text-center text-muted fw-bold" colspan="10">No warehouse products yet.</td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const searchInput = document.getElementById("warehouse-product-search");
        const productRows = Array.from(document.querySelectorAll("[data-warehouse-product-row]"));
        const emptyRow = document.querySelector("[data-warehouse-product-empty-row]");

        if (!searchInput || !emptyRow) {
            return;
        }

        searchInput.addEventListener("input", () => {
            const query = searchInput.value.trim().toLowerCase();
            let visibleCount = 0;

            for (let index = 0; index < productRows.length; index += 1) {
                const row = productRows[index];
                const isVisible = !query || row.textContent.toLowerCase().includes(query);
                row.classList.toggle("d-none", !isVisible);

                if (isVisible) {
                    visibleCount += 1;
                }
            }

            emptyRow.classList.toggle("d-none", productRows.length > 0 && visibleCount > 0);
        });
    });
</script>
