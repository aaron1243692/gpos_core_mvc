@model gpos.Models.ViewModels.ProductStockPageViewModel
@{
    var isEdit = Model.StockForm.Id.HasValue && Model.StockForm.Id.Value > 0;
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Inventory</li>
                <li class="breadcrumb-item active" aria-current="page">Display</li>
            </ol>
        </nav>
        <h1>Display Batches</h1>
        <p class="page-subtitle">View display stock by product batch.</p>
    </div>
</div>

<section class="card content-card table-card full-height-card mb-0">
    <div class="table-toolbar d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
        <form class="products-search-wrap d-flex gap-2 flex-wrap" asp-action="DisplayProducts" method="get">
            <label class="visually-hidden" for="display-product-search">Search display batches</label>
            <input class="form-control form-control-sm products-search" id="display-product-search" name="search" value="@Model.Search" type="search" placeholder="Search display batches" autocomplete="off" />
            <select class="form-select form-select-sm" name="branchId">
                @foreach (var branch in Model.BranchOptions)
                {
                    <option value="@branch.Value" selected="@((Model.BranchId?.ToString() ?? string.Empty) == branch.Value ? "selected" : null)">@branch.Text</option>
                }
            </select>
            <button class="btn btn-sm btn-outline-primary" type="submit">Search</button>
            <a class="btn btn-sm btn-outline-secondary" asp-action="DisplayProducts">Clear</a>
        </form>
        <button class="btn btn-sm btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#displayProductModal">Add Display Stock</button>
    </div>

    <div class="table-responsive table-scroll-wrap flex-table-wrap">
        <table class="table table-sm table-hover align-middle admin-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-normal" />
                <col class="col-name" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-status" />
                <col class="col-action" />
            </colgroup>
            <thead>
                <tr>
                    <th class="col-no" scope="col">No</th>
                    <th class="col-batch" scope="col">Batch Number</th>
                    <th class="col-name" scope="col">Product</th>
                    <th scope="col">Branch</th>
                    <th scope="col">Supplier</th>
                    <th class="col-money" scope="col">Cost Price</th>
                    <th class="col-money" scope="col">Selling Price</th>
                    <th class="col-qty" scope="col">Display Quantity</th>
                    <th scope="col">Expiry Date</th>
                    <th class="col-status" scope="col">Status</th>
                    <th class="col-action" scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DisplayStocks.Count == 0)
                {
                    <tr>
                        <td class="text-center text-muted fw-bold" colspan="11">No display batches found.</td>
                    </tr>
                }
                @for (var index = 0; index < Model.DisplayStocks.Count; index += 1)
                {
                    <tr>
                        <td class="col-no">@(index + 1)</td>
                        <td class="col-batch">@(Model.DisplayStocks[index].Batch?.BatchNo ?? "-")</td>
                        <td class="col-name">@(Model.DisplayStocks[index].Product?.Name ?? "-")</td>
                        <td>@(Model.DisplayStocks[index].Branch?.Name ?? "-")</td>
                        <td>@(Model.DisplayStocks[index].Batch?.Supplier?.Name ?? "-")</td>
                        <td>&#8369;@(Model.DisplayStocks[index].Batch?.CostPrice.ToString("N2") ?? "0.00")</td>
                        <td>&#8369;@(Model.DisplayStocks[index].Batch?.SellingPrice.ToString("N2") ?? "0.00")</td>
                        <td class="col-qty">@Model.DisplayStocks[index].Quantity.ToString("N2")</td>
                        <td>@(Model.DisplayStocks[index].Batch?.ExpiryDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td><span class="badge @((Model.DisplayStocks[index].Product?.IsActive ?? false) && (Model.DisplayStocks[index].Product?.Status == 1) && (Model.DisplayStocks[index].Batch?.IsActive ?? false) && (Model.DisplayStocks[index].Batch?.Status == 1) ? "text-bg-success" : "text-bg-secondary")">@((Model.DisplayStocks[index].Product?.IsActive ?? false) && (Model.DisplayStocks[index].Product?.Status == 1) && (Model.DisplayStocks[index].Batch?.IsActive ?? false) && (Model.DisplayStocks[index].Batch?.Status == 1) ? "Active" : "Inactive")</span></td>
                        <td class="col-action">
                            <div class="setup-row-actions">
                                <a class="btn btn-sm btn-outline-primary" asp-action="DisplayProducts" asp-route-editId="@Model.DisplayStocks[index].Id" asp-route-search="@Model.Search" asp-route-branchId="@Model.BranchId">Edit</a>
                                @if ((Model.DisplayStocks[index].Product?.IsActive ?? false) && Model.DisplayStocks[index].Product?.Status == 1)
                                {
                                    <button class="btn btn-sm btn-outline-danger product-deactivate-button" type="button" data-bs-toggle="modal" data-bs-target="#productStatusModal" data-product-id="@Model.DisplayStocks[index].ProductId" data-product-name="@(Model.DisplayStocks[index].Product?.Name ?? "Product")" data-action-url="@Url.Action("DeactivateProductFromStock", "Configuration")">Deactivate</button>
                                }
                                @if (!((Model.DisplayStocks[index].Product?.IsActive ?? false) && Model.DisplayStocks[index].Product?.Status == 1))
                                {
                                    <form asp-action="ActivateProductFromStock" method="post">
                                        @Html.AntiForgeryToken()
                                        <input name="id" type="hidden" value="@Model.DisplayStocks[index].ProductId" />
                                        <input name="source" type="hidden" value="Display" />
                                        <input name="search" type="hidden" value="@Model.Search" />
                                        <input name="branchId" type="hidden" value="@Model.BranchId" />
                                        <button class="btn btn-sm btn-outline-success" type="submit">Activate</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="displayProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SaveDisplayProduct" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="StockForm.Id" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5">@(isEdit ? "Edit Display Stock" : "Add Display Stock")</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                    <div class="mb-3">
                        <label asp-for="StockForm.BranchId" class="form-label">Branch</label>
                        <input asp-for="StockForm.BranchId" type="hidden" id="displayStockBranchId" />
                        <div class="input-group" data-branch-selector data-branch-hidden="#displayStockBranchId" data-branch-display="#displayStockBranchDisplay" data-branch-empty-text="Select branch">
                            <input class="form-control" id="displayStockBranchDisplay" value="@Model.StockForm.BranchName" placeholder="Select branch" readonly />
                            <button type="button" class="btn btn-outline-secondary branch-select-btn">
                                <img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" />
                            </button>
                        </div>
                        <span asp-validation-for="StockForm.BranchId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="StockForm.ProductId" class="form-label">Product</label>
                        <input asp-for="StockForm.ProductId" type="hidden" id="displayStockProductId" />
                        <div class="input-group">
                            <input class="form-control" id="displayStockProductDisplay" value="@Model.StockForm.ProductDisplayName" placeholder="Select product" readonly />
                            <button type="button" class="btn btn-outline-secondary product-stock-product-select-btn" data-bs-toggle="modal" data-bs-target="#productStockProductSelectorModal">
                                <img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" />
                            </button>
                        </div>
                        <span asp-validation-for="StockForm.ProductId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="StockForm.BatchId" class="form-label">Batch</label>
                        <input asp-for="StockForm.BatchId" type="hidden" id="displayStockBatchId" />
                        <div class="input-group">
                            <input class="form-control" id="displayStockBatchDisplay" value="@Model.StockForm.BatchDisplayName" placeholder="Select batch" readonly />
                            <button type="button" class="btn btn-outline-secondary product-stock-batch-select-btn" data-bs-toggle="modal" data-bs-target="#productStockBatchSelectorModal">
                                <img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" />
                            </button>
                        </div>
                        <span asp-validation-for="StockForm.BatchId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="StockForm.Quantity" class="form-label">@(isEdit ? "Current Quantity" : "Initial Quantity")</label>
                        <input asp-for="StockForm.Quantity" class="form-control" type="number" min="0" step="0.01" readonly="@isEdit" />
                        <span asp-validation-for="StockForm.Quantity" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="productStockProductSelectorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Select Product</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input class="form-control" id="productStockProductSearchInput" type="search" placeholder="Search product, category, or unit" />
                    <button class="btn btn-outline-primary" id="productStockProductSearchButton" type="button">Search</button>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>Product</th>
                                <th>Category</th>
                                <th>Unit</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="productStockProductSelectorResults">
                            <tr><td class="text-center text-muted fw-bold" colspan="5">Search for a product.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="productStockBatchSelectorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Select Batch</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input class="form-control" id="productStockBatchSearchInput" type="search" placeholder="Search batch, product, or supplier" />
                    <button class="btn btn-outline-primary" id="productStockBatchSearchButton" type="button">Search</button>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>Batch</th>
                                <th>Product</th>
                                <th>Supplier</th>
                                <th>Cost Price</th>
                                <th>Selling Price</th>
                                <th>Expiry</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="productStockBatchSelectorResults">
                            <tr><td class="text-center text-muted fw-bold" colspan="8">Search for a batch.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="productStatusModal" tabindex="-1" aria-labelledby="productStatusModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="productStatusForm" method="post">
                @Html.AntiForgeryToken()
                <input id="productStatusId" name="id" type="hidden" />
                <input name="source" type="hidden" value="Display" />
                <input name="search" type="hidden" value="@Model.Search" />
                <input name="branchId" type="hidden" value="@Model.BranchId" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="productStatusModalLabel">Deactivate Record</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0" id="productStatusMessage">Are you sure you want to deactivate this record?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-danger deactivate-confirm-btn" id="productStatusConfirmButton" type="submit">Deactivate</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const activeModalId = "@Model.ActiveModalId";
            const activeModal = activeModalId ? document.getElementById(activeModalId) : null;
            if (activeModal && window.bootstrap) {
                bootstrap.Modal.getOrCreateInstance(activeModal).show();
            }

            const form = document.getElementById("productStatusForm");
            const idInput = document.getElementById("productStatusId");
            const title = document.getElementById("productStatusModalLabel");
            const message = document.getElementById("productStatusMessage");
            const confirmButton = document.getElementById("productStatusConfirmButton");

            document.querySelectorAll(".product-deactivate-button").forEach(button => {
                button.addEventListener("click", () => {
                    const productName = button.dataset.productName || "Product";

                    if (form) {
                        form.action = button.dataset.actionUrl || "";
                    }

                    if (idInput) {
                        idInput.value = button.dataset.productId || "";
                    }

                    if (title) {
                        title.textContent = "Deactivate Record";
                    }

                    if (message) {
                        message.textContent = "Are you sure you want to deactivate this record?";
                    }

                    if (confirmButton) {
                        confirmButton.textContent = "Deactivate";
                        confirmButton.classList.add("btn-danger");
                        confirmButton.classList.remove("btn-primary", "btn-success");
                    }
                });
            });

            const productIdInput = document.getElementById("displayStockProductId");
            const productDisplay = document.getElementById("displayStockProductDisplay");
            const batchIdInput = document.getElementById("displayStockBatchId");
            const batchDisplay = document.getElementById("displayStockBatchDisplay");
            const productResults = document.getElementById("productStockProductSelectorResults");
            const batchResults = document.getElementById("productStockBatchSelectorResults");

            const escapeHtml = value => String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");

            function hideModal(id) {
                const modal = document.getElementById(id);
                if (modal && window.bootstrap) {
                    bootstrap.Modal.getOrCreateInstance(modal).hide();
                }
            }

            function renderProducts(rows) {
                if (!productResults) return;
                productResults.innerHTML = rows.length ? "" : '<tr><td class="text-center text-muted fw-bold" colspan="5">No products found.</td></tr>';
                rows.forEach((row, index) => {
                    const tr = document.createElement("tr");
                    tr.innerHTML = `
                        <td>${index + 1}</td>
                        <td>${escapeHtml(row.productName || "-")}</td>
                        <td>${escapeHtml(row.categoryName || "-")}</td>
                        <td>${escapeHtml(row.unitName || "-")}</td>
                        <td><button class="btn btn-sm btn-outline-primary" type="button">Select</button></td>`;
                    tr.querySelector("button").addEventListener("click", () => {
                        if (productIdInput) productIdInput.value = row.productId || "";
                        if (productDisplay) productDisplay.value = row.productName || "";
                        if (batchIdInput) batchIdInput.value = "";
                        if (batchDisplay) batchDisplay.value = "";
                        productIdInput?.dispatchEvent(new Event("change", { bubbles: true }));
                        hideModal("productStockProductSelectorModal");
                    });
                    productResults.appendChild(tr);
                });
            }

            async function searchProducts() {
                if (!productResults) return;
                productResults.innerHTML = '<tr><td class="text-center text-muted fw-bold" colspan="5">Loading products...</td></tr>';
                const query = encodeURIComponent(document.getElementById("productStockProductSearchInput")?.value || "");
                const response = await fetch(`/Configuration/SearchStockProducts?search=${query}`, { headers: { "Accept": "application/json" } });
                if (!response.ok) {
                    productResults.innerHTML = '<tr><td class="text-center text-danger fw-bold" colspan="5">Unable to load products.</td></tr>';
                    return;
                }
                renderProducts(await response.json());
            }

            function renderBatches(rows) {
                if (!batchResults) return;
                batchResults.innerHTML = rows.length ? "" : '<tr><td class="text-center text-muted fw-bold" colspan="8">No batches found.</td></tr>';
                rows.forEach((row, index) => {
                    const tr = document.createElement("tr");
                    tr.innerHTML = `
                        <td>${index + 1}</td>
                        <td>${escapeHtml(row.batchNumber || "-")}</td>
                        <td>${escapeHtml(row.productName || "-")}</td>
                        <td>${escapeHtml(row.supplierName || "-")}</td>
                        <td>${Number(row.costPrice || 0).toFixed(2)}</td>
                        <td>${Number(row.sellingPrice || 0).toFixed(2)}</td>
                        <td>${escapeHtml(row.expiryDate || "-")}</td>
                        <td><button class="btn btn-sm btn-outline-primary" type="button">Select</button></td>`;
                    tr.querySelector("button").addEventListener("click", () => {
                        if (batchIdInput) batchIdInput.value = row.batchId || "";
                        if (batchDisplay) batchDisplay.value = `${row.batchNumber || ""} - ${row.productName || ""}`.trim();
                        if (productIdInput) productIdInput.value = row.productId || productIdInput.value;
                        if (productDisplay && row.productName) productDisplay.value = row.productName;
                        batchIdInput?.dispatchEvent(new Event("change", { bubbles: true }));
                        hideModal("productStockBatchSelectorModal");
                    });
                    batchResults.appendChild(tr);
                });
            }

            async function searchBatches() {
                if (!batchResults) return;
                batchResults.innerHTML = '<tr><td class="text-center text-muted fw-bold" colspan="8">Loading batches...</td></tr>';
                const query = encodeURIComponent(document.getElementById("productStockBatchSearchInput")?.value || "");
                const productId = encodeURIComponent(productIdInput?.value || "");
                const response = await fetch(`/Configuration/SearchStockBatches?search=${query}&productId=${productId}`, { headers: { "Accept": "application/json" } });
                if (!response.ok) {
                    batchResults.innerHTML = '<tr><td class="text-center text-danger fw-bold" colspan="8">Unable to load batches.</td></tr>';
                    return;
                }
                renderBatches(await response.json());
            }

            document.querySelector(".product-stock-product-select-btn")?.addEventListener("click", searchProducts);
            document.getElementById("productStockProductSearchButton")?.addEventListener("click", searchProducts);
            document.getElementById("productStockProductSearchInput")?.addEventListener("keydown", event => {
                if (event.key === "Enter") {
                    event.preventDefault();
                    searchProducts();
                }
            });
            document.querySelector(".product-stock-batch-select-btn")?.addEventListener("click", searchBatches);
            document.getElementById("productStockBatchSearchButton")?.addEventListener("click", searchBatches);
            document.getElementById("productStockBatchSearchInput")?.addEventListener("keydown", event => {
                if (event.key === "Enter") {
                    event.preventDefault();
                    searchBatches();
                }
            });
        });
    </script>
}
