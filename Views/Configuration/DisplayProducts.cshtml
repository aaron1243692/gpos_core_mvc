@model gpos.Models.ViewModels.ProductStockPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Inventory</li>
                <li class="breadcrumb-item active" aria-current="page">Display</li>
            </ol>
        </nav>
        <h1>Display Batches</h1>
        <p class="page-subtitle">View display stock by product batch.</p>
    </div>
</div>

<section class="card content-card table-card full-height-card mb-0">
    <div class="table-toolbar d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
        <form class="products-search-wrap d-flex gap-2 flex-wrap" asp-action="DisplayProducts" method="get">
            <label class="visually-hidden" for="display-product-search">Search display batches</label>
            <input class="form-control form-control-sm products-search" id="display-product-search" name="search" value="@Model.Search" type="search" placeholder="Search display batches" autocomplete="off" />
            <select class="form-select form-select-sm" name="branchId">
                @foreach (var branch in Model.BranchOptions)
                {
                    <option value="@branch.Value" selected="@((Model.BranchId?.ToString() ?? string.Empty) == branch.Value ? "selected" : null)">@branch.Text</option>
                }
            </select>
            <button class="btn btn-sm btn-outline-primary" type="submit">Search</button>
            <a class="btn btn-sm btn-outline-secondary" asp-action="DisplayProducts">Clear</a>
        </form>
    </div>

    <div class="table-responsive table-scroll-wrap flex-table-wrap">
        <table class="table table-sm table-hover align-middle admin-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-normal" />
                <col class="col-name" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-status" />
                <col class="col-action" />
            </colgroup>
            <thead>
                <tr>
                    <th class="col-no" scope="col">No</th>
                    <th class="col-batch" scope="col">Batch Number</th>
                    <th class="col-name" scope="col">Product</th>
                    <th scope="col">Branch</th>
                    <th scope="col">Supplier</th>
                    <th class="col-money" scope="col">Cost Price</th>
                    <th class="col-money" scope="col">Selling Price</th>
                    <th class="col-qty" scope="col">Display Quantity</th>
                    <th scope="col">Expiry Date</th>
                    <th class="col-status" scope="col">Status</th>
                    <th class="col-action" scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DisplayStocks.Count == 0)
                {
                    <tr>
                        <td class="text-center text-muted fw-bold" colspan="11">No display batches found.</td>
                    </tr>
                }
                @for (var index = 0; index < Model.DisplayStocks.Count; index += 1)
                {
                    <tr>
                        <td class="col-no">@(index + 1)</td>
                        <td class="col-batch">@(Model.DisplayStocks[index].Batch?.BatchNo ?? "-")</td>
                        <td class="col-name">@(Model.DisplayStocks[index].Product?.Name ?? "-")</td>
                        <td>@(Model.DisplayStocks[index].Branch?.Name ?? "-")</td>
                        <td>@(Model.DisplayStocks[index].Batch?.Supplier?.Name ?? "-")</td>
                        <td>&#8369;@(Model.DisplayStocks[index].Batch?.CostPrice.ToString("N2") ?? "0.00")</td>
                        <td>&#8369;@(Model.DisplayStocks[index].Batch?.SellingPrice.ToString("N2") ?? "0.00")</td>
                        <td class="col-qty">@Model.DisplayStocks[index].Quantity.ToString("N2")</td>
                        <td>@(Model.DisplayStocks[index].Batch?.ExpiryDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td><span class="badge @((Model.DisplayStocks[index].Product?.IsActive ?? false) && (Model.DisplayStocks[index].Product?.Status == 1) && (Model.DisplayStocks[index].Batch?.IsActive ?? false) && (Model.DisplayStocks[index].Batch?.Status == 1) ? "text-bg-success" : "text-bg-secondary")">@((Model.DisplayStocks[index].Product?.IsActive ?? false) && (Model.DisplayStocks[index].Product?.Status == 1) && (Model.DisplayStocks[index].Batch?.IsActive ?? false) && (Model.DisplayStocks[index].Batch?.Status == 1) ? "Active" : "Inactive")</span></td>
                        <td class="col-action">
                            <div class="setup-row-actions">
                                @if ((Model.DisplayStocks[index].Product?.IsActive ?? false) && Model.DisplayStocks[index].Product?.Status == 1)
                                {
                                    <button class="btn btn-sm btn-outline-danger product-deactivate-button" type="button" data-bs-toggle="modal" data-bs-target="#productStatusModal" data-product-id="@Model.DisplayStocks[index].ProductId" data-product-name="@(Model.DisplayStocks[index].Product?.Name ?? "Product")" data-action-url="@Url.Action("DeactivateProductFromStock", "Configuration")">Deactivate</button>
                                }
                                @if (!((Model.DisplayStocks[index].Product?.IsActive ?? false) && Model.DisplayStocks[index].Product?.Status == 1))
                                {
                                    <form asp-action="ActivateProductFromStock" method="post">
                                        @Html.AntiForgeryToken()
                                        <input name="id" type="hidden" value="@Model.DisplayStocks[index].ProductId" />
                                        <input name="source" type="hidden" value="Display" />
                                        <input name="search" type="hidden" value="@Model.Search" />
                                        <input name="branchId" type="hidden" value="@Model.BranchId" />
                                        <button class="btn btn-sm btn-outline-success" type="submit">Activate</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="productStatusModal" tabindex="-1" aria-labelledby="productStatusModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="productStatusForm" method="post">
                @Html.AntiForgeryToken()
                <input id="productStatusId" name="id" type="hidden" />
                <input name="source" type="hidden" value="Display" />
                <input name="search" type="hidden" value="@Model.Search" />
                <input name="branchId" type="hidden" value="@Model.BranchId" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="productStatusModalLabel">Deactivate Record</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0" id="productStatusMessage">Are you sure you want to deactivate this record?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-danger deactivate-confirm-btn" id="productStatusConfirmButton" type="submit">Deactivate</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const form = document.getElementById("productStatusForm");
            const idInput = document.getElementById("productStatusId");
            const title = document.getElementById("productStatusModalLabel");
            const message = document.getElementById("productStatusMessage");
            const confirmButton = document.getElementById("productStatusConfirmButton");

            document.querySelectorAll(".product-deactivate-button").forEach(button => {
                button.addEventListener("click", () => {
                    const productName = button.dataset.productName || "Product";

                    if (form) {
                        form.action = button.dataset.actionUrl || "";
                    }

                    if (idInput) {
                        idInput.value = button.dataset.productId || "";
                    }

                    if (title) {
                        title.textContent = "Deactivate Record";
                    }

                    if (message) {
                        message.textContent = "Are you sure you want to deactivate this record?";
                    }

                    if (confirmButton) {
                        confirmButton.textContent = "Deactivate";
                        confirmButton.classList.add("btn-danger");
                        confirmButton.classList.remove("btn-primary", "btn-success");
                    }
                });
            });
        });
    </script>
}
