@model gpos.Models.ViewModels.StockAdjustmentPageViewModel
@{
    var isFuel = Model.Scope == "Fuel";
    var unit = isFuel ? "Liters" : "Quantity";
    var targetId = Model.Scope == "Warehouse" ? Model.Form.WarehouseStockId : Model.Scope == "Display" ? Model.Form.DisplayStockId : Model.Form.TankId;
    var selectedTarget = Model.Targets.FirstOrDefault(x => x.Id == targetId);
    var branchName = Model.BranchOptions.FirstOrDefault(x => x.Value == Model.Form.BranchId.ToString())?.Text ?? string.Empty;
    var details = Model.DetailsId.HasValue ? Model.Rows.FirstOrDefault(x => x.Id == Model.DetailsId.Value) : null;
    string DisplayStatus(string status) => status == "Posted" ? "Applied" : status;
}

<div class="page-header">
    <div class="page-heading">
        <nav><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Transaction</li><li class="breadcrumb-item active">@Model.Title</li></ol></nav>
        <h1>@Model.Title</h1>
        <p class="page-subtitle text-muted">Create auditable inventory corrections. Applied records are permanent and can only be reversed.</p>
    </div>
    <div class="page-actions"><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#adjustmentModal">Add Adjustment</button></div>
</div>

@if (TempData["AdjustmentMessage"] is string message) { <div class="alert alert-info">@message</div> }

<section class="content-card setup-crud-card setup-table-card">
    <div class="table-actions">
        <form method="get" asp-action="@Model.PageAction" class="row g-2 flex-grow-1">
            <div class="col-md-3"><input name="search" value="@Model.Search" class="form-control" placeholder="Search adjustments..." /></div>
            <div class="col-md-2"><select name="branchId" class="form-select"><option value="">All Branches</option>@foreach (var b in Model.BranchOptions) { <option value="@b.Value" selected="@(b.Value == Model.BranchId?.ToString())">@b.Text</option> }</select></div>
            <div class="col-md-2"><input type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="form-control" /></div>
            <div class="col-md-2"><input type="date" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" class="form-control" /></div>
            <div class="col-md-2"><select name="status" class="form-select"><option value="">All Statuses</option>@foreach (var s in new[] { "Draft", "Posted", "Cancelled", "Reversed" }) { <option value="@s" selected="@(Model.Status == s)">@DisplayStatus(s)</option> }</select></div>
            <div class="col-auto"><button class="btn btn-primary">Search</button> <a asp-action="@Model.PageAction" class="btn btn-outline-secondary">Clear</a></div>
        </form>
    </div>
    <div class="setup-table-scroll">
        <table class="table app-table table-sm align-middle admin-table mb-0">
            <thead><tr><th>No</th><th>Adjustment No</th><th>Business Date</th><th>Branch</th><th>@(isFuel ? "Tank" : "Product")</th><th>@(isFuel ? "Fuel" : "Batch")</th><th>Before @unit</th><th>Adjustment</th><th>After @unit</th><th>Reason</th><th>Adjusted By</th><th>Status</th><th>Action</th></tr></thead>
            <tbody>
                @for (var i = 0; i < Model.Rows.Count; i++)
                {
                    var x = Model.Rows[i];
                    <tr>
                        <td>@(i + 1)</td><td>@x.AdjustmentNo</td><td>@x.BusinessDate.ToString("yyyy-MM-dd")</td><td>@x.Branch?.Name</td>
                        <td>@(isFuel ? x.Tank?.TankNo : x.Product?.Name)</td><td>@(isFuel ? x.Fuel?.Name : x.Batch?.BatchNo)</td>
                        <td>@x.BeforeQuantity.ToString("N3")</td>
                        <td class="@(x.SignedQuantity < 0 ? "text-danger" : "text-success")">@(x.Status == "Draft" ? (x.AdjustmentType == "Decrease" ? "-" : "+") + x.AdjustmentQuantity.ToString("N3") : x.SignedQuantity.ToString("+0.000;-0.000;0.000"))</td>
                        <td>@x.AfterQuantity.ToString("N3")</td><td>@x.Reason</td><td>@(x.AdjustedByUser?.FullName ?? x.AdjustedByUser?.Username)</td>
                        <td><span class="badge @(x.Status == "Posted" ? "bg-success" : x.Status == "Draft" ? "bg-warning text-dark" : "bg-secondary")">@DisplayStatus(x.Status)</span></td>
                        <td class="text-nowrap">
                            <a asp-action="@Model.PageAction" asp-route-detailsId="@x.Id" class="btn btn-sm btn-outline-primary">View</a>
                            @if (x.Status == "Draft")
                            {
                                <a asp-action="@Model.PageAction" asp-route-editId="@x.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form class="d-inline" method="post" asp-action="PostStockAdjustment" data-adjustment-apply-form><input type="hidden" name="id" value="@x.Id" /><button type="button" class="btn btn-sm btn-success" data-adjustment-apply-open data-adjustment-number="@x.AdjustmentNo" disabled="@(x.AdjustmentType == "Reconciliation" && !Model.CanApproveReconciliation)">Apply</button></form>
                                <form class="d-inline" method="post" asp-action="CancelStockAdjustment"><input type="hidden" name="id" value="@x.Id" /><button class="btn btn-sm btn-outline-danger">Cancel</button></form>
                            }
                            @if (x.Status == "Posted" && x.AdjustmentType != "Reconciliation")
                            {
                                <form class="d-inline" method="post" asp-action="ReverseStockAdjustment"><input type="hidden" name="id" value="@x.Id" /><button class="btn btn-sm btn-outline-warning">Reverse</button></form>
                            }
                        </td>
                    </tr>
                }
                @if (Model.Rows.Count == 0) { <tr><td colspan="13" class="text-center text-muted">No records found.</td></tr> }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="adjustmentModal" tabindex="-1" aria-hidden="true" data-stock-adjustment
     data-scope="@Model.Scope" data-initial-target-id="@targetId" data-initial-target-name="@selectedTarget?.Label"
     data-initial-product="@selectedTarget?.ProductOrFuel" data-initial-batch="@selectedTarget?.BatchOrTank"
     data-initial-current="@selectedTarget?.CurrentQuantity" data-initial-capacity="@selectedTarget?.Capacity"
     data-initial-active-batch="@selectedTarget?.ActiveBatchLiters" data-initial-difference="@selectedTarget?.Difference"
     data-initial-batch-count="@selectedTarget?.ActiveBatchCount" data-initial-inventory-state="@selectedTarget?.InventoryState">
    <div class="modal-dialog modal-lg modal-dialog-centered"><div class="modal-content">
        <form method="post" asp-action="SaveStockAdjustment">
            <div class="modal-header"><h2 class="modal-title fs-5">@(Model.Form.Id > 0 ? "Edit" : "Add") @Model.Title</h2><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button></div>
            <div class="modal-body">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input asp-for="Form.Id" type="hidden" /><input asp-for="Form.Scope" type="hidden" value="@Model.Scope" />
                <input asp-for="Form.WarehouseStockId" type="hidden" data-adjustment-warehouse-id />
                <input asp-for="Form.DisplayStockId" type="hidden" data-adjustment-display-id />
                <input asp-for="Form.TankId" type="hidden" data-adjustment-tank-id />
                <div class="row g-3">
                    <div class="col-md-6"><label asp-for="Form.BusinessDate" class="form-label">Business Date</label><input asp-for="Form.BusinessDate" type="date" class="form-control" /><span asp-validation-for="Form.BusinessDate" class="text-danger"></span></div>
                    <div class="col-md-6">
                        <label asp-for="Form.BranchId" class="form-label">Branch</label>
                        <input asp-for="Form.BranchId" type="hidden" id="adjustmentBranchId" data-adjustment-branch />
                        <div class="input-group" data-branch-selector data-branch-hidden="#adjustmentBranchId" data-branch-display="#adjustmentBranchDisplay" data-branch-empty-text="Select branch">
                            <input id="adjustmentBranchDisplay" value="@branchName" class="form-control" placeholder="Select branch" readonly />
                            <button type="button" class="btn btn-outline-secondary branch-select-btn" data-branch-open><img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" /></button>
                        </div><span asp-validation-for="Form.BranchId" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label class="form-label">@(isFuel ? "Tank" : "Product / Batch")</label>
                        <div class="input-group"><input class="form-control" readonly placeholder="@(isFuel ? "Select tank" : "Select stock batch")" data-adjustment-target-display /><button type="button" class="btn btn-outline-secondary" data-adjustment-open-target><img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" /></button></div>
                        <div class="text-danger small mt-1 d-none" data-adjustment-target-message>Please select a Branch first.</div>
                    </div>
                    @if (isFuel)
                    {
                        <div class="col-md-6"><label class="form-label">Fuel</label><input class="form-control" readonly data-adjustment-product /></div>
                        <div class="col-md-6"><label class="form-label">Capacity Liters</label><input class="form-control" readonly data-adjustment-capacity /></div>
                    }
                    else
                    {
                        <div class="col-md-6"><label class="form-label">Product</label><input class="form-control" readonly data-adjustment-product /></div>
                        <div class="col-md-6"><label class="form-label">Batch No</label><input class="form-control" readonly data-adjustment-batch /></div>
                    }
                    <div class="col-md-6"><label class="form-label">@(isFuel ? "Physical Tank Liters" : $"Current {unit}")</label><input class="form-control" readonly value="0.000" data-adjustment-current /></div>
                    <div class="col-md-6"><label class="form-label">Adjustment Type</label><select asp-for="Form.AdjustmentType" class="form-select" data-adjustment-type>@if (isFuel) { <option value="Reconciliation">Opening Balance / Reconciliation</option> } else { <option>Increase</option><option>Decrease</option> }</select></div>
                    @if (isFuel)
                    {
                        <div class="col-md-3"><label class="form-label">Active Batch Liters</label><input class="form-control" readonly data-adjustment-active-batch /></div>
                        <div class="col-md-3"><label class="form-label">Difference</label><input class="form-control" readonly data-adjustment-difference /></div>
                        <div class="col-md-3"><label class="form-label">Active Batches</label><input class="form-control" readonly data-adjustment-batch-count /></div>
                        <div class="col-md-3"><label class="form-label">Inventory State</label><input class="form-control" readonly data-adjustment-inventory-state /></div>
                    }
                    <div class="col-md-6"><label class="form-label">Adjustment @unit</label><input asp-for="Form.AdjustmentQuantity" type="number" min="0.001" step="0.001" class="form-control" data-adjustment-quantity /><span asp-validation-for="Form.AdjustmentQuantity" class="text-danger"></span></div>
                    <div class="col-md-6"><label class="form-label">After @unit</label><input class="form-control" readonly value="0.000" data-adjustment-after /></div>
                    <div class="col-md-6"><label class="form-label">Reason</label><select asp-for="Form.Reason" class="form-select"><option value="">Select reason</option>@foreach (var reason in new[] { "Physical Count", "Damaged Items", "Expired Items", "Lost Items", "Found Items", "Shrinkage", "Inventory Correction", "Data Entry Error", "Other" }) { <option>@reason</option> }</select><span asp-validation-for="Form.Reason" class="text-danger"></span></div>
                    <div class="col-md-6"><label class="form-label">Remarks</label><textarea asp-for="Form.Remarks" class="form-control"></textarea></div>
                    @if (isFuel)
                    {
                        <div class="col-md-4"><label asp-for="Form.CostInputMode" class="form-label">Cost Input Mode</label><select asp-for="Form.CostInputMode" class="form-select" data-reconciliation-cost-mode><option value="">Select mode</option><option value="UnitCost">Cost per Liter</option><option value="TotalCost">Total Cost</option></select><span asp-validation-for="Form.CostInputMode" class="text-danger"></span></div>
                        <div class="col-md-4"><label asp-for="Form.UnitCost" class="form-label">Approved Cost per Liter</label><input asp-for="Form.UnitCost" type="number" min="0.01" step="0.01" class="form-control" data-reconciliation-unit-cost /><span asp-validation-for="Form.UnitCost" class="text-danger"></span></div>
                        <div class="col-md-4"><label asp-for="Form.TotalCost" class="form-label">Total Cost</label><input asp-for="Form.TotalCost" type="number" min="0.01" step="0.01" class="form-control" data-reconciliation-total-cost /><span asp-validation-for="Form.TotalCost" class="text-danger"></span></div>
                        <div class="col-md-6"><label asp-for="Form.EvidenceReference" class="form-label">Evidence / Reference</label><input asp-for="Form.EvidenceReference" class="form-control" /></div>
                        <div class="col-md-6"><label class="form-label">Prepared By</label><input class="form-control" readonly value="@User.Identity?.Name" /></div>
                        @if (!Model.CanPrepareReconciliation) { <div class="col-12"><div class="alert alert-warning mb-0">Your role does not have permission to prepare reconciliation drafts.</div></div> }
                    }
                </div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button><button class="btn btn-primary" disabled="@(isFuel && !Model.CanPrepareReconciliation)">Save Draft</button></div>
        </form>
    </div></div>
</div>

<div class="modal fade" id="stockAdjustmentApplyModal" tabindex="-1" aria-labelledby="stockAdjustmentApplyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered"><div class="modal-content">
        <div class="modal-header"><h2 class="modal-title fs-5" id="stockAdjustmentApplyModalLabel">Apply Stock Adjustment</h2><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" data-adjustment-apply-cancel></button></div>
        <div class="modal-body">
            <p class="mb-2">Are you sure you want to apply <strong data-adjustment-apply-number></strong>?</p>
            <p class="text-muted mb-0">Applying this adjustment will update the current stock balance and make the record immutable.</p>
            <div class="alert alert-danger d-none mt-3 mb-0" role="alert" data-adjustment-apply-feedback></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" data-adjustment-apply-cancel>Cancel</button><button type="button" class="btn btn-success" data-adjustment-apply-confirm>Apply</button></div>
    </div></div>
</div>

<div class="modal fade" id="stockAdjustmentTargetSelectorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered"><div class="modal-content">
        <div class="modal-header"><h2 class="modal-title fs-5">Select @(isFuel ? "Tank" : "Stock Batch")</h2><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button></div>
        <div class="modal-body"><div class="input-group mb-3"><input class="form-control" type="search" placeholder="Search @(isFuel ? "tank or fuel" : "product or batch")" data-adjustment-selector-search /><button type="button" class="btn btn-outline-primary" data-adjustment-selector-search-button>Search</button></div>
            <div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><thead><tr><th>No</th>@if (isFuel) { <th>Tank</th><th>Fuel</th><th>Current Liters</th><th>Capacity</th><th>Available Space</th> } else { <th>Product</th><th>Batch No</th><th>Current Quantity</th><th>@(Model.Scope == "Warehouse" ? "Cost Price" : "Selling Price")</th><th>Expiry Date</th> }<th>Status</th><th>Action</th></tr></thead><tbody data-adjustment-selector-body></tbody></table></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button></div>
    </div></div>
</div>

@if (details != null)
{
    <div class="modal fade" id="stockAdjustmentDetailsModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered"><div class="modal-content">
            <div class="modal-header"><h2 class="modal-title fs-5">View @Model.Title</h2><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button></div>
            <div class="modal-body"><div class="row g-3">
                <div class="col-md-6"><label class="form-label">Adjustment No</label><input class="form-control" readonly value="@details.AdjustmentNo" /></div>
                <div class="col-md-6"><label class="form-label">Business Date</label><input class="form-control" readonly value="@details.BusinessDate.ToString("yyyy-MM-dd")" /></div>
                <div class="col-md-6"><label class="form-label">Branch</label><input class="form-control" readonly value="@details.Branch?.Name" /></div>
                @if (isFuel) { <div class="col-md-6"><label class="form-label">Tank</label><input class="form-control" readonly value="@details.Tank?.TankNo" /></div><div class="col-md-6"><label class="form-label">Fuel</label><input class="form-control" readonly value="@details.Fuel?.Name" /></div> }
                else { <div class="col-md-6"><label class="form-label">Product</label><input class="form-control" readonly value="@details.Product?.Name" /></div><div class="col-md-6"><label class="form-label">Batch No</label><input class="form-control" readonly value="@details.Batch?.BatchNo" /></div> }
                <div class="col-md-4"><label class="form-label">Before @unit</label><input class="form-control" readonly value="@details.BeforeQuantity.ToString("N3")" /></div>
                <div class="col-md-4"><label class="form-label">Adjustment Type</label><input class="form-control" readonly value="@details.AdjustmentType" /></div>
                <div class="col-md-4"><label class="form-label">Adjustment @unit</label><input class="form-control" readonly value="@details.AdjustmentQuantity.ToString("N3")" /></div>
                <div class="col-md-6"><label class="form-label">Signed Adjustment</label><input class="form-control" readonly value="@details.SignedQuantity.ToString("+0.000;-0.000;0.000")" /></div>
                <div class="col-md-6"><label class="form-label">After @unit</label><input class="form-control" readonly value="@details.AfterQuantity.ToString("N3")" /></div>
                <div class="col-md-6"><label class="form-label">Reason</label><input class="form-control" readonly value="@details.Reason" /></div>
                <div class="col-md-6"><label class="form-label">Remarks</label><input class="form-control" readonly value="@details.Remarks" /></div>
                <div class="col-md-6"><label class="form-label">Adjusted By</label><input class="form-control" readonly value="@(details.AdjustedByUser?.FullName ?? details.AdjustedByUser?.Username)" /></div>
                <div class="col-md-6"><label class="form-label">Applied By</label><input class="form-control" readonly value="@(details.PostedByUser?.FullName ?? details.PostedByUser?.Username)" /></div>
                <div class="col-md-6"><label class="form-label">Created At</label><input class="form-control" readonly value="@details.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")" /></div>
                <div class="col-md-6"><label class="form-label">Applied At</label><input class="form-control" readonly value="@details.PostedAt?.ToString("yyyy-MM-dd HH:mm:ss")" /></div>
                <div class="col-md-6"><label class="form-label">Status</label><input class="form-control" readonly value="@DisplayStatus(details.Status)" /></div>
            </div></div>
            <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button></div>
        </div></div>
    </div>
}

<script src="~/js/stock-adjustment.js" asp-append-version="true"></script>
@if (Model.Form.Id > 0 || !ViewData.ModelState.IsValid) { <script>document.addEventListener('DOMContentLoaded', function () { bootstrap.Modal.getOrCreateInstance(document.getElementById('adjustmentModal')).show(); });</script> }
@if (details != null) { <script>document.addEventListener('DOMContentLoaded', function () { bootstrap.Modal.getOrCreateInstance(document.getElementById('stockAdjustmentDetailsModal')).show(); });</script> }
