<section class="transaction-ui-page">
    <div class="content-card transaction-ui-card">
        <div class="card-title-row"><div><h1>Fuel Receiving</h1><p>UI-only receiving page. Future flow: fuel receiving adds liters to tanks.current_liters.</p></div><span class="status-badge">UI Only</span></div>
        <div class="transaction-ui-toolbar"><input class="form-control transaction-ui-search" type="search" placeholder="Search fuel receiving..." data-transaction-search="#fuelReceivingTable" /><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#fuelReceivingFormModal">Add Receiving</button></div>
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="fuelReceivingTable">
                <thead><tr><th>No</th><th>Receiving No</th><th>Supplier</th><th>Fuel</th><th>Tank</th><th>Liters</th><th>Price/Liter</th><th>Tank Liters After</th><th>Received By</th><th>Date</th><th>Status</th><th>Action</th></tr></thead>
                <tbody>
                    <tr data-search-row><td>1</td><td>RCV-F-0001</td><td>Fuel Depot</td><td>Diesel</td><td>Tank 1</td><td>2,000.00</td><td>₱54.00</td><td>10,480.00</td><td>admin</td><td>2026-06-24</td><td><span class="badge text-bg-warning">Pending</span></td><td><span class="transaction-ui-actions"><button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#fuelReceivingViewModal">View</button><button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#fuelReceivingFormModal">Edit</button><button class="btn btn-sm btn-outline-danger" type="button" data-bs-toggle="modal" data-bs-target="#fuelReceivingConfirmModal">Complete</button></span></td></tr>
                    <tr data-empty-row hidden><td class="text-center text-muted fw-bold" colspan="12">No records found.</td></tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="content-card transaction-db-card"><h2 class="h5 mb-1">Recommended Future Stock Flow</h2><p class="mb-0">Fuel Receiving -> add liters to <strong>tanks.current_liters</strong>; later write fuel_movements with movement_type = Delivery.</p><ul class="transaction-db-list"><li>fuel_deliveries</li><li>tanks.current_liters</li><li>fuel_movements</li></ul></div>
</section>
<div class="modal fade" id="fuelReceivingFormModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5">Fuel Receiving</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="row g-3"><div class="col-md-6"><label class="form-label">Supplier</label><input class="form-control" value="Fuel Depot" /></div><div class="col-md-6"><label class="form-label">Fuel</label><input class="form-control" value="Diesel" /></div><div class="col-md-6"><label class="form-label">Tank</label><input class="form-control" value="Tank 1" /></div><div class="col-md-6"><label class="form-label">Liters</label><input class="form-control" type="number" value="2000" /></div><div class="col-md-6"><label class="form-label">Price/Liter</label><input class="form-control" type="number" value="54" /></div><div class="col-md-6"><label class="form-label">Status</label><select class="form-select"><option>Pending</option><option>Completed</option><option>Cancelled</option></select></div><div class="col-12"><label class="form-label">Remarks</label><textarea class="form-control" rows="3">Tank receiving draft only.</textarea></div></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="button" data-bs-dismiss="modal">Save UI Draft</button></div></div></div></div>
<div class="modal fade" id="fuelReceivingViewModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5">Fuel Receiving Details</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body">Fuel receiving preview only. No tank liters are added.</div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button></div></div></div></div>
<div class="modal fade" id="fuelReceivingConfirmModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5">Complete Receiving</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body">Complete this fuel receiving? This is UI only and will not update tank liters.</div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="button" data-bs-dismiss="modal">Complete</button></div></div></div></div>
