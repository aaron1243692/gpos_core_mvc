@model gpos.Models.ViewModels.ProductSalesPageViewModel

<section class="transaction-ui-page">
    <div class="content-card transaction-ui-card">
        <div class="card-title-row">
            <div>
                <h1>Product Sales</h1>
                <p>Product items sold from saved POS sales.</p>
            </div>
            <span class="status-badge">Latest 100</span>
        </div>

        <form asp-action="ProductSales" method="get" class="row g-2 mb-3">
            <div class="col-12 col-lg-4">
                <input class="form-control" name="search" value="@Model.Search" type="search" placeholder="Search receipt, product, batch, cashier, member..." />
            </div>
            <div class="col-6 col-lg-2">
                <input class="form-control" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" type="date" />
            </div>
            <div class="col-6 col-lg-2">
                <input class="form-control" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" type="date" />
            </div>
            <div class="col-6 col-lg-2">
                <select class="form-select" name="status">
                    @for (var i = 0; i < Model.StatusOptions.Count; i += 1)
                    {
                        if (Model.StatusOptions[i].Selected)
                        {
                            <option value="@Model.StatusOptions[i].Value" selected>@Model.StatusOptions[i].Text</option>
                        }
                        else
                        {
                            <option value="@Model.StatusOptions[i].Value">@Model.StatusOptions[i].Text</option>
                        }
                    }
                </select>
            </div>
            <div class="col-6 col-lg-2 d-grid">
                <button class="btn btn-primary" type="submit">Filter</button>
            </div>
        </form>

        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Receipt No</th>
                        <th>Product</th>
                        <th>Batch</th>
                        <th>Quantity</th>
                        <th>Price</th>
                        <th>Subtotal</th>
                        <th>Cashier/User</th>
                        <th>Member</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Sales.Count == 0)
                    {
                        <tr><td class="text-center text-muted fw-bold" colspan="12">No sales found.</td></tr>
                    }
                    @for (var i = 0; i < Model.Sales.Count; i += 1)
                    {
                        <tr>
                            <td>@(i + 1)</td>
                            <td>@Model.Sales[i].ReceiptNo</td>
                            <td>@Model.Sales[i].ProductName</td>
                            <td>@Model.Sales[i].BatchNo</td>
                            <td>@Model.Sales[i].Quantity.ToString("N2")</td>
                            <td>₱@Model.Sales[i].Price.ToString("N2")</td>
                            <td>₱@Model.Sales[i].Subtotal.ToString("N2")</td>
                            <td>@Model.Sales[i].CashierName</td>
                            <td>@Model.Sales[i].MemberName</td>
                            <td>@Model.Sales[i].SaleDate?.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><span class="badge @(Model.Sales[i].Status == "Completed" ? "text-bg-success" : Model.Sales[i].Status == "Voided" ? "text-bg-secondary" : Model.Sales[i].Status == "Returned" ? "text-bg-primary" : "text-bg-warning")">@Model.Sales[i].Status</span></td>
                            <td><button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#productSaleViewModal_@Model.Sales[i].SaleItemId">View</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@for (var i = 0; i < Model.Sales.Count; i += 1)
{
    <div class="modal fade" id="productSaleViewModal_@Model.Sales[i].SaleItemId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Product Sale Details</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <dl class="row mb-3">
                        <dt class="col-sm-4">Receipt No</dt><dd class="col-sm-8">@Model.Sales[i].ReceiptNo</dd>
                        <dt class="col-sm-4">Cashier/User</dt><dd class="col-sm-8">@Model.Sales[i].CashierName</dd>
                        <dt class="col-sm-4">Member</dt><dd class="col-sm-8">@Model.Sales[i].MemberName</dd>
                        <dt class="col-sm-4">Sale Date</dt><dd class="col-sm-8">@Model.Sales[i].SaleDate?.ToString("yyyy-MM-dd HH:mm")</dd>
                        <dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.Sales[i].Status</dd>
                    </dl>
                    <div class="table-responsive mb-3">
                        <table class="table app-table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Name (Quantity / Liters)</th>
                                    <th class="text-end">Cost</th>
                                    <th class="text-end">Discount</th>
                                    <th class="text-end">Voucher Discount</th>
                                    <th class="text-end">Total Price</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in Model.Sales[i].DetailLines)
                                {
                                    <tr>
                                        <td>@line.Name</td>
                                        <td class="text-end">₱@line.Cost.ToString("N2")</td>
                                        <td class="text-end">₱@line.Discount.ToString("N2")</td>
                                        <td class="text-end">₱@line.VoucherDiscount.ToString("N2")</td>
                                        <td class="text-end fw-semibold">₱@line.TotalPrice.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <dl class="row mb-0">
                        <dt class="col-sm-6">Subtotal</dt><dd class="col-sm-6 text-sm-end">₱@Model.Sales[i].GrossTotal.ToString("N2")</dd>
                        <dt class="col-sm-6">Gross Total</dt><dd class="col-sm-6 text-sm-end">₱@Model.Sales[i].GrossTotal.ToString("N2")</dd>
                        <dt class="col-sm-6">Member Discount</dt><dd class="col-sm-6 text-sm-end">₱@Model.Sales[i].MemberDiscount.ToString("N2")</dd>
                        <dt class="col-sm-6">Voucher Discount</dt><dd class="col-sm-6 text-sm-end">₱@Model.Sales[i].VoucherDiscount.ToString("N2")</dd>
                        <dt class="col-sm-6 border-top pt-2">Total Discount</dt><dd class="col-sm-6 text-sm-end border-top pt-2">₱@Model.Sales[i].TotalDiscount.ToString("N2")</dd>
                        <dt class="col-sm-6">Net Total</dt><dd class="col-sm-6 text-sm-end">₱@Model.Sales[i].NetTotal.ToString("N2")</dd>
                        <dt class="col-sm-6">Net Sales</dt><dd class="col-sm-6 text-sm-end">₱@Model.Sales[i].NetSales.ToString("N2")</dd>
                        <dt class="col-sm-6">Loss</dt><dd class="col-sm-6 text-sm-end">₱@Model.Sales[i].Loss.ToString("N2")</dd>
                        <dt class="col-sm-6">Payment Method</dt><dd class="col-sm-6 text-sm-end">@Model.Sales[i].PaymentType</dd>
                        @if (string.Equals(Model.Sales[i].PaymentType, "Points", StringComparison.OrdinalIgnoreCase))
                        {
                            <dt class="col-sm-6">Points Paid</dt><dd class="col-sm-6 text-sm-end">@Model.Sales[i].PointsPaid.ToString("N2") pts</dd>
                            <dt class="col-sm-6">Point Conversion Used</dt><dd class="col-sm-6 text-sm-end">₱@Model.Sales[i].PointConversionUsed.ToString("N4") / pt</dd>
                            <dt class="col-sm-6">Monetary Value of Points Paid</dt><dd class="col-sm-6 text-sm-end">₱@Model.Sales[i].PointsMonetaryValue.ToString("N2")</dd>
                        }
                        else
                        {
                            <dt class="col-sm-6">Cash Amount</dt><dd class="col-sm-6 text-sm-end">₱@Model.Sales[i].CashAmount.ToString("N2")</dd>
                            <dt class="col-sm-6">Change</dt><dd class="col-sm-6 text-sm-end">₱@Model.Sales[i].Change.ToString("N2")</dd>
                        }
                    </dl>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}
