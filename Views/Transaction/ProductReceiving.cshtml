@model gpos.Models.ViewModels.ProductReceivingPageViewModel

<section class="product-receiving-page">
    <div class="content-card transaction-ui-card product-receiving-container">
        <div class="card-title-row page-header">
            <div>
                <h1>Product Receiving</h1>
                <p>Receive product batches into warehouse stock.</p>
            </div>
            <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#addProductReceivingModal">Add Receiving</button>
        </div>

        <div class="product-receiving-body">
            @if (TempData["ReceivingMessage"] is not null)
            {
                <div class="alert alert-warning">@TempData["ReceivingMessage"]</div>
            }
            @if (TempData["ReceivingWarning"] is not null)
            {
                <div class="alert alert-warning">@TempData["ReceivingWarning"]</div>
            }

            <form asp-action="ProductReceiving" method="get" class="transaction-ui-toolbar product-receiving-toolbar product-receiving-filter-toolbar toolbar">
                <input class="form-control transaction-ui-search product-receiving-filter-search" name="search" value="@Model.Search" type="search" placeholder="Search receiving, supplier, product, batch, branch, status..." />
                <select class="form-select product-receiving-filter-branch" name="filterBranchId">
                    @for (var i = 0; i < Model.BranchOptions.Count; i += 1)
                    {
                        var option = Model.BranchOptions[i];
                        var selected = option.Value == (Model.BranchId?.ToString() ?? string.Empty);
                        if (selected)
                        {
                            <option value="@option.Value" selected>@option.Text</option>
                        }
                        else
                        {
                            <option value="@option.Value">@option.Text</option>
                        }
                    }
                </select>
                <button class="btn btn-primary" type="submit">Search</button>
                <a class="btn btn-outline-secondary" asp-action="ProductReceiving">Clear</a>
            </form>

            <div class="table-responsive transaction-ui-table-wrap product-receiving-table-wrapper">
                <table class="table app-table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>No</th>
                            <th>Receiving No</th>
                            <th>Branch</th>
                            <th>Supplier</th>
                            <th>Product</th>
                            <th>Batch</th>
                            <th>Quantity</th>
                            <th>Cost Price</th>
                            <th>Selling Price</th>
                            <th>Warehouse Stock Before</th>
                            <th>Warehouse Stock After</th>
                            <th>Received By</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Receivings.Count == 0)
                        {
                            <tr><td class="text-center text-muted fw-bold" colspan="15">No product receiving records found.</td></tr>
                        }
                        @for (var i = 0; i < Model.Receivings.Count; i += 1)
                        {
                            <tr>
                                <td class="text-nowrap">@(i + 1)</td>
                                <td class="text-nowrap">@Model.Receivings[i].ReceivingNo</td>
                                <td class="text-nowrap">@Model.Receivings[i].BranchName</td>
                                <td>@Model.Receivings[i].Supplier</td>
                                <td>@Model.Receivings[i].Product</td>
                                <td class="text-nowrap">@Model.Receivings[i].Batch</td>
                                <td class="text-nowrap">@Model.Receivings[i].Quantity.ToString("N2")</td>
                                <td class="text-nowrap">₱@Model.Receivings[i].CostPrice.ToString("N2")</td>
                                <td class="text-nowrap">₱@Model.Receivings[i].SellingPrice.ToString("N2")</td>
                                <td class="text-nowrap">@(Model.Receivings[i].WarehouseStockBefore.HasValue ? Model.Receivings[i].WarehouseStockBefore!.Value.ToString("N2") : "-")</td>
                                <td class="text-nowrap">@(Model.Receivings[i].WarehouseStockAfter.HasValue ? Model.Receivings[i].WarehouseStockAfter!.Value.ToString("N2") : "-")</td>
                                <td class="text-nowrap">@Model.Receivings[i].ReceivedBy</td>
                                <td class="text-nowrap">@Model.Receivings[i].Date.ToString("yyyy-MM-dd HH:mm")</td>
                                <td><span class="badge @(Model.Receivings[i].Status == 1 ? "text-bg-success" : Model.Receivings[i].Status == 2 ? "text-bg-secondary" : "text-bg-warning")">@(Model.Receivings[i].Status == 1 ? "Completed" : Model.Receivings[i].Status == 2 ? "Cancelled" : "Pending")</span></td>
                                <td class="text-nowrap">
                                    <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#productReceivingViewModal_@Model.Receivings[i].Id">View</button>
                                    @if (Model.Receivings[i].Status == 0)
                                    {
                                        <form asp-action="CompleteProductReceiving" method="post" class="d-inline" onsubmit="return confirm('Complete this product receiving?');">
                                            @Html.AntiForgeryToken()
                                            <input name="id" type="hidden" value="@Model.Receivings[i].Id" />
                                            <input name="search" type="hidden" value="@Model.Search" />
                                            <input name="filterBranchId" type="hidden" value="@Model.BranchId" />
                                            <button class="btn btn-sm btn-outline-success" type="submit">Complete</button>
                                        </form>
                                        <form asp-action="CancelProductReceiving" method="post" class="d-inline" onsubmit="return confirm('Cancel this pending product receiving?');">
                                            @Html.AntiForgeryToken()
                                            <input name="id" type="hidden" value="@Model.Receivings[i].Id" />
                                            <input name="search" type="hidden" value="@Model.Search" />
                                            <input name="filterBranchId" type="hidden" value="@Model.BranchId" />
                                            <button class="btn btn-sm btn-outline-danger" type="submit">Cancel</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="addProductReceivingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form asp-action="SaveProductReceiving" method="post" id="productReceivingForm" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()
                <input name="search" type="hidden" value="@Model.Search" />
                <input name="filterBranchId" type="hidden" value="@Model.BranchId" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Add Product Receiving</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div asp-validation-summary="All" class="text-danger"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Form.BranchId" class="form-label">Branch</label>
                            <input asp-for="Form.BranchId" type="hidden" id="productReceivingBranchId" />
                            <div class="input-group" data-branch-selector data-branch-hidden="#productReceivingBranchId" data-branch-display="#productReceivingBranchDisplay">
                                <input class="form-control" id="productReceivingBranchDisplay" value="@Model.FormBranchName" readonly />
                                <button type="button" class="btn btn-outline-secondary branch-select-btn">
                                    <img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" />
                                </button>
                            </div>
                            <span asp-validation-for="Form.BranchId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.SupplierId" class="form-label">Supplier</label>
                            <input asp-for="Form.SupplierId" type="hidden" id="productReceivingSupplierId" />
                            <div class="input-group">
                                <input class="form-control" id="productReceivingSupplierDisplay" value="@Model.FormSupplierName" placeholder="Select supplier" readonly />
                                <button type="button" class="btn btn-outline-secondary product-receiving-supplier-select-btn">
                                    <img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" />
                                </button>
                            </div>
                            <span asp-validation-for="Form.SupplierId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.ProductMode" class="form-label">Product Mode</label>
                            <select asp-for="Form.ProductMode" class="form-select" data-product-mode>
                                <option value="Existing">Existing Product</option>
                                <option value="New">New Product</option>
                            </select>
                        </div>
                        <div class="col-md-6 product-existing-fields">
                            <label asp-for="Form.ProductId" class="form-label">Product</label>
                            <input asp-for="Form.ProductId" type="hidden" id="productReceivingProductId" />
                            <div class="input-group">
                                <input class="form-control" id="productReceivingProductDisplay" value="@Model.FormProductName" placeholder="Select product" readonly />
                                <button type="button" class="btn btn-outline-secondary product-receiving-product-select-btn">
                                    <img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" />
                                </button>
                            </div>
                            <span asp-validation-for="Form.ProductId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 product-new-fields d-none">
                            <label asp-for="Form.NewProductName" class="form-label">Product Name</label>
                            <input asp-for="Form.NewProductName" class="form-control" />
                            <span asp-validation-for="Form.NewProductName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 product-new-fields d-none">
                            <label asp-for="Form.NewProductCategoryId" class="form-label">Category</label>
                            <select asp-for="Form.NewProductCategoryId" asp-items="Model.CategoryOptions" class="form-select"></select>
                        </div>
                        <div class="col-md-6 product-new-fields d-none">
                            <label asp-for="Form.NewProductUnitId" class="form-label">Unit</label>
                            <select asp-for="Form.NewProductUnitId" asp-items="Model.UnitOptions" class="form-select"></select>
                        </div>
                        <div class="col-md-6 product-new-fields d-none">
                            <label asp-for="Form.NewProductDescription" class="form-label">Description</label>
                            <input asp-for="Form.NewProductDescription" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Batch No</label>
                            <input class="form-control" value="Auto-generated sequential 8-digit number on save" readonly />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Form.ExpiryDate" class="form-label">Expiry Date</label>
                            <input asp-for="Form.ExpiryDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Form.Quantity" class="form-label">Quantity</label>
                            <input asp-for="Form.Quantity" class="form-control" type="number" step="0.01" min="0.01" required />
                            <span asp-validation-for="Form.Quantity" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Form.CostPrice" class="form-label">Cost Price</label>
                            <input asp-for="Form.CostPrice" class="form-control" type="number" step="0.01" min="0" required />
                            <span asp-validation-for="Form.CostPrice" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Form.SellingPrice" class="form-label">Selling Price</label>
                            <input asp-for="Form.SellingPrice" class="form-control" type="number" step="0.01" min="0" required />
                            <span asp-validation-for="Form.SellingPrice" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Form.ReceivedDate" class="form-label">Date</label>
                            <input asp-for="Form.ReceivedDate" class="form-control" type="date" required />
                            <span asp-validation-for="Form.ReceivedDate" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Form.Remarks" class="form-label">Remarks</label>
                            <textarea asp-for="Form.Remarks" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save Receiving</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="productReceivingProductSelectorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Select Product</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input class="form-control" id="productReceivingProductSearchInput" type="search" placeholder="Search product, category, or unit" />
                    <button class="btn btn-outline-primary" id="productReceivingProductSearchButton" type="button">Search</button>
                </div>
                <div class="table-responsive">
                    <table class="table app-table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>Product</th>
                                <th>Category</th>
                                <th>Unit</th>
                                <th>Current Warehouse Quantity</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="productReceivingProductSelectorResults">
                            <tr><td class="text-center text-muted fw-bold" colspan="6">Search for a product.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="productReceivingSupplierSelectorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Select Supplier</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input class="form-control" id="productReceivingSupplierSearchInput" type="search" placeholder="Search supplier, contact, or address" />
                    <button class="btn btn-outline-primary" id="productReceivingSupplierSearchButton" type="button">Search</button>
                </div>
                <div class="table-responsive">
                    <table class="table app-table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>Supplier</th>
                                <th>Contact</th>
                                <th>Address</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="productReceivingSupplierSelectorResults">
                            <tr><td class="text-center text-muted fw-bold" colspan="5">Search for a supplier.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@for (var i = 0; i < Model.Receivings.Count; i += 1)
{
    <div class="modal fade" id="productReceivingViewModal_@Model.Receivings[i].Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Product Receiving Details</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Receiving No</dt><dd class="col-sm-7">@Model.Receivings[i].ReceivingNo</dd>
                        <dt class="col-sm-5">Supplier</dt><dd class="col-sm-7">@Model.Receivings[i].Supplier</dd>
                        <dt class="col-sm-5">Product</dt><dd class="col-sm-7">@Model.Receivings[i].Product</dd>
                        <dt class="col-sm-5">Batch</dt><dd class="col-sm-7">@Model.Receivings[i].Batch</dd>
                        <dt class="col-sm-5">Remarks</dt><dd class="col-sm-7">@Model.Receivings[i].Remarks</dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const mode = document.querySelector("[data-product-mode]");
        const existingFields = Array.from(document.querySelectorAll(".product-existing-fields"));
        const newFields = Array.from(document.querySelectorAll(".product-new-fields"));
        const existingFieldInputs = existingFields.flatMap(field => Array.from(field.querySelectorAll("input, select, textarea, button")));
        const newFieldInputs = newFields.flatMap(field => Array.from(field.querySelectorAll("input, select, textarea, button")));
        const branchInput = document.getElementById("productReceivingBranchId");
        const productInput = document.getElementById("productReceivingProductId");
        const productDisplay = document.getElementById("productReceivingProductDisplay");
        const productSearchInput = document.getElementById("productReceivingProductSearchInput");
        const productSearchButton = document.getElementById("productReceivingProductSearchButton");
        const productResults = document.getElementById("productReceivingProductSelectorResults");
        const productSelectorModal = document.getElementById("productReceivingProductSelectorModal");
        const supplierInput = document.getElementById("productReceivingSupplierId");
        const supplierDisplay = document.getElementById("productReceivingSupplierDisplay");
        const supplierSearchInput = document.getElementById("productReceivingSupplierSearchInput");
        const supplierSearchButton = document.getElementById("productReceivingSupplierSearchButton");
        const supplierResults = document.getElementById("productReceivingSupplierSelectorResults");
        const supplierSelectorModal = document.getElementById("productReceivingSupplierSelectorModal");
        const addProductReceivingModal = document.getElementById("addProductReceivingModal");
        const productReceivingForm = document.getElementById("productReceivingForm");
        const newProductNameInput = document.getElementById("Form_NewProductName");
        const quantityInput = document.getElementById("Form_Quantity");
        const costInput = document.getElementById("Form_CostPrice");
        const sellingInput = document.getElementById("Form_SellingPrice");
        const receivedDateInput = document.getElementById("Form_ReceivedDate");
        const shouldOpenProductReceivingModal = @((ViewData["OpenProductReceivingModal"] is true).ToString().ToLowerInvariant());

        const escapeHtml = value => String(value ?? "")
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#039;");

        function restoreParentModalState() {
            if (addProductReceivingModal?.classList.contains("show")) {
                document.body.classList.add("modal-open");
            }
        }

        function showSelectorOnly(modalElement) {
            if (modalElement && window.bootstrap) {
                bootstrap.Modal.getOrCreateInstance(modalElement, {
                    backdrop: true,
                    keyboard: true
                }).show();
                restoreParentModalState();
            }
        }

        function closeSelectorOnly(modalElement) {
            if (modalElement && window.bootstrap) {
                const modal = bootstrap.Modal.getInstance(modalElement) || bootstrap.Modal.getOrCreateInstance(modalElement);
                modal.hide();
                setTimeout(restoreParentModalState, 150);
            }
        }

        function validationSpan(fieldName) {
            return productReceivingForm?.querySelector(`[data-valmsg-for="${fieldName}"]`);
        }

        function setValidationError(input, fieldName, message) {
            if (input) {
                input.classList.add("is-invalid");
                input.setCustomValidity(message);
            }

            const span = validationSpan(fieldName);
            if (span) {
                span.textContent = message;
                span.classList.remove("field-validation-valid");
                span.classList.add("field-validation-error");
            }
        }

        function clearValidationError(input, fieldName) {
            if (input) {
                input.classList.remove("is-invalid");
                input.setCustomValidity("");
            }

            const span = validationSpan(fieldName);
            if (span) {
                span.textContent = "";
                span.classList.remove("field-validation-error");
                span.classList.add("field-validation-valid");
            }
        }

        function validateRequiredNumber(input, fieldName, label, minimumValue, minimumMessage) {
            const value = input?.value?.trim() ?? "";
            if (!value) {
                setValidationError(input, fieldName, `${label} is required.`);
                return false;
            }

            const numberValue = Number(value);
            if (!Number.isFinite(numberValue) || numberValue < minimumValue) {
                setValidationError(input, fieldName, minimumMessage);
                return false;
            }

            clearValidationError(input, fieldName);
            return true;
        }

        function validateProductReceivingForm() {
            let isValid = true;
            let firstInvalid = null;
            const isNewProduct = mode && (mode.value === "New" || mode.value === "NewProduct");

            const markInvalid = input => {
                isValid = false;
                firstInvalid ??= input;
            };

            if (!branchInput?.value || Number(branchInput.value) <= 0) {
                setValidationError(document.getElementById("productReceivingBranchDisplay"), "Form.BranchId", "Branch is required.");
                markInvalid(document.getElementById("productReceivingBranchDisplay"));
            } else {
                clearValidationError(document.getElementById("productReceivingBranchDisplay"), "Form.BranchId");
            }

            if (!supplierInput?.value || Number(supplierInput.value) <= 0) {
                setValidationError(supplierDisplay, "Form.SupplierId", "Supplier is required.");
                markInvalid(supplierDisplay);
            } else {
                clearValidationError(supplierDisplay, "Form.SupplierId");
            }

            if (isNewProduct) {
                if (!newProductNameInput?.value?.trim()) {
                    setValidationError(newProductNameInput, "Form.NewProductName", "Product Name is required.");
                    markInvalid(newProductNameInput);
                } else {
                    clearValidationError(newProductNameInput, "Form.NewProductName");
                }
                clearValidationError(productDisplay, "Form.ProductId");
            } else if (!productInput?.value || Number(productInput.value) <= 0) {
                setValidationError(productDisplay, "Form.ProductId", "Product is required.");
                markInvalid(productDisplay);
            } else {
                clearValidationError(productDisplay, "Form.ProductId");
                clearValidationError(newProductNameInput, "Form.NewProductName");
            }

            if (!validateRequiredNumber(quantityInput, "Form.Quantity", "Quantity", 0.01, "Quantity must be greater than 0.")) {
                markInvalid(quantityInput);
            }

            if (!validateRequiredNumber(costInput, "Form.CostPrice", "Cost Price", 0, "Cost Price must be greater than or equal to 0.")) {
                markInvalid(costInput);
            }

            if (!validateRequiredNumber(sellingInput, "Form.SellingPrice", "Selling Price", 0, "Selling Price must be greater than or equal to 0.")) {
                markInvalid(sellingInput);
            }

            if (!receivedDateInput?.value) {
                setValidationError(receivedDateInput, "Form.ReceivedDate", "Date is required.");
                markInvalid(receivedDateInput);
            } else {
                clearValidationError(receivedDateInput, "Form.ReceivedDate");
            }

            if (!isValid) {
                productReceivingForm?.classList.add("was-validated");
                firstInvalid?.focus();
            }

            return isValid;
        }

        function hasSelectedBranch() {
            return !!branchInput?.value && Number(branchInput.value) > 0;
        }

        function clearSelectedProduct() {
            if (productInput) productInput.value = "";
            if (productDisplay) productDisplay.value = "";
            clearValidationError(productDisplay, "Form.ProductId");
            if (productResults) {
                productResults.innerHTML = '<tr><td class="text-center text-muted fw-bold" colspan="6">Select a branch, then search for a product.</td></tr>';
            }
        }

        function requireBranchBeforeProductSelector() {
            if (hasSelectedBranch()) {
                clearValidationError(document.getElementById("productReceivingBranchDisplay"), "Form.BranchId");
                clearValidationError(productDisplay, "Form.ProductId");
                return true;
            }

            setValidationError(productDisplay, "Form.ProductId", "Please select a Branch first.");
            productReceivingForm?.classList.add("was-validated");
            document.getElementById("productReceivingBranchDisplay")?.focus();
            return false;
        }

        function syncProductMode() {
            const isNew = mode && (mode.value === "New" || mode.value === "NewProduct");
            existingFields.forEach(function (field) { field.classList.toggle("d-none", isNew); });
            newFields.forEach(function (field) { field.classList.toggle("d-none", !isNew); });
            existingFieldInputs.forEach(input => { input.disabled = isNew; });
            newFieldInputs.forEach(input => { input.disabled = !isNew; });

            if (isNew) {
                clearValidationError(productDisplay, "Form.ProductId");
            } else {
                clearValidationError(newProductNameInput, "Form.NewProductName");
            }

            if (productReceivingForm?.classList.contains("was-validated")) {
                validateProductReceivingForm();
            }
        }

        if (mode) {
            mode.addEventListener("change", syncProductMode);
            syncProductMode();
        }

        function renderProducts(products) {
            if (!productResults) return;
            productResults.innerHTML = "";
            if (!products.length) {
                productResults.innerHTML = '<tr><td class="text-center text-muted fw-bold" colspan="6">No products found.</td></tr>';
                return;
            }

            products.forEach((product, index) => {
                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td>${index + 1}</td>
                    <td>${escapeHtml(product.productName || "-")}</td>
                    <td>${escapeHtml(product.categoryName || "-")}</td>
                    <td>${escapeHtml(product.unitName || "-")}</td>
                    <td>${Number(product.currentWarehouseQuantity || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                    <td><button class="btn btn-sm btn-outline-primary" type="button">Select</button></td>
                `;
                tr.querySelector("button").addEventListener("click", event => {
                    event.preventDefault();
                    event.stopPropagation();
                    if (productInput) productInput.value = product.productId || "";
                    if (productDisplay) productDisplay.value = product.productName || "";
                    productInput?.dispatchEvent(new Event("change", { bubbles: true }));
                    closeSelectorOnly(productSelectorModal);
                });
                productResults.appendChild(tr);
            });
        }

        async function searchProducts(event) {
            event?.preventDefault();
            event?.stopPropagation();
            if (!productResults) return;
            if (!requireBranchBeforeProductSelector()) return;
            productResults.innerHTML = '<tr><td class="text-center text-muted fw-bold" colspan="6">Loading products...</td></tr>';
            const query = encodeURIComponent(productSearchInput?.value || "");
            const branch = encodeURIComponent(branchInput?.value || "");
            const response = await fetch(`/Transaction/SearchProductReceivingProducts?search=${query}&branchId=${branch}`, {
                headers: { "Accept": "application/json" }
            });
            if (!response.ok) {
                productResults.innerHTML = '<tr><td class="text-center text-danger fw-bold" colspan="6">Unable to load products.</td></tr>';
                return;
            }

            renderProducts(await response.json());
        }

        function renderSuppliers(suppliers) {
            if (!supplierResults) return;
            supplierResults.innerHTML = "";
            if (!suppliers.length) {
                supplierResults.innerHTML = '<tr><td class="text-center text-muted fw-bold" colspan="5">No suppliers found.</td></tr>';
                return;
            }

            suppliers.forEach((supplier, index) => {
                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td>${index + 1}</td>
                    <td>${escapeHtml(supplier.supplierName || "-")}</td>
                    <td>${escapeHtml(supplier.contact || "-")}</td>
                    <td>${escapeHtml(supplier.address || "-")}</td>
                    <td><button class="btn btn-sm btn-outline-primary" type="button">Select</button></td>
                `;
                tr.querySelector("button").addEventListener("click", event => {
                    event.preventDefault();
                    event.stopPropagation();
                    if (supplierInput) supplierInput.value = supplier.supplierId || "";
                    if (supplierDisplay) supplierDisplay.value = supplier.supplierName || "";
                    supplierInput?.dispatchEvent(new Event("change", { bubbles: true }));
                    closeSelectorOnly(supplierSelectorModal);
                });
                supplierResults.appendChild(tr);
            });
        }

        async function searchSuppliers(event) {
            event?.preventDefault();
            event?.stopPropagation();
            if (!supplierResults) return;
            supplierResults.innerHTML = '<tr><td class="text-center text-muted fw-bold" colspan="5">Loading suppliers...</td></tr>';
            const query = encodeURIComponent(supplierSearchInput?.value || "");
            const response = await fetch(`/Transaction/SearchProductReceivingSuppliers?search=${query}`, {
                headers: { "Accept": "application/json" }
            });
            if (!response.ok) {
                supplierResults.innerHTML = '<tr><td class="text-center text-danger fw-bold" colspan="5">Unable to load suppliers.</td></tr>';
                return;
            }

            renderSuppliers(await response.json());
        }

        branchInput?.addEventListener("change", function () {
            clearSelectedProduct();
            if (productReceivingForm?.classList.contains("was-validated")) {
                validateProductReceivingForm();
            }
        });

        document.querySelector(".product-receiving-product-select-btn")?.addEventListener("click", event => {
            event.preventDefault();
            event.stopPropagation();
            if (!requireBranchBeforeProductSelector()) return;
            showSelectorOnly(productSelectorModal);
            searchProducts(event);
        });
        productSearchButton?.addEventListener("click", searchProducts);
        productSearchInput?.addEventListener("keydown", event => {
            if (event.key === "Enter") {
                event.preventDefault();
                event.stopPropagation();
                searchProducts();
            }
        });
        productSelectorModal?.addEventListener("hidden.bs.modal", restoreParentModalState);

        [branchInput, productInput, supplierInput].forEach(input => {
            input?.addEventListener("change", function () {
                if (productReceivingForm?.classList.contains("was-validated")) {
                    validateProductReceivingForm();
                }
            });
        });

        [newProductNameInput, quantityInput, costInput, sellingInput, receivedDateInput].forEach(input => {
            input?.addEventListener("input", function () {
                if (productReceivingForm?.classList.contains("was-validated")) {
                    validateProductReceivingForm();
                }
            });
            input?.addEventListener("change", function () {
                if (productReceivingForm?.classList.contains("was-validated")) {
                    validateProductReceivingForm();
                }
            });
        });

        productReceivingForm?.addEventListener("submit", event => {
            if (!validateProductReceivingForm()) {
                event.preventDefault();
                event.stopPropagation();
                showSelectorOnly(addProductReceivingModal);
            }
        });

        document.querySelector(".product-receiving-supplier-select-btn")?.addEventListener("click", event => {
            event.preventDefault();
            event.stopPropagation();
            showSelectorOnly(supplierSelectorModal);
            searchSuppliers(event);
        });
        supplierSearchButton?.addEventListener("click", searchSuppliers);
        supplierSearchInput?.addEventListener("keydown", event => {
            if (event.key === "Enter") {
                event.preventDefault();
                event.stopPropagation();
                searchSuppliers();
            }
        });
        supplierSelectorModal?.addEventListener("hidden.bs.modal", restoreParentModalState);

        if (shouldOpenProductReceivingModal) {
            showSelectorOnly(addProductReceivingModal);
            productReceivingForm?.classList.add("was-validated");
        }
    });
</script>
