@{
    ViewData["Title"] = "Cash In";
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Transaction</li>
                <li class="breadcrumb-item active" aria-current="page">Cash In</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="mb-0">Cash In</h1>
            <span class="badge bg-warning text-dark">UI Preview Only</span>
            <span class="badge bg-secondary">Backend not connected yet</span>
        </div>
        <p class="page-subtitle text-muted mt-2">Register cashier drawer cash-in events (e.g. drawer top-ups).</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#cashInFormModal">Add Cash In</button>
    </div>
</div>

<section class="transaction-ui-page">
    <div class="content-card mb-3">
        <form class="row g-2 align-items-center" onsubmit="return false;">
            <div class="col-md-3">
                <input class="form-control" type="search" placeholder="Search cash in..." id="cashInSearch" />
            </div>
            <div class="col-md-2">
                <select class="form-select" id="cashInBranch">
                    <option value="">All Branches</option>
                    <option>Main Branch</option>
                    <option>Branch 2</option>
                </select>
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="cashInDateFrom" />
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="cashInDateTo" />
            </div>
            <div class="col-md-1">
                <select class="form-select" id="cashInStatus">
                    <option value="">All Statuses</option>
                    <option>Approved</option>
                    <option>Pending</option>
                    <option>Cancelled</option>
                </select>
            </div>
            <div class="col-md-auto d-flex gap-1">
                <button class="btn btn-primary" type="button">Search</button>
                <button class="btn btn-outline-secondary" type="button">Clear</button>
            </div>
        </form>
    </div>

    <div class="content-card transaction-ui-card">
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="cashInTable">
                <thead>
                    <tr>
                        <th class="text-nowrap">No</th>
                        <th class="text-nowrap">Date/Time</th>
                        <th class="text-nowrap">Branch</th>
                        <th class="text-nowrap">Shift</th>
                        <th class="text-nowrap">User</th>
                        <th class="text-nowrap">Amount</th>
                        <th class="text-nowrap">Reason</th>
                        <th class="text-nowrap">Remarks</th>
                        <th class="text-nowrap">Created By</th>
                        <th class="text-nowrap">Status</th>
                        <th class="text-nowrap">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td class="text-nowrap">2026-07-09 10:15</td>
                        <td>Main Branch</td>
                        <td>Morning Shift</td>
                        <td>cashier_01</td>
                        <td>₱500.00</td>
                        <td>Drawer top-up</td>
                        <td>Standard morning start-up fund top-up</td>
                        <td>admin</td>
                        <td><span class="badge bg-success text-nowrap">Approved</span></td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#cashInViewModal">View</button>
                        </td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td class="text-nowrap">2026-07-08 14:30</td>
                        <td>Main Branch</td>
                        <td>Afternoon Shift</td>
                        <td>cashier_02</td>
                        <td>₱1,000.00</td>
                        <td>Additional float</td>
                        <td>Approved by supervisor</td>
                        <td>supervisor_01</td>
                        <td><span class="badge bg-success text-nowrap">Approved</span></td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#cashInViewModal">View</button>
                        </td>
                    </tr>
                    <tr class="d-none">
                        <td class="text-center text-muted fw-bold" colspan="11">No records found.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- Add Modal -->
<div class="modal fade" id="cashInFormModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Add Cash In</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Branch</label>
                        <select class="form-select">
                            <option>Main Branch</option>
                            <option>Branch 2</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Date/Time</label>
                        <input class="form-control" type="datetime-local" value="2026-07-09T10:15" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Shift</label>
                        <select class="form-select">
                            <option>Morning Shift</option>
                            <option>Afternoon Shift</option>
                            <option>Night Shift</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">User</label>
                        <input class="form-control" value="cashier_01" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Amount</label>
                        <input class="form-control" type="number" value="500" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Reason</label>
                        <input class="form-control" value="Drawer top-up" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Remarks</label>
                        <textarea class="form-control" rows="3" placeholder="Enter remarks here..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" type="button" onclick="alert('Backend not connected yet.');" data-bs-dismiss="modal">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- View Modal -->
<div class="modal fade" id="cashInViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Cash In Details</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>This is a UI preview. Cash In backend is not connected yet.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
