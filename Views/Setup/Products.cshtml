<div class="products-page setup-products-page">
    <div class="page-header">
        <div class="page-heading">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">GPOS</li>
                    <li class="breadcrumb-item">Setup</li>
                    <li class="breadcrumb-item active" aria-current="page">Products</li>
                </ol>
            </nav>
            <h1>Products</h1>
            <p class="page-subtitle">Manage product pricing and current product quantities.</p>
        </div>
    </div>

    <section class="card products-card setup-products-card">
        <div class="card-body">
            <div class="products-toolbar d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
                <div class="products-search-wrap">
                    <label class="visually-hidden" for="setup-product-search">Search products</label>
                    <input class="form-control form-control-sm products-search" id="setup-product-search" type="search" placeholder="Search products" autocomplete="off" />
                </div>
                <div class="col-12 col-sm-auto ms-sm-auto">
                    <button class="btn btn-primary btn-sm w-100" type="button">Add Product</button>
                </div>
            </div>

            <div class="table-responsive products-table-wrap">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">No</th>
                            <th scope="col">ID</th>
                            <th scope="col">Batch #</th>
                            <th scope="col">Name</th>
                            <th scope="col">Cost Price</th>
                            <th scope="col">Selling Price</th>
                            <th scope="col">Quantity</th>
                            <th scope="col">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr data-setup-product-row>
                            <td>1</td>
                            <td>PRD-001</td>
                            <td>IB-024</td>
                            <td>Engine Oil 1L</td>
                            <td>&#8369;220.00</td>
                            <td>&#8369;320.00</td>
                            <td>48</td>
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    <button class="btn btn-outline-secondary btn-sm" type="button" disabled>Edit</button>
                                    <button class="btn btn-outline-danger btn-sm" type="button" disabled>Delete</button>
                                </div>
                            </td>
                        </tr>
                        <tr data-setup-product-row>
                            <td>2</td>
                            <td>PRD-002</td>
                            <td>IB-025</td>
                            <td>Coolant 1L</td>
                            <td>&#8369;110.00</td>
                            <td>&#8369;180.00</td>
                            <td>36</td>
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    <button class="btn btn-outline-secondary btn-sm" type="button" disabled>Edit</button>
                                    <button class="btn btn-outline-danger btn-sm" type="button" disabled>Delete</button>
                                </div>
                            </td>
                        </tr>
                        <tr data-setup-product-row>
                            <td>3</td>
                            <td>PRD-003</td>
                            <td>IB-026</td>
                            <td>Brake Fluid</td>
                            <td>&#8369;145.00</td>
                            <td>&#8369;210.00</td>
                            <td>24</td>
                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    <button class="btn btn-outline-secondary btn-sm" type="button" disabled>Edit</button>
                                    <button class="btn btn-outline-danger btn-sm" type="button" disabled>Delete</button>
                                </div>
                            </td>
                        </tr>
                        <tr class="d-none" data-setup-product-empty-row>
                            <td class="text-center text-muted fw-bold" colspan="8">No products found.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const searchInput = document.getElementById("setup-product-search");
        const productRows = Array.from(document.querySelectorAll("[data-setup-product-row]"));
        const emptyRow = document.querySelector("[data-setup-product-empty-row]");

        if (!searchInput || !emptyRow) {
            return;
        }

        searchInput.addEventListener("input", () => {
            const query = searchInput.value.trim().toLowerCase();
            let visibleCount = 0;

            for (let index = 0; index < productRows.length; index += 1) {
                const row = productRows[index];
                const isVisible = row.textContent.toLowerCase().includes(query);
                row.classList.toggle("d-none", !isVisible);
                visibleCount += isVisible ? 1 : 0;
            }

            emptyRow.classList.toggle("d-none", visibleCount !== 0);
        });
    });
</script>
