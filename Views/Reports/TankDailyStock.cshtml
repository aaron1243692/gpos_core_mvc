@model gpos.Models.ViewModels.DailyStockPageViewModel

@{
    var isEdit = Model.Form.Id > 0;
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Reports</li>
                <li class="breadcrumb-item">Daily Stock</li>
                <li class="breadcrumb-item active" aria-current="page">Tank</li>
            </ol>
        </nav>
        <h1>@Model.PageTitle</h1>
        <p class="page-subtitle">@Model.Description</p>
    </div>
</div>

<section class="content-card setup-crud-card setup-table-card">
    <div class="table-actions fuel-toolbar">
        <form asp-action="@Model.PageAction" method="get" class="setup-search-form fuel-toolbar-search flex-wrap">
            <input class="form-control" name="search" value="@Model.Search" placeholder="Search tank daily stock" />
            <select class="form-select" name="filterBranchId">
                @foreach (var branch in Model.BranchOptions)
                {
                    <option value="@branch.Value" selected="@((Model.BranchId?.ToString() ?? string.Empty) == branch.Value ? "selected" : null)">@branch.Text</option>
                }
            </select>
            <button class="btn btn-outline-primary" type="submit">Search</button>
            <a class="btn btn-outline-secondary" asp-action="@Model.PageAction">Clear</a>
        </form>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#dailyStockModal">Add Record</button>
    </div>

    <div class="setup-table-scroll">
        <table class="table app-table table-sm align-middle admin-table mb-0">
            <thead>
                <tr>
                    <th>No</th>
                    <th>Date</th>
                    <th>Branch</th>
                    <th>Tank</th>
                    <th>Fuel</th>
                    <th>Beginning Liters</th>
                    <th>Sold Liters</th>
                    <th>Actual Liters</th>
                    <th>Ending Liters</th>
                    <th>Loss Liters</th>
                    <th>Remarks</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Records.Count == 0)
                {
                    <tr><td class="text-center text-muted fw-bold" colspan="12">No records yet.</td></tr>
                }
                @for (var i = 0; i < Model.Records.Count; i += 1)
                {
                    var record = Model.Records[i];
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@record.StockDate.ToString("yyyy-MM-dd")</td>
                        <td>@(record.Branch?.Name ?? "Unassigned")</td>
                        <td>@(record.Tank?.TankNo ?? "-")</td>
                        <td>@(record.Tank?.Fuel?.Name ?? "-")</td>
                        <td>@record.Beginning.ToString("N2")</td>
                        <td>@record.Sold.ToString("N2")</td>
                        <td>@record.Actual.ToString("N2")</td>
                        <td>@record.Ending.ToString("N2")</td>
                        <td>@record.Loss.ToString("N2")</td>
                        <td>@(record.Remarks ?? "-")</td>
                        <td class="col-action"><a class="btn btn-sm btn-outline-primary" asp-action="@Model.PageAction" asp-route-editId="@record.Id" asp-route-search="@Model.Search" asp-route-filterBranchId="@Model.BranchId">Edit</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="dailyStockModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form asp-action="@Model.SaveAction" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Form.Id" type="hidden" />
                <input asp-for="Form.StockType" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <input name="filterBranchId" type="hidden" value="@Model.BranchId" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5">@(isEdit ? "Edit Tank Daily Stock" : "Add Tank Daily Stock")</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Form.BranchId" class="form-label">Branch</label>
                            <input asp-for="Form.BranchId" type="hidden" id="dailyStockTankBranchId" data-daily-stock-branch />
                            <input class="form-control" id="dailyStockTankBranchDisplay" value="@Model.FormBranchName" placeholder="Selected with tank" readonly data-daily-stock-branch-display />
                            <span asp-validation-for="Form.BranchId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.StockDate" class="form-label">Date</label>
                            <input asp-for="Form.StockDate" class="form-control" type="date" />
                            <span asp-validation-for="Form.StockDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.TankId" class="form-label">Tank</label>
                            <input asp-for="Form.TankId" type="hidden" data-daily-stock-tank />
                            <div class="input-group">
                                <input class="form-control" value="" placeholder="Select tank, fuel, and branch" readonly data-daily-stock-tank-display />
                                <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#dailyStockTankSelectorModal">
                                    <img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" />
                                </button>
                            </div>
                            <span asp-validation-for="Form.TankId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Fuel</label>
                            <input class="form-control" data-daily-stock-fuel readonly />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.Beginning" class="form-label">Beginning Liters</label>
                            <input asp-for="Form.Beginning" class="form-control" type="number" min="0" step="0.01" data-daily-stock-beginning />
                            <span asp-validation-for="Form.Beginning" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.Sold" class="form-label">Sold Liters</label>
                            <input asp-for="Form.Sold" class="form-control" type="number" step="0.01" readonly data-daily-stock-sold />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.Actual" class="form-label">Actual Liters</label>
                            <input asp-for="Form.Actual" class="form-control" type="number" step="0.01" readonly data-daily-stock-actual />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.Ending" class="form-label">Ending Liters</label>
                            <input asp-for="Form.Ending" class="form-control" type="number" min="0" step="0.01" data-daily-stock-ending />
                            <span asp-validation-for="Form.Ending" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.Loss" class="form-label">Loss Liters</label>
                            <input asp-for="Form.Loss" class="form-control" type="number" step="0.01" readonly data-daily-stock-loss />
                        </div>
                        <div class="col-12">
                            <label asp-for="Form.Remarks" class="form-label">Remarks</label>
                            <textarea asp-for="Form.Remarks" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="dailyStockTankSelectorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Select Tank</h2>
                <button class="btn-close" type="button" data-bs-target="#dailyStockModal" data-bs-toggle="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <input class="form-control" placeholder="Search branch, tank, or fuel" data-daily-stock-selector-search />
                </div>
                <div class="setup-table-scroll">
                    <table class="table app-table table-sm align-middle admin-table mb-0">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>Branch</th>
                                <th>Tank</th>
                                <th>Fuel</th>
                                <th>Current Liters</th>
                                <th>Capacity</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody data-daily-stock-selector-body></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_DailyStockScripts" model="Model" />
}
