@{
    ViewData["Title"] = "Daily Sales";
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Reports</li>
                <li class="breadcrumb-item active" aria-current="page">Daily Sales</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="mb-0">Daily Sales</h1>
            <span class="badge bg-warning text-dark">UI Preview Only</span>
            <span class="badge bg-secondary">Backend not connected yet</span>
        </div>
        <p class="page-subtitle text-muted mt-2">Summary of daily sales, taxes, discounts, and breakdowns per branch.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-outline-secondary" type="button" onclick="alert('Export backend not connected yet.');">Export CSV</button>
        <button class="btn btn-outline-secondary" type="button" onclick="alert('Print backend not connected yet.');">Print</button>
    </div>
</div>

<section class="reports-ui-page">
    <div class="content-card mb-3">
        <form class="row g-2 align-items-center" onsubmit="return false;">
            <div class="col-md-3">
                <input class="form-control" type="search" placeholder="Search report..." id="dailySalesSearch" />
            </div>
            <div class="col-md-3">
                <select class="form-select" id="dailySalesBranch">
                    <option value="">All Branches</option>
                    <option>Main Branch</option>
                    <option>Branch 2</option>
                </select>
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="dailySalesDateFrom" />
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="dailySalesDateTo" />
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button class="btn btn-primary w-100" type="button">Search</button>
                <button class="btn btn-outline-secondary" type="button">Clear</button>
            </div>
        </form>
    </div>

    <div class="content-card transaction-ui-card">
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="dailySalesTable">
                <thead>
                    <tr>
                        <th class="text-nowrap">No</th>
                        <th class="text-nowrap">Date</th>
                        <th class="text-nowrap">Branch</th>
                        <th class="text-nowrap">Total Sales</th>
                        <th class="text-nowrap">Product Sales</th>
                        <th class="text-nowrap">Fuel Sales</th>
                        <th class="text-nowrap">Discount</th>
                        <th class="text-nowrap">VAT</th>
                        <th class="text-nowrap">Net Sales</th>
                        <th class="text-nowrap">Cashier/Shift</th>
                        <th class="text-nowrap">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td class="text-nowrap">2026-07-09</td>
                        <td>Main Branch</td>
                        <td>₱45,600.00</td>
                        <td>₱5,600.00</td>
                        <td>₱40,000.00</td>
                        <td>₱1,200.00</td>
                        <td>₱4,800.00</td>
                        <td>₱39,600.00</td>
                        <td>admin / Morning</td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-primary" type="button" onclick="alert('Details backend not connected yet.');">Details</button>
                        </td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td class="text-nowrap">2026-07-08</td>
                        <td>Main Branch</td>
                        <td>₱52,300.00</td>
                        <td>₱7,300.00</td>
                        <td>₱45,000.00</td>
                        <td>₱1,500.00</td>
                        <td>₱5,400.00</td>
                        <td>₱45,400.00</td>
                        <td>cashier_01 / Afternoon</td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-primary" type="button" onclick="alert('Details backend not connected yet.');">Details</button>
                        </td>
                    </tr>
                    <tr class="d-none">
                        <td class="text-center text-muted fw-bold" colspan="11">No records found.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
