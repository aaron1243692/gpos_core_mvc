<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"]?.ToString() ?? "Salesman") - GPOS Salesman</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/gpos_core_mvc.styles.css" asp-append-version="true" />
</head>
<body class="app-shell salesman-shell">
    <div class="salesman-layout">
        <main class="app-main salesman-main">
            <header class="eg-rb salesman-rb" aria-label="Salesman navigation">
                <div class="eg-rb-top">
                    <a class="eg-rb-brand" asp-controller="Salesman" asp-action="POS" aria-label="GPOS salesman POS">
                        <span class="eg-rb-brand-mark" aria-hidden="true">S</span>
                        <span>GPOS / Salesman POS</span>
                    </a>

                    <nav class="eg-rb-tabs" aria-label="Salesman pages">
                        <a class="eg-rb-tab @(string.Equals(ViewContext.RouteData.Values["action"]?.ToString(), "POS", StringComparison.OrdinalIgnoreCase) ? "is-active" : "")" asp-controller="Salesman" asp-action="POS">POS</a>
                        @* Hidden: Salesman sales history is a sample/view-only page and is not production-ready yet. *@
                    </nav>

                    <details class="eg-rb-user" id="salesmanUserDropdown">
                        <summary class="eg-rb-userbtn" aria-controls="salesmanUserMenu">
                            <span class="eg-rb-avatar" aria-hidden="true">S</span>
                            <span class="eg-rb-userlabel">@(Context.Session.GetString("EmployeeName") ?? Context.Session.GetString("EmployeeUsername") ?? Context.Session.GetString("Username") ?? Context.Session.GetString("Name") ?? User.Identity?.Name ?? "Salesman")</span>
                            <span class="eg-rb-usercaret" aria-hidden="true"></span>
                        </summary>
                        <div class="eg-rb-usermenu" id="salesmanUserMenu" role="menu">
                            <div class="eg-rb-usercaption">Signed in as</div>
                            <div class="eg-rb-username">@(Context.Session.GetString("EmployeeName") ?? Context.Session.GetString("EmployeeUsername") ?? Context.Session.GetString("Username") ?? Context.Session.GetString("Name") ?? User.Identity?.Name ?? "Salesman")</div>
                            <a class="eg-rb-usermenu-link eg-rb-usermenu-link--danger" href="/Salesman/Logout" role="menuitem">Logout</a>
                        </div>
                    </details>
                </div>
            </header>

            <div class="app-content salesman-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
