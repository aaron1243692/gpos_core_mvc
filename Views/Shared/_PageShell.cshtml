@{
    var title = ViewData["Title"]?.ToString() ?? "Page";
    var appSection = ViewData["Section"]?.ToString() ?? "GPOS";
    var pageKind = ViewData["PageKind"]?.ToString() ?? "table";
    var fields = FormFields(title);
    var columns = TableColumns(title, pageKind);
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">@appSection</li>
                <li class="breadcrumb-item active" aria-current="page">@title</li>
            </ol>
        </nav>
        <h1>@title</h1>
        <p class="page-subtitle">@Subtitle(title, pageKind)</p>
    </div>
    <div class="page-actions">
        <span class="status-pill">Frontend only</span>
        <button class="btn btn-primary btn-sm" type="button" disabled>New</button>
    </div>
</div>

@if (pageKind == "dashboard")
{
    var dashboard = DashboardFor(title);
    <div class="row g-3 mb-4">
        @foreach (var metric in dashboard.Metrics)
        {
            <div class="col-12 col-md-6 col-xl-3">
                <div class="metric-card">
                    <span class="metric-label">@metric.Label</span>
                    <strong>@metric.Value</strong>
                    <small>@metric.Note</small>
                </div>
            </div>
        }
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-xl-7">
            <section class="content-card h-100">
                <div class="card-title-row">
                    <div>
                        <h2>@dashboard.ChartTitle</h2>
                        <p>Static chart area for future reporting widgets.</p>
                    </div>
                    <span class="status-badge">Preview</span>
                </div>
                <div class="chart-placeholder">
                    <span></span><span></span><span></span><span></span><span></span><span></span>
                </div>
            </section>
        </div>
        <div class="col-12 col-xl-5">
            <section class="content-card h-100">
                <div class="card-title-row">
                    <div>
                        <h2>@dashboard.SideTitle</h2>
                        <p>At-a-glance operational items.</p>
                    </div>
                </div>
                <div class="stack-list">
                    @foreach (var item in dashboard.SideItems)
                    {
                        <div class="stack-item">
                            <div><strong>@item.Label</strong><span>@item.Note</span></div>
                            <span class="status-badge @(item.Warn ? "status-badge-muted" : "")">@item.Value</span>
                        </div>
                    }
                </div>
            </section>
        </div>
    </div>

    @foreach (var table in dashboard.Tables)
    {
        <partial name="_MockTable" model="@(Tuple.Create(table.Title, table.Columns, table.Rows))" />
    }
}
else if (title == "Pump Transaction")
{
    <div class="row g-4">
        <div class="col-12 col-xl-8">
            <section class="content-card mb-4">
                <div class="card-title-row">
                    <div>
                        <h2>Fuel Sale Form</h2>
                        <p>Select a pump, enter sale details, then review the receipt preview.</p>
                    </div>
                    <button class="btn btn-primary btn-sm" type="button" disabled>Complete sale</button>
                </div>
                <div class="pump-grid mb-4">
                    @foreach (var pump in new[] { "Pump 1 - Diesel", "Pump 2 - Gasoline", "Pump 3 - Premium", "Pump 4 - Diesel" })
                    {
                        <button class="pump-card" type="button">
                            <strong>@pump.Split(" - ")[0]</strong>
                            <span>@pump.Split(" - ")[1]</span>
                        </button>
                    }
                </div>
                <partial name="_MockForm" model="fields" />
            </section>
            <partial name="_MockTable" model='@(Tuple.Create("Recent Pump Transactions", columns, RowsFor(title, columns)))' />
        </div>
        <div class="col-12 col-xl-4">
            <section class="content-card mb-4">
                <div class="card-title-row">
                    <div>
                        <h2>Customer Search</h2>
                        <p>Static lookup UI for account and rewards selection.</p>
                    </div>
                </div>
                <input class="form-control mb-3" placeholder="Search customer or plate number" disabled />
                <div class="stack-list">
                    <div class="stack-item"><div><strong>Juan Dela Cruz</strong><span>ABC-1234</span></div><span class="status-badge">1,240 pts</span></div>
                    <div class="stack-item"><div><strong>Maria Santos</strong><span>NBS-8841</span></div><span class="status-badge">860 pts</span></div>
                </div>
            </section>
            <partial name="_ReceiptPreviewCard" model="@("Fuel Receipt Preview")" />
        </div>
    </div>
}
else if (title == "POS Sales")
{
    <div class="row g-4">
        <div class="col-12 col-xl-7">
            <section class="content-card mb-4">
                <div class="card-title-row">
                    <div>
                        <h2>Product Search</h2>
                        <p>Mock products and category filters for cashier sales.</p>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-12 col-md-8"><input class="form-control" placeholder="Search product" disabled /></div>
                    <div class="col-12 col-md-4">
                        <select class="form-select" disabled><option>All categories</option><option>Oil</option><option>Coolant</option></select>
                    </div>
                </div>
                <div class="product-grid">
                    @foreach (var product in new[] { "Engine Oil 1L|PHP 320", "Coolant 1L|PHP 180", "Brake Fluid|PHP 210", "Lubricant Bottle|PHP 145" })
                    {
                        var parts = product.Split("|");
                        <button class="product-card" type="button">
                            <span class="product-thumb">@parts[0].Substring(0, 1)</span>
                            <strong>@parts[0]</strong>
                            <span>@parts[1]</span>
                        </button>
                    }
                </div>
            </section>
            <partial name="_MockTable" model='@(Tuple.Create("Cart", new[] { "Product", "Batch", "Quantity", "Price", "Subtotal", "Action" }, RowsFor(title, new[] { "Product", "Batch", "Quantity", "Price", "Subtotal", "Action" })))' />
        </div>
        <div class="col-12 col-xl-5">
            <section class="content-card mb-4">
                <div class="card-title-row">
                    <div>
                        <h2>Customer, Discount, and Payment</h2>
                        <p>Readonly controls for the future checkout flow.</p>
                    </div>
                </div>
                <partial name="_MockForm" model='@(new[] { "Customer Search", "Discount", "Points To Redeem", "Payment Method", "Reference No" })' />
            </section>
            <partial name="_ReceiptPreviewCard" model="@("POS Receipt Preview")" />
        </div>
    </div>
}
else
{
    if (fields.Any())
    {
        <section class="content-card mb-4">
            <div class="card-title-row">
                <div>
                    <h2>@FormTitle(title, pageKind)</h2>
                    <p>Fields are visible for layout review and are not connected to backend actions.</p>
                </div>
                <button class="btn btn-primary btn-sm" type="button" disabled>Save later</button>
            </div>
            <partial name="_MockForm" model="fields" />
        </section>
    }

    if (pageKind == "report")
    {
        <section class="content-card mb-4">
            <div class="card-title-row">
                <div>
                    <h2>Report Filters</h2>
                    <p>Date range, search, dropdown filters, export, and print controls.</p>
                </div>
                <div class="table-actions">
                    <button class="btn btn-outline-secondary btn-sm" type="button" disabled>Export</button>
                    <button class="btn btn-outline-secondary btn-sm" type="button" disabled>Print</button>
                </div>
            </div>
            <partial name="_MockForm" model='@(new[] { "Date From", "Date To", "Search", "Filter" })' />
        </section>
    }

    if (title == "Open Shift")
    {
        <section class="content-card mb-4">
            <div class="stack-item active-shift">
                <div><strong>Active Shift</strong><span>Cashier Ana Reyes - Morning Shift - Started 6:00 AM</span></div>
                <span class="status-badge">Open</span>
            </div>
        </section>
    }

    if (title == "Daily Beginning Balance")
    {
        <partial name="_MockTable" model='@(Tuple.Create("Product Beginning Balance", new[] { "Product", "Opening Quantity", "Unit", "Remarks" }, RowsFor("Product Beginning Balance", new[] { "Product", "Opening Quantity", "Unit", "Remarks" })))' />
        <partial name="_MockTable" model='@(Tuple.Create("Fuel Beginning Balance", new[] { "Fuel Tank", "Opening Liters", "Fuel Type", "Remarks" }, RowsFor("Fuel Beginning Balance", new[] { "Fuel Tank", "Opening Liters", "Fuel Type", "Remarks" })))' />
    }

    if (title == "Daily Closing Balance" || title == "Cash Drawer Movement")
    {
        <section class="content-card mb-4 formula-card">
            <strong>Formula</strong>
            <span>Expected Cash = Beginning Cash + Total Cash Payments + Cash In - Cash Out</span>
            @if (title == "Daily Closing Balance")
            {
                <span>Cash Difference = Actual Cash - Expected Cash</span>
            }
        </section>
    }

    if (columns.Any())
    {
        <partial name="_MockTable" model='@(Tuple.Create(pageKind == "report" ? "Report Preview" : $"{title} Table", columns, RowsFor(title, columns)))' />
    }

    <div class="empty-preview">
        <span class="empty-preview-icon" aria-hidden="true">i</span>
        <div>
            <strong>Static frontend preview</strong>
            <span>Buttons, filters, and forms are intentionally not wired to save or process data yet.</span>
        </div>
    </div>
}

@functions {
    record Metric(string Label, string Value, string Note);
    record SideItem(string Label, string Value, string Note, bool Warn = false);
    record DataTable(string Title, string[] Columns, string[][] Rows);
    record DashboardData(Metric[] Metrics, string ChartTitle, string SideTitle, SideItem[] SideItems, DataTable[] Tables);

    string Subtitle(string title, string kind) => kind switch
    {
        "dashboard" => "A responsive command center for sales, shifts, inventory alerts, and cash monitoring.",
        "report" => "Filterable report preview with export and print placeholders.",
        "transaction" => "Frontend transaction workspace with mock records and disabled action buttons.",
        _ => $"Static frontend UI for {title.ToLowerInvariant()} with mock data and non-functional controls."
    };

    DashboardData DashboardFor(string title)
    {
        return new(
            new[] {
                new Metric("Total Sales Today", "PHP 186K", "All transactions"),
                new Metric("Sales This Month", "PHP 4.8M", "Month-to-date"),
                new Metric("Fuel Sales Today", "PHP 151K", "Diesel, gasoline, premium"),
                new Metric("Product Sales Today", "PHP 35K", "Store products"),
                new Metric("Total Transactions", "128", "Pump and POS"),
                new Metric("Inventory Value", "PHP 1.2M", "Warehouse and display"),
                new Metric("Fuel Tank Levels", "68%", "Average capacity"),
                new Metric("Current Shift", "Open", "Morning shift"),
                new Metric("Points Redeemed", "3,420", "Rewards activity"),
                new Metric("Low Stock Items", "12", "Needs replenishment"),
                new Metric("Fuel Low Level", "2", "Tank alerts"),
                new Metric("Cash Difference", "PHP 350", "Short/over")
            },
            "Today Sales Chart",
            "Station Snapshot",
            new[] {
                new SideItem("Diesel Tank 1", "Low", "Minimum threshold", true),
                new SideItem("Ana Reyes", "Open", "Morning shift"),
                new SideItem("Premium", "PHP 69.50", "Current price"),
                new SideItem("Engine Oil 1L", "84 sold", "Top product"),
                new SideItem("Daily Closing Balance", "Ready", "End shift")
            },
            new[] {
                new DataTable("Recent Pump Transactions", new[] { "Transaction No", "Pump", "Fuel Type", "Liters", "Net Amount", "Status" }, RowsFor("Recent Pump Transactions", new[] { "Transaction No", "Pump", "Fuel Type", "Liters", "Net Amount", "Status" })),
                new DataTable("Recent POS Transactions", new[] { "Transaction No", "Customer", "Product", "Net Amount", "Status" }, RowsFor("Recent POS Transactions", new[] { "Transaction No", "Customer", "Product", "Net Amount", "Status" })),
                new DataTable("Top Products", new[] { "Product", "Quantity", "Sales", "Status" }, RowsFor("Top Products", new[] { "Product", "Quantity", "Sales", "Status" })),
                new DataTable("Low Stock", new[] { "Product", "Category", "Quantity", "Minimum Stock", "Status" }, RowsFor("Low Stock", new[] { "Product", "Category", "Quantity", "Minimum Stock", "Status" })),
                new DataTable("Fuel Tank Level", new[] { "Tank Code", "Fuel Type", "Capacity Liters", "Current Liters", "Status" }, RowsFor("Fuel Tank Level", new[] { "Tank Code", "Fuel Type", "Capacity Liters", "Current Liters", "Status" })),
                new DataTable("Cashier Shift Summary", new[] { "Shift", "Cashier", "Expected Cash", "Actual Cash", "Cash Difference" }, RowsFor("Cashier Shift Summary", new[] { "Shift", "Cashier", "Expected Cash", "Actual Cash", "Cash Difference" }))
            });
    }

    string[] FormFields(string title) => title switch
    {
        "Users" => new[] { "Name", "Email", "Username", "Password", "Role", "Status" },
        "Customers" => new[] { "Customer Code", "Name", "Contact Number", "Address", "Plate Number", "Status" },
        "Categories" => new[] { "Name", "Status" },
        "Item Units" => new[] { "Name", "Short Name" },
        "Fuel Units" => new[] { "Name", "Short Name" },
        "Fuel Types" => new[] { "Name", "Current Price Per Liter", "Fuel Unit", "Status" },
        "Pump Units" => new[] { "Pump Unit Code", "Pump Unit Name", "Location", "Status" },
        "Pumps" => new[] { "Pump Unit", "Pump Number", "Fuel Type", "Fuel Tank", "Status" },
        "Fuel Tanks" => new[] { "Tank Code", "Tank Name", "Fuel Type", "Capacity Liters", "Current Liters", "Minimum Liters", "Status" },
        "Suppliers" => new[] { "Name", "Contact Person", "Email", "Phone", "Address", "Supplier Type", "Status" },
        "Products" => new[] { "Product Code", "Product Name", "Category", "Unit", "Cost Price", "Selling Price", "Status" },
        "Item Batches" => new[] { "Batch No", "Product", "Supplier", "Location", "Quantity Received", "Cost Price", "Selling Price", "Expiration Date", "Remarks" },
        "Fuel Batches" => new[] { "Batch No", "Fuel Type", "Fuel Tank", "Supplier", "Received Liters", "Cost Per Liter", "Received At", "Remarks" },
        "Stock Receiving" => new[] { "Receiving No", "Supplier", "Received By", "Remarks" },
        "Stock Transfer" => new[] { "Transfer No", "From Location", "To Location", "Transferred By", "Remarks" },
        "Stock Adjustment" => new[] { "Adjustment No", "Product", "Item Batch", "Location", "Adjustment Type", "Quantity", "Reason" },
        "Fuel Delivery" => new[] { "Batch No", "Fuel Type", "Fuel Tank", "Supplier", "Received Liters", "Cost Per Liter", "Received By", "Received At", "Remarks" },
        "Open Shift" => new[] { "Cashier", "Shift", "Opening Cash", "Started At", "Status" },
        "Daily Beginning Balance" => new[] { "Balance Date", "Cashier", "Shift", "Beginning Cash", "Remarks" },
        "Cash Drawer Movement" => new[] { "Cashier Shift", "Movement Type", "Amount", "Reason", "Approved By", "Remarks" },
        "Pump Transaction" => new[] { "Pump Unit", "Pump Number", "Fuel Type", "Fuel Tank", "Liters", "Price Per Liter", "Gross Amount", "Customer Account", "Discount", "Points To Redeem", "Net Amount", "Payment Method" },
        "Transaction Payments" => new[] { "Transaction Type", "Transaction No", "Payment Method", "Amount", "Reference No" },
        "Daily Closing Balance" => new[] { "Balance Date", "Cashier", "Shift", "Beginning Cash", "Total Fuel Sales", "Total Product Sales", "Gross Sales", "Total Discount", "Total Points Redeemed", "Net Sales", "Total Cash Payments", "Total Non-Cash Payments", "Total Cash In", "Total Cash Out", "Expected Cash", "Actual Cash", "Cash Difference", "Remarks" },
        "Cash Turnover" => new[] { "Cashier", "Shift", "Daily Closing Balance", "Expected Cash", "Actual Cash", "Cash Difference", "Received By", "Turnover Status", "Remarks", "Received At" },
        "Void Transactions" => new[] { "Void Reason" },
        "Discounts" => new[] { "Name", "Discount Type", "Value", "Status" },
        "Settings" => new[] { "Gas Station Name", "Address", "Contact Number", "Points Rule", "Receipt Footer Message", "Theme Settings" },
        "Profile" => new[] { "Name", "Email", "Username", "Role", "Status" },
        _ => Array.Empty<string>()
    };

    string[] TableColumns(string title, string kind)
    {
        if (kind == "report" && title != "Points Report")
            return new[] { "Date", "Reference", "Customer", "Cashier", "Fuel/Product", "Amount", "Status" };

        return title switch
        {
            "Users" => new[] { "Name", "Email", "Username", "Role", "Status", "Actions" },
            "Customers" => new[] { "Customer Code", "Name", "Contact Number", "Plate Number", "Points Balance", "Status", "Actions" },
            "Categories" => new[] { "Name", "Status", "Created At", "Actions" },
            "Item Units" or "Fuel Units" => new[] { "Name", "Short Name", "Actions" },
            "Fuel Types" => new[] { "Fuel Name", "Current Price Per Liter", "Unit", "Status", "Actions" },
            "Fuel Price History" => new[] { "Fuel Type", "Old Price", "New Price", "Changed By", "Effective At", "Remarks" },
            "Pump Units" => new[] { "Pump Unit Code", "Pump Unit Name", "Location", "Status", "Actions" },
            "Pumps" => new[] { "Pump Number", "Pump Unit", "Fuel Type", "Fuel Tank", "Status", "Actions" },
            "Fuel Tanks" => new[] { "Tank Code", "Tank Name", "Fuel Type", "Capacity Liters", "Current Liters", "Minimum Liters", "Status", "Actions" },
            "Suppliers" => new[] { "Name", "Contact Person", "Email", "Phone", "Supplier Type", "Status", "Actions" },
            "Products" => new[] { "Product Code", "Name", "Category", "Unit", "Cost Price", "Selling Price", "Status", "Actions" },
            "Warehouse Inventory" or "Display Inventory" => new[] { "Product", "Category", "Unit", "Quantity", "Minimum Stock", "Status" },
            "Item Batches" => new[] { "Batch No", "Product", "Supplier", "Location", "Quantity Received", "Quantity Remaining", "Cost Price", "Selling Price", "Expiration Date", "Status" },
            "Fuel Batches" => new[] { "Batch No", "Fuel Type", "Fuel Tank", "Supplier", "Received Liters", "Remaining Liters", "Cost Per Liter", "Received By", "Received At", "Status" },
            "Stock Receiving" => new[] { "Product", "Quantity", "Cost Price", "Selling Price", "Expiration Date", "Subtotal", "Remove" },
            "Stock Transfer" => new[] { "Product", "Item Batch", "Available Quantity", "Transfer Quantity", "Remove" },
            "Fuel Inventory Movement" => new[] { "Date", "Fuel Tank", "Fuel Batch", "Fuel Type", "Movement Type", "Liters In", "Liters Out", "Balance After", "Remarks" },
            "Item Inventory Movement" => new[] { "Date", "Product", "Item Batch", "Location", "Movement Type", "Quantity In", "Quantity Out", "Balance After", "Remarks" },
            "Low Stock" or "Low Stock Items" => new[] { "Product", "Category", "Location", "Quantity", "Minimum Stock", "Status" },
            "Cash Drawer Movement" => new[] { "Date", "Shift", "Cashier", "Movement Type", "Amount", "Reason", "Approved By", "Remarks" },
            "Transaction Payments" => new[] { "Transaction Type", "Transaction No", "Payment Method", "Amount", "Reference No", "Created At" },
            "Cash Turnover" => new[] { "Date", "Cashier", "Shift", "Expected Cash", "Actual Cash", "Difference", "Received By", "Status", "Received At", "Actions" },
            "Void Transactions" => new[] { "Transaction No", "Type", "Cashier", "Customer", "Net Amount", "Status", "Void Reason", "Voided By", "Voided At" },
            "Points Report" => new[] { "Customer", "Transaction Type", "Source Type", "Points", "Amount Value", "Remarks", "Date" },
            "Activity Logs" => new[] { "Date", "User", "Action", "Description" },
            _ => Array.Empty<string>()
        };
    }

    string[][] RowsFor(string title, string[] columns)
    {
        var names = new[] { "Juan Dela Cruz", "Maria Santos", "Pedro Reyes" };
        var products = new[] { "Engine Oil 1L", "Coolant 1L", "Brake Fluid" };
        return Enumerable.Range(0, 3)
            .Select(i => columns.Select(column => ValueFor(column, i, names, products)).ToArray())
            .ToArray();
    }

    string ValueFor(string column, int i, string[] names, string[] products) => column switch
    {
        "Name" or "Customer" or "Cashier" or "Received By" or "Approved By" or "Voided By" or "Changed By" => names[i],
        "Email" => $"user{i + 1}@gpos.local",
        "Username" => $"user{i + 1}",
        "Role" => i == 0 ? "Admin" : i == 1 ? "Manager" : "Cashier",
        "Customer Code" => $"CUS-00{i + 1}",
        "Contact Number" or "Phone" => $"0917-000-00{i + 1}",
        "Plate Number" => i == 0 ? "ABC-1234" : i == 1 ? "NBS-8841" : "PRD-7712",
        "Points Balance" or "Points" => (1240 - i * 180).ToString("N0"),
        "Product" or "Fuel/Product" => products[i],
        "Category" => i == 0 ? "Oil" : i == 1 ? "Coolant" : "Fluids",
        "Unit" or "Short Name" => i == 0 ? "L" : i == 1 ? "pc" : "bottle",
        "Quantity" or "Quantity Remaining" or "Available Quantity" or "Transfer Quantity" or "Quantity In" => (24 - i * 5).ToString(),
        "Quantity Received" => (60 + i * 10).ToString(),
        "Minimum Stock" => "20",
        "Fuel Name" or "Fuel Type" => i == 0 ? "Diesel" : i == 1 ? "Gasoline" : "Premium",
        "Fuel Tank" or "Tank Name" => i == 0 ? "Diesel Tank 1" : "Gasoline Tank 1",
        "Tank Code" => $"TANK-00{i + 1}",
        "Capacity Liters" => "20,000",
        "Current Liters" or "Balance After" => i == 0 ? "8,400" : "13,200",
        "Minimum Liters" => "4,000",
        "Pump Unit" or "Pump Unit Name" => i == 0 ? "Pump Unit 1" : "Pump Unit 2",
        "Pump Unit Code" => $"PU-00{i + 1}",
        "Pump" or "Pump Number" => $"Pump {i + 1}",
        "Supplier" or "Supplier Type" => i == 0 ? "fuel" : i == 1 ? "item" : "both",
        "Contact Person" => names[(i + 1) % 3],
        "Product Code" => $"PRD-10{i + 1}",
        "Batch No" or "Fuel Batch" or "Item Batch" => i == 0 ? "IB-024" : i == 1 ? "FB-018" : "IB-021",
        "Location" or "From Location" or "To Location" => i == 0 ? "Warehouse" : "Display",
        "Cost Price" or "Cost Per Liter" or "Old Price" => $"PHP {120 + i * 10}.00",
        "Selling Price" or "New Price" or "Price" => $"PHP {180 + i * 25}.00",
        "Current Price Per Liter" => $"PHP {58 + i * 5}.50",
        "Received Liters" or "Remaining Liters" or "Liters" or "Liters In" => (1200 - i * 150).ToString("N0"),
        "Liters Out" => (240 + i * 50).ToString("N0"),
        "Subtotal" or "Amount" or "Net Amount" or "Sales" or "Expected Cash" or "Actual Cash" or "Difference" or "Cash Difference" or "Gross Sales" or "Product Sales" or "Fuel Sales" => $"PHP {(1250 + i * 620):N2}",
        "Date" or "Created At" or "Effective At" or "Expiration Date" or "Received At" or "Voided At" => DateTime.Today.AddDays(-i).ToString("MMM dd, yyyy"),
        "Status" => i == 2 ? "Low" : "Active",
        "Actions" or "Action" or "Remove" => "View",
        "Movement Type" => i == 0 ? "cash_in" : i == 1 ? "cash_out" : "correction",
        "Transaction Type" or "Type" or "Source Type" => i == 0 ? "fuel" : i == 1 ? "pos" : "rewards",
        "Transaction No" or "Reference" or "Reference No" => $"TXN-2026-00{i + 1}",
        "Payment Method" => i == 0 ? "Cash" : i == 1 ? "Card" : "GCash",
        "Shift" => i == 0 ? "Morning" : i == 1 ? "Afternoon" : "Night",
        "Reason" or "Void Reason" or "Remarks" or "Description" => i == 0 ? "Sample note" : "Frontend placeholder",
        _ => i == 0 ? "Sample" : i == 1 ? "Preview" : "Mock"
    };

    string FormTitle(string title, string kind) => kind == "report" ? "Report Criteria" : title switch
    {
        "Stock Receiving" => "Receiving Form",
        "Stock Transfer" => "Transfer Form",
        "Stock Adjustment" => "Adjustment Form",
        "Fuel Delivery" => "Fuel Delivery Form",
        "Void Transactions" => "Void Modal UI",
        _ => $"{title} Form"
    };

    bool IsSelectField(string field) => field.Contains("Status") || field.Contains("Type") || field.Contains("Role") || field.Contains("Unit") || field.Contains("Supplier") || field.Contains("Fuel") || field.Contains("Pump") || field.Contains("Shift") || field.Contains("Payment") || field.Contains("Location") || field.Contains("Discount") || field.Contains("Theme") || field.Contains("Cashier");
    bool IsDateField(string field) => field.Contains("Date") || field.Contains("At");
    bool IsAmountField(string field) => field.Contains("Price") || field.Contains("Cash") || field.Contains("Amount") || field.Contains("Liters") || field.Contains("Quantity") || field.Contains("Value") || field.Contains("Points");

    string[] OptionsFor(string field)
    {
        if (field.Contains("Role")) return new[] { "Admin", "Manager", "Cashier" };
        if (field.Contains("Status")) return new[] { "active", "inactive", "pending", "received", "short", "over", "disputed" };
        if (field.Contains("Adjustment Type")) return new[] { "add", "deduct", "damage", "missing", "expired", "correction" };
        if (field.Contains("Movement Type")) return new[] { "cash_in", "cash_out", "correction" };
        if (field.Contains("Discount Type")) return new[] { "percentage", "fixed", "points_rebate" };
        if (field.Contains("Supplier Type")) return new[] { "fuel", "item", "both" };
        if (field.Contains("Payment")) return new[] { "Cash", "Card", "GCash", "Bank Transfer" };
        if (field.Contains("Fuel")) return new[] { "Diesel", "Gasoline", "Premium" };
        if (field.Contains("Pump")) return new[] { "Pump Unit 1", "Pump Unit 2", "Pump 1", "Pump 2" };
        if (field.Contains("Unit")) return new[] { "Liter / L", "Gallon / gal", "Piece / pc", "Bottle / bottle", "Can / can" };
        if (field.Contains("Location")) return new[] { "Warehouse", "Display", "Front Island", "Back Island" };
        if (field.Contains("Shift")) return new[] { "Morning", "Afternoon", "Night" };
        return new[] { "Option 1", "Option 2", "Option 3" };
    }

    string SampleFor(string field) => field switch
    {
        "Customer Code" => "CUS-001",
        "Product Code" => "PRD-101",
        "Batch No" => "IB-024",
        "Pump Unit Code" => "PU-001",
        "Tank Code" => "TANK-001",
        "Name" => "Juan Dela Cruz",
        "Email" => "admin@gpos.local",
        "Username" => "admin",
        "Password" => "Password placeholder",
        "Plate Number" => "ABC-1234",
        "Gas Station Name" => "Main Station",
        _ => $"Enter {field.ToLowerInvariant()}"
    };
}
