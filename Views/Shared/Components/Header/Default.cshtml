@model gpos.Models.ViewModels.HeaderViewModel

<header class="eg-rb" data-gpos-ribbon aria-label="Primary navigation">
    <div class="eg-rb-top">
        <a class="eg-rb-brand" asp-controller="Dashboard" asp-action="Index" aria-label="GPOS dashboard">
            <span class="eg-rb-brand-mark" aria-hidden="true">G</span>
            <span>GPOS / Gas Station POS</span>
        </a>

        <nav class="eg-rb-tabs" aria-label="Main page groups">
            <a class="eg-rb-tab @(Model.ActivePage == "Transaction.POS" ? "is-active" : "")" asp-controller="Transaction" asp-action="POS">POS</a>
            <div class="dropdown eg-rb-nav-dropdown eg-rb-setup-dropdown">
                <button class="eg-rb-tab dropdown-toggle @(Model.ActiveTab == "Configuration" ? "is-active" : "")" type="button" id="gposSetupDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">Setup</button>
                <div class="dropdown-menu eg-rb-setup-menu" aria-labelledby="gposSetupDropdown">
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Config</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Suppliers.Index" ? "active" : "")" asp-controller="Suppliers" asp-action="Index">Suppliers</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Branch" ? "active" : "")" asp-controller="Configuration" asp-action="Branch">Branch</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Department" ? "active" : "")" asp-controller="Configuration" asp-action="Department">Department</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Members" ? "active" : "")" asp-controller="Configuration" asp-action="Members">Members</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Rebate" ? "active" : "")" asp-controller="Configuration" asp-action="Rebate">Rebate</a>
                            @* Hidden: points ledger is an audit/admin detail page, not a production-ready primary setup menu item yet. *@
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Vouchers.Index" ? "active" : "")" asp-controller="Vouchers" asp-action="Index">Vouchers</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Vat" ? "active" : "")" asp-controller="Configuration" asp-action="Vat">VAT</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Fuel</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Fuels" ? "active" : "")" asp-controller="Configuration" asp-action="Fuels">Fuels</a>
                            @* Hidden: fuel batch page is not part of the production navigation standard yet. *@
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Pumps" ? "active" : "")" asp-controller="Configuration" asp-action="Pumps">Pumps</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Nozzles" ? "active" : "")" asp-controller="Configuration" asp-action="Nozzles">Nozzles</a>
                            @* Hidden: fuel deliveries are handled by Transaction > Stock Receiving > Fuel Receiving. *@
                            @* Hidden: pump meter readings are not part of the production-ready menu yet. *@
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Discount Management</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Discounts" ? "active" : "")" asp-controller="Configuration" asp-action="Discounts">Discounts</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.DiscountRules" ? "active" : "")" asp-controller="Configuration" asp-action="DiscountRules">Rules</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Earning Management</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Earnings" ? "active" : "")" asp-controller="Configuration" asp-action="Earnings">Earnings</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.EarningRules" ? "active" : "")" asp-controller="Configuration" asp-action="EarningRules">Rules</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Access</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Users.Index" ? "active" : "")" asp-controller="Users" asp-action="Index">Users</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Roles.Index" ? "active" : "")" asp-controller="Roles" asp-action="Index">Roles</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Permissions.Index" ? "active" : "")" asp-controller="Permissions" asp-action="Index">Permissions</a>
                            @* Hidden: activity logs are audit/admin detail, not a production-ready primary setup menu item yet. *@
                        </div>
                    </div>
                </div>
            </div>
            <div class="dropdown eg-rb-nav-dropdown">
                <button class="eg-rb-tab dropdown-toggle @(Model.ActiveTab == "Inventory" ? "is-active" : "")" type="button" id="gposInventoryDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">Inventory</button>
                <div class="dropdown-menu eg-rb-setup-menu" aria-labelledby="gposInventoryDropdown">
                    <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.DisplayProducts" ? "active" : "")" asp-controller="Configuration" asp-action="DisplayProducts">Display</a>
                    <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.WarehouseProducts" ? "active" : "")" asp-controller="Configuration" asp-action="WarehouseProducts">Warehouse</a>
                    <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.ProductCategories" ? "active" : "")" asp-controller="Configuration" asp-action="ProductCategories">Categories</a>
                    <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.ProductBatches" ? "active" : "")" asp-controller="Configuration" asp-action="ProductBatches">Product Batches</a>
                    <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.ProductUnits" ? "active" : "")" asp-controller="Configuration" asp-action="ProductUnits">Product Units</a>
                    @* Hidden: low stock settings are backend-backed but not ready as a primary production menu item. *@
                    <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Configuration.Tanks" ? "active" : "")" asp-controller="Configuration" asp-action="Tanks">Tanks</a>
                </div>
            </div>
            <div class="dropdown eg-rb-nav-dropdown">
                <button class="eg-rb-tab dropdown-toggle @(Model.ActiveTab == "Transactions" ? "is-active" : "")" type="button" id="gposTransactionDropdown" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">Transaction</button>
                <div class="dropdown-menu eg-rb-setup-menu" aria-labelledby="gposTransactionDropdown">
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Sales</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.ProductSales" ? "active" : "")" asp-controller="Transaction" asp-action="ProductSales">Product Sales</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.FuelSales" ? "active" : "")" asp-controller="Transaction" asp-action="FuelSales">Fuel Sales</a>
                        </div>
                    </div>
                    @* Hidden: Cash group is UI-only; Daily Cash, Cash In, and Cash Out backend are not implemented yet. *@
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Stock Receiving</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.ProductReceiving" ? "active" : "")" asp-controller="Transaction" asp-action="ProductReceiving">Product Receiving</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.FuelReceiving" ? "active" : "")" asp-controller="Transaction" asp-action="FuelReceiving">Fuel Receiving</a>
                        </div>
                    </div>
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Stock Transfer</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.WarehouseToDisplayProduct" ? "active" : "")" asp-controller="Transaction" asp-action="WarehouseToDisplayProduct">Warehouse to Display Product</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.DisplayToWarehouseProduct" ? "active" : "")" asp-controller="Transaction" asp-action="DisplayToWarehouseProduct">Display to Warehouse Product</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.BranchToBranchProduct" ? "active" : "")" asp-controller="Transaction" asp-action="BranchToBranchProduct">Branch to Branch Product</a>
                        </div>
                    </div>
                    @* Hidden: Returns group is UI-only; product and fuel return backend are not implemented yet. *@
                    @* Hidden: Void group is UI-only; sale, product, and fuel void backend are not implemented yet. *@
                    @* Hidden: Stock Adjustments group is UI-only; display, warehouse, and tank adjustment backend are not implemented yet. *@
                    <div class="dropend eg-rb-dropdown-group">
                        <button class="dropdown-item eg-rb-dropdown-group-toggle" type="button">Price Adjustment</button>
                        <div class="dropdown-menu eg-rb-submenu">
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.ProductPriceAdjustment" ? "active" : "")" asp-controller="Transaction" asp-action="ProductPriceAdjustment">Product Price Adjustment</a>
                            <a class="dropdown-item eg-rb-dropdown-link @(Model.ActivePage == "Transaction.FuelPriceAdjustment" ? "active" : "")" asp-controller="Transaction" asp-action="FuelPriceAdjustment">Fuel Price Adjustment</a>
                        </div>
                    </div>
                </div>
            </div>
            @* Hidden: Reports menu is placeholder/static; report pages should return once data-backed. *@
        </nav>

        <details class="eg-rb-user" id="gposUserDropdown">
            <summary class="eg-rb-userbtn" aria-controls="gposUserMenu">
                <span class="eg-rb-avatar" aria-hidden="true">@Model.UserInitials</span>
                <span class="eg-rb-userlabel">@Model.Username</span>
                <span class="eg-rb-usercaret" aria-hidden="true"></span>
            </summary>
            <div class="eg-rb-usermenu" id="gposUserMenu" role="menu">
                <div class="eg-rb-usercaption">Signed in as</div>
                <div class="eg-rb-username">@Model.Username</div>
                <form asp-controller="SignIn" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button class="eg-rb-usermenu-link eg-rb-usermenu-link--danger" type="submit" role="menuitem">Logout</button>
                </form>
            </div>
        </details>
    </div>
</header>
