@model gpos.Models.ViewModels.HeaderViewModel

<header class="eg-rb" data-gpos-ribbon aria-label="Primary navigation">
    <div class="eg-rb-top">
        <a class="eg-rb-brand" asp-controller="Dashboard" asp-action="Index" aria-label="GPOS dashboard">
            <span class="eg-rb-brand-mark" aria-hidden="true">G</span>
            <span>GPOS / Gas Station POS</span>
        </a>

        <nav class="eg-rb-tabs" aria-label="Main page groups">
            <button class="eg-rb-tab @(Model.ActiveTab == "Configuration" ? "is-active" : "")" type="button" data-gpos-tab="Configuration" aria-controls="gposHeaderPanel-Configuration" aria-selected="@(Model.ActiveTab == "Configuration" ? "true" : "false")">Setup</button>
            <button class="eg-rb-tab @(Model.ActiveTab == "Transactions" ? "is-active" : "")" type="button" data-gpos-tab="Transactions" aria-controls="gposHeaderPanel-Transactions" aria-selected="@(Model.ActiveTab == "Transactions" ? "true" : "false")">Transaction</button>
            <button class="eg-rb-tab @(Model.ActiveTab == "Reports" ? "is-active" : "")" type="button" data-gpos-tab="Reports" aria-controls="gposHeaderPanel-Reports" aria-selected="@(Model.ActiveTab == "Reports" ? "true" : "false")">Reports</button>
        </nav>

        <details class="eg-rb-user" id="gposUserDropdown">
            <summary class="eg-rb-userbtn" aria-controls="gposUserMenu">
                <span class="eg-rb-avatar" aria-hidden="true">@Model.UserInitials</span>
                <span class="eg-rb-userlabel">@Model.Username</span>
                <span class="eg-rb-usercaret" aria-hidden="true"></span>
            </summary>
            <div class="eg-rb-usermenu" id="gposUserMenu" role="menu">
                <div class="eg-rb-usercaption">Signed in as</div>
                <div class="eg-rb-username">@Model.Username</div>
                <form asp-controller="SignIn" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button class="eg-rb-usermenu-link eg-rb-usermenu-link--danger" type="submit" role="menuitem">Logout</button>
                </form>
            </div>
        </details>
    </div>

    <div class="eg-rb-ribbon">
        <section class="eg-rb-pages-panel @(Model.ActiveTab == "Configuration" ? "is-active" : "")" id="gposHeaderPanel-Configuration" data-gpos-panel="Configuration" aria-label="Configuration pages">
            <div class="eg-rb-subgroups">
                <section class="eg-rb-page-card">
                    <div class="eg-rb-subgroup-title">Products</div>
                    <nav class="eg-rb-items" aria-label="Page links">
                        <a class="eg-rb-tile @(Model.ActivePage == "Configuration.DisplayProducts" ? "is-active" : "")" asp-controller="Configuration" asp-action="DisplayProducts"><span>Display</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Configuration.WarehouseProducts" ? "is-active" : "")" asp-controller="Configuration" asp-action="WarehouseProducts"><span>Warehouse</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Configuration.ProductCategories" ? "is-active" : "")" asp-controller="Configuration" asp-action="ProductCategories"><span>Categories</span></a>
                    </nav>
                </section>
                <section class="eg-rb-page-card">
                    <div class="eg-rb-subgroup-title">Fuel</div>
                    <nav class="eg-rb-items" aria-label="Page links">
                        <a class="eg-rb-tile @(Model.ActivePage == "Configuration.Fuels" ? "is-active" : "")" asp-controller="Configuration" asp-action="Fuels"><span>Fuels</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Configuration.FuelTypes" ? "is-active" : "")" asp-controller="Configuration" asp-action="FuelTypes"><span>Types</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Configuration.Pumps" ? "is-active" : "")" asp-controller="Configuration" asp-action="Pumps"><span>Pumps</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Configuration.Tanks" ? "is-active" : "")" asp-controller="Configuration" asp-action="Tanks"><span>Tanks</span></a>
                    </nav>
                </section>
                <section class="eg-rb-page-card">
                    <div class="eg-rb-subgroup-title">Discounts</div>
                    <nav class="eg-rb-items" aria-label="Page links">
                        <a class="eg-rb-tile @(Model.ActivePage == "Configuration.Discounts" ? "is-active" : "")" asp-controller="Configuration" asp-action="Discounts"><span>Discounts</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Configuration.Members" ? "is-active" : "")" asp-controller="Configuration" asp-action="Members"><span>Members</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Configuration.Rebate" ? "is-active" : "")" asp-controller="Configuration" asp-action="Rebate"><span>Rebate</span></a>
                    </nav>
                </section>
                <section class="eg-rb-page-card">
                    <div class="eg-rb-subgroup-title">Access</div>
                    <nav class="eg-rb-items" aria-label="Page links">
                        <a class="eg-rb-tile @(Model.ActivePage == "Roles.Index" ? "is-active" : "")" asp-controller="Roles" asp-action="Index"><span>Roles</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Permissions.Index" ? "is-active" : "")" asp-controller="Permissions" asp-action="Index"><span>Permissions</span></a>
                    </nav>
                </section>
                <section class="eg-rb-page-card">
                    <div class="eg-rb-subgroup-title">Setting</div>
                    <nav class="eg-rb-items" aria-label="Page links">
                        <a class="eg-rb-tile @(Model.ActivePage == "Users.Index" ? "is-active" : "")" asp-controller="Users" asp-action="Index"><span>Users</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Employees.Index" ? "is-active" : "")" asp-controller="Employees" asp-action="Index"><span>Employees</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Suppliers.Index" ? "is-active" : "")" asp-controller="Suppliers" asp-action="Index"><span>Suppliers</span></a>
                    </nav>
                </section>
            </div>
        </section>

        <section class="eg-rb-pages-panel @(Model.ActiveTab == "Transactions" ? "is-active" : "")" id="gposHeaderPanel-Transactions" data-gpos-panel="Transactions" aria-label="Transaction pages">
            <div class="eg-rb-subgroups">
                <section class="eg-rb-page-card">
                    <div class="eg-rb-subgroup-title">Sales</div>
                    <nav class="eg-rb-items" aria-label="Page links">
                        <a class="eg-rb-tile @(Model.ActivePage == "Salesman.POS" ? "is-active" : "")" asp-controller="Salesman" asp-action="POS"><span>POS</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Transactions.FuelTransactions" ? "is-active" : "")" asp-controller="Transactions" asp-action="FuelTransactions"><span>Fuel Transactions</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Transactions.ProductSales" ? "is-active" : "")" asp-controller="Transactions" asp-action="ProductSales"><span>Product Sales</span></a>
                    </nav>
                </section>
                <section class="eg-rb-page-card">
                    <div class="eg-rb-subgroup-title">Shift</div>
                    <nav class="eg-rb-items" aria-label="Page links">
                        <a class="eg-rb-tile @(Model.ActivePage == "Transactions.OpenShift" ? "is-active" : "")" asp-controller="Transactions" asp-action="OpenShift"><span>Open Shift</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Transactions.CloseShift" ? "is-active" : "")" asp-controller="Transactions" asp-action="CloseShift"><span>Close Shift</span></a>
                    </nav>
                </section>
                <section class="eg-rb-page-card">
                    <div class="eg-rb-subgroup-title">Cash</div>
                    <nav class="eg-rb-items" aria-label="Page links">
                        <a class="eg-rb-tile @(Model.ActivePage == "Transactions.CashIn" ? "is-active" : "")" asp-controller="Transactions" asp-action="CashIn"><span>Cash In</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Transactions.CashOut" ? "is-active" : "")" asp-controller="Transactions" asp-action="CashOut"><span>Cash Out</span></a>
                    </nav>
                </section>
            </div>
        </section>

        <section class="eg-rb-pages-panel @(Model.ActiveTab == "Reports" ? "is-active" : "")" id="gposHeaderPanel-Reports" data-gpos-panel="Reports" aria-label="Reports pages">
            <div class="eg-rb-subgroups">
                <section class="eg-rb-page-card">
                    <div class="eg-rb-subgroup-title">Sales Reports</div>
                    <nav class="eg-rb-items" aria-label="Page links">
                        <a class="eg-rb-tile @(Model.ActivePage == "Reports.DailySales" ? "is-active" : "")" asp-controller="Reports" asp-action="DailySales"><span>Daily Sales</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Reports.FuelSales" ? "is-active" : "")" asp-controller="Reports" asp-action="FuelSales"><span>Fuel Sales</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Reports.ProductSales" ? "is-active" : "")" asp-controller="Reports" asp-action="ProductSales"><span>Product Sales</span></a>
                    </nav>
                </section>
                <section class="eg-rb-page-card">
                    <div class="eg-rb-subgroup-title">Shift and Cash Reports</div>
                    <nav class="eg-rb-items" aria-label="Page links">
                        <a class="eg-rb-tile @(Model.ActivePage == "Reports.ShiftReport" ? "is-active" : "")" asp-controller="Reports" asp-action="ShiftReport"><span>Shift Report</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Reports.CashReport" ? "is-active" : "")" asp-controller="Reports" asp-action="CashReport"><span>Cash Report</span></a>
                    </nav>
                </section>
                <section class="eg-rb-page-card">
                    <div class="eg-rb-subgroup-title">Inventory Reports</div>
                    <nav class="eg-rb-items" aria-label="Page links">
                        <a class="eg-rb-tile @(Model.ActivePage == "Reports.InventoryReport" ? "is-active" : "")" asp-controller="Reports" asp-action="InventoryReport"><span>Inventory Report</span></a>
                    </nav>
                </section>
                <section class="eg-rb-page-card">
                    <div class="eg-rb-subgroup-title">Daily Stock</div>
                    <nav class="eg-rb-items" aria-label="Page links">
                        <a class="eg-rb-tile @(Model.ActivePage == "Reports.WarehouseDailyStock" ? "is-active" : "")" asp-controller="Reports" asp-action="WarehouseDailyStock"><span>Warehouse</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Reports.DisplayDailyStock" ? "is-active" : "")" asp-controller="Reports" asp-action="DisplayDailyStock"><span>Display</span></a>
                        <a class="eg-rb-tile @(Model.ActivePage == "Reports.TankDailyStock" ? "is-active" : "")" asp-controller="Reports" asp-action="TankDailyStock"><span>Tank</span></a>
                    </nav>
                </section>
            </div>
        </section>

    </div>
</header>
