@model string

<section class="content-card receipt-preview">
    <h2>@Model</h2>
    <div class="receipt-paper">
        <strong>Gas Station POS</strong>
        <span>Main Station</span>
        <hr />
        <div class="d-flex justify-content-between"><span>Subtotal</span><span>PHP 1,250.00</span></div>
        <div class="d-flex justify-content-between"><span>Discount</span><span>PHP 50.00</span></div>
        <div class="d-flex justify-content-between"><span>Points</span><span>100</span></div>
        <hr />
        <div class="d-flex justify-content-between fw-bold"><span>Net Amount</span><span>PHP 1,200.00</span></div>
    </div>
</section>
