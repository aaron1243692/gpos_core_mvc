                    <th scope="col">Beginning Display Stock</th>
                    <th scope="col">Ending Display Stock</th>
                    <th scope="col">Difference</th>
                    <th scope="col">Status</th>
                    <th scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="text-center text-muted fw-bold" colspan="8">No display stock records yet.</td>
                </tr>
            </tbody>
        </table>
    </div>
</section>

<section class="card content-card mb-4">
    <div class="card-title-row">
        <div>
            <h2>Tank Stock</h2>
            <p>Beginning and ending stock recorded for fuel tanks.</p>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th scope="col">No</th>
                    <th scope="col">Date</th>
                    <th scope="col">Tank</th>
                    <th scope="col">Fuel Type</th>
                    <th scope="col">Beginning Tank Stock</th>
                    <th scope="col">Ending Tank Stock</th>
                    <th scope="col">Difference</th>
                    <th scope="col">Status</th>
                    <th scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="text-center text-muted fw-bold" colspan="9">No tank stock records yet.</td>
                </tr>
            </tbody>
        </table>
    </div>
</section>
