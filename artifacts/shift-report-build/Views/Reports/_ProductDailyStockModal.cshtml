@model gpos.Models.ViewModels.DailyStockPageViewModel

@{
    var isEdit = Model.Form.Id > 0;
}

<div class="modal fade" id="dailyStockModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form asp-action="@Model.SaveAction" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Form.Id" type="hidden" />
                <input asp-for="Form.StockType" type="hidden" />
                <input asp-for="Form.ProductId" type="hidden" data-daily-stock-product-id />
                <input asp-for="Form.BatchId" type="hidden" data-daily-stock-batch-id />
                <input asp-for="Form.WarehouseStockId" type="hidden" data-daily-stock-warehouse-stock-id />
                <input asp-for="Form.DisplayStockId" type="hidden" data-daily-stock-display-stock-id />
                <input name="search" type="hidden" value="@Model.Search" />
                <input name="filterBranchId" type="hidden" value="@Model.BranchId" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5">@(isEdit ? $"Edit {Model.StockType} Daily Stock" : $"Add {Model.StockType} Daily Stock")</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Form.BranchId" class="form-label">Branch</label>
                            <input asp-for="Form.BranchId" type="hidden" id="dailyStockProductBranchId" data-daily-stock-branch />
                            <div class="input-group" data-branch-selector data-branch-hidden="#dailyStockProductBranchId" data-branch-display="#dailyStockProductBranchDisplay" data-branch-empty-text="Select branch">
                                <input class="form-control" id="dailyStockProductBranchDisplay" value="@Model.FormBranchName" placeholder="Select branch" readonly data-daily-stock-branch-display />
                                <button type="button" class="btn btn-outline-secondary branch-select-btn" data-branch-open>
                                    <img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" />
                                </button>
                            </div>
                            <span asp-validation-for="Form.BranchId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.StockDate" class="form-label">Date</label>
                            <input asp-for="Form.StockDate" class="form-control" type="date" />
                            <span asp-validation-for="Form.StockDate" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Product</label>
                            <div class="input-group">
                                <input class="form-control" value="" placeholder="Select product and batch" readonly data-daily-stock-product-display />
                                <button type="button" class="btn btn-outline-secondary" data-daily-stock-open-product-selector>
                                    <img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" />
                                </button>
                            </div>
                            <div class="text-danger small mt-1 d-none" data-daily-stock-product-message>Please select a Branch first.</div>
                            <span asp-validation-for="Form.WarehouseStockId" class="text-danger"></span>
                            <span asp-validation-for="Form.DisplayStockId" class="text-danger"></span>
                            <span asp-validation-for="Form.BatchId" class="text-danger"></span>
                            <span asp-validation-for="Form.ProductId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.Beginning" class="form-label">Beginning</label>
                            <input asp-for="Form.Beginning" class="form-control" type="number" step="0.01" readonly data-daily-stock-beginning />
                            <span asp-validation-for="Form.Beginning" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.Received" class="form-label">Received</label>
                            <input asp-for="Form.Received" class="form-control" type="number" step="0.01" readonly data-daily-stock-received />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.TransferIn" class="form-label">Transfer In</label>
                            <input asp-for="Form.TransferIn" class="form-control" type="number" step="0.01" readonly data-daily-stock-transfer-in />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.TransferOut" class="form-label">Transfer Out</label>
                            <input asp-for="Form.TransferOut" class="form-control" type="number" step="0.01" readonly data-daily-stock-transfer-out />
                        </div>
                        <div class="col-md-6 @(Model.StockType == "Warehouse" ? "d-none" : "")">
                            <label asp-for="Form.Sold" class="form-label">Sold</label>
                            <input asp-for="Form.Sold" class="form-control" type="number" step="0.01" readonly data-daily-stock-sold />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.Adjustment" class="form-label">Adjustment</label>
                            <input asp-for="Form.Adjustment" class="form-control" type="number" step="0.01" readonly data-daily-stock-adjustment />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.Expected" class="form-label">Expected</label>
                            <input asp-for="Form.Expected" class="form-control" type="number" step="0.01" readonly data-daily-stock-expected />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.Ending" class="form-label">Ending</label>
                            <input asp-for="Form.Ending" class="form-control" type="number" min="0" step="0.01" data-daily-stock-ending />
                            <span asp-validation-for="Form.Ending" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.Variance" class="form-label">Variance</label>
                            <input asp-for="Form.Variance" class="form-control" type="number" step="0.01" readonly data-daily-stock-variance />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.Loss" class="form-label">Loss</label>
                            <input asp-for="Form.Loss" class="form-control" type="number" step="0.01" readonly data-daily-stock-loss />
                        </div>
                        <div class="col-md-4"><label class="form-label">Current Official Stock</label><input asp-for="Form.CurrentOfficialQuantity" class="form-control" readonly data-daily-stock-current-official /></div>
                        <div class="col-md-4"><label class="form-label">Reconciliation Adjustment</label><input asp-for="Form.ReconciliationAdjustment" class="form-control" readonly data-daily-stock-reconciliation /></div>
                        <div class="col-md-4"><label class="form-label">New Official Stock</label><input asp-for="Form.NewOfficialQuantity" class="form-control" readonly data-daily-stock-new-official /></div>
                        <div class="col-12">
                            <label asp-for="Form.Remarks" class="form-label">Remarks</label>
                            <textarea asp-for="Form.Remarks" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save Draft</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="dailyStockItemSelectorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Select @Model.StockType Stock</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <input class="form-control" placeholder="Search product or batch" data-daily-stock-selector-search />
                </div>
                <div class="setup-table-scroll">
                    <table class="table app-table table-sm align-middle admin-table mb-0">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>Product</th>
                                <th>Batch No</th>
                                <th>Current Quantity</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody data-daily-stock-selector-body></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
