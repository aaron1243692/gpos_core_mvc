@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Access</li><li class="breadcrumb-item active">Activity Logs</li></ol></nav><h1>Activity Logs</h1><p class="page-subtitle">Review user and system activity history.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="ActivityLogs" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search activity logs" /></form></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Username</th><th>Action</th><th>Module</th><th>Description</th><th>IP Address</th><th>Date</th></tr></thead><tbody>
@if (Model.ActivityLogs.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="8">No activity logs yet.</td></tr> }
@for (var i = 0; i < Model.ActivityLogs.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.ActivityLogs[i].Id</td><td>@Model.ActivityLogs[i].Username</td><td>@Model.ActivityLogs[i].Action</td><td>@Model.ActivityLogs[i].Module</td><td>@Model.ActivityLogs[i].Description</td><td>@Model.ActivityLogs[i].IpAddress</td><td>@Model.ActivityLogs[i].CreatedAt?.ToString("yyyy-MM-dd HH:mm")</td></tr> }
</tbody></table></div></section>
