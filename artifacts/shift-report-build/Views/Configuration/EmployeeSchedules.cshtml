@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Config</li><li class="breadcrumb-item active">Employee Schedules</li></ol></nav><h1>Employee Schedules</h1><p class="page-subtitle">Assign one active schedule to each employee account.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="EmployeeSchedules" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search employee or schedule" /></form></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-normal" /><col class="col-name" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Employee</th><th>Username</th><th>Schedule</th></tr></thead><tbody>
@if (Model.EmployeeScheduleAccounts.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="5">No employees found.</td></tr> }
@for (var i = 0; i < Model.EmployeeScheduleAccounts.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.EmployeeScheduleAccounts[i].Id</td><td>@Model.EmployeeScheduleAccounts[i].FullName</td><td>@Model.EmployeeScheduleAccounts[i].Username</td><td><form asp-action="AssignEmployeeSchedule" method="post">@Html.AntiForgeryToken()<input name="search" type="hidden" value="@Model.Search" /><input name="EmployeeScheduleForm.EmployeeAccountId" type="hidden" value="@Model.EmployeeScheduleAccounts[i].Id" /><select name="EmployeeScheduleForm.ScheduleId" class="form-select form-select-sm" onchange="this.form.submit()"><option value="">No schedule</option>@for (var optionIndex = 0; optionIndex < Model.ScheduleOptions.Count; optionIndex++) { <option value="@Model.ScheduleOptions[optionIndex].Value" selected="@(Model.EmployeeScheduleAccounts[i].ScheduleId?.ToString() == Model.ScheduleOptions[optionIndex].Value ? "selected" : null)">@Model.ScheduleOptions[optionIndex].Text</option> }</select></form></td></tr> }
</tbody></table></div></section>
