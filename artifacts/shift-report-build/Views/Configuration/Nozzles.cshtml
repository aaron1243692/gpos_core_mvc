@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item">Config</li>
                <li class="breadcrumb-item active">Nozzles</li>
            </ol>
        </nav>
        <h1>Nozzles</h1>
        <p class="page-subtitle">Manage dispenser nozzles for meter readings and fuel audit.</p>
    </div>
</div>

<section class="content-card setup-crud-card setup-table-card">
    <div class="table-actions fuel-toolbar">
        <form asp-action="Nozzles" method="get" class="setup-search-form fuel-toolbar-search">
            <input class="form-control" name="search" value="@Model.Search" placeholder="Search nozzles" />
        </form>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#nozzleModal">Add Nozzle</button>
    </div>
    <div class="setup-table-scroll">
        <table class="table app-table table-sm align-middle admin-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-id" />
                <col class="col-name" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-status" />
                <col class="col-action" />
            </colgroup>
            <thead>
                <tr>
                    <th>No</th>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Dispenser</th>
                    <th>Tank</th>
                    <th>Fuel</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Nozzles.Count == 0)
                {
                    <tr><td class="text-center text-muted fw-bold" colspan="8">No nozzles yet.</td></tr>
                }
                @for (var i = 0; i < Model.Nozzles.Count; i++)
                {
                    var nozzleTank = Model.Nozzles[i].Tank ?? Model.Nozzles[i].Pump?.Tank;
                    var nozzleFuel = nozzleTank?.Fuel;
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@Model.Nozzles[i].Id</td>
                        <td>@Model.Nozzles[i].NozzleNo</td>
                        <td>@(Model.Nozzles[i].Pump?.Name ?? "-")</td>
                        <td>@(nozzleTank?.TankNo ?? "-")</td>
                        <td>@(nozzleFuel?.Name ?? "-")</td>
                        <td><span class="badge @(Model.Nozzles[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.Nozzles[i].Status == 1 ? "Active" : "Inactive")</span></td>
                        <td class="col-action">
                            <div class="setup-row-actions">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Nozzles" asp-route-editId="@Model.Nozzles[i].Id" asp-route-search="@Model.Search">Edit</a>
                                @if (Model.Nozzles[i].Status == 1)
                                {
                                    <form asp-action="DeleteNozzle" method="post" data-deactivate-form>
                                        @Html.AntiForgeryToken()
                                        <input name="id" type="hidden" value="@Model.Nozzles[i].Id" />
                                        <input name="search" type="hidden" value="@Model.Search" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">Deactivate</button>
                                    </form>
                                }
                                @if (Model.Nozzles[i].Status != 1)
                                {
                                    <form asp-action="ActivateNozzle" method="post">
                                        @Html.AntiForgeryToken()
                                        <input name="id" type="hidden" value="@Model.Nozzles[i].Id" />
                                        <input name="search" type="hidden" value="@Model.Search" />
                                        <button class="btn btn-sm btn-outline-success" type="submit">Activate</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="nozzleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SaveNozzle" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="NozzleForm.Id" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Nozzle</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="NozzleForm.NozzleNo" class="form-label">Name</label>
                        <input asp-for="NozzleForm.NozzleNo" class="form-control" placeholder="Enter nozzle name" />
                        <span asp-validation-for="NozzleForm.NozzleNo" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NozzleForm.PumpId" class="form-label">Dispenser</label>
                        <select asp-for="NozzleForm.PumpId" class="form-select" data-selected-dispenser="@Model.NozzleForm.PumpId">
                            <option value="0">Select dispenser</option>
                            @for (var i = 0; i < Model.Pumps.Count; i++)
                            {
                                <option value="@Model.Pumps[i].Id">@(Model.Pumps[i].Name)</option>
                            }
                        </select>
                        <span asp-validation-for="NozzleForm.PumpId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NozzleForm.TankId" class="form-label">Tank</label>
                        <select asp-for="NozzleForm.TankId" class="form-select" data-nozzle-tank-source data-selected-tank="@Model.NozzleForm.TankId">
                            <option value="0" data-fuel="">Select tank</option>
                            @for (var i = 0; i < Model.Tanks.Count; i++)
                            {
                                <option value="@Model.Tanks[i].Id" data-fuel="@(Model.Tanks[i].Fuel?.Name ?? string.Empty)">@(Model.Tanks[i].TankNo) - @(Model.Tanks[i].Fuel?.Name ?? "-")</option>
                            }
                        </select>
                        <span asp-validation-for="NozzleForm.TankId" class="text-danger"></span>
                    </div>
                    <div class="row g-2">
                        <div class="col-12 mb-3">
                            <label class="form-label">Fuel</label>
                            <input class="form-control" type="text" data-derived-fuel readonly />
                        </div>
                    </div>
                    <input asp-for="NozzleForm.Status" type="hidden" />
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const modalId = "@Model.ActiveModalId";
            const modalElement = modalId ? document.getElementById(modalId) : null;

            if (modalElement && window.bootstrap) {
                bootstrap.Modal.getOrCreateInstance(modalElement).show();
            }

            const dispenserSelect = document.querySelector("[data-selected-dispenser]");
            const tankSelect = document.querySelector("[data-nozzle-tank-source]");
            const fuelField = document.querySelector("[data-derived-fuel]");

            if (!dispenserSelect || !tankSelect || !fuelField) {
                return;
            }

            const selectedDispenser = dispenserSelect.getAttribute("data-selected-dispenser");
            if (selectedDispenser) {
                dispenserSelect.value = selectedDispenser;
            }

            const selectedTank = tankSelect.getAttribute("data-selected-tank");
            if (selectedTank) {
                tankSelect.value = selectedTank;
            }

            const updateDerivedFields = () => {
                const option = tankSelect.selectedOptions.length > 0 ? tankSelect.selectedOptions[0] : null;
                fuelField.value = option?.getAttribute("data-fuel") || "";
            };

            tankSelect.addEventListener("change", updateDerivedFields);
            updateDerivedFields();
        });
    </script>
}
