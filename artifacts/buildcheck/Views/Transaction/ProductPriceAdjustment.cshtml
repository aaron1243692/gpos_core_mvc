@model gpos.Models.ViewModels.SetupModulesPageViewModel
<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Transaction</li><li class="breadcrumb-item">Price Adjustment</li><li class="breadcrumb-item active">Product Price Adjustment</li></ol></nav><h1>Product Price Adjustment</h1><p class="page-subtitle">Product price history and adjustments.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions"><form asp-action="ProductPriceAdjustment" method="get" class="row g-2 flex-grow-1"><div class="col-md-3"><input class="form-control" name="search" value="@Model.Search" placeholder="Search product prices"/></div><div class="col-md-3"><select class="form-select" name="filterBranchId" asp-items="Model.BranchOptions"></select></div><div class="col-md-2"><input class="form-control" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" type="date"/></div><div class="col-md-2"><input class="form-control" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" type="date"/></div><div class="col-md-auto"><button class="btn btn-primary" type="submit">Search</button> <a class="btn btn-outline-secondary" asp-action="ProductPriceAdjustment">Clear</a></div></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#productPriceAdjustmentModal">Add Price Adjustment</button></div>
<div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><thead><tr><th>No</th><th>Created Date</th><th>Branch</th><th>Product</th><th>Batch</th><th>Old Price</th><th>New Price</th><th>Effective Date</th><th>Reason</th><th>Changed By</th><th>Status</th><th>Action</th></tr></thead><tbody>@if(Model.ProductPriceHistory.Count==0){<tr><td colspan="12" class="text-center text-muted fw-bold">No product price adjustments found.</td></tr>}@for(var i=0;i<Model.ProductPriceHistory.Count;i++){var item=Model.ProductPriceHistory[i];var user=item.CreatedBy.HasValue&&Model.ProductPriceHistoryCreatedBy.TryGetValue(item.CreatedBy.Value,out var n)?n:"-";<tr><td>@(i+1)</td><td>@item.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</td><td>@(item.Branch?.Name??"-")</td><td>@item.Product?.Name</td><td>@item.Batch?.BatchNo</td><td>@item.OldPrice.ToString("N2")</td><td>@item.NewPrice.ToString("N2")</td><td>@item.EffectiveDate.ToString("yyyy-MM-dd HH:mm")</td><td>@(item.Reason??"-")</td><td>@user</td><td><span class="badge @(item.Status==1?"text-bg-success":"text-bg-secondary")">@(item.Status==1?"Active":"Inactive")</span></td><td><button class="btn btn-sm btn-outline-primary" type="button">View</button></td></tr>}</tbody></table></div></section>
<div class="modal fade" id="productPriceAdjustmentModal" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveProductPriceAdjustment" method="post">@Html.AntiForgeryToken()<input name="search" type="hidden" value="@Model.Search"/><input name="filterBranchId" type="hidden" value="@Model.BranchId"/><input name="dateFrom" type="hidden" value="@Model.DateFrom?.ToString("yyyy-MM-dd")"/><input name="dateTo" type="hidden" value="@Model.DateTo?.ToString("yyyy-MM-dd")"/><div class="modal-header"><h2 class="modal-title fs-5">Product Price Adjustment</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="mb-3"><label class="form-label">Branch</label><input asp-for="ProductPriceHistoryForm.BranchId" id="productAdjustmentBranchId" type="hidden"/><div class="input-group"><input asp-for="ProductPriceHistoryForm.BranchName" id="productAdjustmentBranchName" class="form-control" readonly/><button id="productAdjustmentBranchOpen" class="btn btn-outline-secondary" type="button"><img src="/icons/search.png" alt="Search" width="16" height="16"/></button></div><span asp-validation-for="ProductPriceHistoryForm.BranchId" class="text-danger"></span></div>
<div class="mb-3"><label class="form-label">Product/Batch</label><input asp-for="ProductPriceHistoryForm.ProductId" id="productAdjustmentProductId" type="hidden"/><input asp-for="ProductPriceHistoryForm.BatchId" id="productAdjustmentBatchId" type="hidden"/><div class="input-group"><input asp-for="ProductPriceHistoryForm.ProductBatchDisplay" id="productAdjustmentProductName" class="form-control" readonly/><button id="productAdjustmentProductOpen" class="btn btn-outline-secondary" type="button"><img src="/icons/search.png" alt="Search" width="16" height="16"/></button></div><span asp-validation-for="ProductPriceHistoryForm.ProductId" class="text-danger"></span><span asp-validation-for="ProductPriceHistoryForm.BatchId" class="text-danger"></span></div>
<div class="mb-3"><label class="form-label">Current Selling Price</label><input asp-for="ProductPriceHistoryForm.CurrentPrice" id="productAdjustmentCurrentPrice" class="form-control" readonly/></div><div class="mb-3"><label class="form-label">New Selling Price</label><input asp-for="ProductPriceHistoryForm.NewPrice" class="form-control" type="number" step="0.01" min="0"/></div><div class="mb-3"><label class="form-label">Effective Date/Time</label><input asp-for="ProductPriceHistoryForm.EffectiveDate" class="form-control" type="datetime-local"/></div><div class="mb-3"><label class="form-label">Reason</label><input asp-for="ProductPriceHistoryForm.Reason" class="form-control"/></div><div class="mb-3"><label class="form-label">Remarks</label><textarea asp-for="ProductPriceHistoryForm.Remarks" class="form-control"></textarea></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
<partial name="_PriceAdjustmentSelectors"/>
@section Scripts{<partial name="_ValidationScriptsPartial"/><script>window.priceAdjustmentSelectorConfig={kind:'product',parentModal:'productPriceAdjustmentModal',branch:{id:'productAdjustmentBranchId',name:'productAdjustmentBranchName',open:'productAdjustmentBranchOpen'},item:{id:'productAdjustmentProductId',batchId:'productAdjustmentBatchId',name:'productAdjustmentProductName',open:'productAdjustmentProductOpen',price:'productAdjustmentCurrentPrice'}};</script><script src="~/js/price-adjustment-selectors.js" asp-append-version="true"></script>@if(!string.IsNullOrWhiteSpace(Model.ActiveModalId)){<script>document.addEventListener('DOMContentLoaded',()=>bootstrap.Modal.getOrCreateInstance(document.getElementById('@Model.ActiveModalId')).show());</script>}}
