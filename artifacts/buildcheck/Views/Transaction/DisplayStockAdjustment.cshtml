@{
    ViewData["Title"] = "Display Stock Adjustment";
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Transaction</li>
                <li class="breadcrumb-item active" aria-current="page">Display Stock Adjustment</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="mb-0">Display Stock Adjustment</h1>
            <span class="badge bg-warning text-dark">UI Preview Only</span>
            <span class="badge bg-secondary">Backend not connected yet</span>
        </div>
        <p class="page-subtitle text-muted mt-2">Create manual inventory quantity adjustments for retail shelf display stock.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#displayAdjustmentModal">Add Adjustment</button>
    </div>
</div>

<section class="transaction-ui-page">
    <div class="content-card mb-3">
        <form class="row g-2 align-items-center" onsubmit="return false;">
            <div class="col-md-3">
                <input class="form-control" type="search" placeholder="Search adjustments..." id="dispSearch" />
            </div>
            <div class="col-md-2">
                <select class="form-select" id="dispBranch">
                    <option value="">All Branches</option>
                    <option>Main Branch</option>
                    <option>Branch 2</option>
                </select>
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="dispDateFrom" />
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="dispDateTo" />
            </div>
            <div class="col-md-1">
                <select class="form-select" id="dispStatus">
                    <option value="">All Statuses</option>
                    <option>Completed</option>
                    <option>Pending</option>
                    <option>Cancelled</option>
                </select>
            </div>
            <div class="col-md-auto d-flex gap-1">
                <button class="btn btn-primary" type="button">Search</button>
                <button class="btn btn-outline-secondary" type="button">Clear</button>
            </div>
        </form>
    </div>

    <div class="content-card transaction-ui-card">
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="dispTable">
                <thead>
                    <tr>
                        <th class="text-nowrap">No</th>
                        <th class="text-nowrap">Date</th>
                        <th class="text-nowrap">Branch</th>
                        <th class="text-nowrap">Product</th>
                        <th class="text-nowrap">Batch</th>
                        <th class="text-nowrap">Before Qty</th>
                        <th class="text-nowrap">Adjustment</th>
                        <th class="text-nowrap">After Qty</th>
                        <th class="text-nowrap">Reason</th>
                        <th class="text-nowrap">Adjusted By</th>
                        <th class="text-nowrap">Status</th>
                        <th class="text-nowrap">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td class="text-nowrap">2026-07-09</td>
                        <td>Main Branch</td>
                        <td>Coolant 1L</td>
                        <td>B-CLT-002</td>
                        <td>50.00</td>
                        <td>+1.00</td>
                        <td>51.00</td>
                        <td>Found untracked item during counter count</td>
                        <td>admin</td>
                        <td><span class="badge bg-success text-nowrap">Completed</span></td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#dispViewModal">View</button>
                        </td>
                    </tr>
                    <tr class="d-none">
                        <td class="text-center text-muted fw-bold" colspan="12">No records found.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- Add Modal -->
<div class="modal fade" id="displayAdjustmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Add Display Stock Adjustment</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Branch</label>
                        <select class="form-select">
                            <option>Main Branch</option>
                            <option>Branch 2</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Product/Batch</label>
                        <div class="input-group">
                            <input class="form-control" type="text" placeholder="Search/select product batch..." readonly />
                            <button class="btn btn-outline-secondary" type="button" onclick="alert('Selector backend not connected yet.');"><img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" /></button>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Current Qty (Readonly)</label>
                        <input class="form-control" value="0.00" readonly />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Adjustment Type</label>
                        <select class="form-select">
                            <option>Add (Plus)</option>
                            <option>Deduct (Minus)</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Adjustment Qty</label>
                        <input class="form-control" type="number" step="0.01" value="0.00" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">New Qty (Readonly)</label>
                        <input class="form-control" value="0.00" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Reason</label>
                        <select class="form-select">
                            <option>Physical count correction</option>
                            <option>Damaged shelf stock</option>
                            <option>Lost / Stolen stock</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Remarks</label>
                        <textarea class="form-control" rows="3" placeholder="Enter remarks..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" type="button" onclick="alert('Backend not connected yet.');" data-bs-dismiss="modal">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- View Modal -->
<div class="modal fade" id="dispViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Adjustment Details</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>This is a UI preview. Display adjustment backend is not connected yet.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
