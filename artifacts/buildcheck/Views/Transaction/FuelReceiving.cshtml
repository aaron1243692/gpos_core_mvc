@model gpos.Models.ViewModels.FuelReceivingPageViewModel

<section class="transaction-ui-page product-receiving-page">
    <div class="content-card transaction-ui-card product-receiving-container">
        <div class="card-title-row page-header">
            <div>
                <h1>Fuel Receiving</h1>
                <p>Receive fuel deliveries into tanks.</p>
            </div>
            <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#addFuelReceivingModal">Add Receiving</button>
        </div>

        <div class="product-receiving-body">
            @if (TempData["ReceivingMessage"] is not null)
            {
                <div class="alert alert-warning">@TempData["ReceivingMessage"]</div>
            }

            <form asp-action="FuelReceiving" method="get" class="transaction-ui-toolbar product-receiving-toolbar fuel-receiving-toolbar toolbar">
                <input class="form-control transaction-ui-search" name="search" value="@Model.Search" type="search" placeholder="Search receiving, supplier, fuel, tank, branch, status..." />
                <select class="form-select" name="filterBranchId" style="max-width: 220px;">
                    @for (var i = 0; i < Model.BranchOptions.Count; i += 1)
                    {
                        var option = Model.BranchOptions[i];
                        var selected = option.Value == (Model.BranchId?.ToString() ?? string.Empty);
                        if (selected)
                        {
                            <option value="@option.Value" selected>@option.Text</option>
                        }
                        else
                        {
                            <option value="@option.Value">@option.Text</option>
                        }
                    }
                </select>
                <button class="btn btn-outline-primary" type="submit">Search</button>
                <a class="btn btn-outline-secondary" asp-action="FuelReceiving">Clear</a>
            </form>

            <div class="table-responsive transaction-ui-table-wrap product-receiving-table-wrapper">
            <table class="table app-table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Receiving No</th>
                        <th>Branch</th>
                        <th>Supplier</th>
                        <th>Fuel</th>
                        <th>Tank</th>
                        <th>Liters</th>
                        <th>Cost/Liter</th>
                        <th>Tank Liters Before</th>
                        <th>Tank Liters After</th>
                        <th>Received By</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Receivings.Count == 0)
                    {
                        <tr><td class="text-center text-muted fw-bold" colspan="14">No fuel receiving records found.</td></tr>
                    }
                    @for (var i = 0; i < Model.Receivings.Count; i += 1)
                    {
                        <tr>
                            <td class="text-nowrap">@(i + 1)</td>
                            <td class="text-nowrap">@Model.Receivings[i].ReceivingNo</td>
                            <td class="text-nowrap">@Model.Receivings[i].BranchName</td>
                            <td>@Model.Receivings[i].Supplier</td>
                            <td>@Model.Receivings[i].Fuel</td>
                            <td>@Model.Receivings[i].Tank</td>
                            <td class="text-nowrap">@Model.Receivings[i].Liters.ToString("N2")</td>
                            <td class="text-nowrap">₱@Model.Receivings[i].CostPerLiter.ToString("N2")</td>
                            <td class="text-nowrap">@(Model.Receivings[i].TankLitersBefore.HasValue ? Model.Receivings[i].TankLitersBefore!.Value.ToString("N2") : "-")</td>
                            <td class="text-nowrap">@(Model.Receivings[i].TankLitersAfter.HasValue ? Model.Receivings[i].TankLitersAfter!.Value.ToString("N2") : "-")</td>
                            <td class="text-nowrap">@Model.Receivings[i].ReceivedBy</td>
                            <td class="text-nowrap">@Model.Receivings[i].Date.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><span class="badge @(Model.Receivings[i].Status == 1 ? "text-bg-success" : Model.Receivings[i].Status == 2 ? "text-bg-secondary" : "text-bg-warning")">@(Model.Receivings[i].Status == 1 ? "Completed" : Model.Receivings[i].Status == 2 ? "Cancelled" : "Pending")</span></td>
                            <td class="text-nowrap">
                                <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#fuelReceivingViewModal_@Model.Receivings[i].Id">View</button>
                                @if (Model.Receivings[i].Status == 0)
                                {
                                    <form asp-action="CompleteFuelReceiving" method="post" class="d-inline" onsubmit="return confirm('Complete this fuel receiving?');">
                                        @Html.AntiForgeryToken()
                                        <input name="id" type="hidden" value="@Model.Receivings[i].Id" />
                                        <input name="search" type="hidden" value="@Model.Search" />
                                        <input name="filterBranchId" type="hidden" value="@Model.BranchId" />
                                        <button class="btn btn-sm btn-outline-success" type="submit">Complete</button>
                                    </form>
                                    <form asp-action="CancelFuelReceiving" method="post" class="d-inline" onsubmit="return confirm('Cancel this pending fuel receiving?');">
                                        @Html.AntiForgeryToken()
                                        <input name="id" type="hidden" value="@Model.Receivings[i].Id" />
                                        <input name="search" type="hidden" value="@Model.Search" />
                                        <input name="filterBranchId" type="hidden" value="@Model.BranchId" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">Cancel</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="addFuelReceivingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form asp-action="SaveFuelReceiving" method="post" id="fuelReceivingForm" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()
                <input name="search" type="hidden" value="@Model.Search" />
                <input name="filterBranchId" type="hidden" value="@Model.BranchId" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Add Fuel Receiving</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div asp-validation-summary="All" class="text-danger"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Form.BranchId" class="form-label">Branch</label>
                            <input asp-for="Form.BranchId" type="hidden" id="fuelReceivingBranchId" />
                            <div class="input-group" data-branch-selector data-branch-hidden="#fuelReceivingBranchId" data-branch-display="#fuelReceivingBranchDisplay" data-branch-empty-text="Select branch">
                                <input class="form-control" id="fuelReceivingBranchDisplay" value="@Model.FormBranchName" placeholder="Select branch" readonly />
                                <button type="button" class="btn btn-outline-secondary branch-select-btn">
                                    <img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" />
                                </button>
                            </div>
                            <span asp-validation-for="Form.BranchId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.TankId" class="form-label">Tank</label>
                            <input asp-for="Form.TankId" type="hidden" id="fuelReceivingTankId" data-fuel-receiving-tank />
                            <input asp-for="Form.FuelId" type="hidden" id="fuelReceivingFuelId" />
                            <div class="input-group">
                                <input class="form-control" id="fuelReceivingTankDisplay" value="@Model.FormTankName" placeholder="Select tank" readonly />
                                <button type="button" class="btn btn-outline-secondary fuel-receiving-tank-select-btn">
                                    <img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" />
                                </button>
                            </div>
                            <span asp-validation-for="Form.TankId" class="text-danger"></span>
                            <span asp-validation-for="Form.FuelId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="fuelReceivingFuelDisplay">Fuel</label>
                            <input class="form-control" id="fuelReceivingFuelDisplay" value="@Model.FormFuelName" placeholder="Fuel from selected tank" readonly />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Form.SupplierId" class="form-label">Supplier</label>
                            <input asp-for="Form.SupplierId" type="hidden" id="fuelReceivingSupplierId" />
                            <div class="input-group">
                                <input class="form-control" id="fuelReceivingSupplierDisplay" value="@Model.FormSupplierName" placeholder="Select supplier" readonly />
                                <button type="button" class="btn btn-outline-secondary fuel-receiving-supplier-select-btn">
                                    <img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" />
                                </button>
                            </div>
                            <span asp-validation-for="Form.SupplierId" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Form.Liters" class="form-label">Liters</label>
                            <input asp-for="Form.Liters" class="form-control" type="number" step="0.01" min="0.01" required />
                            <span asp-validation-for="Form.Liters" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Form.CostPerLiter" class="form-label">Cost/Liter</label>
                            <input asp-for="Form.CostPerLiter" class="form-control" type="number" step="0.01" min="0" required />
                            <span asp-validation-for="Form.CostPerLiter" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Form.ReceivedDate" class="form-label">Date</label>
                            <input asp-for="Form.ReceivedDate" class="form-control" type="date" required />
                            <span asp-validation-for="Form.ReceivedDate" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Form.Remarks" class="form-label">Remarks</label>
                            <textarea asp-for="Form.Remarks" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save Receiving</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="fuelReceivingTankSelectorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Select Tank</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input class="form-control" id="fuelReceivingTankSearchInput" type="search" placeholder="Search tank, fuel, or branch" />
                    <button class="btn btn-outline-primary" id="fuelReceivingTankSearchButton" type="button">Search</button>
                </div>
                <div class="table-responsive">
                    <table class="table app-table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>Branch</th>
                                <th>Tank</th>
                                <th>Fuel</th>
                                <th>Current Liters</th>
                                <th>Capacity</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="fuelReceivingTankSelectorResults">
                            <tr><td class="text-center text-muted fw-bold" colspan="7">Search for a tank.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="fuelReceivingSupplierSelectorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Select Supplier</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="input-group mb-3">
                    <input class="form-control" id="fuelReceivingSupplierSearchInput" type="search" placeholder="Search supplier, contact, address, or status" />
                    <button class="btn btn-outline-primary" id="fuelReceivingSupplierSearchButton" type="button">Search</button>
                </div>
                <div class="table-responsive">
                    <table class="table app-table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>Supplier</th>
                                <th>Contact</th>
                                <th>Address</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="fuelReceivingSupplierSelectorResults">
                            <tr><td class="text-center text-muted fw-bold" colspan="6">Search for a supplier.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@for (var i = 0; i < Model.Receivings.Count; i += 1)
{
    <div class="modal fade" id="fuelReceivingViewModal_@Model.Receivings[i].Id" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Fuel Receiving Details</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Receiving No</dt><dd class="col-sm-7">@Model.Receivings[i].ReceivingNo</dd>
                        <dt class="col-sm-5">Supplier</dt><dd class="col-sm-7">@Model.Receivings[i].Supplier</dd>
                        <dt class="col-sm-5">Fuel</dt><dd class="col-sm-7">@Model.Receivings[i].Fuel</dd>
                        <dt class="col-sm-5">Tank</dt><dd class="col-sm-7">@Model.Receivings[i].Tank</dd>
                        <dt class="col-sm-5">Remarks</dt><dd class="col-sm-7">@Model.Receivings[i].Remarks</dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const branchInput = document.getElementById("fuelReceivingBranchId");
        const branchDisplay = document.getElementById("fuelReceivingBranchDisplay");
        const tankInput = document.getElementById("fuelReceivingTankId");
        const tankDisplay = document.getElementById("fuelReceivingTankDisplay");
        const fuelInput = document.getElementById("fuelReceivingFuelId");
        const fuelDisplay = document.getElementById("fuelReceivingFuelDisplay");
        const tankSearchInput = document.getElementById("fuelReceivingTankSearchInput");
        const tankSearchButton = document.getElementById("fuelReceivingTankSearchButton");
        const tankResults = document.getElementById("fuelReceivingTankSelectorResults");
        const tankSelectorModal = document.getElementById("fuelReceivingTankSelectorModal");
        const addFuelReceivingModal = document.getElementById("addFuelReceivingModal");
        const fuelReceivingForm = document.getElementById("fuelReceivingForm");
        const supplierInput = document.getElementById("fuelReceivingSupplierId");
        const supplierDisplay = document.getElementById("fuelReceivingSupplierDisplay");
        const supplierSearchInput = document.getElementById("fuelReceivingSupplierSearchInput");
        const supplierSearchButton = document.getElementById("fuelReceivingSupplierSearchButton");
        const supplierResults = document.getElementById("fuelReceivingSupplierSelectorResults");
        const supplierSelectorModal = document.getElementById("fuelReceivingSupplierSelectorModal");
        const litersInput = document.getElementById("Form_Liters");
        const costInput = document.getElementById("Form_CostPerLiter");
        const receivedDateInput = document.getElementById("Form_ReceivedDate");
        const shouldOpenFuelReceivingModal = @((ViewData["OpenFuelReceivingModal"] is true).ToString().ToLowerInvariant());

        const escapeHtml = value => String(value ?? "")
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#039;");

        function restoreParentModalState() {
            if (addFuelReceivingModal?.classList.contains("show")) {
                document.body.classList.add("modal-open");
            }
        }

        function showSelectorOnly(modalElement) {
            if (modalElement && window.bootstrap) {
                bootstrap.Modal.getOrCreateInstance(modalElement, {
                    backdrop: true,
                    keyboard: true
                }).show();
                restoreParentModalState();
            }
        }

        function closeSelectorOnly(modalElement) {
            if (modalElement && window.bootstrap) {
                const modal = bootstrap.Modal.getInstance(modalElement) || bootstrap.Modal.getOrCreateInstance(modalElement);
                modal.hide();
                setTimeout(restoreParentModalState, 150);
            }
        }

        function validationSpan(fieldName) {
            return fuelReceivingForm?.querySelector(`[data-valmsg-for="${fieldName}"]`);
        }

        function setValidationError(input, fieldName, message) {
            if (input) {
                input.classList.add("is-invalid");
                input.setCustomValidity(message);
            }

            const span = validationSpan(fieldName);
            if (span) {
                span.textContent = message;
                span.classList.remove("field-validation-valid");
                span.classList.add("field-validation-error");
            }
        }

        function clearValidationError(input, fieldName) {
            if (input) {
                input.classList.remove("is-invalid");
                input.setCustomValidity("");
            }

            const span = validationSpan(fieldName);
            if (span) {
                span.textContent = "";
                span.classList.remove("field-validation-error");
                span.classList.add("field-validation-valid");
            }
        }

        function validateRequiredNumber(input, fieldName, label, minimumValue, minimumMessage) {
            const value = input?.value?.trim() ?? "";
            if (!value) {
                setValidationError(input, fieldName, `${label} is required.`);
                return false;
            }

            const numberValue = Number(value);
            if (!Number.isFinite(numberValue) || numberValue < minimumValue) {
                setValidationError(input, fieldName, minimumMessage);
                return false;
            }

            clearValidationError(input, fieldName);
            return true;
        }

        function validateFuelReceivingForm() {
            let isValid = true;
            let firstInvalid = null;

            const markInvalid = input => {
                isValid = false;
                firstInvalid ??= input;
            };

            if (!branchInput?.value || Number(branchInput.value) <= 0) {
                setValidationError(branchDisplay, "Form.BranchId", "Branch is required.");
                markInvalid(branchDisplay);
            } else {
                clearValidationError(branchDisplay, "Form.BranchId");
            }

            if (!tankInput?.value || Number(tankInput.value) <= 0) {
                setValidationError(tankDisplay, "Form.TankId", "Tank is required.");
                markInvalid(tankDisplay);
            } else {
                clearValidationError(tankDisplay, "Form.TankId");
            }

            if (!fuelInput?.value || Number(fuelInput.value) <= 0) {
                setValidationError(fuelDisplay, "Form.FuelId", "Fuel is required from selected tank.");
                markInvalid(fuelDisplay);
            } else {
                clearValidationError(fuelDisplay, "Form.FuelId");
            }

            if (!supplierInput?.value || Number(supplierInput.value) <= 0) {
                setValidationError(supplierDisplay, "Form.SupplierId", "Supplier is required.");
                markInvalid(supplierDisplay);
            } else {
                clearValidationError(supplierDisplay, "Form.SupplierId");
            }

            if (!validateRequiredNumber(litersInput, "Form.Liters", "Liters", 0.01, "Liters must be greater than 0.")) {
                markInvalid(litersInput);
            }

            if (!validateRequiredNumber(costInput, "Form.CostPerLiter", "Cost/Liter", 0, "Cost/Liter must be greater than or equal to 0.")) {
                markInvalid(costInput);
            }

            if (!receivedDateInput?.value) {
                setValidationError(receivedDateInput, "Form.ReceivedDate", "Date is required.");
                markInvalid(receivedDateInput);
            } else {
                clearValidationError(receivedDateInput, "Form.ReceivedDate");
            }

            if (!isValid) {
                fuelReceivingForm?.classList.add("was-validated");
                firstInvalid?.focus();
            }

            return isValid;
        }

        function hasSelectedBranch() {
            return !!branchInput?.value && Number(branchInput.value) > 0;
        }

        function clearSelectedTank() {
            if (tankInput) tankInput.value = "";
            if (tankDisplay) tankDisplay.value = "";
            if (fuelInput) fuelInput.value = "";
            if (fuelDisplay) fuelDisplay.value = "";
            clearValidationError(tankDisplay, "Form.TankId");
            clearValidationError(fuelDisplay, "Form.FuelId");
            if (tankResults) {
                tankResults.innerHTML = '<tr><td class="text-center text-muted fw-bold" colspan="7">Select a branch, then search for a tank.</td></tr>';
            }
        }

        function requireBranchBeforeTankSelector() {
            if (hasSelectedBranch()) {
                clearValidationError(branchDisplay, "Form.BranchId");
                clearValidationError(tankDisplay, "Form.TankId");
                return true;
            }

            setValidationError(tankDisplay, "Form.TankId", "Please select a Branch first.");
            fuelReceivingForm?.classList.add("was-validated");
            branchDisplay?.focus();
            return false;
        }

        function renderTankRows(tanks) {
            if (!tankResults) return;
            tankResults.innerHTML = "";
            if (!tanks.length) {
                tankResults.innerHTML = '<tr><td class="text-center text-muted fw-bold" colspan="7">No tanks found.</td></tr>';
                return;
            }

            tanks.forEach((tank, index) => {
                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td>${index + 1}</td>
                    <td>${escapeHtml(tank.branchName || "-")}</td>
                    <td>${escapeHtml(tank.tankName || "-")}</td>
                    <td>${escapeHtml(tank.fuelName || "-")}</td>
                    <td>${Number(tank.currentLiters || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                    <td>${Number(tank.capacity || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                    <td><button class="btn btn-sm btn-outline-primary" type="button">Select</button></td>
                `;
                tr.querySelector("button").addEventListener("click", event => {
                    event.preventDefault();
                    event.stopPropagation();
                    if (tankInput) tankInput.value = tank.tankId || "";
                    if (tankDisplay) tankDisplay.value = tank.tankName || "";
                    if (fuelInput) fuelInput.value = tank.fuelId || "";
                    if (fuelDisplay) fuelDisplay.value = tank.fuelName || "";
                    if (branchInput) branchInput.value = tank.branchId || "";
                    if (branchDisplay) branchDisplay.value = tank.branchName || "";

                    tankInput?.dispatchEvent(new Event("change", { bubbles: true }));
                    fuelInput?.dispatchEvent(new Event("change", { bubbles: true }));

                    closeSelectorOnly(tankSelectorModal);
                });
                tankResults.appendChild(tr);
            });
        }

        async function searchTanks(event) {
            event?.preventDefault();
            event?.stopPropagation();
            if (!tankResults) return;
            if (!requireBranchBeforeTankSelector()) return;
            tankResults.innerHTML = '<tr><td class="text-center text-muted fw-bold" colspan="7">Loading tanks...</td></tr>';
            const query = encodeURIComponent(tankSearchInput?.value || "");
            const branch = encodeURIComponent(branchInput?.value || "");
            const response = await fetch(`/Transaction/SearchFuelReceivingTanks?search=${query}&branchId=${branch}`, {
                headers: { "Accept": "application/json" }
            });
            if (!response.ok) {
                tankResults.innerHTML = '<tr><td class="text-center text-danger fw-bold" colspan="7">Unable to load tanks.</td></tr>';
                return;
            }

            renderTankRows(await response.json());
        }

        function renderSupplierRows(suppliers) {
            if (!supplierResults) return;
            supplierResults.innerHTML = "";
            if (!suppliers.length) {
                supplierResults.innerHTML = '<tr><td class="text-center text-muted fw-bold" colspan="6">No suppliers found.</td></tr>';
                return;
            }

            suppliers.forEach((supplier, index) => {
                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td>${index + 1}</td>
                    <td>${escapeHtml(supplier.supplierName || "-")}</td>
                    <td>${escapeHtml(supplier.contact || "-")}</td>
                    <td>${escapeHtml(supplier.address || "-")}</td>
                    <td>${escapeHtml(supplier.status || "-")}</td>
                    <td><button class="btn btn-sm btn-outline-primary" type="button">Select</button></td>
                `;
                tr.querySelector("button").addEventListener("click", event => {
                    event.preventDefault();
                    event.stopPropagation();
                    if (supplierInput) supplierInput.value = supplier.supplierId || "";
                    if (supplierDisplay) supplierDisplay.value = supplier.supplierName || "";
                    supplierInput?.dispatchEvent(new Event("change", { bubbles: true }));
                    clearValidationError(supplierDisplay, "Form.SupplierId");
                    closeSelectorOnly(supplierSelectorModal);
                });
                supplierResults.appendChild(tr);
            });
        }

        async function searchSuppliers(event) {
            event?.preventDefault();
            event?.stopPropagation();
            if (!supplierResults) return;
            supplierResults.innerHTML = '<tr><td class="text-center text-muted fw-bold" colspan="6">Loading suppliers...</td></tr>';
            const query = encodeURIComponent(supplierSearchInput?.value || "");
            const response = await fetch(`/Transaction/SearchFuelReceivingSuppliers?search=${query}`, {
                headers: { "Accept": "application/json" }
            });
            if (!response.ok) {
                supplierResults.innerHTML = '<tr><td class="text-center text-danger fw-bold" colspan="6">Unable to load suppliers.</td></tr>';
                return;
            }

            renderSupplierRows(await response.json());
        }

        branchInput?.addEventListener("change", function () {
            clearSelectedTank();
        });

        [branchInput, tankInput, fuelInput].forEach(input => {
            input?.addEventListener("change", function () {
                if (fuelReceivingForm?.classList.contains("was-validated")) {
                    validateFuelReceivingForm();
                }
            });
        });

        [supplierInput, litersInput, costInput, receivedDateInput].forEach(input => {
            input?.addEventListener("input", function () {
                if (fuelReceivingForm?.classList.contains("was-validated")) {
                    validateFuelReceivingForm();
                }
            });
            input?.addEventListener("change", function () {
                if (fuelReceivingForm?.classList.contains("was-validated")) {
                    validateFuelReceivingForm();
                }
            });
        });

        fuelReceivingForm?.addEventListener("submit", event => {
            if (!validateFuelReceivingForm()) {
                event.preventDefault();
                event.stopPropagation();
                showSelectorOnly(addFuelReceivingModal);
            }
        });

        document.querySelector(".fuel-receiving-tank-select-btn")?.addEventListener("click", event => {
            event.preventDefault();
            event.stopPropagation();
            if (!requireBranchBeforeTankSelector()) return;
            showSelectorOnly(tankSelectorModal);
            searchTanks(event);
        });
        tankSearchButton?.addEventListener("click", searchTanks);
        tankSearchInput?.addEventListener("keydown", event => {
            if (event.key === "Enter") {
                event.preventDefault();
                event.stopPropagation();
                searchTanks();
            }
        });
        tankSelectorModal?.addEventListener("hidden.bs.modal", restoreParentModalState);

        document.querySelector(".fuel-receiving-supplier-select-btn")?.addEventListener("click", event => {
            event.preventDefault();
            event.stopPropagation();
            showSelectorOnly(supplierSelectorModal);
            searchSuppliers(event);
        });
        supplierSearchButton?.addEventListener("click", searchSuppliers);
        supplierSearchInput?.addEventListener("keydown", event => {
            if (event.key === "Enter") {
                event.preventDefault();
                event.stopPropagation();
                searchSuppliers();
            }
        });
        supplierSelectorModal?.addEventListener("hidden.bs.modal", restoreParentModalState);

        if (shouldOpenFuelReceivingModal) {
            showSelectorOnly(addFuelReceivingModal);
            fuelReceivingForm?.classList.add("was-validated");
        }
    });
</script>
