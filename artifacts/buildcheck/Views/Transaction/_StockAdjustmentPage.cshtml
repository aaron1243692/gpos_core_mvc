@model gpos.Models.ViewModels.StockAdjustmentPageViewModel
@{ var unit = Model.Scope == "Fuel" ? "Liters" : "Qty"; var targetName = Model.Scope == "Fuel" ? "Tank" : $"{Model.Scope} Stock"; }
<div class="page-header"><div class="page-heading"><nav><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Transaction</li><li class="breadcrumb-item active">@Model.Title</li></ol></nav><h1>@Model.Title</h1><p class="page-subtitle text-muted">Create auditable inventory corrections. Posted records are permanent and can only be reversed.</p></div><div class="page-actions"><button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#adjustmentModal">Add Adjustment</button></div></div>
@if (TempData["AdjustmentMessage"] is string message) { <div class="alert alert-info">@message</div> }
<section class="content-card setup-crud-card setup-table-card">
<div class="table-actions"><form method="get" asp-action="@Model.PageAction" class="row g-2 flex-grow-1">
 <div class="col-md-3"><input name="search" value="@Model.Search" class="form-control" placeholder="Search adjustments..." /></div>
 <div class="col-md-2"><select name="branchId" class="form-select"><option value="">All Branches</option>@foreach(var b in Model.BranchOptions){<option value="@b.Value" selected="@(b.Value == Model.BranchId?.ToString())">@b.Text</option>}</select></div>
 <div class="col-md-2"><input type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="form-control" /></div><div class="col-md-2"><input type="date" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" class="form-control" /></div>
 <div class="col-md-2"><select name="status" class="form-select"><option value="">All Statuses</option>@foreach(var s in new[]{"Draft","Posted","Cancelled","Reversed"}){<option selected="@(Model.Status == s)">@s</option>}</select></div>
 <div class="col-auto"><button class="btn btn-primary">Search</button> <a asp-action="@Model.PageAction" class="btn btn-outline-secondary">Clear</a></div></form></div>
<div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><thead><tr><th>No</th><th>Adjustment No</th><th>Business Date</th><th>Branch</th><th>@(Model.Scope == "Fuel" ? "Tank" : "Product")</th><th>@(Model.Scope == "Fuel" ? "Fuel" : "Batch")</th><th>Before @unit</th><th>Adjustment</th><th>After @unit</th><th>Reason</th><th>Adjusted By</th><th>Status</th><th>Action</th></tr></thead><tbody>
@for(var i=0;i<Model.Rows.Count;i++){var x=Model.Rows[i];<tr><td>@(i+1)</td><td>@x.AdjustmentNo</td><td>@x.BusinessDate.ToString("yyyy-MM-dd")</td><td>@x.Branch?.Name</td><td>@(Model.Scope=="Fuel"?x.Tank?.TankNo:x.Product?.Name)</td><td>@(Model.Scope=="Fuel"?x.Fuel?.Name:x.Batch?.BatchNo)</td><td>@x.BeforeQuantity.ToString("N3")</td><td class="@(x.SignedQuantity < 0 ? "text-danger" : "text-success")">@(x.Status=="Draft"?(x.AdjustmentType=="Decrease"?"-":"+")+x.AdjustmentQuantity.ToString("N3"):x.SignedQuantity.ToString("+0.000;-0.000;0.000"))</td><td>@x.AfterQuantity.ToString("N3")</td><td>@x.Reason</td><td>@(x.AdjustedByUser?.FullName ?? x.AdjustedByUser?.Username)</td><td><span class="badge @(x.Status=="Posted"?"bg-success":x.Status=="Draft"?"bg-warning text-dark":"bg-secondary")">@x.Status</span></td><td class="text-nowrap">
<a asp-action="@Model.PageAction" asp-route-detailsId="@x.Id" class="btn btn-sm btn-outline-primary">View</a>
@if(x.Status=="Draft"){<a asp-action="@Model.PageAction" asp-route-editId="@x.Id" class="btn btn-sm btn-outline-secondary">Edit</a><form class="d-inline" method="post" asp-action="PostStockAdjustment"><input type="hidden" name="id" value="@x.Id"/><button class="btn btn-sm btn-success">Post</button></form><form class="d-inline" method="post" asp-action="CancelStockAdjustment"><input type="hidden" name="id" value="@x.Id"/><button class="btn btn-sm btn-outline-danger">Cancel</button></form>}
@if(x.Status=="Posted"){<form class="d-inline" method="post" asp-action="ReverseStockAdjustment"><input type="hidden" name="id" value="@x.Id"/><button class="btn btn-sm btn-outline-warning">Reverse</button></form>}
</td></tr>} @if(Model.Rows.Count==0){<tr><td colspan="13" class="text-center text-muted">No records found.</td></tr>}</tbody></table></div></section>
<div class="modal fade" id="adjustmentModal"><div class="modal-dialog modal-lg modal-dialog-centered"><div class="modal-content"><form method="post" asp-action="SaveStockAdjustment"><div class="modal-header"><h2 class="modal-title fs-5">@(Model.Form.Id>0?"Edit":"Add") @Model.Title</h2><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><div asp-validation-summary="ModelOnly" class="text-danger"></div><input asp-for="Form.Id" type="hidden"/><input asp-for="Form.Scope" type="hidden" value="@Model.Scope"/><div class="row g-3">
<div class="col-md-6"><label asp-for="Form.BusinessDate" class="form-label">Business Date</label><input asp-for="Form.BusinessDate" type="date" class="form-control"/><span asp-validation-for="Form.BusinessDate" class="text-danger"></span></div>
<div class="col-md-6"><label class="form-label">Branch</label><select asp-for="Form.BranchId" class="form-select" id="adjBranch"><option value="0">Select branch</option>@foreach(var b in Model.BranchOptions){<option value="@b.Value">@b.Text</option>}</select><span asp-validation-for="Form.BranchId" class="text-danger"></span></div>
<div class="col-12"><label class="form-label">@targetName</label><select name="Form.@(Model.Scope=="Warehouse"?"WarehouseStockId":Model.Scope=="Display"?"DisplayStockId":"TankId")" class="form-select" id="adjTarget"><option value="">Select @targetName</option>@foreach(var t in Model.Targets){<option value="@t.Id" data-branch="@t.BranchId" data-current="@t.CurrentQuantity" data-name="@t.ProductOrFuel" data-sub="@t.BatchOrTank">@t.Label (@t.CurrentQuantity.ToString("N3"))</option>}</select></div>
<div class="col-md-6"><label class="form-label">@(Model.Scope=="Fuel"?"Fuel":"Product / Batch") (Readonly)</label><input id="adjName" readonly class="form-control"/></div><div class="col-md-6"><label class="form-label">Current @unit (Readonly)</label><input id="adjCurrent" readonly class="form-control" value="0.000"/></div>
<div class="col-md-4"><label class="form-label">Adjustment Type</label><select asp-for="Form.AdjustmentType" id="adjType" class="form-select"><option>Increase</option><option>Decrease</option></select></div><div class="col-md-4"><label class="form-label">Adjustment @unit</label><input asp-for="Form.AdjustmentQuantity" id="adjQty" type="number" min="0.001" step="0.001" class="form-control"/><span asp-validation-for="Form.AdjustmentQuantity" class="text-danger"></span></div><div class="col-md-4"><label class="form-label">New @unit (Readonly)</label><input id="adjNew" readonly class="form-control" value="0.000"/></div>
<div class="col-md-6"><label class="form-label">Reason</label><select asp-for="Form.Reason" class="form-select"><option value="">Select reason</option><option>Physical Count</option><option>Damaged Items</option><option>Expired Items</option><option>Lost Items</option><option>Found Items</option><option>Shrinkage</option><option>Inventory Correction</option><option>Data Entry Error</option><option>Other</option></select><span asp-validation-for="Form.Reason" class="text-danger"></span></div><div class="col-md-6"><label class="form-label">Remarks</label><textarea asp-for="Form.Remarks" class="form-control"></textarea></div></div></div><div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button><button class="btn btn-primary">Save Draft</button></div></form></div></div></div>
<script>document.addEventListener('DOMContentLoaded',()=>{const b=document.querySelector('#adjBranch'),t=document.querySelector('#adjTarget'),c=document.querySelector('#adjCurrent'),n=document.querySelector('#adjName'),q=document.querySelector('#adjQty'),y=document.querySelector('#adjType'),z=document.querySelector('#adjNew');function calc(){const v=+(c.value||0),a=+(q.value||0);z.value=(v+(y.value==='Increase'?a:-a)).toFixed(3)}function filter(){[...t.options].forEach((o,i)=>{if(i)o.hidden=o.dataset.branch!==b.value});if(t.selectedOptions[0]?.hidden)t.value='';load()}function load(){const o=t.selectedOptions[0];c.value=o?.dataset.current||'0.000';n.value=o?.dataset.name?o.dataset.name+' / '+o.dataset.sub:'';calc()}b.addEventListener('change',filter);t.addEventListener('change',load);q.addEventListener('input',calc);y.addEventListener('change',calc);filter();@if(Model.Form.Id>0 || !ViewData.ModelState.IsValid){<text>bootstrap.Modal.getOrCreateInstance(document.querySelector('#adjustmentModal')).show();</text>}});</script>
