<section class="transaction-ui-page">
    <div class="content-card transaction-ui-card">
        <div class="card-title-row">
            <div>
                <h1>Daily Cash</h1>
                <p>UI-only cash control sheet. Expected Cash = Beginning Cash + Sales Cash + Cash In - Cash Out.</p>
            </div>
            <span class="status-badge">UI Only</span>
        </div>
        <div class="transaction-ui-toolbar">
            <input class="form-control transaction-ui-search" type="search" placeholder="Search daily cash..." data-transaction-search="#dailyCashTable" />
            <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#dailyCashFormModal">Add Daily Cash</button>
        </div>
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="dailyCashTable">
                <thead><tr><th>No</th><th>Date</th><th>User/Cashier</th><th>Beginning Cash</th><th>Cash In</th><th>Cash Out</th><th>Sales Cash</th><th>Expected Cash</th><th>Ending Cash</th><th>Difference</th><th>Status</th><th>Action</th></tr></thead>
                <tbody>
                    <tr data-search-row><td>1</td><td>2026-06-24</td><td>admin</td><td>₱5,000.00</td><td>₱500.00</td><td>₱200.00</td><td>₱18,400.00</td><td>₱23,700.00</td><td>₱23,650.00</td><td>₱-50.00</td><td><span class="badge text-bg-primary">Open</span></td><td><span class="transaction-ui-actions"><button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#dailyCashViewModal">View</button><button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#dailyCashFormModal">Edit</button><button class="btn btn-sm btn-outline-danger" type="button" data-bs-toggle="modal" data-bs-target="#dailyCashConfirmModal">Close Cash</button></span></td></tr>
                    <tr data-empty-row hidden><td class="text-center text-muted fw-bold" colspan="12">No records found.</td></tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="content-card transaction-db-card">
        <h2 class="h5 mb-1">Recommended Future Tables</h2>
        <p class="mb-0">Reference only: daily totals should roll up user cash movements, cash payments, and sales.</p>
        <ul class="transaction-db-list"><li>daily_cash</li><li>cash_movements</li><li>payments</li><li>sales</li></ul>
    </div>
</section>

<div class="modal fade" id="dailyCashFormModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h2 class="modal-title fs-5">Daily Cash</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">Date</label><input class="form-control" type="date" value="2026-06-24" /></div>
                    <div class="col-md-6"><label class="form-label">User/Cashier</label><input class="form-control" value="admin" /></div>
                    <div class="col-md-4"><label class="form-label">Beginning Cash</label><input class="form-control" type="number" value="5000" /></div>
                    <div class="col-md-4"><label class="form-label">Cash In</label><input class="form-control" type="number" value="500" /></div>
                    <div class="col-md-4"><label class="form-label">Cash Out</label><input class="form-control" type="number" value="200" /></div>
                    <div class="col-md-4"><label class="form-label">Sales Cash</label><input class="form-control" type="number" value="18400" /></div>
                    <div class="col-md-4"><label class="form-label">Expected Cash</label><input class="form-control" value="23700.00" readonly /></div>
                    <div class="col-md-4"><label class="form-label">Ending Cash</label><input class="form-control" type="number" value="23650" /></div>
                    <div class="col-md-4"><label class="form-label">Difference</label><input class="form-control" value="-50.00" readonly /></div>
                    <div class="col-md-4"><label class="form-label">Status</label><select class="form-select"><option>Open</option><option>Closed</option><option>Reviewed</option></select></div>
                    <div class="col-md-12"><label class="form-label">Remarks</label><textarea class="form-control" rows="3">Short by ₱50.00 pending review.</textarea></div>
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="button" data-bs-dismiss="modal">Save UI Draft</button></div>
        </div>
    </div>
</div>
<div class="modal fade" id="dailyCashViewModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5">Daily Cash Summary</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body">This preview is UI only. No cash records are saved.</div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button></div></div></div></div>
<div class="modal fade" id="dailyCashConfirmModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5">Close Cash</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body">Close this daily cash record? This button is UI only.</div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="button" data-bs-dismiss="modal">Close Cash</button></div></div></div></div>
