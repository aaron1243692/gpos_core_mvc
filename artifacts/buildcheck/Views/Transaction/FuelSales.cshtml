@model gpos.Models.ViewModels.FuelSalesPageViewModel

<section class="transaction-ui-page">
    <div class="content-card transaction-ui-card">
        <div class="card-title-row">
            <div>
                <h1>Fuel Sales</h1>
                <p>Fuel items sold from saved POS sales.</p>
            </div>
            <span class="status-badge">Latest 100</span>
        </div>

        <form asp-action="FuelSales" method="get" class="row g-2 mb-3">
            <div class="col-12 col-lg-3">
                <input class="form-control" name="search" value="@Model.Search" type="search" placeholder="Search receipt, fuel, tank, nozzle, cashier, member, branch..." />
            </div>
            <div class="col-6 col-lg-2">
                <input class="form-control" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" type="date" />
            </div>
            <div class="col-6 col-lg-2">
                <input class="form-control" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" type="date" />
            </div>
            <div class="col-6 col-lg-2">
                <select class="form-select" name="branchId">
                    @for (var i = 0; i < Model.BranchOptions.Count; i += 1)
                    {
                        var option = Model.BranchOptions[i];
                        var selected = option.Value == (Model.BranchId?.ToString() ?? string.Empty);
                        if (selected)
                        {
                            <option value="@option.Value" selected>@option.Text</option>
                        }
                        else
                        {
                            <option value="@option.Value">@option.Text</option>
                        }
                    }
                </select>
            </div>
            <div class="col-6 col-lg-2">
                <select class="form-select" name="status">
                    @for (var i = 0; i < Model.StatusOptions.Count; i += 1)
                    {
                        if (Model.StatusOptions[i].Selected)
                        {
                            <option value="@Model.StatusOptions[i].Value" selected>@Model.StatusOptions[i].Text</option>
                        }
                        else
                        {
                            <option value="@Model.StatusOptions[i].Value">@Model.StatusOptions[i].Text</option>
                        }
                    }
                </select>
            </div>
            <div class="col-6 col-lg-1 d-grid">
                <button class="btn btn-primary" type="submit">Filter</button>
            </div>
            <div class="col-6 col-lg-1 d-grid">
                <a class="btn btn-outline-secondary" asp-action="FuelSales">Clear</a>
            </div>
        </form>

        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0 sales-summary-table">
                <thead>
                    <tr>
                        <th>Receipt No.</th>
                        <th>Branch</th>
                        <th>Date &amp; Time</th>
                        <th>Customer</th>
                        <th>Name (Quantity / Liters)</th>
                        <th>Amount Paid</th>
                        <th>Points Paid</th>
                        <th>Cost</th>
                        <th>Discount</th>
                        <th>Voucher Discount</th>
                        <th>Total Price</th>
                        <th>Subtotal</th>
                        <th>Gross</th>
                        <th>Net Sales</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Sales.Count == 0)
                    {
                        <tr><td class="text-center text-muted fw-bold" colspan="16">No sales found.</td></tr>
                    }
                    @for (var i = 0; i < Model.Sales.Count; i += 1)
                    {
                        var sale = Model.Sales[i];
                        var amountPaid = sale.PointsPaid > 0m ? 0m : sale.CashAmount;
                        var totalPrice = sale.Subtotal - sale.MemberDiscount - sale.VoucherDiscount;

                        <tr>
                            <td class="text-nowrap">@sale.ReceiptNo</td>
                            <td class="text-nowrap">@sale.BranchName</td>
                            <td class="text-nowrap">@sale.SaleDate?.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@sale.MemberName</td>
                            <td style="min-width: 16rem;" title="@sale.ItemSummaryTitle">@sale.ItemSummary</td>
                            <td class="text-nowrap">₱@amountPaid.ToString("N2")</td>
                            <td class="text-nowrap">@sale.PointsPaid.ToString("N0")</td>
                            <td class="text-nowrap">Cost unavailable</td>
                            <td class="text-nowrap">₱@sale.MemberDiscount.ToString("N2")</td>
                            <td class="text-nowrap">₱@sale.VoucherDiscount.ToString("N2")</td>
                            <td class="text-nowrap">₱@totalPrice.ToString("N2")</td>
                            <td class="text-nowrap">Gross profit unavailable</td>
                            <td class="text-nowrap">₱@sale.GrossTotal.ToString("N2")</td>
                            <td class="text-nowrap">₱@sale.NetSales.ToString("N2")</td>
                            <td><span class="badge @(sale.Status == "Completed" ? "text-bg-success" : sale.Status == "Voided" ? "text-bg-secondary" : sale.Status == "Returned" ? "text-bg-primary" : "text-bg-warning")">@sale.Status</span></td>
                            <td><button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#fuelSaleViewModal_@sale.SaleItemId">View</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@for (var i = 0; i < Model.Sales.Count; i += 1)
{
    <div class="modal fade" id="fuelSaleViewModal_@Model.Sales[i].SaleItemId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5">Fuel Sale Details</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Receipt No</dt><dd class="col-sm-8">@Model.Sales[i].ReceiptNo</dd>
                        <dt class="col-sm-4">Fuel</dt><dd class="col-sm-8">@Model.Sales[i].FuelName</dd>
                        <dt class="col-sm-4">Tank</dt><dd class="col-sm-8">@Model.Sales[i].TankNo</dd>
                        <dt class="col-sm-4">Liters</dt><dd class="col-sm-8">@Model.Sales[i].Liters.ToString("N2")</dd>
                        <dt class="col-sm-4">Price/Liter</dt><dd class="col-sm-8">₱@Model.Sales[i].Price.ToString("N2")</dd>
                        <dt class="col-sm-4">Subtotal</dt><dd class="col-sm-8">₱@Model.Sales[i].Subtotal.ToString("N2")</dd>
                        <dt class="col-sm-4">Cashier/User</dt><dd class="col-sm-8">@Model.Sales[i].CashierName</dd>
                        <dt class="col-sm-4">Member</dt><dd class="col-sm-8">@Model.Sales[i].MemberName</dd>
                        <dt class="col-sm-4">Sale Date</dt><dd class="col-sm-8">@Model.Sales[i].SaleDate?.ToString("yyyy-MM-dd HH:mm")</dd>
                        <dt class="col-sm-4">Payment Type</dt><dd class="col-sm-8">@Model.Sales[i].PaymentType</dd>
                        <dt class="col-sm-4">Gross Total</dt><dd class="col-sm-8">₱@Model.Sales[i].GrossTotal.ToString("N2")</dd>
                        <dt class="col-sm-4">Rebate Amount</dt><dd class="col-sm-8">₱@Model.Sales[i].RebateAmount.ToString("N2")</dd>
                        <dt class="col-sm-4">Net Total</dt><dd class="col-sm-8">₱@Model.Sales[i].NetTotal.ToString("N2")</dd>
                        <dt class="col-sm-4">Status</dt><dd class="col-sm-8">@Model.Sales[i].Status</dd>
                    </dl>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}
