@model gpos.Models.ViewModels.CashRemittancePageViewModel
@{
    ViewData["Title"] = "Cash Remittance";
    string Money(decimal value) => value.ToString("N2");
    string UserName(gpos.Models.User? user) => user is null ? "-" : string.IsNullOrWhiteSpace(user.FullName) ? user.Username : user.FullName;
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Transaction</li>
                <li class="breadcrumb-item">Cash</li>
                <li class="breadcrumb-item active" aria-current="page">Cash Remittance</li>
            </ol>
        </nav>
        <h1 class="mb-0">Cash Remittance</h1>
        <p class="page-subtitle text-muted mt-2">Record the final cash turnover and complete an open Daily Cash session.</p>
    </div>
    <div class="page-actions"><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#cashRemittanceModal">Add Remittance</button></div>
</div>

<section class="transaction-ui-page">
    <div class="content-card mb-3">
        <form asp-action="CashRemittance" method="get" class="row g-2 align-items-center">
            <div class="col-md-2"><input class="form-control" name="search" value="@Model.Filter.Search" type="search" placeholder="Search remittance..." /></div>
            <div class="col-md-2"><select class="form-select" name="branchId" asp-items="Model.BranchOptions"></select></div>
            <div class="col-md-2"><select class="form-select" name="shiftId" asp-items="Model.ShiftOptions"></select></div>
            <div class="col-md-2"><input class="form-control" name="dateFrom" value="@Model.Filter.DateFrom?.ToString("yyyy-MM-dd")" type="date" /></div>
            <div class="col-md-2"><input class="form-control" name="dateTo" value="@Model.Filter.DateTo?.ToString("yyyy-MM-dd")" type="date" /></div>
            <div class="col-md-1"><select class="form-select" name="status"><option value="">All</option><option value="Active" selected="@(Model.Filter.Status == "Active")">Active</option><option value="Inactive" selected="@(Model.Filter.Status == "Inactive")">Inactive</option></select></div>
            <div class="col-md-auto d-flex gap-1"><button class="btn btn-primary" type="submit">Search</button><a class="btn btn-outline-secondary" asp-action="CashRemittance">Clear</a></div>
        </form>
    </div>

    <div class="content-card transaction-ui-card">
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>No</th><th>Remittance No</th><th>Business Date</th><th>Branch</th><th>Shift</th><th>Cashier</th>
                        <th class="text-end">Expected Cash</th><th class="text-end">Remitted Amount</th><th class="text-end">Remittance Difference</th>
                        <th>Variance</th><th>Received By</th><th>Received Date/Time</th><th>Status</th><th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Records.Count == 0)
                    {
                        <tr><td class="text-center text-muted fw-bold" colspan="14">No remittance records found.</td></tr>
                    }
                    else
                    {
                        @for (var i = 0; i < Model.Records.Count; i++)
                        {
                            var item = Model.Records[i];
                            <tr>
                                <td>@(i + 1)</td><td class="fw-bold">@item.RemittanceNo</td><td>@item.DailyCash?.BusinessDate.ToString("yyyy-MM-dd")</td><td>@item.Branch?.Name</td><td>@item.Shift?.Name</td><td>@UserName(item.User)</td>
                                <td class="text-end">@Money(item.ExpectedCash)</td><td class="text-end">@Money(item.RemittedAmount)</td><td class="text-end">@Money(item.RemittanceDifference)</td><td>@(item.RemittanceDifference == 0 ? "Balanced" : item.RemittanceDifference < 0 ? "Shortage" : "Excess")</td><td>@UserName(item.ReceivedByUser)</td><td>@item.ReceivedDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td><span class="badge @(item.Status == 1 ? "bg-success" : "bg-secondary")">@(item.Status == 1 ? "Active" : "Inactive")</span></td>
                                <td><button class="btn btn-sm btn-outline-primary remittance-view-button" type="button" data-bs-toggle="modal" data-bs-target="#remittanceViewModal"
                                    data-no="@item.RemittanceNo" data-daily-cash="DC-@item.DailyCashId.ToString("000000")" data-date="@item.CreatedAt?.ToString("yyyy-MM-dd HH:mm")" data-branch="@item.Branch?.Name" data-business-date="@item.DailyCash?.BusinessDate.ToString("yyyy-MM-dd")" data-shift="@item.Shift?.Name" data-cashier="@UserName(item.User)" data-opening="@Money(item.DailyCash?.OpeningCash ?? 0)" data-sales="@Money(item.DailyCash?.CashSales ?? 0)" data-cash-in="@Money(item.DailyCash?.TotalCashIn ?? 0)" data-cash-out="@Money(item.DailyCash?.TotalCashOut ?? 0)"
                                    data-expected="@Money(item.ExpectedCash)" data-actual="@Money(item.ActualCash)" data-count-difference="@Money(item.ActualCash - item.ExpectedCash)" data-remitted="@Money(item.RemittedAmount)" data-difference="@Money(item.RemittanceDifference)" data-variance="@(item.RemittanceDifference == 0 ? "Balanced" : item.RemittanceDifference < 0 ? "Shortage" : "Excess")" data-receiver="@UserName(item.ReceivedByUser)" data-received="@item.ReceivedDateTime.ToString("yyyy-MM-dd HH:mm")" data-created-by="@UserName(item.CreatedByUser)" data-created-at="@item.CreatedAt?.ToString("yyyy-MM-dd HH:mm")" data-remarks="@item.Remarks" data-status="Completed">View</button></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<div class="modal fade" id="remittanceViewModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered modal-lg"><div class="modal-content">
    <div class="modal-header"><h2 class="modal-title fs-5">View Cash Remittance</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div>
    <div class="modal-body"><div class="row g-3">
        <div class="col-md-6"><label class="form-label">Remittance No</label><input id="viewRemittanceNo" class="form-control" readonly /></div><div class="col-md-6"><label class="form-label">Daily Cash No</label><input id="viewRemittanceDailyCash" class="form-control" readonly /></div>
        <div class="col-md-6"><label class="form-label">Branch</label><input id="viewRemittanceBranch" class="form-control" readonly /></div><div class="col-md-6"><label class="form-label">Business Date</label><input id="viewRemittanceBusinessDate" class="form-control" readonly /></div>
        <div class="col-md-6"><label class="form-label">Shift</label><input id="viewRemittanceShift" class="form-control" readonly /></div><div class="col-md-6"><label class="form-label">Cashier</label><input id="viewRemittanceCashier" class="form-control" readonly /></div>
        <div class="col-md-3"><label class="form-label">Opening Cash</label><input id="viewRemittanceOpening" class="form-control" readonly /></div><div class="col-md-3"><label class="form-label">Cash Sales</label><input id="viewRemittanceSales" class="form-control" readonly /></div><div class="col-md-3"><label class="form-label">Cash In</label><input id="viewRemittanceCashIn" class="form-control" readonly /></div><div class="col-md-3"><label class="form-label">Cash Out</label><input id="viewRemittanceCashOut" class="form-control" readonly /></div>
        <div class="col-md-4"><label class="form-label">Expected Cash</label><input id="viewRemittanceExpected" class="form-control" readonly /></div><div class="col-md-4"><label class="form-label">Actual Cash (Cashier Count)</label><input id="viewRemittanceActual" class="form-control" readonly /></div><div class="col-md-4"><label class="form-label">Count Difference</label><input id="viewRemittanceCountDifference" class="form-control" readonly /></div>
        <div class="col-md-4"><label class="form-label">Remitted Amount (Receiver Count)</label><input id="viewRemittanceRemitted" class="form-control" readonly /></div><div class="col-md-4"><label class="form-label">Remittance Difference</label><input id="viewRemittanceDifference" class="form-control" readonly /></div><div class="col-md-4"><label class="form-label">Variance</label><input id="viewRemittanceVariance" class="form-control" readonly /></div>
        <div class="col-md-6"><label class="form-label">Received By</label><input id="viewRemittanceReceiver" class="form-control" readonly /></div><div class="col-md-6"><label class="form-label">Received DateTime</label><input id="viewRemittanceReceived" class="form-control" readonly /></div>
        <div class="col-md-6"><label class="form-label">Created By</label><input id="viewRemittanceCreatedBy" class="form-control" readonly /></div><div class="col-md-6"><label class="form-label">Created At</label><input id="viewRemittanceCreatedAt" class="form-control" readonly /></div><div class="col-md-6"><label class="form-label">Status</label><input id="viewRemittanceStatus" class="form-control" readonly /></div><div class="col-12"><label class="form-label">Remarks</label><textarea id="viewRemittanceRemarks" class="form-control" rows="3" readonly></textarea></div>
    </div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button></div>
</div></div></div>

<div class="modal fade" id="cashRemittanceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form asp-action="SaveCashRemittance" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header"><h2 class="modal-title fs-5">Add Cash Remittance</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="Form.BranchId" class="form-label">Branch</label>
                            <input asp-for="Form.BranchId" id="remitBranchId" type="hidden" />
                            <div class="input-group" data-branch-selector data-branch-hidden="#remitBranchId" data-branch-display="#remitBranchDisplay" data-branch-empty-text="Select branch">
                                <input asp-for="Form.BranchName" id="remitBranchDisplay" class="form-control" placeholder="Select branch" readonly />
                                <button type="button" class="btn btn-outline-secondary branch-select-btn" data-branch-open><img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" /></button>
                            </div>
                            <span asp-validation-for="Form.BranchId" class="text-danger"></span>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Form.DailyCashId" class="form-label">Daily Cash</label>
                            <input asp-for="Form.DailyCashId" id="remitDailyCashId" type="hidden" />
                            <div class="input-group" data-daily-cash-selector data-daily-cash-hidden="#remitDailyCashId" data-daily-cash-display="#remitDailyCashDisplay" data-branch-hidden="#remitBranchId" data-branch-display="#remitBranchDisplay" data-business-date-display="#remitBusinessDateDisplay" data-shift-display="#remitShiftDisplay" data-user-display="#remitUserDisplay" data-expected-cash-display="#remitExpectedCashDisplay" data-remitted-amount-input="#remitAmount" data-difference-display="#remitDifferenceDisplay" data-variance-display="#remitVarianceDisplay">
                                <input asp-for="Form.DailyCashDisplay" id="remitDailyCashDisplay" class="form-control" placeholder="Select open Daily Cash" readonly />
                                <button type="button" class="btn btn-outline-secondary" data-daily-cash-open><img src="/icons/search.png" alt="Search" style="width:16px;height:16px;" /></button>
                            </div>
                            <span asp-validation-for="Form.DailyCashId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6"><label class="form-label">Business Date</label><input value="@Model.Form.BusinessDate?.ToString("yyyy-MM-dd")" id="remitBusinessDateDisplay" class="form-control" readonly /></div>
                        <div class="col-md-6"><label class="form-label">Shift</label><input asp-for="Form.ShiftName" id="remitShiftDisplay" class="form-control" readonly /></div>
                        <div class="col-md-6"><label class="form-label">Cashier</label><input asp-for="Form.UserName" id="remitUserDisplay" class="form-control" readonly /></div>
                        <div class="col-md-6"><label class="form-label">Expected Cash</label><input asp-for="Form.ExpectedCash" id="remitExpectedCashDisplay" class="form-control" readonly /></div>
                        <div class="col-md-6"><label asp-for="Form.RemittedAmount" class="form-label">Remitted Amount (Receiver Count)</label><input asp-for="Form.RemittedAmount" id="remitAmount" class="form-control" type="number" step="0.01" min="0" max="9999999999999999.99" /><span asp-validation-for="Form.RemittedAmount" class="text-danger"></span></div>
                        <div class="col-md-6"><label class="form-label">Remittance Difference</label><input id="remitDifferenceDisplay" class="form-control" readonly /></div>
                        <div class="col-12"><label class="form-label">Variance Classification</label><div id="remitVarianceDisplay" class="alert d-none mb-0"></div></div>
                        <div class="col-md-6"><label class="form-label">Received By</label><input class="form-control" value="@Model.CurrentUserName" readonly /></div>
                        <div class="col-md-6"><label asp-for="Form.ReceivedDateTime" class="form-label">Received Date/Time</label><input asp-for="Form.ReceivedDateTime" class="form-control" type="datetime-local" /><span asp-validation-for="Form.ReceivedDateTime" class="text-danger"></span></div>
                        <div class="col-12"><label asp-for="Form.Remarks" class="form-label">Remarks</label><textarea asp-for="Form.Remarks" class="form-control" rows="3"></textarea></div>
                    </div>
                </div>
                <div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save Remittance</button></div>
            </form>
        </div>
    </div>
</div>

<partial name="_DailyCashMovementSelector" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.remittance-view-button').forEach(button => button.addEventListener('click', function () {
                const fields = { No: 'no', DailyCash: 'dailyCash', Branch: 'branch', BusinessDate: 'businessDate', Shift: 'shift', Cashier: 'cashier', Opening: 'opening', Sales: 'sales', CashIn: 'cashIn', CashOut: 'cashOut', Expected: 'expected', Actual: 'actual', CountDifference: 'countDifference', Remitted: 'remitted', Difference: 'difference', Variance: 'variance', Receiver: 'receiver', Received: 'received', CreatedBy: 'createdBy', CreatedAt: 'createdAt', Remarks: 'remarks', Status: 'status' };
                Object.entries(fields).forEach(([field, key]) => { const element = document.getElementById(`viewRemittance${field}`); if (element) element.value = this.dataset[key] || '-'; });
            }));
        });
    </script>
    <script src="~/js/daily-cash-movement-selector.js" asp-append-version="true"></script>
    @if (!string.IsNullOrWhiteSpace(Model.ActiveModalId))
    {
        <script>document.addEventListener('DOMContentLoaded', () => bootstrap.Modal.getOrCreateInstance(document.getElementById('@Model.ActiveModalId')).show());</script>
    }
}
