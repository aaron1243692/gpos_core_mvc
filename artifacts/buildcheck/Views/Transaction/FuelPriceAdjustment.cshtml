@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Transaction</li><li class="breadcrumb-item">Price Adjustment</li><li class="breadcrumb-item active">Fuel Price Adjustment</li></ol></nav><h1>Fuel Price Adjustment</h1><p class="page-subtitle">Fuel price history and adjustments.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="FuelPriceAdjustment" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search fuel prices" /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#fuelPriceAdjustmentModal">Add Price Adjustment</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-normal" /><col class="col-date" /><col class="col-status" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Fuel</th><th>Old Price</th><th>New Price</th><th>Effective Date</th><th>Created By</th><th>Created At</th><th>Status</th><th>Action</th></tr></thead><tbody>
@if (Model.FuelPriceHistory.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="10">No fuel price adjustments yet.</td></tr> }
@for (var i = 0; i < Model.FuelPriceHistory.Count; i++) { var item = Model.FuelPriceHistory[i]; var isCurrent = Model.CurrentFuelPriceHistoryIds.Contains(item.Id); var createdBy = item.CreatedBy.HasValue && Model.FuelPriceHistoryCreatedBy.TryGetValue(item.CreatedBy.Value, out var name) ? name : "-"; <tr><td>@(i + 1)</td><td>@item.Id</td><td>@item.Fuel?.Name</td><td>@item.OldPrice?.ToString("N2")</td><td>@item.NewPrice.ToString("N2")</td><td>@item.EffectiveAt.ToString("yyyy-MM-dd")</td><td>@createdBy</td><td>@item.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</td><td><span class="badge @(item.Status == 1 ? (isCurrent ? "text-bg-primary" : "text-bg-success") : "text-bg-secondary")">@(item.Status == 1 ? (isCurrent ? "Current" : "History") : "Disabled")</span></td><td class="col-action"><div class="setup-row-actions">@if (item.Status == 1) { <form asp-action="DeleteFuelPriceAdjustment" method="post" onsubmit="return confirm('Are you sure you want to disable this price adjustment?');">@Html.AntiForgeryToken()<input name="id" type="hidden" value="@item.Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-danger" type="submit">Disable</button></form> }</div></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="fuelPriceAdjustmentModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveFuelPriceAdjustment" method="post">@Html.AntiForgeryToken()<input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Fuel Price Adjustment</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="FuelPriceHistoryForm.FuelId" class="form-label">Fuel</label><select asp-for="FuelPriceHistoryForm.FuelId" asp-items="Model.FuelOptions" class="form-select"></select><span asp-validation-for="FuelPriceHistoryForm.FuelId" class="text-danger"></span></div><div class="mb-3"><label asp-for="FuelPriceHistoryForm.NewPrice" class="form-label">New Price</label><input asp-for="FuelPriceHistoryForm.NewPrice" class="form-control" type="number" step="0.01" min="0" /><span asp-validation-for="FuelPriceHistoryForm.NewPrice" class="text-danger"></span></div><div class="mb-3"><label asp-for="FuelPriceHistoryForm.EffectiveAt" class="form-label">Effective Date</label><input asp-for="FuelPriceHistoryForm.EffectiveAt" class="form-control" type="date" /><span asp-validation-for="FuelPriceHistoryForm.EffectiveAt" class="text-danger"></span></div><div class="mb-3"><label asp-for="FuelPriceHistoryForm.Remarks" class="form-label">Remarks</label><input asp-for="FuelPriceHistoryForm.Remarks" class="form-control" /></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
