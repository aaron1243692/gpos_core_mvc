@{
    ViewData["Title"] = "Inventory Report";
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Reports</li>
                <li class="breadcrumb-item active" aria-current="page">Inventory Report</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="mb-0">Inventory Report</h1>
            <span class="badge bg-warning text-dark">UI Preview Only</span>
            <span class="badge bg-secondary">Backend not connected yet</span>
        </div>
        <p class="page-subtitle text-muted mt-2">Current stock quantities and financial valuations of products and fuels across warehouse, display, and storage tanks.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-outline-secondary" type="button" onclick="alert('Export backend not connected yet.');">Export CSV</button>
        <button class="btn btn-outline-secondary" type="button" onclick="alert('Print backend not connected yet.');">Print</button>
    </div>
</div>

<section class="reports-ui-page">
    <div class="content-card mb-3">
        <form class="row g-2 align-items-center" onsubmit="return false;">
            <div class="col-md-3">
                <input class="form-control" type="search" placeholder="Search inventory..." id="inventorySearch" />
            </div>
            <div class="col-md-3">
                <select class="form-select" id="inventoryBranch">
                    <option value="">All Branches</option>
                    <option>Main Branch</option>
                    <option>Branch 2</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select" id="inventoryType">
                    <option value="">All Types</option>
                    <option>Warehouse Product</option>
                    <option>Display Product</option>
                    <option>Fuel Tank</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select" id="inventoryStatus">
                    <option value="">All Statuses</option>
                    <option>Active</option>
                    <option>Low Stock</option>
                    <option>Out of Stock</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button class="btn btn-primary w-100" type="button">Search</button>
                <button class="btn btn-outline-secondary" type="button">Clear</button>
            </div>
        </form>
    </div>

    <div class="content-card transaction-ui-card">
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="inventoryTable">
                <thead>
                    <tr>
                        <th class="text-nowrap">No</th>
                        <th class="text-nowrap">Branch</th>
                        <th class="text-nowrap">Type</th>
                        <th class="text-nowrap">Product/Tank</th>
                        <th class="text-nowrap">Fuel</th>
                        <th class="text-nowrap">Total Quantity/Liters</th>
                        <th class="text-nowrap">Value</th>
                        <th class="text-nowrap">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td>Main Branch</td>
                        <td>Warehouse</td>
                        <td>Engine Oil 1L</td>
                        <td>-</td>
                        <td>150.00 pcs</td>
                        <td>₱48,000.00</td>
                        <td><span class="badge bg-success text-nowrap">Active</span></td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td>Main Branch</td>
                        <td>Display</td>
                        <td>Coolant 1L</td>
                        <td>-</td>
                        <td>5.00 pcs</td>
                        <td>₱900.00</td>
                        <td><span class="badge bg-warning text-nowrap">Low Stock</span></td>
                    </tr>
                    <tr>
                        <td>3</td>
                        <td>Main Branch</td>
                        <td>Tank</td>
                        <td>Tank 1</td>
                        <td>Diesel</td>
                        <td>12,450.00 Liters</td>
                        <td>₱747,000.00</td>
                        <td><span class="badge bg-success text-nowrap">Active</span></td>
                    </tr>
                    <tr class="d-none">
                        <td class="text-center text-muted fw-bold" colspan="8">No records found.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
