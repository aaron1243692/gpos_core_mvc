@{
    ViewData["Title"] = "Shift Configuration";
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item">Config</li>
                <li class="breadcrumb-item active" aria-current="page">Shift</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="mb-0">Shift</h1>
            <span class="badge bg-warning text-dark">UI Preview Only</span>
            <span class="badge bg-secondary">Backend not connected yet</span>
        </div>
        <p class="page-subtitle text-muted mt-2">Manage cashier shift settings, timings, and cash control policies.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#shiftFormModal">Add Shift</button>
    </div>
</div>

<section class="transaction-ui-page">
    <div class="content-card mb-3">
        <form class="row g-2 align-items-center" onsubmit="return false;">
            <div class="col-md-4">
                <input class="form-control" type="search" placeholder="Search shift name..." id="shiftSearchInput" />
            </div>
            <div class="col-md-3">
                <select class="form-select" id="shiftStatusFilter">
                    <option value="">All Statuses</option>
                    <option>Active</option>
                    <option>Inactive</option>
                </select>
            </div>
            <div class="col-md-auto d-flex gap-1">
                <button class="btn btn-primary" type="button">Search</button>
                <button class="btn btn-outline-secondary" type="button">Clear</button>
            </div>
        </form>
    </div>

    <div class="content-card transaction-ui-card">
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="shiftTable">
                <thead>
                    <tr>
                        <th class="text-nowrap">No</th>
                        <th class="text-nowrap">Shift Name</th>
                        <th class="text-nowrap">Start Time</th>
                        <th class="text-nowrap">End Time</th>
                        <th class="text-nowrap">Opening Cash Amount</th>
                        <th class="text-nowrap">Allow Cash In</th>
                        <th class="text-nowrap">Allow Cash Out</th>
                        <th class="text-nowrap">Status</th>
                        <th class="text-nowrap">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td class="text-nowrap fw-bold">Morning Shift</td>
                        <td>06:00 AM</td>
                        <td>02:00 PM</td>
                        <td>₱5,000.00</td>
                        <td>Yes</td>
                        <td>Yes</td>
                        <td><span class="badge bg-success text-nowrap">Active</span></td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#shiftViewModal">View</button>
                            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#shiftFormModal">Edit</button>
                        </td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td class="text-nowrap fw-bold">Afternoon Shift</td>
                        <td>02:00 PM</td>
                        <td>10:00 PM</td>
                        <td>₱5,000.00</td>
                        <td>Yes</td>
                        <td>Yes</td>
                        <td><span class="badge bg-success text-nowrap">Active</span></td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#shiftViewModal">View</button>
                            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#shiftFormModal">Edit</button>
                        </td>
                    </tr>
                    <tr>
                        <td>3</td>
                        <td class="text-nowrap fw-bold">Night Shift</td>
                        <td>10:00 PM</td>
                        <td>06:00 AM</td>
                        <td>₱5,000.00</td>
                        <td>Yes</td>
                        <td>Yes</td>
                        <td><span class="badge bg-success text-nowrap">Active</span></td>
                        <td class="text-nowrap">
                            <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#shiftViewModal">View</button>
                            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#shiftFormModal">Edit</button>
                        </td>
                    </tr>
                    <tr class="d-none">
                        <td class="text-center text-muted fw-bold" colspan="9">No records found.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- Add/Edit Modal -->
<div class="modal fade" id="shiftFormModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Add/Edit Shift</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label">Shift Name</label>
                        <input class="form-control" placeholder="e.g. Morning Shift" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Start Time</label>
                        <input class="form-control" type="time" value="06:00" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">End Time</label>
                        <input class="form-control" type="time" value="14:00" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Opening Cash Amount</label>
                        <input class="form-control" type="number" step="0.01" min="0" placeholder="1234.00" />
                    </div>
                    <div class="col-md-4">
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" id="allowCashInCheckbox" checked />
                            <label class="form-check-label" for="allowCashInCheckbox">Allow Cash In</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-check mt-4">
                            <input class="form-check-input" type="checkbox" id="allowCashOutCheckbox" checked />
                            <label class="form-check-label" for="allowCashOutCheckbox">Allow Cash Out</label>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Status</label>
                        <select class="form-select">
                            <option>Active</option>
                            <option>Inactive</option>
                        </select>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Remarks</label>
                        <textarea class="form-control" rows="3" placeholder="Enter remarks..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" type="button" onclick="alert('Backend not connected yet.');" data-bs-dismiss="modal">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- View Modal -->
<div class="modal fade" id="shiftViewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title fs-5">Shift Details</h2>
                <button class="btn-close" type="button" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>This is a UI preview. Shift configuration backend is not connected yet.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
