@model gpos.Models.ViewModels.SupplierPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item active" aria-current="page">Suppliers</li>
            </ol>
        </nav>
        <h1>Suppliers</h1>
        <p class="page-subtitle">Manage supplier contacts used across setup records.</p>
    </div>
</div>

<section class="content-card setup-crud-card setup-table-card">
    @if (TempData["SupplierFeedback"] is string feedback)
    {
        <div class="alert alert-info mb-0" role="alert">@feedback</div>
    }
    <div class="table-actions fuel-toolbar">
        <form asp-action="Index" method="get" class="setup-search-form fuel-toolbar-search">
            <input class="form-control" name="search" value="@Model.Search" placeholder="Search suppliers" />
        </form>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#supplierModal">Add Supplier</button>
    </div>
    <div class="setup-table-scroll">
        <table class="table app-table table-sm align-middle admin-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-id" />
                <col class="col-name" />
                <col class="col-address" />
                <col class="col-status" />
                <col class="col-action" />
            </colgroup>
            <thead>
                <tr>
                    <th class="col-no">No</th>
                    <th class="col-id">ID</th>
                    <th class="col-name">Name</th>
                    <th class="col-address">Address</th>
                    <th class="col-status">Status</th>
                    <th class="col-action">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Suppliers.Count == 0)
                {
                    <tr><td class="text-center text-muted fw-bold" colspan="6">No records yet.</td></tr>
                }
                @for (var i = 0; i < Model.Suppliers.Count; i++)
                {
                    <tr>
                        <td class="col-no">@(i + 1)</td>
                        <td class="col-id">@Model.Suppliers[i].Id</td>
                        <td>@Model.Suppliers[i].Name</td>
                        <td>@(Model.Suppliers[i].Address ?? "-")</td>
                        <td><span class="badge @(Model.Suppliers[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.Suppliers[i].Status == 1 ? "Active" : "Disabled")</span></td>
                        <td class="col-action">
                            <div class="setup-row-actions">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Index" asp-route-editId="@Model.Suppliers[i].Id" asp-route-search="@Model.Search">Edit</a>
                                @if (Model.Suppliers[i].Status == 1)
                                {
                                    <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to disable this supplier?');">
                                    @Html.AntiForgeryToken()
                                    <input name="id" type="hidden" value="@Model.Suppliers[i].Id" />
                                    <input name="search" type="hidden" value="@Model.Search" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Disable</button>
                                </form>
                                }
                                @if (!(Model.Suppliers[i].Status == 1))
                                {
                                    <form asp-action="Activate" method="post" onsubmit="return confirm('Are you sure you want to activate this supplier?');">
                                    @Html.AntiForgeryToken()
                                    <input name="id" type="hidden" value="@Model.Suppliers[i].Id" />
                                    <input name="search" type="hidden" value="@Model.Search" />
                                    <button class="btn btn-sm btn-outline-success" type="submit">Activate</button>
                                </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="supplierModal" tabindex="-1" aria-labelledby="supplierModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="Save" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="SupplierForm.Id" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="supplierModalLabel">@(Model.SupplierForm.Id > 0 ? "Edit Supplier" : "Add Supplier")</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="SupplierForm.Name" class="form-label">Name</label>
                        <input asp-for="SupplierForm.Name" class="form-control" placeholder="Supplier name" />
                        <span asp-validation-for="SupplierForm.Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SupplierForm.Email" class="form-label">Email</label>
                        <input asp-for="SupplierForm.Email" class="form-control" placeholder="supplier@example.com" type="email" />
                        <span asp-validation-for="SupplierForm.Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SupplierForm.ContactPerson" class="form-label">Contact Person</label>
                        <input asp-for="SupplierForm.ContactPerson" class="form-control" placeholder="Contact person" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="SupplierForm.ContactNumber" class="form-label">Contact Number</label>
                        <input asp-for="SupplierForm.ContactNumber" class="form-control" placeholder="Contact number" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="SupplierForm.Address" class="form-label">Address</label>
                        <textarea asp-for="SupplierForm.Address" class="form-control" rows="3" placeholder="Address"></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="SupplierForm.Status" class="form-label">Status</label>
                        <select asp-for="SupplierForm.Status" class="form-select">
                            <option value="1">Active</option>
                            <option value="0">Disabled</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const modalId = "@Model.ActiveModalId";
            const modalElement = modalId ? document.getElementById(modalId) : null;

            if (modalElement && window.bootstrap) {
                bootstrap.Modal.getOrCreateInstance(modalElement).show();
            }
        });
    </script>
}
