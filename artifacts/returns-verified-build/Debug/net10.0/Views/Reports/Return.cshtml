@model gpos.Models.ViewModels.ReturnCreatePageViewModel
@{ ViewData["Title"] = "Return"; }
<div class="page-header"><div class="page-heading"><nav><ol class="breadcrumb"><li class="breadcrumb-item">Returns</li><li class="breadcrumb-item active">Return</li></ol></nav><h1>Return</h1><p class="page-subtitle text-muted">Create a pending customer Return from an eligible completed Sale.</p></div></div>
@if (TempData["ReturnError"] is string error) { <div class="alert alert-danger">@error</div> }
<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
<div class="content-card mb-3"><form method="get" class="row g-2 align-items-end"><div class="col-md-8"><label class="form-label" for="receiptNo">Original receipt number</label><input class="form-control" id="receiptNo" name="receiptNo" value="@Model.ReceiptNo" required /></div><div class="col-md-4 d-flex gap-2"><button class="btn btn-primary">Find Sale</button><a class="btn btn-outline-secondary" asp-action="Return">Clear</a></div></form></div>
@if (Model.Sale is { } sale) {
<div class="content-card mb-3"><dl class="row mb-0"><dt class="col-md-2">Receipt</dt><dd class="col-md-4">@sale.ReceiptNo</dd><dt class="col-md-2">Customer</dt><dd class="col-md-4">@sale.Customer</dd><dt class="col-md-2">Branch</dt><dd class="col-md-4">@sale.Branch</dd><dt class="col-md-2">Original cashier</dt><dd class="col-md-4">@sale.Cashier</dd></dl></div>
<form method="post" asp-action="CreateReturn">@Html.AntiForgeryToken()<input type="hidden" name="saleId" value="@sale.SaleId" />
<div class="content-card mb-3"><h2 class="fs-6">Product Items</h2><div class="table-responsive"><table class="table table-sm align-middle"><thead><tr><th>Product</th><th>Batch</th><th class="text-end">Sold</th><th class="text-end">Previously Returned</th><th class="text-end">Remaining</th><th class="text-end">Original Price</th><th>Quantity to Return</th></tr></thead><tbody>
@if (sale.Products.Count == 0) { <tr><td colspan="7" class="text-center text-muted">No Product items.</td></tr> }
@foreach (var item in sale.Products) { <tr><td>@item.Product</td><td>@item.Batch</td><td class="text-end">@item.Sold.ToString("N2")</td><td class="text-end">@item.Returned.ToString("N2")</td><td class="text-end">@item.Remaining.ToString("N2")</td><td class="text-end">@item.UnitPrice.ToString("N2")</td><td><input class="form-control form-control-sm" type="number" min="0" max="@item.Remaining" step="0.01" name="productQuantities[@item.ProductSaleId]" value="0" @(item.Remaining <= 0 ? "disabled" : null) /></td></tr> }
</tbody></table></div></div>
<div class="content-card mb-3"><h2 class="fs-6">Fuel Items</h2><div class="table-responsive"><table class="table table-sm align-middle"><thead><tr><th>Fuel</th><th>Original Source</th><th class="text-end">Liters Sold</th><th class="text-end">Previously Returned</th><th class="text-end">Remaining</th><th class="text-end">Original Price/Liter</th><th>Liters to Return</th></tr></thead><tbody>
@if (sale.Fuels.Count == 0) { <tr><td colspan="7" class="text-center text-muted">No Fuel items.</td></tr> }
@foreach (var item in sale.Fuels) { <tr><td>@item.Fuel</td><td>@item.Source</td><td class="text-end">@item.Sold.ToString("N2")</td><td class="text-end">@item.Returned.ToString("N2")</td><td class="text-end">@item.Remaining.ToString("N2")</td><td class="text-end">@item.UnitPrice.ToString("N2")</td><td><input class="form-control form-control-sm" type="number" min="0" max="@item.Remaining" step="0.01" name="fuelQuantities[@item.FuelSaleId]" value="0" @(item.Remaining <= 0 ? "disabled" : null) /></td></tr> }
</tbody></table></div></div>
<div class="content-card"><label class="form-label" for="reason">Reason</label><textarea class="form-control mb-3" id="reason" name="reason" minlength="3" maxlength="500" required></textarea><div class="alert alert-info">Creating this Return records it as Pending Inspection. No inventory, fuel, payment, points, or accounting balances are changed.</div><button class="btn btn-primary">Submit Return</button></div></form> }
