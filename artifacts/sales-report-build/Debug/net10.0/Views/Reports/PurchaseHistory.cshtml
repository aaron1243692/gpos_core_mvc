@{
    ViewData["Title"] = "Purchase History";
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Reports</li>
                <li class="breadcrumb-item active" aria-current="page">Purchase History</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="mb-0">Purchase History</h1>
            <span class="badge bg-warning text-dark">UI Preview Only</span>
            <span class="badge bg-secondary">Backend not connected yet</span>
        </div>
        <p class="page-subtitle text-muted mt-2">Log of inventory purchase orders and supplier delivery receiving records.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-outline-secondary" type="button" onclick="alert('Export backend not connected yet.');">Export CSV</button>
        <button class="btn btn-outline-secondary" type="button" onclick="alert('Print backend not connected yet.');">Print</button>
    </div>
</div>

<section class="reports-ui-page">
    <div class="content-card mb-3">
        <form class="row g-2 align-items-center" onsubmit="return false;">
            <div class="col-md-3">
                <input class="form-control" type="search" placeholder="Search purchase logs..." id="purchaseSearch" />
            </div>
            <div class="col-md-3">
                <select class="form-select" id="purchaseBranch">
                    <option value="">All Branches</option>
                    <option>Main Branch</option>
                    <option>Branch 2</option>
                </select>
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="purchaseDateFrom" />
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="purchaseDateTo" />
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button class="btn btn-primary w-100" type="button">Search</button>
                <button class="btn btn-outline-secondary" type="button">Clear</button>
            </div>
        </form>
    </div>

    <div class="content-card transaction-ui-card">
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="purchaseTable">
                <thead>
                    <tr>
                        <th class="text-nowrap">No</th>
                        <th class="text-nowrap">Date</th>
                        <th class="text-nowrap">Branch</th>
                        <th class="text-nowrap">Type</th>
                        <th class="text-nowrap">Supplier</th>
                        <th class="text-nowrap">Product/Fuel</th>
                        <th class="text-nowrap">Tank if fuel</th>
                        <th class="text-nowrap">Quantity/Liters</th>
                        <th class="text-nowrap">Cost</th>
                        <th class="text-nowrap">Total Cost</th>
                        <th class="text-nowrap">Received By</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td class="text-nowrap">2026-07-09</td>
                        <td>Main Branch</td>
                        <td>Fuel</td>
                        <td>Petron Corp</td>
                        <td>Diesel</td>
                        <td>Tank 1</td>
                        <td>10,000.00 Liters</td>
                        <td>₱50.00</td>
                        <td>₱500,000.00</td>
                        <td>admin</td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td class="text-nowrap">2026-07-08</td>
                        <td>Main Branch</td>
                        <td>Product</td>
                        <td>Caltex Logistics</td>
                        <td>Engine Oil 1L</td>
                        <td>-</td>
                        <td>100.00 pcs</td>
                        <td>₱250.00</td>
                        <td>₱25,000.00</td>
                        <td>admin</td>
                    </tr>
                    <tr class="d-none">
                        <td class="text-center text-muted fw-bold" colspan="11">No records found.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
