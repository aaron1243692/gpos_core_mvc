@{
    ViewData["Title"] = "POS";
    ViewData["Section"] = "Transactions";

    var salesmanName = Context.Session.GetString("EmployeeName")
        ?? Context.Session.GetString("EmployeeUsername")
        ?? Context.Session.GetString("Username")
        ?? Context.Session.GetString("Name")
        ?? User.Identity?.Name
        ?? "Salesman";
}

<style>
    .salesman-pos-page {
        width: 100%;
    }

    .salesman-pos-shell {
        width: 100%;
        max-width: none;
        padding: 28px;
        border: 1px solid rgba(15, 118, 70, 0.1);
        border-radius: 18px;
        background: #ffffff;
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
    }

    .salesman-pos-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 22px;
    }

    .salesman-pos-title-row h1 {
        margin: 0;
        color: #0f172a;
        font-size: clamp(1.35rem, 2vw, 1.9rem);
        font-weight: 800;
        letter-spacing: 0;
    }

    .salesman-pos-kicker {
        margin: 0 0 4px;
        color: #15803d;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .salesman-pos-search {
        width: min(360px, 100%);
    }

    .salesman-pos-search .form-control,
    .salesman-pos-panel .form-control,
    .salesman-pos-panel .form-select {
        min-height: 46px;
        border-color: #d8eadf;
        border-radius: 12px;
    }

    .salesman-pos-purchase-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 22px;
        align-items: stretch;
    }

    .salesman-pos-panel {
        display: flex;
        min-width: 0;
        min-height: 520px;
        flex-direction: column;
        gap: 18px;
        padding: 22px;
        border: 1px solid #dcefe3;
        border-radius: 16px;
        background: linear-gradient(180deg, #ffffff 0%, #f8fcfa 100%);
        box-shadow: 0 12px 26px rgba(15, 23, 42, 0.055);
    }

    .salesman-pos-panel-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
    }

    .salesman-pos-panel-header p {
        margin: 0 0 4px;
        color: #15803d;
        font-size: 0.74rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .salesman-pos-panel-header h2 {
        margin: 0;
        color: #0f172a;
        font-size: 1.22rem;
        font-weight: 800;
    }

    .salesman-pos-panel-header > span {
        padding: 6px 10px;
        border-radius: 999px;
        background: #dcfce7;
        color: #166534;
        font-size: 0.78rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .salesman-product-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .salesman-product-grid .pos-menu-product-card {
        min-width: 0;
        border-color: #e2efe7;
        border-radius: 15px;
        box-shadow: none;
    }

    .salesman-fuel-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
    }

    .salesman-fuel-grid .fuel-option {
        min-height: 64px;
        border-radius: 14px;
        background: #ffffff;
    }

    .salesman-fuel-fields {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-top: auto;
    }

    .salesman-fuel-note {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 16px;
        border-radius: 14px;
        background: #ecfdf5;
        color: #14532d;
    }

    .salesman-fuel-note span {
        font-size: 0.9rem;
        font-weight: 600;
    }

    .salesman-fuel-note strong {
        white-space: nowrap;
    }

    .salesman-pos-bottom-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin-top: 22px;
        padding: 18px 20px;
        border-radius: 16px;
        background: #f0fdf4;
        box-shadow: inset 0 0 0 1px rgba(22, 101, 52, 0.1);
    }

    .salesman-total-block {
        display: flex;
        align-items: baseline;
        gap: 16px;
    }

    .salesman-total-block span {
        color: #166534;
        font-size: 1rem;
        font-weight: 800;
        text-transform: uppercase;
    }

    .salesman-total-block strong {
        color: #052e16;
        font-size: clamp(1.4rem, 3vw, 2rem);
        font-weight: 900;
    }

    .salesman-pos-bottom-bar .pos-charge-button {
        min-width: 180px;
        border-radius: 14px;
        font-weight: 800;
    }

    @@media (max-width: 991.98px) {
        .salesman-pos-shell {
            padding: 20px;
        }

        .salesman-pos-title-row,
        .salesman-pos-bottom-bar {
            align-items: stretch;
            flex-direction: column;
        }

        .salesman-pos-search,
        .salesman-pos-bottom-bar .pos-charge-button {
            width: 100%;
        }

        .salesman-pos-purchase-grid {
            grid-template-columns: 1fr;
        }

        .salesman-pos-panel {
            min-height: auto;
        }
    }

    @@media (max-width: 575.98px) {
        .salesman-product-grid,
        .salesman-fuel-fields {
            grid-template-columns: 1fr;
        }

        .salesman-total-block {
            align-items: flex-start;
            flex-direction: column;
            gap: 4px;
        }
    }
</style>

<section class="salesman-pos-page">
    <form id="posSaleForm" method="post" class="salesman-pos-card salesman-pos-shell">
        <div class="salesman-pos-title-row">
            <div>
                <p class="salesman-pos-kicker">Point of Sale</p>
                <h1>Salesman POS</h1>
            </div>
            <div class="salesman-pos-search">
                <input class="form-control" id="productSearch" type="search" placeholder="Search product or fuel" autocomplete="off" />
            </div>
        </div>

        <div class="salesman-pos-purchase-grid">
            <section class="salesman-pos-panel product-purchase-panel" aria-label="Product purchase">
                <div class="salesman-pos-panel-header">
                    <div>
                        <p>Product Purchase</p>
                        <h2>Products</h2>
                    </div>
                    <span>Items</span>
                </div>

                <div class="pos-product-grid salesman-product-grid">
                    <article class="pos-menu-product-card" data-product-name="premium lubricant">
                        <div class="pos-product-visual">PL</div>
                        <h3>Premium Lubricant</h3>
                        <p>₱530.00</p>
                        <label class="pos-quantity-control" for="productQuantity_LUB001">
                            <span>Qty</span>
                            <input class="form-control product-quantity-input" id="productQuantity_LUB001" name="Products[0].Quantity" type="number" min="0" value="0" data-price="530" data-no="LUB-001" data-name="Premium Lubricant" aria-label="Premium Lubricant quantity" />
                        </label>
                        <input type="hidden" name="Products.Index" value="0" />
                        <input type="hidden" name="Products[0].Code" value="LUB-001" />
                        <input type="hidden" name="Products[0].Name" value="Premium Lubricant" />
                    </article>
                    <article class="pos-menu-product-card" data-product-name="engine coolant">
                        <div class="pos-product-visual">EC</div>
                        <h3>Engine Coolant</h3>
                        <p>₱280.00</p>
                        <label class="pos-quantity-control" for="productQuantity_CLT001">
                            <span>Qty</span>
                            <input class="form-control product-quantity-input" id="productQuantity_CLT001" name="Products[1].Quantity" type="number" min="0" value="0" data-price="280" data-no="CLT-001" data-name="Engine Coolant" aria-label="Engine Coolant quantity" />
                        </label>
                        <input type="hidden" name="Products.Index" value="1" />
                        <input type="hidden" name="Products[1].Code" value="CLT-001" />
                        <input type="hidden" name="Products[1].Name" value="Engine Coolant" />
                    </article>
                    <article class="pos-menu-product-card" data-product-name="brake fluid">
                        <span class="pos-product-badge">New</span>
                        <div class="pos-product-visual">BF</div>
                        <h3>Brake Fluid</h3>
                        <p>₱190.00</p>
                        <label class="pos-quantity-control" for="productQuantity_BRK001">
                            <span>Qty</span>
                            <input class="form-control product-quantity-input" id="productQuantity_BRK001" name="Products[2].Quantity" type="number" min="0" value="0" data-price="190" data-no="BRK-001" data-name="Brake Fluid" aria-label="Brake Fluid quantity" />
                        </label>
                        <input type="hidden" name="Products.Index" value="2" />
                        <input type="hidden" name="Products[2].Code" value="BRK-001" />
                        <input type="hidden" name="Products[2].Name" value="Brake Fluid" />
                    </article>
                    <article class="pos-menu-product-card" data-product-name="wiper fluid">
                        <div class="pos-product-visual">WF</div>
                        <h3>Wiper Fluid</h3>
                        <p>₱160.00</p>
                        <label class="pos-quantity-control" for="productQuantity_WPR001">
                            <span>Qty</span>
                            <input class="form-control product-quantity-input" id="productQuantity_WPR001" name="Products[3].Quantity" type="number" min="0" value="0" data-price="160" data-no="WPR-001" data-name="Wiper Fluid" aria-label="Wiper Fluid quantity" />
                        </label>
                        <input type="hidden" name="Products.Index" value="3" />
                        <input type="hidden" name="Products[3].Code" value="WPR-001" />
                        <input type="hidden" name="Products[3].Name" value="Wiper Fluid" />
                    </article>
                </div>
            </section>

            <section class="salesman-pos-panel fuel-purchase-panel" aria-label="Fuel purchase">
                <div class="salesman-pos-panel-header">
                    <div>
                        <p>Fuel Purchase</p>
                        <h2>Fuel</h2>
                    </div>
                    <span>Cash Sale</span>
                </div>

                <div class="fuel-type-grid salesman-fuel-grid">
                    <label class="fuel-option">
                        <input class="form-check-input fuel-choice" type="radio" name="FuelType" value="Diesel" data-price="65" checked />
                        <span>Diesel <small>₱65.00/L</small></span>
                    </label>
                    <label class="fuel-option">
                        <input class="form-check-input fuel-choice" type="radio" name="FuelType" value="Gasoline" data-price="68" />
                        <span>Gasoline <small>₱68.00/L</small></span>
                    </label>
                    <label class="fuel-option">
                        <input class="form-check-input fuel-choice" type="radio" name="FuelType" value="Premium" data-price="72" />
                        <span>Premium <small>₱72.00/L</small></span>
                    </label>
                </div>

                <div class="pos-fuel-fields salesman-fuel-fields">
                    <div>
                        <label class="form-label" for="fuelLiters">Liters</label>
                        <input class="form-control" id="fuelLiters" name="FuelLiters" type="number" min="0" step="0.01" placeholder="0.00" />
                    </div>
                    <div>
                        <label class="form-label" for="fuelCashAmount">Cash Amount</label>
                        <div class="input-group">
                            <span class="input-group-text">₱</span>
                            <input class="form-control pos-total-input" id="fuelCashAmount" name="FuelCashAmount" type="number" min="0" step="0.01" placeholder="0.00" />
                        </div>
                    </div>
                </div>

                <div class="salesman-fuel-note">
                    <span>Choose fuel type, then enter either cash amount or liters.</span>
                    <strong id="selectedFuelPrice">₱65.00/L</strong>
                </div>
            </section>
        </div>

        <input id="paymentMethod" name="PaymentMethod" type="hidden" value="Cash" />
        <input id="paymentAmount" name="PaymentAmount" type="hidden" value="0.00" />
        <input id="paymentChange" name="PaymentChange" type="hidden" value="0.00" />
        <input id="membershipCardNo" name="MembershipCardNo" type="hidden" />

        <div class="salesman-pos-bottom-bar" aria-label="Checkout summary">
            <div class="salesman-total-block">
                <span>Total</span>
                <strong id="posGrandTotal">₱0.00</strong>
            </div>
            <button class="btn btn-primary btn-lg pos-charge-button" id="checkoutButton" type="button">Checkout</button>
        </div>

        <section class="salesman-receipt-preview" id="receiptPreview" hidden aria-live="polite">
            <div class="salesman-receipt-print" id="receiptPrintArea">
                <div class="receipt-title">
                    <h2>GPOS Main Station</h2>
                    <p>Sales Receipt Preview</p>
                </div>

                <div class="receipt-meta">
                    <div><span>Date / Time</span><strong id="receiptDateTime"></strong></div>
                    <div><span>Salesman</span><strong id="receiptSalesman"></strong></div>
                    <div><span>Payment Method</span><strong id="receiptPaymentMethod"></strong></div>
                    <div><span id="receiptPaymentDetailLabel">Amount</span><strong id="receiptPaymentDetail"></strong></div>
                    <div id="receiptChangeLine"><span>Change</span><strong id="receiptPaymentChange"></strong></div>
                </div>

                <div class="receipt-block">
                    <h3>Gas / Fuel</h3>
                    <div class="receipt-line"><span>Fuel type</span><strong id="receiptFuelType"></strong></div>
                    <div class="receipt-line"><span>Cash amount</span><strong id="receiptFuelAmount"></strong></div>
                    <div class="receipt-line"><span>Liters</span><strong id="receiptFuelLiters"></strong></div>
                </div>

                <div class="receipt-block">
                    <h3>Products</h3>
                    <table class="receipt-product-table">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>Name</th>
                                <th>Quantity</th>
                            </tr>
                        </thead>
                        <tbody id="receiptProductRows">
                            <tr><td colspan="3">No selected products.</td></tr>
                        </tbody>
                    </table>
                </div>

                <div class="receipt-total-line">
                    <span>Total</span>
                    <strong id="receiptTotalAmount">₱0.00</strong>
                </div>
            </div>

            <div class="salesman-receipt-actions">
                <button class="btn btn-outline-secondary" id="printReceiptButton" type="button">Print</button>
                <button class="btn btn-primary" id="submitSaleButton" type="submit">Submit</button>
                <button class="btn btn-outline-secondary" id="newSaleButton" type="button">New Sale</button>
            </div>
        </section>
    </form>
</section>

@section Scripts {
    <script>
        (() => {
            const peso = new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP", currencyDisplay: "narrowSymbol" });
            const salesmanName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(salesmanName));
            const form = document.getElementById("posSaleForm");
            const productQuantityInputs = Array.from(document.querySelectorAll(".product-quantity-input"));
            const totalInputs = Array.from(document.querySelectorAll(".pos-total-input"));
            const fuelChoices = Array.from(document.querySelectorAll(".fuel-choice"));
            const fuelAmountInput = document.getElementById("fuelCashAmount");
            const fuelLitersInput = document.getElementById("fuelLiters");
            const paymentMethodInput = document.getElementById("paymentMethod");
            const paymentAmountInput = document.getElementById("paymentAmount");
            const paymentChangeInput = document.getElementById("paymentChange");
            const membershipCardNoInput = document.getElementById("membershipCardNo");
            const grandTotal = document.getElementById("posGrandTotal");
            const selectedFuelPriceLabel = document.getElementById("selectedFuelPrice");
            const productSearch = document.getElementById("productSearch");
            const productRows = Array.from(document.querySelectorAll(".pos-menu-product-card"));
            const checkoutButton = document.getElementById("checkoutButton");
            const receiptPreview = document.getElementById("receiptPreview");
            const receiptDateTime = document.getElementById("receiptDateTime");
            const receiptSalesman = document.getElementById("receiptSalesman");
            const receiptPaymentMethod = document.getElementById("receiptPaymentMethod");
            const receiptPaymentDetailLabel = document.getElementById("receiptPaymentDetailLabel");
            const receiptPaymentDetail = document.getElementById("receiptPaymentDetail");
            const receiptChangeLine = document.getElementById("receiptChangeLine");
            const receiptPaymentChange = document.getElementById("receiptPaymentChange");
            const receiptFuelType = document.getElementById("receiptFuelType");
            const receiptFuelAmount = document.getElementById("receiptFuelAmount");
            const receiptFuelLiters = document.getElementById("receiptFuelLiters");
            const receiptProductRows = document.getElementById("receiptProductRows");
            const receiptTotalAmount = document.getElementById("receiptTotalAmount");
            const printReceiptButton = document.getElementById("printReceiptButton");
            const newSaleButton = document.getElementById("newSaleButton");

            function numericValue(input) {
                return Number.parseFloat(input.value) || 0;
            }

            function selectedFuelType() {
                return fuelChoices.find(choice => choice.checked)?.value || "Fuel";
            }

            function selectedFuelPrice() {
                const selected = fuelChoices.find(choice => choice.checked);
                return selected ? Number.parseFloat(selected.dataset.price) || 0 : 0;
            }

            function updateSelectedFuelPriceLabel() {
                selectedFuelPriceLabel.textContent = `${peso.format(selectedFuelPrice())}/L`;
            }

            function calculatedLiters() {
                const price = selectedFuelPrice();
                const amount = Math.max(0, numericValue(fuelAmountInput));

                return Number.isFinite(price) && price > 0 ? amount / price : 0;
            }

            function updateLiters() {
                fuelLitersInput.value = calculatedLiters().toFixed(2);
            }

            function updateFuelAmountFromLiters() {
                const price = selectedFuelPrice();
                const liters = Math.max(0, numericValue(fuelLitersInput));
                const amount = Number.isFinite(price) && price > 0 ? liters * price : 0;

                if (numericValue(fuelLitersInput) < 0) {
                    fuelLitersInput.value = 0;
                }

                fuelAmountInput.value = amount > 0 ? amount.toFixed(2) : "";
            }

            function selectedPaymentMethod() {
                return paymentMethodInput.value || "Cash";
            }

            function cashReceivedAmount() {
                if (numericValue(paymentAmountInput) < 0) {
                    paymentAmountInput.value = 0;
                }

                return Math.max(0, numericValue(paymentAmountInput));
            }

            function changeAmount() {
                return 0;
            }

            function updateChange() {
                paymentChangeInput.value = changeAmount().toFixed(2);
            }

            function updatePaymentFields() {
                paymentMethodInput.value = "Cash";
                paymentAmountInput.value = totalAmount().toFixed(2);
                paymentChangeInput.value = "0.00";
                membershipCardNoInput.value = "";

                if (!receiptPreview.hidden) {
                    renderReceipt();
                }
            }

            function selectedProducts() {
                return productQuantityInputs.reduce((products, input) => {
                    const quantity = Math.max(0, numericValue(input));

                    if (numericValue(input) < 0) {
                        input.value = 0;
                    }

                    if (quantity > 0) {
                        products.push({
                            no: input.dataset.no,
                            name: input.dataset.name,
                            quantity,
                            price: Number.parseFloat(input.dataset.price) || 0
                        });
                    }

                    return products;
                }, []);
            }

            function productTotalAmount() {
                return selectedProducts().reduce((total, product) => {
                    return total + (product.quantity * product.price);
                }, 0);
            }

            function fuelTotalAmount() {
                if (numericValue(fuelAmountInput) < 0) {
                    fuelAmountInput.value = 0;
                }

                return Math.max(0, numericValue(fuelAmountInput));
            }

            function totalAmount() {
                return productTotalAmount() + fuelTotalAmount();
            }

            function updateSummaryAmounts() {
                grandTotal.textContent = peso.format(totalAmount());
                paymentAmountInput.value = totalAmount().toFixed(2);
                updateChange();
                updateSelectedFuelPriceLabel();
            }

            function updateTotal() {
                updateLiters();
                updateSummaryAmounts();

                if (!receiptPreview.hidden) {
                    renderReceipt();
                }
            }

            function renderReceipt() {
                const products = selectedProducts();
                const fuelAmount = fuelTotalAmount();

                receiptDateTime.textContent = new Date().toLocaleString();
                receiptSalesman.textContent = salesmanName;
                receiptPaymentMethod.textContent = selectedPaymentMethod();
                receiptPaymentDetailLabel.textContent = "Amount";
                receiptPaymentDetail.textContent = peso.format(totalAmount());
                receiptChangeLine.hidden = true;
                receiptPaymentChange.textContent = peso.format(changeAmount());
                receiptFuelType.textContent = selectedFuelType();
                receiptFuelAmount.textContent = peso.format(fuelAmount);
                receiptFuelLiters.textContent = `${calculatedLiters().toFixed(2)} L`;
                receiptTotalAmount.textContent = peso.format(totalAmount());
                receiptProductRows.innerHTML = products.length
                    ? products.map(product => `<tr><td>${product.no}</td><td>${product.name}</td><td>${product.quantity}</td></tr>`).join("")
                    : `<tr><td colspan="3">No selected products.</td></tr>`;
            }

            function showReceipt() {
                updateTotal();
                renderReceipt();

                receiptPreview.hidden = false;
                receiptPreview.scrollIntoView({ behavior: "smooth", block: "start" });
            }

            function restoreProductSubmitFields() {
                productRows.forEach(row => {
                    Array.from(row.querySelectorAll("input[type='hidden'], .product-quantity-input")).forEach(input => {
                        input.disabled = false;
                    });
                });
            }

            function disableZeroQuantityProducts() {
                productQuantityInputs.forEach(input => {
                    const rowInputs = Array.from(input.closest(".pos-menu-product-card").querySelectorAll("input[type='hidden'], .product-quantity-input"));
                    const shouldSubmit = Math.max(0, numericValue(input)) > 0;

                    rowInputs.forEach(rowInput => {
                        rowInput.disabled = !shouldSubmit;
                    });
                });
            }

            function resetSale() {
                form.reset();
                restoreProductSubmitFields();
                productSearch.value = "";
                productRows.forEach(row => {
                    row.hidden = false;
                });
                productQuantityInputs.forEach(input => {
                    input.value = 0;
                });
                fuelChoices[0].checked = true;
                fuelLitersInput.value = "";
                fuelAmountInput.value = "";
                receiptPreview.hidden = true;
                updatePaymentFields();
                updateTotal();
            }

            productQuantityInputs.forEach(input => input.addEventListener("input", updateTotal));
            totalInputs.forEach(input => input.addEventListener("input", updateTotal));
            fuelLitersInput.addEventListener("input", () => {
                updateFuelAmountFromLiters();
                updateTotal();
            });
            fuelChoices.forEach(choice => choice.addEventListener("change", updateTotal));
            productSearch.addEventListener("input", () => {
                const query = productSearch.value.trim().toLowerCase();

                productRows.forEach(row => {
                    row.hidden = query.length > 0 && !row.dataset.productName.includes(query);
                });
            });
            checkoutButton.addEventListener("click", showReceipt);
            printReceiptButton.addEventListener("click", () => window.print());
            newSaleButton.addEventListener("click", resetSale);
            form.addEventListener("submit", disableZeroQuantityProducts);
            window.addEventListener("pageshow", restoreProductSubmitFields);
            updatePaymentFields();
            updateTotal();
        })();
    </script>
}
