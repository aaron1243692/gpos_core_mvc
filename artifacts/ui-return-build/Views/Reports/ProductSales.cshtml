@{
    ViewData["Title"] = "Product Sales";
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Reports</li>
                <li class="breadcrumb-item active" aria-current="page">Product Sales</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="mb-0">Product Sales</h1>
            <span class="badge bg-warning text-dark">UI Preview Only</span>
            <span class="badge bg-secondary">Backend not connected yet</span>
        </div>
        <p class="page-subtitle text-muted mt-2">Detailed report of merchandise product sales transactions.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-outline-secondary" type="button" onclick="alert('Export backend not connected yet.');">Export CSV</button>
        <button class="btn btn-outline-secondary" type="button" onclick="alert('Print backend not connected yet.');">Print</button>
    </div>
</div>

<section class="reports-ui-page">
    <div class="content-card mb-3">
        <form class="row g-2 align-items-center" onsubmit="return false;">
            <div class="col-md-3">
                <input class="form-control" type="search" placeholder="Search product sales..." id="productSalesSearch" />
            </div>
            <div class="col-md-3">
                <select class="form-select" id="productSalesBranch">
                    <option value="">All Branches</option>
                    <option>Main Branch</option>
                    <option>Branch 2</option>
                </select>
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="productSalesDateFrom" />
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="productSalesDateTo" />
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button class="btn btn-primary w-100" type="button">Search</button>
                <button class="btn btn-outline-secondary" type="button">Clear</button>
            </div>
        </form>
    </div>

    <div class="content-card transaction-ui-card">
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="productSalesTable">
                <thead>
                    <tr>
                        <th class="text-nowrap">No</th>
                        <th class="text-nowrap">Date</th>
                        <th class="text-nowrap">Branch</th>
                        <th class="text-nowrap">Receipt No</th>
                        <th class="text-nowrap">Product</th>
                        <th class="text-nowrap">Batch</th>
                        <th class="text-nowrap">Quantity</th>
                        <th class="text-nowrap">Unit Price</th>
                        <th class="text-nowrap">Total</th>
                        <th class="text-nowrap">Cashier</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td class="text-nowrap">2026-07-09 09:12</td>
                        <td>Main Branch</td>
                        <td>RCPT-20260709-0004</td>
                        <td>Engine Oil 1L</td>
                        <td>B-OIL-001</td>
                        <td>2.00</td>
                        <td>₱320.00</td>
                        <td>₱640.00</td>
                        <td>cashier_01</td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td class="text-nowrap">2026-07-09 09:15</td>
                        <td>Main Branch</td>
                        <td>RCPT-20260709-0005</td>
                        <td>Coolant 1L</td>
                        <td>B-CLT-002</td>
                        <td>1.00</td>
                        <td>₱180.00</td>
                        <td>₱180.00</td>
                        <td>cashier_01</td>
                    </tr>
                    <tr class="d-none">
                        <td class="text-center text-muted fw-bold" colspan="10">No records found.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
