@model gpos.Models.ViewModels.ReturnManagementPageViewModel
@{ ViewData["Title"] = "Return Management"; }
<div class="page-header"><div class="page-heading"><nav><ol class="breadcrumb"><li class="breadcrumb-item">Returns</li><li class="breadcrumb-item active">Return Management</li></ol></nav><h1>Return Management</h1><p class="page-subtitle text-muted">Inspect, decide, process, and review customer Returns.</p></div></div>
@if (TempData["ReturnMessage"] is string message) { <div class="alert alert-success">@message</div> } @if (TempData["ReturnError"] is string error) { <div class="alert alert-danger">@error</div> }
<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
<div class="content-card mb-3"><form method="get" class="row g-2 align-items-end"><div class="col-md-3"><label class="form-label">Search</label><input class="form-control" name="search" value="@Model.Search" placeholder="Return, receipt, or member" /></div><div class="col-md-2"><label class="form-label">Branch</label><select class="form-select" name="branchId" asp-items="Model.BranchOptions"></select></div><div class="col-md-2"><label class="form-label">Return Type</label><select class="form-select" name="returnType"><option value="">All</option>@foreach(var value in new[]{"Product","Fuel","Mixed"}){<option value="@value" selected="@(Model.ReturnType==value)">@value</option>}</select></div><div class="col-md-2"><label class="form-label">Status</label><select class="form-select" name="status"><option value="">All</option>@foreach(var value in new[]{"Pending Inspection","Approved","Rejected","Completed"}){<option value="@value" selected="@(Model.Status==value)">@value</option>}</select></div><div class="col-md-1"><label class="form-label">From</label><input class="form-control" type="date" name="from" value="@Model.From?.ToString("yyyy-MM-dd")" /></div><div class="col-md-1"><label class="form-label">To</label><input class="form-control" type="date" name="to" value="@Model.To?.ToString("yyyy-MM-dd")" /></div><div class="col-md-1"><button class="btn btn-primary">Filter</button></div></form></div>
<div class="content-card"><div class="table-responsive"><table class="table app-table table-sm align-middle mb-0"><thead><tr><th>Receipt No.</th><th>Return Ref.</th><th>Return Date</th><th>Branch</th><th>Customer</th><th>Type</th><th class="text-end">Gross Return Amount</th><th>Status</th><th>Actions</th></tr></thead><tbody>@if(Model.Rows.Count==0){<tr><td colspan="9" class="text-center text-muted py-4">No Returns found.</td></tr>}@foreach(var row in Model.Rows){<tr><td>@row.ReceiptNo</td><td>@row.ReturnNo</td><td>@row.ReturnDate.ToString("yyyy-MM-dd HH:mm")</td><td>@row.Branch</td><td>@row.Customer</td><td>@row.ReturnType</td><td class="text-end">@row.RefundAmount.ToString("N2")</td><td><span class="badge text-bg-secondary">@row.Status</span></td><td><a class="btn btn-sm btn-outline-primary" asp-route-detailsId="@row.Id" asp-route-search="@Model.Search" asp-route-branchId="@Model.BranchId" asp-route-returnType="@Model.ReturnType" asp-route-status="@Model.Status" asp-route-from="@Model.From?.ToString("yyyy-MM-dd")" asp-route-to="@Model.To?.ToString("yyyy-MM-dd")">Items</a></td></tr>}</tbody></table></div></div>
@if(Model.Details is {} d){<div class="modal fade" id="returnDetails" tabindex="-1"><div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content"><div class="modal-header"><h2 class="modal-title fs-5">@d.ReturnNo — @d.Status</h2><a class="btn-close" asp-action="ReturnManagement"></a></div><div class="modal-body"><dl class="row"><dt class="col-sm-2">Original receipt</dt><dd class="col-sm-4">@d.ReceiptNo</dd><dt class="col-sm-2">Return date</dt><dd class="col-sm-4">@d.ReturnDate.ToString("yyyy-MM-dd HH:mm:ss")</dd><dt class="col-sm-2">Branch / Customer</dt><dd class="col-sm-4">@d.Branch / @d.Customer</dd><dt class="col-sm-2">Type / Gross amount</dt><dd class="col-sm-4">@d.ReturnType / @d.RefundAmount.ToString("N2")</dd><dt class="col-sm-2">Reason</dt><dd class="col-sm-10">@d.Reason</dd><dt class="col-sm-2">Created by</dt><dd class="col-sm-4">@d.CreatedBy</dd><dt class="col-sm-2">Inspector</dt><dd class="col-sm-4">@d.Inspector @d.InspectedAt?.ToString("yyyy-MM-dd HH:mm")</dd><dt class="col-sm-2">Decision / Notes</dt><dd class="col-sm-10">@d.Decision @d.InspectionNotes</dd><dt class="col-sm-2">Processed by</dt><dd class="col-sm-4">@d.ProcessedBy</dd><dt class="col-sm-2">Completed</dt><dd class="col-sm-4">@d.CompletedAt?.ToString("yyyy-MM-dd HH:mm")</dd></dl>
<h3 class="fs-6">Product Items</h3><table class="table table-sm"><thead><tr><th>Product</th><th>Batch</th><th>Quantity</th><th>Original Price</th><th>Amount</th><th>Inspection</th><th>Disposition</th></tr></thead><tbody>@foreach(var item in d.Products){<tr><td>@item.Product</td><td>@item.Batch</td><td>@item.Quantity</td><td>@item.UnitPrice.ToString("N2")</td><td>@item.Amount.ToString("N2")</td><td>@item.InspectionResult</td><td>@item.Disposition</td></tr>}</tbody></table>
<h3 class="fs-6">Fuel Items</h3><table class="table table-sm"><thead><tr><th>Fuel</th><th>Original Source</th><th>Liters</th><th>Original Price</th><th>Amount</th><th>Inspection</th><th>Disposition</th></tr></thead><tbody>@foreach(var item in d.Fuels){<tr><td>@item.Fuel</td><td>@item.Source</td><td>@item.Liters</td><td>@item.UnitPrice.ToString("N2")</td><td>@item.Amount.ToString("N2")</td><td>@item.InspectionResult</td><td>@item.Disposition</td></tr>}</tbody></table>
@if(d.Status=="Pending Inspection"){<form method="post" asp-action="InspectReturn">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@d.Id" /><h3 class="fs-6 mt-3">Inspection</h3>@foreach(var item in d.Products){<label class="form-label">@item.Product</label><select class="form-select mb-2" name="productResults[@item.Id]" required><option value="">Select result</option>@foreach(var value in new[]{"Restockable","Damaged","Expired","Rejected","Disposal"}){<option>@value</option>}</select>}@foreach(var item in d.Fuels){<label class="form-label">@item.Fuel</label><select class="form-select mb-2" name="fuelResults[@item.Id]" required><option value="">Select result</option>@foreach(var value in new[]{"Approved for controlled handling","Contaminated","Wrong Fuel","Water Suspected","Rejected","Disposal"}){<option>@value</option>}</select>}<label class="form-label">Inspection notes</label><textarea class="form-control mb-2" name="notes" required></textarea><button class="btn btn-success me-2" name="decision" value="Approved">Approve</button><button class="btn btn-danger" name="decision" value="Rejected">Reject</button></form>}
@if(d.Status=="Approved"){<form method="post" asp-action="ProcessReturn" class="mt-3">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@d.Id" /><div class="alert alert-warning">Restockable Products will move to their original Batch in Warehouse Stock. Fuel never increases Tank stock. No financial refund is posted.</div><button class="btn btn-primary">Process Approved Return</button></form>}</div><div class="modal-footer"><a class="btn btn-secondary" asp-action="ReturnManagement">Close</a></div></div></div></div>}
@section Scripts {
<script>const returnDetails=document.getElementById('returnDetails');if(returnDetails)bootstrap.Modal.getOrCreateInstance(returnDetails).show();</script>
}
