@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Config</li><li class="breadcrumb-item active">Shift Schedule</li></ol></nav><h1>Shift Schedule</h1><p class="page-subtitle">Assign working schedules to active employee accounts.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="ShiftSchedule" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search employee, username, day, or shift" /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#shiftScheduleModal">Add Schedule</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-status" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Employee</th><th>Username</th><th>Day</th><th>Shift</th><th>Start Time</th><th>End Time</th><th>Status</th><th>Action</th></tr></thead><tbody>
@if (Model.EmployeeShiftSchedules.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="10">No shift schedules yet.</td></tr> }
@for (var i = 0; i < Model.EmployeeShiftSchedules.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.EmployeeShiftSchedules[i].Id</td><td>@(Model.EmployeeShiftSchedules[i].EmployeeAccount?.FullName ?? "-")</td><td>@(Model.EmployeeShiftSchedules[i].EmployeeAccount?.Username ?? "-")</td><td>@Model.EmployeeShiftSchedules[i].DayName</td><td>@(Model.EmployeeShiftSchedules[i].ShiftSetting?.Name ?? "Manual")</td><td>@Model.EmployeeShiftSchedules[i].StartTime.ToString(@"hh\:mm")</td><td>@Model.EmployeeShiftSchedules[i].EndTime.ToString(@"hh\:mm")</td><td><span class="badge @(Model.EmployeeShiftSchedules[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.EmployeeShiftSchedules[i].Status == 1 ? "Active" : "Inactive")</span></td><td class="col-action"><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="ShiftSchedule" asp-route-editId="@Model.EmployeeShiftSchedules[i].Id" asp-route-search="@Model.Search">Edit</a><form asp-action="DeleteShiftSchedule" method="post" data-deactivate-form>@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.EmployeeShiftSchedules[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-danger" type="submit">Deactivate</button></form></div></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="shiftScheduleModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveShiftSchedule" method="post">@Html.AntiForgeryToken()<input asp-for="EmployeeShiftScheduleForm.Id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Shift Schedule</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="EmployeeShiftScheduleForm.EmployeeAccountId" class="form-label">Employee</label><select asp-for="EmployeeShiftScheduleForm.EmployeeAccountId" asp-items="Model.EmployeeAccountOptions" class="form-select"><option value="0">Select employee</option></select><span asp-validation-for="EmployeeShiftScheduleForm.EmployeeAccountId" class="text-danger"></span></div><div class="mb-3"><label asp-for="EmployeeShiftScheduleForm.DayOfWeek" class="form-label">Day</label><select asp-for="EmployeeShiftScheduleForm.DayOfWeek" asp-items="Model.DayOptions" class="form-select"><option value="0">Select day</option></select><span asp-validation-for="EmployeeShiftScheduleForm.DayOfWeek" class="text-danger"></span></div><div class="mb-3"><label asp-for="EmployeeShiftScheduleForm.ShiftSettingId" class="form-label">Shift</label><select asp-for="EmployeeShiftScheduleForm.ShiftSettingId" class="form-select" data-shift-schedule-select><option value="">Manual schedule</option>@for (var i = 0; i < Model.ShiftScheduleShiftOptions.Count; i++) { <option value="@Model.ShiftScheduleShiftOptions[i].Id" data-start="@Model.ShiftScheduleShiftOptions[i].StartTimeValue" data-end="@Model.ShiftScheduleShiftOptions[i].EndTimeValue" selected="@(Model.EmployeeShiftScheduleForm.ShiftSettingId == Model.ShiftScheduleShiftOptions[i].Id ? "selected" : null)">@Model.ShiftScheduleShiftOptions[i].Name</option> }</select><span asp-validation-for="EmployeeShiftScheduleForm.ShiftSettingId" class="text-danger"></span></div><div class="row g-2"><div class="col-md-6 mb-3"><label asp-for="EmployeeShiftScheduleForm.StartTime" class="form-label">Start Time</label><input asp-for="EmployeeShiftScheduleForm.StartTime" class="form-control" type="time" data-shift-start /><span asp-validation-for="EmployeeShiftScheduleForm.StartTime" class="text-danger"></span></div><div class="col-md-6 mb-3"><label asp-for="EmployeeShiftScheduleForm.EndTime" class="form-label">End Time</label><input asp-for="EmployeeShiftScheduleForm.EndTime" class="form-control" type="time" data-shift-end /><span asp-validation-for="EmployeeShiftScheduleForm.EndTime" class="text-danger"></span></div></div><input asp-for="EmployeeShiftScheduleForm.Status" type="hidden" /></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const modalId="@Model.ActiveModalId";const modalEl=modalId?document.getElementById(modalId):null;if(modalEl&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(modalEl).show();}const shiftSelect=document.querySelector("[data-shift-schedule-select]");const startInput=document.querySelector("[data-shift-start]");const endInput=document.querySelector("[data-shift-end]");if(shiftSelect&&startInput&&endInput){shiftSelect.addEventListener("change",()=>{const option=shiftSelect.selectedOptions[0];if(!option){return;}if(option.dataset.start){startInput.value=option.dataset.start;}if(option.dataset.end){endInput.value=option.dataset.end;}});}});</script> }
