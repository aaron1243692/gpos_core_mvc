@model gpos.Models.ViewModels.VatSetupPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Config</li><li class="breadcrumb-item active">VAT</li></ol></nav><h1>VAT</h1><p class="page-subtitle">Add VAT changes and keep historical VAT settings.</p></div></div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="Vat" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search VAT" /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#vatModal">Add VAT</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-status" /><col class="col-status" /><col class="col-date" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>VAT Name</th><th>Rate</th><th>Type</th><th>Current</th><th>Status</th><th>Created At</th><th>Action</th></tr></thead><tbody>
@if (Model.VatSettings.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="9">No VAT history yet.</td></tr> }
@for (var i = 0; i < Model.VatSettings.Count; i++) { var isCurrent = Model.CurrentVatSetting is not null && Model.VatSettings[i].Id == Model.CurrentVatSetting.Id; <tr><td>@(i + 1)</td><td>@Model.VatSettings[i].Id</td><td>@Model.VatSettings[i].Name</td><td>@Model.VatSettings[i].Rate.ToString("N2")%</td><td>@Model.VatSettings[i].Type</td><td><span class="badge @(isCurrent ? "text-bg-primary" : "text-bg-secondary")">@(isCurrent ? "Current" : "History")</span></td><td><span class="badge @(Model.VatSettings[i].IsActive ? "text-bg-success" : "text-bg-secondary")">@(Model.VatSettings[i].IsActive ? "Active" : "Inactive")</span></td><td>@Model.VatSettings[i].CreatedAt.ToString("yyyy-MM-dd HH:mm")</td><td class="col-action"><div class="setup-row-actions">@if (isCurrent && Model.VatSettings[i].IsActive) { <form asp-action="DisableVat" method="post" data-deactivate-form>@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.VatSettings[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-danger" type="submit">Deactivate</button></form> } @if (isCurrent && !Model.VatSettings[i].IsActive) { <form asp-action="ActivateVat" method="post">@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.VatSettings[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-success" type="submit">Activate</button></form> }</div></td></tr> }
</tbody></table></div></section>

<div class="modal fade" id="vatModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveVat" method="post">@Html.AntiForgeryToken()<input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">VAT</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="VatForm.Name" class="form-label">VAT Name</label><input asp-for="VatForm.Name" class="form-control" autocomplete="off" /><span asp-validation-for="VatForm.Name" class="text-danger"></span></div><div class="mb-3"><label asp-for="VatForm.Rate" class="form-label">Rate</label><div class="input-group"><input asp-for="VatForm.Rate" class="form-control" type="number" step="0.01" min="0" /><span class="input-group-text">%</span></div><span asp-validation-for="VatForm.Rate" class="text-danger"></span></div><div class="mb-3"><label asp-for="VatForm.Type" class="form-label">Type</label><select asp-for="VatForm.Type" asp-items="Model.TypeOptions" class="form-select"></select><span asp-validation-for="VatForm.Type" class="text-danger"></span></div><div class="mb-3"><label class="form-check"><input asp-for="VatForm.IsDefault" class="form-check-input" /><span class="form-check-label">Set as Default</span></label><span asp-validation-for="VatForm.IsDefault" class="text-danger"></span></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>

@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
