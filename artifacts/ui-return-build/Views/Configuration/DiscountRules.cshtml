@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Discount Management</li><li class="breadcrumb-item active">Discount Rules</li></ol></nav><h1>Discount Rules</h1><p class="page-subtitle">Configure discount rules by discount, value type, and application area.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="DiscountRules" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search discount rules..." /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#discountRuleModal">Add Discount Rule</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table discount-rules-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-discount" /><col class="col-applies-to" /><col class="col-type" /><col class="col-value" /><col class="col-minimum" /><col class="col-member-required" /><col class="col-date" /><col class="col-date" /><col class="col-status" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Discount</th><th>Applies To</th><th>Type</th><th>Value</th><th>Minimum Amount</th><th>Member Required</th><th>Start Date</th><th>End Date</th><th>Status</th><th>Action</th></tr></thead><tbody>
@if (Model.DiscountRules.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="12">No discount rules yet.</td></tr> }
@for (var i = 0; i < Model.DiscountRules.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.DiscountRules[i].Id</td><td>@(Model.DiscountRules[i].Discount?.Name ?? Model.DiscountRules[i].Name)</td><td>@Model.DiscountRules[i].AppliesTo</td><td>@Model.DiscountRules[i].DiscountType</td><td>@(Model.DiscountRules[i].DiscountType == "Percentage" ? Model.DiscountRules[i].DiscountValue.ToString("0.##") + "%" : "₱" + Model.DiscountRules[i].DiscountValue.ToString("N2"))</td><td>₱@Model.DiscountRules[i].MinimumAmount.ToString("N2")</td><td>@(Model.DiscountRules[i].MemberRequired == 1 ? "Yes" : "No")</td><td>@Model.DiscountRules[i].StartDate?.ToString("yyyy-MM-dd")</td><td>@Model.DiscountRules[i].EndDate?.ToString("yyyy-MM-dd")</td><td><span class="badge @(Model.DiscountRules[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.DiscountRules[i].Status == 1 ? "Active" : "Inactive")</span></td><td class="col-action"><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="DiscountRules" asp-route-editId="@Model.DiscountRules[i].Id" asp-route-search="@Model.Search">Edit</a>@if (Model.DiscountRules[i].Status == 1) { <button class="btn btn-sm btn-outline-danger discount-rule-delete-button" type="button" data-bs-toggle="modal" data-bs-target="#discountRuleDeleteModal" data-rule-id="@Model.DiscountRules[i].Id" data-rule-name="@(Model.DiscountRules[i].Discount?.Name ?? Model.DiscountRules[i].Name)">Deactivate</button> } @if (Model.DiscountRules[i].Status != 1) { <form asp-action="ActivateDiscountRule" method="post">@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.DiscountRules[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-success" type="submit">Activate</button></form> }</div></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="discountRuleModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered modal-lg"><div class="modal-content"><form asp-action="SaveDiscountRule" method="post">@Html.AntiForgeryToken()<input asp-for="DiscountRuleForm.Id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Discount Rule</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="row g-3"><div class="col-md-6"><label asp-for="DiscountRuleForm.DiscountId" class="form-label">Discount</label><select asp-for="DiscountRuleForm.DiscountId" asp-items="Model.DiscountOptions" class="form-select"></select><span asp-validation-for="DiscountRuleForm.DiscountId" class="text-danger"></span></div><div class="col-md-6"><label asp-for="DiscountRuleForm.AppliesTo" class="form-label">Applies To</label><select asp-for="DiscountRuleForm.AppliesTo" class="form-select"><option>Fuel</option><option>Product</option><option>Both</option></select><span asp-validation-for="DiscountRuleForm.AppliesTo" class="text-danger"></span></div><div class="col-md-6"><label asp-for="DiscountRuleForm.DiscountType" class="form-label">Discount Type</label><select asp-for="DiscountRuleForm.DiscountType" class="form-select"><option>Percentage</option><option>Fixed Amount</option></select><span asp-validation-for="DiscountRuleForm.DiscountType" class="text-danger"></span></div><div class="col-md-6"><label asp-for="DiscountRuleForm.DiscountValue" class="form-label">Discount Value</label><input asp-for="DiscountRuleForm.DiscountValue" class="form-control" type="number" step="0.01" /><span asp-validation-for="DiscountRuleForm.DiscountValue" class="text-danger"></span></div><div class="col-md-6"><label asp-for="DiscountRuleForm.MinimumAmount" class="form-label">Minimum Amount</label><input asp-for="DiscountRuleForm.MinimumAmount" class="form-control" type="number" step="0.01" min="0" /><span asp-validation-for="DiscountRuleForm.MinimumAmount" class="text-danger"></span></div><div class="col-md-6"><label asp-for="DiscountRuleForm.MemberRequired" class="form-label">Member Required</label><select asp-for="DiscountRuleForm.MemberRequired" class="form-select"><option value="false">No</option><option value="true">Yes</option></select></div><div class="col-md-6"><label asp-for="DiscountRuleForm.StartDate" class="form-label">Start Date</label><input asp-for="DiscountRuleForm.StartDate" class="form-control" type="date" /><span asp-validation-for="DiscountRuleForm.StartDate" class="text-danger"></span></div><div class="col-md-6"><label asp-for="DiscountRuleForm.EndDate" class="form-label">End Date</label><input asp-for="DiscountRuleForm.EndDate" class="form-control" type="date" /><span asp-validation-for="DiscountRuleForm.EndDate" class="text-danger"></span></div><input asp-for="DiscountRuleForm.Status" type="hidden" /></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
<div class="modal fade" id="discountRuleDeleteModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="DeleteDiscountRule" method="post">@Html.AntiForgeryToken()<input id="discountRuleDeleteId" name="id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Deactivate Record</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><p class="mb-0">Are you sure you want to deactivate this record?</p><p class="fw-bold mb-0" id="discountRuleDeleteName"></p></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-danger" type="submit">Deactivate</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}const deleteModal=document.getElementById("discountRuleDeleteModal");if(deleteModal){deleteModal.addEventListener("show.bs.modal",event=>{const button=event.relatedTarget;document.getElementById("discountRuleDeleteId").value=button?.dataset.ruleId||"";document.getElementById("discountRuleDeleteName").textContent=button?.dataset.ruleName||"";});}});</script> }
