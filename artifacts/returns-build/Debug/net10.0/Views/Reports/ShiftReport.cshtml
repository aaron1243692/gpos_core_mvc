@{
    ViewData["Title"] = "Shift Report";
}

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Reports</li>
                <li class="breadcrumb-item active" aria-current="page">Shift Report</li>
            </ol>
        </nav>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="mb-0">Shift Report</h1>
            <span class="badge bg-warning text-dark">UI Preview Only</span>
            <span class="badge bg-secondary">Backend not connected yet</span>
        </div>
        <p class="page-subtitle text-muted mt-2">Reconciliation of shifts, sales totals, opening/closing times, and cash counts.</p>
    </div>
    <div class="page-actions">
        <button class="btn btn-outline-secondary" type="button" onclick="alert('Export backend not connected yet.');">Export CSV</button>
        <button class="btn btn-outline-secondary" type="button" onclick="alert('Print backend not connected yet.');">Print</button>
    </div>
</div>

<section class="reports-ui-page">
    <div class="content-card mb-3">
        <form class="row g-2 align-items-center" onsubmit="return false;">
            <div class="col-md-3">
                <input class="form-control" type="search" placeholder="Search shift logs..." id="shiftReportSearch" />
            </div>
            <div class="col-md-2">
                <select class="form-select" id="shiftReportBranch">
                    <option value="">All Branches</option>
                    <option>Main Branch</option>
                    <option>Branch 2</option>
                </select>
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="shiftReportDateFrom" />
            </div>
            <div class="col-md-2">
                <input class="form-control" type="date" value="2026-07-09" id="shiftReportDateTo" />
            </div>
            <div class="col-md-1">
                <select class="form-select" id="shiftReportStatus">
                    <option value="">All Statuses</option>
                    <option>Open</option>
                    <option>Closed</option>
                    <option>Reconciled</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-1">
                <button class="btn btn-primary w-100" type="button">Search</button>
                <button class="btn btn-outline-secondary" type="button">Clear</button>
            </div>
        </form>
    </div>

    <div class="content-card transaction-ui-card">
        <div class="table-responsive transaction-ui-table-wrap">
            <table class="table app-table table-sm align-middle mb-0" id="shiftReportTable">
                <thead>
                    <tr>
                        <th class="text-nowrap">No</th>
                        <th class="text-nowrap">Date</th>
                        <th class="text-nowrap">Branch</th>
                        <th class="text-nowrap">Shift</th>
                        <th class="text-nowrap">Cashier</th>
                        <th class="text-nowrap">Opening Time</th>
                        <th class="text-nowrap">Closing Time</th>
                        <th class="text-nowrap">Sales</th>
                        <th class="text-nowrap">Cash In</th>
                        <th class="text-nowrap">Cash Out</th>
                        <th class="text-nowrap">Expected Cash</th>
                        <th class="text-nowrap">Actual Cash</th>
                        <th class="text-nowrap">Difference</th>
                        <th class="text-nowrap">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td class="text-nowrap">2026-07-09</td>
                        <td>Main Branch</td>
                        <td>Morning Shift</td>
                        <td>cashier_01</td>
                        <td>06:00 AM</td>
                        <td>02:00 PM</td>
                        <td>₱45,600.00</td>
                        <td>₱500.00</td>
                        <td>₱10,000.00</td>
                        <td>₱41,100.00</td>
                        <td>₱41,050.00</td>
                        <td>₱-50.00</td>
                        <td><span class="badge bg-success text-nowrap">Closed</span></td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td class="text-nowrap">2026-07-09</td>
                        <td>Main Branch</td>
                        <td>Afternoon Shift</td>
                        <td>cashier_02</td>
                        <td>02:00 PM</td>
                        <td>10:00 PM</td>
                        <td>₱52,300.00</td>
                        <td>₱1,000.00</td>
                        <td>₱200.00</td>
                        <td>₱58,100.00</td>
                        <td>₱58,100.00</td>
                        <td>₱0.00</td>
                        <td><span class="badge bg-primary text-nowrap">Open</span></td>
                    </tr>
                    <tr class="d-none">
                        <td class="text-center text-muted fw-bold" colspan="14">No records found.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>
