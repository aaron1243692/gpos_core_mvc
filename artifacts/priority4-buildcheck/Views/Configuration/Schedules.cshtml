@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Config</li><li class="breadcrumb-item active">Schedules</li></ol></nav><h1>Schedules</h1><p class="page-subtitle">Create schedules and configure daily time-in and time-out rules.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="Schedules" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search schedules" /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#scheduleModal">Add Schedule</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-status" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Name</th><th>Status</th><th>Action</th></tr></thead><tbody>
@if (Model.Schedules.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="5">No schedules yet.</td></tr> }
@for (var i = 0; i < Model.Schedules.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.Schedules[i].Id</td><td>@Model.Schedules[i].Name</td><td><span class="badge @(Model.Schedules[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.Schedules[i].Status == 1 ? "Active" : "Inactive")</span></td><td class="col-action"><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="Schedules" asp-route-editId="@Model.Schedules[i].Id" asp-route-search="@Model.Search">Edit</a><a class="btn btn-sm btn-outline-success" asp-action="Schedules" asp-route-detailsId="@Model.Schedules[i].Id" asp-route-search="@Model.Search">Schedule</a><form asp-action="DeleteSchedule" method="post" data-deactivate-form>@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.Schedules[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-danger" type="submit">Deactivate</button></form></div></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="scheduleModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SaveSchedule" method="post">@Html.AntiForgeryToken()<input asp-for="ScheduleForm.Id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Schedule</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="ScheduleForm.Name" class="form-label">Name</label><input asp-for="ScheduleForm.Name" class="form-control" /><span asp-validation-for="ScheduleForm.Name" class="text-danger"></span></div><input asp-for="ScheduleForm.Status" type="hidden" /></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save Schedule</button></div></form></div></div></div>
<div class="modal fade" id="scheduleDetailsModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-xl modal-dialog-centered"><div class="modal-content"><form asp-action="SaveScheduleDetails" method="post">@Html.AntiForgeryToken()<input asp-for="ScheduleDetailsForm.ScheduleId" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Schedule Details</h2><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button></div><div class="modal-body"><div class="table-responsive"><table class="table app-table table-sm align-middle admin-table mb-0"><thead><tr><th>Day</th><th>Name</th><th>AM In</th><th>AM Out</th><th>PM In</th><th>PM Out</th></tr></thead><tbody>
@for (var i = 0; i < Model.ScheduleDetailsForm.Details.Count; i++) { <tr><td>@Model.ScheduleDetailsForm.Details[i].DayOfWeek<input name="ScheduleDetailsForm.Details[@i].DayOfWeek" type="hidden" value="@Model.ScheduleDetailsForm.Details[i].DayOfWeek" /></td><td>@Model.ScheduleDetailsForm.Details[i].DayName<input name="ScheduleDetailsForm.Details[@i].DayName" type="hidden" value="@Model.ScheduleDetailsForm.Details[i].DayName" /></td><td><input name="ScheduleDetailsForm.Details[@i].AmIn" class="form-control" type="time" value="@Model.ScheduleDetailsForm.Details[i].AmIn?.ToString(@"hh\:mm")" /></td><td><input name="ScheduleDetailsForm.Details[@i].AmOut" class="form-control" type="time" value="@Model.ScheduleDetailsForm.Details[i].AmOut?.ToString(@"hh\:mm")" /></td><td><input name="ScheduleDetailsForm.Details[@i].PmIn" class="form-control" type="time" value="@Model.ScheduleDetailsForm.Details[i].PmIn?.ToString(@"hh\:mm")" /></td><td><input name="ScheduleDetailsForm.Details[@i].PmOut" class="form-control" type="time" value="@Model.ScheduleDetailsForm.Details[i].PmOut?.ToString(@"hh\:mm")" /></td></tr> }
</tbody></table></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save Details</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
