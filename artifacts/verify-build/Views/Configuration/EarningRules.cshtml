@model gpos.Models.ViewModels.DiscountSetupPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item">Discounts</li>
                <li class="breadcrumb-item active" aria-current="page">Earning Rules</li>
            </ol>
        </nav>
        <h1>Earning Rules</h1>
        <p class="page-subtitle">Manage member point earning rates.</p>
    </div>
</div>

<section class="content-card setup-crud-card setup-table-card">
    @if (TempData["DiscountSetupFeedback"] is string feedback)
    {
        <div class="alert alert-info mb-0" role="alert">@feedback</div>
    }
    <div class="table-actions fuel-toolbar">
        <form asp-action="EarningRules" method="get" class="setup-search-form fuel-toolbar-search">
            <input class="form-control" name="search" value="@Model.Search" placeholder="Search earning rules" />
        </form>
        <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#earningRuleModal">Add Earning Rule</button>
    </div>
    <div class="setup-table-scroll">
        <table class="table app-table table-sm align-middle admin-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-id" />
                <col class="col-name" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-status" />
                <col class="col-action" />
            </colgroup>
            <thead>
                <tr>
                    <th class="col-no">No</th>
                    <th class="col-id">ID</th>
                    <th class="col-name">Name</th>
                    <th>Earn Rate</th>
                    <th>Description</th>
                    <th class="col-status">Status</th>
                    <th class="col-action">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.EarningRules.Count == 0)
                {
                    <tr><td class="text-center text-muted fw-bold" colspan="7">No earning rules yet.</td></tr>
                }
                @for (var i = 0; i < Model.EarningRules.Count; i++)
                {
                    <tr>
                        <td class="col-no">@(i + 1)</td>
                        <td class="col-id">@Model.EarningRules[i].Id</td>
                        <td>@Model.EarningRules[i].Name</td>
                        <td>@Model.EarningRules[i].EarnRate.ToString("N2")%</td>
                        <td>@(Model.EarningRules[i].Description ?? "-")</td>
                        <td class="col-status">
                            @if (Model.EarningRules[i].IsActive)
                            {
                                <span class="badge text-bg-success">Active</span>
                            }
                            @if (!Model.EarningRules[i].IsActive)
                            {
                                <span class="badge text-bg-secondary">Disabled</span>
                            }
                        </td>
                        <td class="col-action">
                            <div class="setup-row-actions">
                                <a class="btn btn-sm btn-outline-primary" asp-action="EarningRules" asp-route-editId="@Model.EarningRules[i].Id" asp-route-search="@Model.Search">Edit</a>
                                <form asp-action="DeleteEarningRule" method="post" onsubmit="return confirm('Disable this earning rule?');">
                                    @Html.AntiForgeryToken()
                                    <input name="id" type="hidden" value="@Model.EarningRules[i].Id" />
                                    <input name="search" type="hidden" value="@Model.Search" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="earningRuleModal" tabindex="-1" aria-labelledby="earningRuleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SaveEarningRule" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="EarningRuleForm.Id" type="hidden" />
                <input name="search" type="hidden" value="@Model.Search" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="earningRuleModalLabel">Earning Rule</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label asp-for="EarningRuleForm.Name" class="form-label">Name</label>
                        <input asp-for="EarningRuleForm.Name" class="form-control" autocomplete="off" />
                        <span asp-validation-for="EarningRuleForm.Name" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="EarningRuleForm.EarnRate" class="form-label">Earn Rate</label>
                        <input asp-for="EarningRuleForm.EarnRate" class="form-control" min="0" step="0.01" type="number" />
                        <span asp-validation-for="EarningRuleForm.EarnRate" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="EarningRuleForm.Description" class="form-label">Description</label>
                        <input asp-for="EarningRuleForm.Description" class="form-control" autocomplete="off" />
                        <span asp-validation-for="EarningRuleForm.Description" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="EarningRuleForm.IsActive" class="form-label">Status</label>
                        <select asp-for="EarningRuleForm.IsActive" class="form-select">
                            <option value="true">Active</option>
                            <option value="false">Disabled</option>
                        </select>
                        <span asp-validation-for="EarningRuleForm.IsActive" class="text-danger"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const modalId = "@Model.ActiveModalId";
            const modalElement = modalId ? document.getElementById(modalId) : null;

            if (modalElement && window.bootstrap) {
                bootstrap.Modal.getOrCreateInstance(modalElement).show();
            }
        });
    </script>
}
