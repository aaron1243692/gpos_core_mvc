@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Discounts</li><li class="breadcrumb-item active">Earning Rules</li></ol></nav><h1>Earning Rules</h1><p class="page-subtitle">Configure earning rules by earnings profile, value type, and application area.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="EarningRules" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search earning rules..." /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#earningRuleModal">Add Earning Rule</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table discount-rules-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-discount" /><col class="col-name" /><col class="col-applies-to" /><col class="col-type" /><col class="col-value" /><col class="col-minimum" /><col class="col-member-required" /><col class="col-date" /><col class="col-date" /><col class="col-status" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Earnings</th><th>Name</th><th>Applies To</th><th>Type</th><th>Value</th><th>Minimum Amount</th><th>Member Required</th><th>Start Date</th><th>End Date</th><th>Status</th><th>Action</th></tr></thead><tbody>
@if (Model.EarningRules.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="13">No earning rules yet.</td></tr> }
@for (var i = 0; i < Model.EarningRules.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.EarningRules[i].Id</td><td>@(Model.EarningRules[i].Earnings?.Name ?? "-")</td><td>@Model.EarningRules[i].Name</td><td>@Model.EarningRules[i].AppliesTo</td><td>@Model.EarningRules[i].EarnType</td><td>@(Model.EarningRules[i].EarnType == "Percentage" ? Model.EarningRules[i].EarnValue.ToString("0.##") + "%" : Model.EarningRules[i].EarnValue.ToString("N2") + " pts")</td><td>PHP @Model.EarningRules[i].MinimumAmount.ToString("N2")</td><td>@(Model.EarningRules[i].MemberRequired == 1 ? "Yes" : "No")</td><td>@Model.EarningRules[i].StartDate?.ToString("yyyy-MM-dd")</td><td>@Model.EarningRules[i].EndDate?.ToString("yyyy-MM-dd")</td><td><span class="badge @(Model.EarningRules[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.EarningRules[i].Status == 1 ? "Active" : "Disabled")</span></td><td class="col-action"><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="EarningRules" asp-route-editId="@Model.EarningRules[i].Id" asp-route-search="@Model.Search">Edit</a><button class="btn btn-sm btn-outline-danger earning-rule-delete-button" type="button" data-bs-toggle="modal" data-bs-target="#earningRuleDeleteModal" data-rule-id="@Model.EarningRules[i].Id" data-rule-name="@Model.EarningRules[i].Name">Delete</button></div></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="earningRuleModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered modal-lg"><div class="modal-content"><form asp-action="SaveEarningRule" method="post">@Html.AntiForgeryToken()<input asp-for="EarningRuleForm.Id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Earning Rule</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="row g-3"><div class="col-md-6"><label asp-for="EarningRuleForm.EarningsId" class="form-label">Earnings</label><select asp-for="EarningRuleForm.EarningsId" asp-items="Model.EarningsOptions" class="form-select"></select><span asp-validation-for="EarningRuleForm.EarningsId" class="text-danger"></span></div><div class="col-md-6"><label asp-for="EarningRuleForm.Name" class="form-label">Name</label><input asp-for="EarningRuleForm.Name" class="form-control" autocomplete="off" /><span asp-validation-for="EarningRuleForm.Name" class="text-danger"></span></div><div class="col-md-6"><label asp-for="EarningRuleForm.AppliesTo" class="form-label">Applies To</label><select asp-for="EarningRuleForm.AppliesTo" class="form-select"><option>Fuel</option><option>Products</option><option>Both</option></select><span asp-validation-for="EarningRuleForm.AppliesTo" class="text-danger"></span></div><div class="col-md-6"><label asp-for="EarningRuleForm.EarnType" class="form-label">Earn Type</label><select asp-for="EarningRuleForm.EarnType" class="form-select"><option>Percentage</option><option>Fixed Points</option></select><span asp-validation-for="EarningRuleForm.EarnType" class="text-danger"></span></div><div class="col-md-6"><label asp-for="EarningRuleForm.EarnValue" class="form-label">Earn Value</label><input asp-for="EarningRuleForm.EarnValue" class="form-control" type="number" step="0.01" /><span asp-validation-for="EarningRuleForm.EarnValue" class="text-danger"></span></div><div class="col-md-6"><label asp-for="EarningRuleForm.MinimumAmount" class="form-label">Minimum Amount</label><input asp-for="EarningRuleForm.MinimumAmount" class="form-control" type="number" step="0.01" min="0" /><span asp-validation-for="EarningRuleForm.MinimumAmount" class="text-danger"></span></div><div class="col-md-6"><label asp-for="EarningRuleForm.MemberRequired" class="form-label">Member Required</label><select asp-for="EarningRuleForm.MemberRequired" class="form-select"><option value="false">No</option><option value="true">Yes</option></select></div><div class="col-md-6"><label asp-for="EarningRuleForm.StartDate" class="form-label">Start Date</label><input asp-for="EarningRuleForm.StartDate" class="form-control" type="date" /><span asp-validation-for="EarningRuleForm.StartDate" class="text-danger"></span></div><div class="col-md-6"><label asp-for="EarningRuleForm.EndDate" class="form-label">End Date</label><input asp-for="EarningRuleForm.EndDate" class="form-control" type="date" /><span asp-validation-for="EarningRuleForm.EndDate" class="text-danger"></span></div><div class="col-md-6"><label asp-for="EarningRuleForm.Status" class="form-label">Status</label><select asp-for="EarningRuleForm.Status" class="form-select"><option value="1">Active</option><option value="0">Disabled</option></select></div></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
<div class="modal fade" id="earningRuleDeleteModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="DeleteEarningRule" method="post">@Html.AntiForgeryToken()<input id="earningRuleDeleteId" name="id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Delete Earning Rule</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><p class="mb-0">Disable this earning rule?</p><p class="fw-bold mb-0" id="earningRuleDeleteName"></p></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-danger" type="submit">Delete</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}const deleteModal=document.getElementById("earningRuleDeleteModal");if(deleteModal){deleteModal.addEventListener("show.bs.modal",event=>{const button=event.relatedTarget;document.getElementById("earningRuleDeleteId").value=button?.dataset.ruleId||"";document.getElementById("earningRuleDeleteName").textContent=button?.dataset.ruleName||"";});}});</script> }
