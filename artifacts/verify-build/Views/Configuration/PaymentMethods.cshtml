@model gpos.Models.ViewModels.SetupModulesPageViewModel

<div class="page-header"><div class="page-heading"><nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item">GPOS</li><li class="breadcrumb-item">Setup</li><li class="breadcrumb-item">Config</li><li class="breadcrumb-item active">Payment Methods</li></ol></nav><h1>Payment Methods</h1><p class="page-subtitle">Manage payment method names and codes.</p></div></div>
<section class="content-card setup-crud-card setup-table-card"><div class="table-actions fuel-toolbar"><form asp-action="PaymentMethods" method="get" class="setup-search-form fuel-toolbar-search"><input class="form-control" name="search" value="@Model.Search" placeholder="Search payment methods" /></form><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#paymentMethodModal">Add Payment Method</button></div><div class="setup-table-scroll"><table class="table app-table table-sm align-middle admin-table mb-0"><colgroup><col class="col-no" /><col class="col-id" /><col class="col-name" /><col class="col-normal" /><col class="col-normal" /><col class="col-action" /></colgroup><thead><tr><th>No</th><th>ID</th><th>Name</th><th>Code</th><th>Status</th><th>Action</th></tr></thead><tbody>
@if (Model.PaymentMethods.Count == 0) { <tr><td class="text-center text-muted fw-bold" colspan="6">No payment methods yet.</td></tr> }
@for (var i = 0; i < Model.PaymentMethods.Count; i++) { <tr><td>@(i + 1)</td><td>@Model.PaymentMethods[i].Id</td><td>@Model.PaymentMethods[i].Name</td><td>@Model.PaymentMethods[i].Code</td><td><span class="badge @(Model.PaymentMethods[i].Status == 1 ? "text-bg-success" : "text-bg-secondary")">@(Model.PaymentMethods[i].Status == 1 ? "Active" : "Disabled")</span></td><td class="col-action"><div class="setup-row-actions"><a class="btn btn-sm btn-outline-primary" asp-action="PaymentMethods" asp-route-editId="@Model.PaymentMethods[i].Id" asp-route-search="@Model.Search">Edit</a><form asp-action="DeletePaymentMethod" method="post" onsubmit="return confirm('Disable this method?');">@Html.AntiForgeryToken()<input name="id" type="hidden" value="@Model.PaymentMethods[i].Id" /><input name="search" type="hidden" value="@Model.Search" /><button class="btn btn-sm btn-outline-danger" type="submit">Delete</button></form></div></td></tr> }
</tbody></table></div></section>
<div class="modal fade" id="paymentMethodModal" tabindex="-1" aria-hidden="true"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><form asp-action="SavePaymentMethod" method="post">@Html.AntiForgeryToken()<input asp-for="PaymentMethodForm.Id" type="hidden" /><input name="search" type="hidden" value="@Model.Search" /><div class="modal-header"><h2 class="modal-title fs-5">Payment Method</h2><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="mb-3"><label asp-for="PaymentMethodForm.Name" class="form-label">Name</label><input asp-for="PaymentMethodForm.Name" class="form-control" /><span asp-validation-for="PaymentMethodForm.Name" class="text-danger"></span></div><div class="mb-3"><label asp-for="PaymentMethodForm.Code" class="form-label">Code</label><input asp-for="PaymentMethodForm.Code" class="form-control" /><span asp-validation-for="PaymentMethodForm.Code" class="text-danger"></span></div><div class="mb-3"><label asp-for="PaymentMethodForm.Status" class="form-label">Status</label><select asp-for="PaymentMethodForm.Status" class="form-select"><option value="1">Active</option><option value="0">Disabled</option></select></div></div><div class="modal-footer"><button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button><button class="btn btn-primary" type="submit">Save</button></div></form></div></div></div>
@section Scripts { <partial name="_ValidationScriptsPartial" /><script>document.addEventListener("DOMContentLoaded",()=>{const id="@Model.ActiveModalId";const el=id?document.getElementById(id):null;if(el&&window.bootstrap){bootstrap.Modal.getOrCreateInstance(el).show();}});</script> }
