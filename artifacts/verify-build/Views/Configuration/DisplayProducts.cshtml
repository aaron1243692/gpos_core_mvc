@model gpos.Models.ViewModels.ProductStockPageViewModel

<div class="page-header">
    <div class="page-heading">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">GPOS</li>
                <li class="breadcrumb-item">Setup</li>
                <li class="breadcrumb-item">Products</li>
                <li class="breadcrumb-item active" aria-current="page">Display</li>
            </ol>
        </nav>
        <h1>Display Products</h1>
        <p class="page-subtitle">Manage products available on display.</p>
    </div>
</div>

<section class="card content-card table-card full-height-card mb-0">
    <div class="table-toolbar d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
        <form class="products-search-wrap" asp-action="DisplayProducts" method="get">
            <label class="visually-hidden" for="display-product-search">Search display products</label>
            <input class="form-control form-control-sm products-search" id="display-product-search" name="search" value="@Model.Search" type="search" placeholder="Search display products" autocomplete="off" />
        </form>
        <div class="col-12 col-sm-auto ms-sm-auto">
            <button class="btn btn-primary btn-sm w-100" id="addDisplayProductButton" type="button" data-bs-toggle="modal" data-bs-target="#displayProductModal">Add Product</button>
        </div>
    </div>

    <div class="table-responsive table-scroll-wrap flex-table-wrap">
        <table class="table table-sm table-hover align-middle admin-table mb-0">
            <colgroup>
                <col class="col-no" />
                <col class="col-id" />
                <col class="col-normal" />
                <col class="col-name" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-normal" />
                <col class="col-action" />
            </colgroup>
            <thead>
                <tr>
                    <th class="col-no" scope="col">No</th>
                    <th class="col-id" scope="col">ID</th>
                    <th class="col-batch" scope="col">Batch #</th>
                    <th class="col-name" scope="col">Name</th>
                    <th scope="col">Category</th>
                    <th class="col-money" scope="col">Cost Price</th>
                    <th class="col-money" scope="col">Selling Price</th>
                    <th class="col-qty" scope="col">Quantity</th>
                    <th class="col-action" scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DisplayStocks.Count == 0)
                {
                    <tr>
                        <td class="text-center text-muted fw-bold" colspan="9">No display products yet.</td>
                    </tr>
                }
                @for (var index = 0; index < Model.DisplayStocks.Count; index += 1)
                {
                    <tr>
                        <td class="col-no">@(index + 1)</td>
                        <td class="col-id">@Model.DisplayStocks[index].Id</td>
                        <td class="col-batch">@(Model.DisplayStocks[index].Batch?.BatchNo ?? "-")</td>
                        <td class="col-name">@(Model.DisplayStocks[index].Product?.Name ?? "-")</td>
                        <td>@(Model.DisplayStocks[index].Product?.Category?.Name ?? "No category")</td>
                        <td>₱@(Model.DisplayStocks[index].Batch?.CostPrice.ToString("N2") ?? "0.00")</td>
                        <td>₱@(Model.DisplayStocks[index].Batch?.SellingPrice.ToString("N2") ?? "0.00")</td>
                        <td class="col-qty">@Model.DisplayStocks[index].Quantity.ToString("N0")</td>
                        <td class="col-action">
                            <button class="btn btn-outline-secondary btn-sm display-product-edit-button" type="button" data-bs-toggle="modal" data-bs-target="#displayProductModal" data-stock-id="@Model.DisplayStocks[index].Id" data-category-id="@Model.DisplayStocks[index].Product?.CategoryId" data-product-name="@Model.DisplayStocks[index].Product?.Name" data-batch-no="@Model.DisplayStocks[index].Batch?.BatchNo" data-cost-price="@Model.DisplayStocks[index].Batch?.CostPrice" data-selling-price="@Model.DisplayStocks[index].Batch?.SellingPrice" data-quantity="@Model.DisplayStocks[index].Quantity.ToString("N0")" data-is-active="@((Model.DisplayStocks[index].Product?.IsActive ?? true) && (Model.DisplayStocks[index].Batch?.IsActive ?? true))">Edit</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="displayProductModal" tabindex="-1" aria-labelledby="displayProductModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="SaveDisplayProduct" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="search" value="@Model.Search" />
                <input asp-for="StockForm.Id" type="hidden" />
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="displayProductModalLabel">Add Display Product</h2>
                    <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="d-grid gap-3">
                        <div>
                            <label class="form-label" asp-for="StockForm.CategoryId">Category</label>
                            <select class="form-select" asp-for="StockForm.CategoryId" asp-items="Model.CategoryOptions">
                                <option value="">Select category</option>
                            </select>
                            <span class="text-danger small" asp-validation-for="StockForm.CategoryId"></span>
                        </div>
                        <div>
                            <label class="form-label" asp-for="StockForm.ProductName">Product Name</label>
                            <input class="form-control" asp-for="StockForm.ProductName" autocomplete="off" />
                            <span class="text-danger small" asp-validation-for="StockForm.ProductName"></span>
                        </div>
                        <div>
                            <label class="form-label" for="displayProductBatchNo">Batch #</label>
                            <input class="form-control" id="displayProductBatchNo" type="text" readonly />
                        </div>
                        <div>
                            <label class="form-label" asp-for="StockForm.CostPrice">Cost Price</label>
                            <input class="form-control" asp-for="StockForm.CostPrice" type="number" min="0" step="0.01" placeholder="Enter cost price" />
                            <span class="text-danger small" asp-validation-for="StockForm.CostPrice"></span>
                        </div>
                        <div>
                            <label class="form-label" asp-for="StockForm.SellingPrice">Selling Price</label>
                            <input class="form-control" asp-for="StockForm.SellingPrice" type="number" min="0" step="0.01" placeholder="Enter selling price" />
                            <span class="text-danger small" asp-validation-for="StockForm.SellingPrice"></span>
                        </div>
                        <div>
                            <label class="form-label" asp-for="StockForm.Quantity">Quantity</label>
                            <input class="form-control" asp-for="StockForm.Quantity" type="number" min="0" step="1" placeholder="Enter quantity" />
                            <span class="text-danger small" asp-validation-for="StockForm.Quantity"></span>
                        </div>
                        <div>
                            <label class="form-check">
                                <input class="form-check-input" asp-for="StockForm.IsActive" />
                                <span class="form-check-label">Active</span>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const activeModalId = "@Model.ActiveModalId";
            const addButton = document.getElementById("addDisplayProductButton");
            const modalTitle = document.getElementById("displayProductModalLabel");
            const stockIdInput = document.getElementById("StockForm_Id");
            const categoryInput = document.getElementById("StockForm_CategoryId");
            const productNameInput = document.getElementById("StockForm_ProductName");
            const batchNoInput = document.getElementById("displayProductBatchNo");
            const costPriceInput = document.getElementById("StockForm_CostPrice");
            const sellingPriceInput = document.getElementById("StockForm_SellingPrice");
            const quantityInput = document.getElementById("StockForm_Quantity");
            const isActiveInput = document.getElementById("StockForm_IsActive");

            function setModalMode(title) {
                modalTitle.textContent = title;
            }

            function resetModal() {
                setModalMode("Add Display Product");
                stockIdInput.value = "";
                categoryInput.value = "";
                productNameInput.value = "";
                batchNoInput.value = "";
                costPriceInput.value = "";
                sellingPriceInput.value = "";
                quantityInput.value = "";
                isActiveInput.checked = true;
            }

            function fillEditModal(button) {
                setModalMode("Edit Display Product");
                stockIdInput.value = button.dataset.stockId || "";
                categoryInput.value = button.dataset.categoryId || "";
                productNameInput.value = button.dataset.productName || "";
                batchNoInput.value = button.dataset.batchNo || "";
                costPriceInput.value = button.dataset.costPrice || "0";
                sellingPriceInput.value = button.dataset.sellingPrice || "0";
                quantityInput.value = button.dataset.quantity || "0";
                isActiveInput.checked = (button.dataset.isActive || "True").toLowerCase() === "true";
            }

            addButton.addEventListener("click", resetModal);
            document.addEventListener("click", event => {
                const editButton = event.target.closest(".display-product-edit-button");

                if (editButton) {
                    fillEditModal(editButton);
                }
            });

            if (!activeModalId || !window.bootstrap) {
                return;
            }

            const activeModal = document.getElementById(activeModalId);

            if (activeModal) {
                bootstrap.Modal.getOrCreateInstance(activeModal).show();
            }
        });
    </script>
}
